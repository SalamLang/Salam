# chktex config for books/salam-codeblocks.tex, a low-level TeX macro
# package (custom lexer for syntax-highlighted code listings), not prose.
# Its @-named internal control sequences (\salamfa@..., \@ne, \m@ne, ...)
# are intentionally terminated by a literal space, which is warning 1
# ("Command terminated with space") for ordinary text macros but is
# standard, unavoidable TeX plumbing here.
Silent
{
    \ifcsname \egroup \VerbatimEnvironment
}
[
    \\.*@.*
]
