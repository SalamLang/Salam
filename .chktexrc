QuoteStyle = Traditional

# Baseline list of commands that are commonly (and correctly) terminated by a
# space/newline rather than braces, taken from ChkTeX's own default resource
# file, plus the extra TeX-primitive-heavy macros used by
# books/salam-codeblocks.tex (which hand-rolls syntax highlighting with
# \makeatletter-style code) and the book classes' front/mainmatter commands.
Silent
{
    \rm \em \bf \it \sl \sf \sc \tt \selectfont
    \rmfamily \sffamily \ttfamily \mdseries \bfseries \itshape
    \slshape \scshape \relax
    \vskip \pagebreak \nopagebreak

    \textrm \textem \textbf \textit \textsl \textsf \textsc \texttt

    \clearpage \ddots \dotfill \flushbottom \fussy \indent \linebreak
    \onecolumn \pagebreak \pushtabs \poptabs \scriptsize \sloppy
    \twocolumn \vdots
    \today \kill \newline \thicklines \thinlines

    \columnsep \space \item \tiny \footnotesize \small \normalsize
    \normal \large \Large \LARGE \huge \Huge \printindex

    \newpage \listoffigures \listoftables \tableofcontents
    \maketitle \makeindex

    \hline \hrule \vrule

    \centering

    \noindent \expandafter

    \makeatletter \makeatother

    \columnseprule

    \textwidth \textheight \hsize \vsize

    \if \fi \else \ifnum \ifsalamfa@inlead

    \csname \endcsname

    \z@ \p@  warning \typeout

    \dots \ldots \input \endinput \nextline \leavevmode \cdots
    \appendix \listfiles \and \quad \bigskip \medskip \smallskip
    \hskip \vfill \vfil \hfill \hfil \topmargin \oddsidemargin
    \frenchspacing \nonfrenchspacing
    \begingroup \endgroup \par

    \vrefwarning \upshape \headheight \headsep \hoffset \voffset
    \cdot \qquad \left \right \qedhere \xspace

    \addlinespace \cr \fill \frontmatter \mainmatter \beginappendices
    \toprule \midrule \bottomrule \endhead

    \ifcsname \egroup \VerbatimEnvironment \exercise
    \advance \phantomsection \raggedbottom \ignorespaces
    \FrameCommand \endMakeFramed \salamcodefont \XeLaTeX \fa \lr
    \textbackslash
}
[
    \\.*@.*
]

VerbEnvir
{
    salam salamfa salamen shell progout
}

WipeArg
{
    \code:{}
}

# Warning categories below are prose/typography heuristics (compound-word
# hyphens, spacing-after-abbreviation, quote/punctuation ordering, space
# before parenthesis, punctuation around inline math) that misfire
# constantly on ordinary English/Farsi technical writing full of inline
# \code{} snippets and are not actionable here; disabled repo-wide rather
# than suppressed line-by-line across hundreds of prose lines.
#  8  Wrong length of dash may have been used.
# 12  Interword spacing (`\ ') should perhaps be used.
# 13  Intersentence spacing (`\@') should perhaps be used.
# 15  No match found for `{'.
# 17  Number of `{' doesn't match the number of `}'!
# 18  Use either `` or '' as an alternative to `"'.
# 36  You should put a space in front of parenthesis.
# 38  You should not use punctuation after quotes.
# 40  You should put punctuation outside inner math mode.
CmdLine
{
    -n8 -n12 -n13 -n15 -n17 -n18 -n36 -n38 -n40
}
