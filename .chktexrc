# chktex config for books/salam-codeblocks.tex, a low-level TeX macro
# package (custom lexer for syntax-highlighted code listings), not prose.
# Its @-named internal control sequences (\salamfa@..., \@ne, \m@ne, ...)
# are intentionally terminated by a literal space, which is warning 1
# ("Command terminated with space") for ordinary text macros but is
# standard, unavoidable TeX plumbing here. \exercise (book.tex) is a
# plain text-introducing macro always terminated by a space too.
Silent
{
    \ifcsname \egroup \VerbatimEnvironment \exercise
}
[
    \\.*@.*
]

# The `salam' and `salamfa' environments (book.tex) hold Salam source,
# not LaTeX prose: colons in type annotations, straight quotes in
# string literals, and apostrophes in comments are code syntax, not
# punctuation/quoting mistakes.
VerbEnvir
{
    salam salamfa
}
