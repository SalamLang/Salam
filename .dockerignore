# Keep the Docker build context small and the image reproducible.
# Anything that is generated, host-specific, or irrelevant to building
# the compiler is excluded here.

# ---- VCS / CI ----
.git
.github
.gitattributes
.gitignore

# ---- Build artifacts (rebuilt inside the image) ----
build/
dist/
salam
salam.exe
*.o
*.a
*.obj
*.hash
*.exe
*.tmp
*.log

# ---- Test scratch ----
tests/.work/
cmttest/

# ---- WebAssembly playground bundle ----
salam-wa.js
salam-wa.wasm
salam-wa.data
salam-wa.html

# ---- Dependencies & caches ----
**/node_modules/
**/__pycache__/
.mypy_cache/
*.pyc

# ---- Editor / IDE / agent state ----
.vscode/
.idea/
.claude/

# ---- Docker's own files ----
Dockerfile
.dockerignore
docker-compose.yml

# ---- Large docs not needed to build ----
books/
