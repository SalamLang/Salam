<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Salam" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="android:windowBackground">@color/brand</item>
    </style>

    <style name="Theme.Salam" parent="Base.Theme.Salam" />

    <!-- Splash screen theme (AndroidX Core SplashScreen) used as the launch theme. -->
    <style name="Theme.Salam.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Salam</item>
        <!-- فریم اولیه‌ی cold start (و دستگاه‌های قبل از API 31) نارنجی بماند، نه مشکی -->
        <item name="android:windowBackground">@color/brand</item>
        <item name="android:statusBarColor">@color/brand</item>
        <item name="android:navigationBarColor">@color/brand</item>
    </style>
</resources>
