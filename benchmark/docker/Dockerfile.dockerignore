# Build context is the repo root; only compiler/ and benchmark/ are needed.

# ---- Everything else at the repo root ----
android/
books/
design/
docs/
editor/
examples/
extensions/
node_modules/
*.html

# ---- Build artifacts (rebuilt inside the image) ----
compiler/build/
compiler/dist/
compiler/salam
compiler/salam.exe
salam
salam.exe
**/*.o
**/*.a
**/*.obj
**/*.hash
**/*.exe
**/*.tmp
**/*.log

# ---- Benchmark scratch (regenerated on each run) ----
benchmark/results/*.json
benchmark/results/*.csv

# ---- Test scratch ----
compiler/tests/.work/
compiler/cmttest/

# ---- Dependencies & caches ----
**/node_modules/
**/__pycache__/
.mypy_cache/
*.pyc

# ---- Editor / IDE / agent state / VCS ----
.vscode/
.idea/
.claude/
.git/

# ---- Docker's own files (not needed inside the image) ----
benchmark/docker/
compiler/docker/
