func main:
    mut count := 1 as i64
    mut i := 3 as i64
    until i < 100000:
        mut is_p := 1 as i64
        mut j := 3 as i64
        until j * j <= i:
            if i % j == 0:
                is_p = 0
                break
            end
            j = j + 2
        end
        count = count + is_p
        i = i + 2
    end
    println count
end
