func main:
    mut count : i64 = 1
    for mut i : i64 = 3, i < 100000, i = i + 2:
        mut is_p : i64 = 1
        for mut j : i64 = 3, j * j <= i, j = j + 2:
            if i % j == 0:
                is_p = 0
                break
            end
        end
        count = count + is_p
    end
    __ count
end
