func main:
    mut count := 1 as i64
    repeat 3 to 99999 by 2 with i:
        mut is p := 1 as i64
        mut j := 3 as i64
        until j * j <= i:
            if i % j == 0:
                is p = 0
                break
            end
            j = j + 2
        end
        count = count + is p
    end
    println count
end
