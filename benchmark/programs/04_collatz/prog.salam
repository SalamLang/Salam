func main:
    mut best_steps i64 = 0
    mut best_n i64 = 1
    for mut n i64 = 1; n <= 30000; n = n + 1:
        mut m i64 = n
        mut c i64 = 0
        while m != 1:
            if m % 2 == 0:
                m = m / 2
            else:
                m = 3 * m + 1
            end
            c = c + 1
        end
        if c > best_steps:
            best_steps = c
            best_n = n
        end
    end
    __ best_steps
    __ best_n
end
