func main:
    mut best_steps := 0 as i64
    mut best_n := 1 as i64
    mut n := 1 as i64
    until n <= 30000:
        mut m := n
        mut c := 0 as i64
        until m != 1:
            if m % 2 == 0:
                m = m / 2
            else:
                m = 3 * m + 1
            end
            c = c + 1
        end
        if c > best_steps:
            best_steps = c
            best_n = n
        end
        n = n + 1
    end
    println best_steps
    println best_n
end
