func gcd(a: i64, b: i64): i64:
    mut x := a
    mut y := b
    until y != 0:
        t := x % y
        x = y
        y = t
    end
    ret x
end

func main:
    mut s := 0 as i64
    mut i := 1 as i64
    until i <= 300000:
        s = s + gcd(i, 987654321)
        i = i + 1
    end
    println s
end
