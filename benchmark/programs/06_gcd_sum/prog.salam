func gcd(a : i64, b : i64) : i64:
    mut x : i64 = a
    mut y : i64 = b
    while y != 0:
        t : i64 = x % y
        x = y
        y = t
    end
    ret x
end

func main:
    mut s : i64 = 0
    for mut i : i64 = 1, i <= 300000, i = i + 1:
        s = s + gcd(i, 987654321)
    end
    println s
end
