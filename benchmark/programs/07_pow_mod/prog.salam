func powmod(base i64, e i64, m i64) i64:
    mut result i64 = 1
    mut b i64 = base % m
    mut ex i64 = e
    while ex > 0:
        if ex % 2 == 1:
            result = (result * b) % m
        end
        b = (b * b) % m
        ex = ex / 2
    end
    ret result
end

func main:
    mut s i64 = 0
    for mut i i64 = 1; i <= 30000; i = i + 1:
        s = (s + powmod(i, 65537, 1000000007)) % 1000000007
    end
    __ s
end
