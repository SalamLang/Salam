func powmod(base: i64, e: i64, m: i64): i64:
    mut result := 1 as i64
    mut b := base % m
    mut ex := e
    until ex > 0:
        if ex % 2 == 1:
            result = (result * b) % m
        end
        b = (b * b) % m
        ex = ex / 2
    end
    ret result
end

func main:
    mut s := 0 as i64
    repeat 1 to 30000 with i:
        s = (s + powmod(i, 65537, 1000000007)) % 1000000007
    end
    println s
end
