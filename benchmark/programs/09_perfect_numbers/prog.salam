func main:
    mut count := 0 as i64
    mut total := 0 as i64
    mut n := 2 as i64
    until n <= 30000:
        mut s := 1 as i64
        mut j := 2 as i64
        until j * j <= n:
            if n % j == 0:
                s = s + j
                q := n / j
                if q != j:
                    s = s + q
                end
            end
            j = j + 1
        end
        if s == n:
            count = count + 1
            total = total + n
        end
        n = n + 1
    end
    println count
    println total
end
