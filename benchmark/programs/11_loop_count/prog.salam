func main:
    mut acc := 0 as i64
    lens := [1, 10, 100, 1000, 10000, 100000, 1000000] as int[7]
    mut li := 0
    until li < 7:
        L := lens[li]
        mut i := 1
        until i <= L:
            acc = (acc + (i as i64)) % 1000000007
            i = i + 1
        end
        li = li + 1
    end
    println acc
end
