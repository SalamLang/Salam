func main:
    mut arr := Vector {} as Vector<i64> mut i := 0
    until i < 1000000:
        n := i as i64
        arr.push((n * n + 3 * n + 7) % 1000000007)
        i = i + 1
    end
    mut sum := 0 as i64
    repeat 5 with pass:
        repeat 1000000 with j:
            sum = (sum + arr.get(j)[0] + (pass as i64)) % 1000000007
        end
    end
    println sum
end
