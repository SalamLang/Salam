func main:
    mut arr := Vector {} as Vector<i64>
    mut i := 0
    until i < 1000000:
        n := i as i64
        arr.push((n * n + 3 * n + 7) % 1000000007)
        i = i + 1
    end
    mut sum := 0 as i64
    mut pass := 0
    until pass < 5:
        mut j := 0
        until j < 1000000:
            sum = (sum + arr.get(j)[0] + (pass as i64)) % 1000000007
            j = j + 1
        end
        pass = pass + 1
    end
    println sum
end
