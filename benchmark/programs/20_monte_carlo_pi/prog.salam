func main:
    mut x := 1 as i64
    mut count := 0 as i64
    repeat 5000000 with step:
        x = (x * 1103515245 + 12345) % 2147483648
        ux := (x as f64) / 2147483648.0 * 2.0 - 1.0
        x = (x * 1103515245 + 12345) % 2147483648
        uy := (x as f64) / 2147483648.0 * 2.0 - 1.0
        if ux * ux + uy * uy <= 1.0:
            count = count + 1
        end
    end
    println count
end
