func main:
    mut x := 1 as i64
    mut checksum := 0 as i64
    mut step := 0 as i64
    until step < 3000000:
        x = (x * 1103515245 + 12345) % 2147483648
        letter := x % 26
        shifted := (letter + 13) % 26
        checksum = (checksum + shifted) % 1000000007
        step = step + 1
    end
    println checksum
end
