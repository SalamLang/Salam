func main:
    mut count := 0 as i64
    repeat 1 to 2000000 with n:
        mut temp := n
        mut rev := 0 as i64
        until temp > 0:
            rev = rev * 10 + temp % 10
            temp = temp / 10
        end
        if rev == n:
            count = count + 1
        end
    end
    println count
end
