func main:
    mut count := 0 as i64
    mut n := 1 as i64
    until n <= 2000000:
        mut temp := n
        mut rev := 0 as i64
        until temp > 0:
            rev = rev * 10 + temp % 10
            temp = temp / 10
        end
        if rev == n:
            count = count + 1
        end
        n = n + 1
    end
    println count
end
