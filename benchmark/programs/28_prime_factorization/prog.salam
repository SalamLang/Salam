func main:
    limit := 2000000 as i64
    mut total := 0 as i64
    repeat 2 to limit with n:
        mut temp := n
        mut d := 2 as i64
        until d * d <= temp:
            until temp % d == 0:
                total = total + 1
                temp = temp / d
            end
            d = d + 1
        end
        if temp > 1:
            total = total + 1
        end
    end
    println total
end
