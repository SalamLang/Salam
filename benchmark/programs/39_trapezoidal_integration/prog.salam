func f(x : f64) : f64:
    ret x*x*x - 2.0*x*x + 1.0
end

func main:
    a := 0.0
    b := 10.0
    steps := 10000000 as i64
    h := (b - a) / (steps as f64)
    mut sum := 0.5 * (f(a) + f(b))
    mut i := 1 as i64
    until i < steps:
        x := a + (i as f64) * h
        sum = sum + f(x)
        i = i + 1
    end
    result := sum * h
    scaled := result * 1000000.0
    println scaled as i64
end
