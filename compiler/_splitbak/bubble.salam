package sort

@en "BubbleSort"
@fa "مرتب‌سازی_حبابی"
pub func BubbleSort<T>(v Vector<T>):
    n i32 = v.len()
    mut end_i i32 = n - 1
    mut swapped bool = true
    while swapped:
        swapped = false
        mut i i32 = 0
        while i < end_i:
            if v.get(i + 1)[0] < v.get(i)[0]:
                Swap(v, i, i + 1)
                swapped = true
            end
            i = i + 1
        end
        end_i = end_i - 1
    end
end
