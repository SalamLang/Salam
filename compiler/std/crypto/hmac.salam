package crypto

@en "HmacSha256Hex"
@fa "اچ مک شا۲۵۶ شانزدهی"
@ar "اتش ماک شا٢٥٦ سداسی"
pub func HmacSha256Hex(key: str, msg: str): str:
    klen := key.len()
    mlen := msg.len()
    out := mem.Allocate(32 as u64)
    defer mem.Free(out)
    _hmac_sha256_core(key as void*, klen, msg as void*, mlen, out)
    mut result := ""
    repeat 32 with i:
        result = result.concat(_hex_byte(_bget(out, i)))
    end
    ret result
end
