package crypto

@en "RandomHex"
@fa "تصادفی ایمن شانزدهی"
@ar "عشوائی سداسی"
pub func RandomHex(n: int): str:
    if n <= 0:
        ret ""
    end
    buf := mem.Allocate(n as u64)
    defer mem.Free(buf)
    _os_random_fill(buf, n)
    mut result := ""
    repeat n with i:
        result = result.concat(_hex_byte(_bget(buf, i)))
    end
    ret result
end

@en "RandomToken"
@fa "توکن تصادفی ایمن"
@ar "رمز عشوائی"
pub func RandomToken(n: int): str:
    ret RandomHex(n)
end
