package crypto

const SHA512_K_HI := [
    1116352408, 1899447441, 3049323471, 3921009573, 961987163, 1508970993, 2453635748, 2870763221
    3624381080, 310598401, 607225278, 1426881987, 1925078388, 2162078206, 2614888103, 3248222580
    3835390401, 4022224774, 264347078, 604807628, 770255983, 1249150122, 1555081692, 1996064986
    2554220882, 2821834349, 2952996808, 3210313671, 3336571891, 3584528711, 113926993, 338241895
    666307205, 773529912, 1294757372, 1396182291, 1695183700, 1986661051, 2177026350, 2456956037
    2730485921, 2820302411, 3259730800, 3345764771, 3516065817, 3600352804, 4094571909, 275423344
    430227734, 506948616, 659060556, 883997877, 958139571, 1322822218, 1537002063, 1747873779
    1955562222, 2024104815, 2227730452, 2361852424, 2428436474, 2756734187, 3204031479, 3329325298
    3391569614, 3515267271, 3940187606, 4118630271, 116418474, 174292421, 289380356, 460393269
    685471733, 852142971, 1017036298, 1126000580, 1288033470, 1501505948, 1607167915, 1816402316
] as i64[80]

const SHA512_K_LO := [
    3609767458, 602891725, 3964484399, 2173295548, 4081628472, 3053834265, 2937671579, 3664609560
    2734883394, 1164996542, 1323610764, 3590304994, 4068182383, 991336113, 633803317, 3479774868
    2666613458, 944711139, 2341262773, 2007800933, 1495990901, 1856431235, 3175218132, 2198950837
    3999719339, 766784016, 2566594879, 3203337956, 1034457026, 2466948901, 3758326383, 168717936
    1188179964, 1546045734, 1522805485, 2643833823, 2343527390, 1014477480, 1206759142, 344077627
    1290863460, 3158454273, 3505952657, 106217008, 3606008344, 1432725776, 1467031594, 851169720
    3100823752, 1363258195, 3750685593, 3785050280, 3318307427, 3812723403, 2003034995, 3602036899
    1575990012, 1125592928, 2716904306, 442776044, 593698344, 3733110249, 2999351573, 3815920427
    3928383900, 566280711, 3454069534, 4000239992, 1914138554, 2731055270, 3203993006, 320620315
    587496836, 1086792851, 365543100, 2618297676, 3409855158, 4234509866, 987167468, 1246189591
] as i64[80]

func _sha512_pad_byte(data : void*, dlen : int, total : int, i : int) : int:
    if i < dlen:
        ret _bget(data, i)
    end
    if i == dlen:
        ret 128
    end
    if i >= total - 8:
        ml := (dlen as i64) * 8
        shift := total - 1 - i
        mut d := ml
        mut j := 0
        until j < shift:
            d /= 256
            j += 1
        end
        ret (d % 256) as int
    end
    ret 0
end

func _sha512_core(data : void*, dlen : int, outp : void*):
    total := ((dlen + 16) / 128 + 1) * 128
    mut h0 := _u64(1779033703, 4089235720)
    mut h1 := _u64(3144134277, 2227873595)
    mut h2 := _u64(1013904242, 4271175723)
    mut h3 := _u64(2773480762, 1595750129)
    mut h4 := _u64(1359893119, 2917565137)
    mut h5 := _u64(2600822924, 725511199)
    mut h6 := _u64(528734635, 4215389547)
    mut h7 := _u64(1541459225, 327033209)
    w_hi := mem.Allocate(80 * 8 as u64) as i64*
    w_lo := mem.Allocate(80 * 8 as u64) as i64*
    defer mem.Free(w_hi as void*)
    defer mem.Free(w_lo as void*)
    mut blk := 0
    until blk < total:
        mut t := 0
        until t < 16:
            base := blk + t * 8
            b0 := _sha512_pad_byte(data, dlen, total, base) as i64
            b1 := _sha512_pad_byte(data, dlen, total, base + 1) as i64
            b2 := _sha512_pad_byte(data, dlen, total, base + 2) as i64
            b3 := _sha512_pad_byte(data, dlen, total, base + 3) as i64
            b4 := _sha512_pad_byte(data, dlen, total, base + 4) as i64
            b5 := _sha512_pad_byte(data, dlen, total, base + 5) as i64
            b6 := _sha512_pad_byte(data, dlen, total, base + 6) as i64
            b7 := _sha512_pad_byte(data, dlen, total, base + 7) as i64
            w_hi[t] = b0 * 16777216 + b1 * 65536 + b2 * 256 + b3
            w_lo[t] = b4 * 16777216 + b5 * 65536 + b6 * 256 + b7
            t += 1
        end
        until t < 80:
            wt15 := _u64(w_hi[t - 15], w_lo[t - 15])
            wt2 := _u64(w_hi[t - 2], w_lo[t - 2])
            w16 := _u64(w_hi[t - 16], w_lo[t - 16])
            w7 := _u64(w_hi[t - 7], w_lo[t - 7])
            s0 := _xor64(_xor64(_rotr64(wt15, 1), _rotr64(wt15, 8)), _shr64(wt15, 7))
            s1 := _xor64(_xor64(_rotr64(wt2, 19), _rotr64(wt2, 61)), _shr64(wt2, 6))
            wt := _add64(_add64(w16, s0), _add64(w7, s1))
            w_hi[t] = wt.hi
            w_lo[t] = wt.lo
            t += 1
        end
        mut a := h0
        mut b := h1
        mut c := h2
        mut d := h3
        mut e := h4
        mut f := h5
        mut g := h6
        mut h := h7
        t = 0
        until t < 80:
            s1cap := _xor64(_xor64(_rotr64(e, 14), _rotr64(e, 18)), _rotr64(e, 41))
            ch := _xor64(_and64(e, f), _and64(_not64(e), g))
            k := _u64(SHA512_K_HI[t], SHA512_K_LO[t])
            wtc := _u64(w_hi[t], w_lo[t])
            temp1 := _add64(_add64(_add64(h, s1cap), ch), _add64(k, wtc))
            s0cap := _xor64(_xor64(_rotr64(a, 28), _rotr64(a, 34)), _rotr64(a, 39))
            maj := _xor64(_xor64(_and64(a, b), _and64(a, c)), _and64(b, c))
            temp2 := _add64(s0cap, maj)
            h = g
            g = f
            f = e
            e = _add64(d, temp1)
            d = c
            c = b
            b = a
            a = _add64(temp1, temp2)
            t += 1
        end
        h0 = _add64(h0, a)
        h1 = _add64(h1, b)
        h2 = _add64(h2, c)
        h3 = _add64(h3, d)
        h4 = _add64(h4, e)
        h5 = _add64(h5, f)
        h6 = _add64(h6, g)
        h7 = _add64(h7, h)
        blk += 128
    end
    _put_word32(outp, 0, h0.hi)
    _put_word32(outp, 4, h0.lo)
    _put_word32(outp, 8, h1.hi)
    _put_word32(outp, 12, h1.lo)
    _put_word32(outp, 16, h2.hi)
    _put_word32(outp, 20, h2.lo)
    _put_word32(outp, 24, h3.hi)
    _put_word32(outp, 28, h3.lo)
    _put_word32(outp, 32, h4.hi)
    _put_word32(outp, 36, h4.lo)
    _put_word32(outp, 40, h5.hi)
    _put_word32(outp, 44, h5.lo)
    _put_word32(outp, 48, h6.hi)
    _put_word32(outp, 52, h6.lo)
    _put_word32(outp, 56, h7.hi)
    _put_word32(outp, 60, h7.lo)
end

@en "Sha512Hex"
@fa "شا۵۱۲ شانزدهی"
@ar "شا٥١٢ سداسی"
pub func Sha512Hex(data : str) : str:
    dlen := data.len()
    out := mem.Allocate(64 as u64)
    defer mem.Free(out)
    _sha512_core(data as void*, dlen, out)
    mut result := ""
    mut i := 0
    until i < 16:
        base := i * 4
        w := (_bget(out, base) as i64) * 16777216 + (_bget(out, base + 1) as i64) * 65536 + (_bget(out, base + 2) as i64) * 256 + (_bget(out, base + 3) as i64)
        result = result.concat(_hex32(w))
        i += 1
    end
    ret result
end
