package redis

@en "HSet"
@fa "تنظیم فیلد هش"
@ar "تعیین حقل التجزئة"
pub func HSet(c: Client, key: str, field: str, val: str): bool:
    if c.handle == null:
        ret false
    end
    args := Vector {} as Vector<str>
    args.push("HSET")
    args.push(key)
    args.push(field)
    args.push(val)
    reply := _raw_command(c.handle, args)
    if reply == null:
        ret false
    end
    n := _reply_integer(reply)
    freeReplyObject(reply)
    ret n >= 0
end

@en "HGet"
@fa "دریافت فیلد هش"
@ar "جلب حقل التجزئة"
pub func HGet(c: Client, key: str, field: str): str:
    if c.handle == null:
        ret ""
    end
    args := Vector {} as Vector<str>
    args.push("HGET")
    args.push(key)
    args.push(field)
    reply := _raw_command(c.handle, args)
    if reply == null:
        ret ""
    end
    mut out := ""
    if _reply_type(reply) == REPLY_STRING:
        out = _reply_str(reply)
    end
    freeReplyObject(reply)
    ret out
end

@en "HDel"
@fa "حذف فیلد هش"
@ar "إزالة حقل التجزئة"
pub func HDel(c: Client, key: str, field: str): bool:
    if c.handle == null:
        ret false
    end
    args := Vector {} as Vector<str>
    args.push("HDEL")
    args.push(key)
    args.push(field)
    reply := _raw_command(c.handle, args)
    if reply == null:
        ret false
    end
    n := _reply_integer(reply)
