@en "LPop"
@fa "برداشتن از ابتدای لیست"
@ar "سحب من بدایة القائمة"
pub func LPop(c: Client, key: str): str:
    if c.handle == null:
        ret ""
    end
    reply := _raw_command(c.handle, _args2("LPOP", key))
    if reply == null:
        ret ""
    end
    mut out := ""
    if _reply_type(reply) == REPLY_STRING:
        out = _reply_str(reply)
    end
    freeReplyObject(reply)
    ret out
end

@en "RPop"
@fa "برداشتن از انتهای لیست"
@ar "سحب من نهایة القائمة"
pub func RPop(c: Client, key: str): str:
    if c.handle == null:
        ret ""
    end
    reply := _raw_command(c.handle, _args2("RPOP", key))
