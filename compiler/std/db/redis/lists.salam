@en "LRange"
@fa "بازه لیست"
@ar "مدى القائمة"
pub func LRange(c: Client, key: str, start: int, stop: int): Vector<str>:
    mut out := Vector {} as Vector<str>
    if c.handle == null:
        ret out
    end
    args := Vector {} as Vector<str>
    args.push("LRANGE")
    args.push(key)
    args.push(conv.FormatInt(start as i64))
    args.push(conv.FormatInt(stop as i64))
    reply := _raw_command(c.handle, args)
    if reply == null:
        ret out
    end
    if _reply_type(reply) == REPLY_ARRAY:
        n := _reply_elements_count(reply)
        repeat n as int with i:
            out.push(_reply_str(_reply_element_at(reply, i)))
        end
    end
    freeReplyObject(reply)
    ret out
end
