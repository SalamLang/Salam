package redis

@en "LPush"
@fa "افزودن به ابتدای لیست"
@ar "إضافة لبدایة القائمة"
pub func LPush(c: Client, key: str, val: str): i64:
    if c.handle == null:
        ret 0
    end
    reply := _raw_command(c.handle, _args3("LPUSH", key, val))
    if reply == null:
        ret 0
    end
    n := _reply_integer(reply)
    freeReplyObject(reply)
    ret n
end

@en "RPush"
@fa "افزودن به انتهای لیست"
