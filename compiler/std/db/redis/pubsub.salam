package redis

@en "Publish"
@fa "انتشار"
@ar "نشر"
pub func Publish(c: Client, channel: str, message: str): i64:
    if c.handle == null:
        ret 0
    end
    reply := _raw_command(c.handle, _args3("PUBLISH", channel, message))
    if reply == null:
        ret 0
    end
    n := _reply_integer(reply)
    freeReplyObject(reply)
    ret n
end
