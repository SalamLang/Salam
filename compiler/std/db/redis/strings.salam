@en "Keys"
@fa "کلیدها"
@ar "مفاتیح"
pub func Keys(c: Client, pattern: str): Vector<str>:
    mut out := Vector {} as Vector<str>
    if c.handle == null:
        ret out
    end
    reply := _raw_command(c.handle, _args2("KEYS", pattern))
    if reply == null:
        ret out
    end
    if _reply_type(reply) == REPLY_ARRAY:
        n := _reply_elements_count(reply)
        repeat n as int with i:
            out.push(_reply_str(_reply_element_at(reply, i)))
        end
    end
    freeReplyObject(reply)
    ret out
end
