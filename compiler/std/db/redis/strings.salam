package redis

@en "Set"
@fa "تنظیم"
@ar "تعیین"
pub func Set(c: Client, key: str, val: str): bool:
    if c.handle == null:
        ret false
    end
    reply := _raw_command(c.handle, _args3("SET", key, val))
    if reply == null:
        ret false
    end
    ok := _reply_type(reply) == REPLY_STATUS
    freeReplyObject(reply)
    ret ok
end

@en "SetEx"
@fa "تنظیم با انقضا"
@ar "تعیین مع انتهاء"
pub func SetEx(c: Client, key: str, val: str, seconds: int): bool:
    if c.handle == null:
        ret false
    end
    reply := _raw_command(c.handle, _args4("SETEX", key, conv.FormatInt(seconds as i64), val))
    if reply == null:
        ret false
    end
    ok := _reply_type(reply) == REPLY_STATUS
    freeReplyObject(reply)
    ret ok
end

@en "Get"
@fa "دریافت"
@ar "جلب"
pub func Get(c: Client, key: str): str:
    if c.handle == null:
        ret ""
    end
    reply := _raw_command(c.handle, _args2("GET", key))
    if reply == null:
        ret ""
    end
    mut out := ""
    if _reply_type(reply) == REPLY_STRING:
        out = _reply_str(reply)
    end
    freeReplyObject(reply)
    ret out
end

