@en "Head"
@fa "سرصفحه"
@ar "ترویسة"
pub func Head(url: str): Response: ret send("HEAD", url, "", "") end

@en "HeadWith"
@fa "سرصفحه با"
@ar "ترویسة مع"
pub func HeadWith(url: str, headers: HashMap<str, str>): Response:
    ret send("HEAD", url, serialize(headers), "")
end

@en "EncodeForm"
@fa "کدگذاری فرم"
@ar "ترمیز نموذج"
pub func EncodeForm(params: HashMap<str, str>): str:
    mut out := ""
    it := params.iter()
    mut first := true
    until it.has_next():
        if first == false: out = out.concat("&") end
        out = out.concat(encoding.URLEncode(it.key())).concat("=").concat(encoding.URLEncode(it.value()))
        first = false
        it.next()
    end
    ret out
end

@en "WithQuery"
@fa "با پرسمان"
@ar "مع استعلام"
pub func WithQuery(base: str, params: HashMap<str, str>): str:
    q := EncodeForm(params)
    if q.len() == 0: ret base end
    mut sep := "?"
    if base.find("?") >= 0: sep = "&" end
    ret base.concat(sep).concat(q)
end

@en "SetCookieLines"
@fa "خطوط کوکی"
@ar "أسطر الكوكي"
pub func SetCookieLines(r: Response): Vector<str>:
    ret HeaderValues(r, "Set-Cookie")
end

@en "CookieMap"
@fa "نگاشت کوکی"
@ar "خریطة الكوكیز"
pub func CookieMap(r: Response): HashMap<str, str>:
    m := HashMap {} as HashMap<str, str>
    raw := SetCookieLines(r)
    repeat raw.len() with i:
        rawline := raw.get(i)[0]
        semi := rawline.find(";")
        mut pair := rawline
        if semi >= 0:
            pair = rawline.substr(0, semi)
        end
        eq := pair.find("=")
        mut nm := pair
        mut vl := ""
        if eq >= 0:
            nm = pair.substr(0, eq)
            vl = pair.substr(eq + 1, pair.len() - eq - 1)
        end
        m.put(nm.trim(), vl.trim())
    end
    raw.free()
    ret m
end

@en "CookieHeader"
@fa "سرصفحه کوکی"
@ar "ترویسة الكوكي"
pub func CookieHeader(cookies: HashMap<str, str>): str:
    if cookies.size() == 0: ret "" end
    mut out := ""
    it := cookies.iter()
    mut first := true
    until it.has_next():
        if first == false: out = out.concat("; ") end
        out = out.concat(it.key()).concat("=").concat(it.value())
        first = false
        it.next()
    end
    ret out
end

@en "NewClient"
@fa "کارخواه جدید"
@ar "عمیل جدید"
pub func NewClient(): Client:
    ret Client {}
end
