package layout

@en ["ltr" "left to right" "left-to-right"]
@fa "چپ به راست"
@ar "من الیسار إلى الیمین"
pub const ltr := LayoutValue { group = "dir" generated_value = "ltr" }

@en ["rtl" "right to left" "right-to-left"]
@fa "راست به چپ"
@ar "من الیمین إلى الیسار"
pub const rtl := LayoutValue { group = "dir" generated_value = "rtl" }
