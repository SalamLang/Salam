@en "math"
@fa "ریاضی"
package math

extern "C":
    pure func sqrt(x : f64) : f64
    pure func sin(x : f64) : f64
    pure func cos(x : f64) : f64
    pure func tan(x : f64) : f64
    pure func asin(x : f64) : f64
    pure func acos(x : f64) : f64
    pure func atan(x : f64) : f64
    pure func atan2(y : f64, x : f64) : f64
    pure func log(x : f64) : f64
    pure func log10(x : f64) : f64
    pure func exp(x : f64) : f64
    pure func floor(x : f64) : f64
    pure func ceil(x : f64) : f64
    pure func fabs(x : f64) : f64
    pure func fmod(x : f64, y : f64) : f64
end

@en "PI"
@fa "پی"
pub const PI = 3.141592653589793

@en "E"
@fa "ای"
pub const E = 2.718281828459045

@en "TAU"
@fa "تاو"
pub const TAU = 6.283185307179586

@en "Sqrt"
@fa "جذر"
pub inline pure func Sqrt(x : f64) : f64: ret sqrt(x) end

@en "Sin"
@fa "سینوس"
pub inline pure func Sin(x : f64) : f64: ret sin(x) end

@en "Cos"
@fa "کسینوس"
pub inline pure func Cos(x : f64) : f64: ret cos(x) end

@en "Tan"
@fa "تانژانت"
pub inline pure func Tan(x : f64) : f64: ret tan(x) end

@en "Asin"
@fa "وارون_سینوس"
pub inline pure func Asin(x : f64) : f64: ret asin(x) end

@en "Acos"
@fa "وارون_کسینوس"
pub inline pure func Acos(x : f64) : f64: ret acos(x) end

@en "Atan"
@fa "وارون_تانژانت"
pub inline pure func Atan(x : f64) : f64: ret atan(x) end

@en "Atan2"
@fa "وارون_تانژانت_دو"
pub inline pure func Atan2(y : f64, x : f64) : f64: ret atan2(y, x) end

@en "Log"
@fa "لگاریتم"
pub inline pure func Log(x : f64) : f64: ret log(x) end

@en "Log10"
@fa "لگاریتم_ده"
pub inline pure func Log10(x : f64) : f64: ret log10(x) end

@en "Log2"
@fa "لگاریتم_دو"
pub inline pure func Log2(x : f64) : f64: ret log(x) / log(2.0) end

@en "Exp"
@fa "نمایی"
pub inline pure func Exp(x : f64) : f64: ret exp(x) end

@en "Floor"
@fa "کف"
pub inline pure func Floor(x : f64) : f64: ret floor(x) end

@en "Ceil"
@fa "سقف"
pub inline pure func Ceil(x : f64) : f64: ret ceil(x) end

@en "Round"
@fa "گردکردن"
pub inline pure func Round(x : f64) : f64: ret floor(x + 0.5) end

@en "Abs"
@fa "قدرمطلق"
pub inline pure func Abs(x : f64) : f64: ret fabs(x) end

@en "Pow"
@fa "توان"
pub inline pure func Pow(base : f64, exp : f64) : f64: ret base ** exp end

@en "Cbrt"
@fa "ریشه‌سوم"
pub inline pure func Cbrt(x : f64) : f64: ret x ** 0.3333333333333333 end

@en "Hypot"
@fa "وتر"
pub inline pure func Hypot(x : f64, y : f64) : f64: ret sqrt(x * x + y * y) end

@en "Sign"
@fa "علامت"
pub inline pure func Sign(x : f64) : f64:
    if x > 0.0: ret 1.0 end
    if x < 0.0: ret 0.0 - 1.0 end
    ret 0.0
end

@en "Min"
@fa "کمینه"
pub inline pure func Min(a : f64, b : f64) : f64: if a < b: ret a end ret b end

@en "Max"
@fa "بیشینه"
pub inline pure func Max(a : f64, b : f64) : f64: if a > b: ret a end ret b end

@en "ClampF"
@fa "محدودسازی_اعشار"
pub inline pure func ClampF(x : f64, lo : f64, hi : f64) : f64:
    if x < lo: ret lo end
    if x > hi: ret hi end
    ret x
end

@en "MinI"
@fa "کمینه_صحیح"
pub inline pure func MinI(a : int, b : int) : int: if a < b: ret a end ret b end

@en "MaxI"
@fa "بیشینه_صحیح"
pub inline pure func MaxI(a : int, b : int) : int: if a > b: ret a end ret b end

@en "AbsI"
@fa "قدرمطلق_صحیح"
pub inline pure func AbsI(x : int) : int: if x < 0: ret 0 - x end ret x end

@en "ClampI"
@fa "محدودسازی_صحیح"
pub inline pure func ClampI(x : int, lo : int, hi : int) : int:
    if x < lo: ret lo end
    if x > hi: ret hi end
    ret x
end

@en "Gcd"
@fa "بزرگترین_مقسوم‌علیه_مشترک"
pub pure func Gcd(a : int, b : int) : int:
    mut x : int = a
    mut y : int = b
    if x < 0: x = 0 - x end
    if y < 0: y = 0 - y end
    while y != 0:
        t : int = y
        y = x % y
        x = t
    end
    ret x
end

@en "Lcm"
@fa "کوچکترین_مضرب_مشترک"
pub pure func Lcm(a : int, b : int) : int:
    if a == 0:
        ret 0
    end
    if b == 0:
        ret 0
    end
    g : int = Gcd(a, b)
    p : int = a / g * b
    if p < 0: ret 0 - p end
    ret p
end

@en "AbsI64"
@fa "قدرمطلق_صحیح۶۴"
pub inline pure func AbsI64(x : i64) : i64: if x < 0: ret 0 - x end ret x end

@en "Mod"
@fa "باقیمانده"
pub inline pure func Mod(x : f64, y : f64) : f64: ret fmod(x, y) end

@en "Trunc"
@fa "بریدن"
pub inline pure func Trunc(x : f64) : f64:
    if x < 0.0: ret ceil(x) end
    ret floor(x)
end

@en "IsNaN"
@fa "نامعدد_است"
pub inline pure func IsNaN(x : f64) : bool: ret x != x end

@en "Inf"
@fa "بی‌نهایت"
pub inline pure func Inf() : f64:
    mut big : f64 = 1.0e308
    ret big * 10.0
end

@en "NaN"
@fa "نامعدد"
pub inline pure func NaN() : f64:
    mut z : f64 = 0.0
    ret z / z
end

@en "IsInf"
@fa "بی‌نهایت_است"
pub inline pure func IsInf(x : f64) : bool:
    mut v : f64 = x
    if v < 0.0: v = 0.0 - v end
    ret v > 0.0 && v / 2.0 == v
end

@en "Sinh"
@fa "سینوس_هذلولی"
pub inline pure func Sinh(x : f64) : f64: ret (exp(x) - exp(0.0 - x)) / 2.0 end

@en "Cosh"
@fa "کسینوس_هذلولی"
pub inline pure func Cosh(x : f64) : f64: ret (exp(x) + exp(0.0 - x)) / 2.0 end

@en "Tanh"
@fa "تانژانت_هذلولی"
pub inline pure func Tanh(x : f64) : f64:
    if x > 20.0: ret 1.0 end
    if x < 0.0 - 20.0: ret 0.0 - 1.0 end
    e2 : f64 = exp(2.0 * x)
    ret (e2 - 1.0) / (e2 + 1.0)
end

@en "Pow10"
@fa "توان_ده"
pub pure func Pow10(n : int) : f64:
    mut r : f64 = 1.0
    mut k : int = n
    if k >= 0:
        while k > 0:
            r *= 10.0
            k -= 1
        end
    else:
        while k < 0:
            r /= 10.0
            k += 1
        end
    end
    ret r
end

@en "Lerp"
@fa "درون‌یابی_خطی"
pub inline pure func Lerp(a : f64, b : f64, t : f64) : f64: ret a + (b - a) * t end

@en "Radians"
@fa "رادیان"
pub inline pure func Radians(deg : f64) : f64: ret deg * PI / 180.0 end

@en "Degrees"
@fa "درجه"
pub inline pure func Degrees(rad : f64) : f64: ret rad * 180.0 / PI end

@en "Factorial"
@fa "فاکتوریل"
pub pure func Factorial(n : int) : i64:
    mut r : i64 = 1
    mut i : i64 = 2
    while i <= n as i64:
        r *= i
        i += 1
    end
    ret r
end

@en "GcdI64"
@fa "ب_م_م_۶۴"
pub pure func GcdI64(a : i64, b : i64) : i64:
    mut x : i64 = a
    mut y : i64 = b
    if x < 0: x = 0 - x end
    if y < 0: y = 0 - y end
    while y != 0:
        t : i64 = y
        y = x % y
        x = t
    end
    ret x
end

@en "MinI64"
@fa "کمینه_صحیح۶۴"
pub inline pure func MinI64(a : i64, b : i64) : i64: if a < b: ret a end ret b end

@en "MaxI64"
@fa "بیشینه_صحیح۶۴"
pub inline pure func MaxI64(a : i64, b : i64) : i64: if a > b: ret a end ret b end
