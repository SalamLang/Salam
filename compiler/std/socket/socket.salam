@en "NONE"
@fa "هیچ"
@ar "لا شیء"
pub const NONE := 0

@en "TEXT"
@fa "متن"
@ar "نص"
pub const TEXT := 1

@en "BINARY"
@fa "دودویی"
@ar "ثنائی"
