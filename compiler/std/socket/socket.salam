@en "Server"
@fa "سرور"
@ar "خادم"
pub struct Server:
    pub fd: i64 = 0 - 1
    pub port: int = 0
end

@en "Conn"
@fa "اتصال وب"
@ar "اتصال"
pub struct Conn:
    pub fd: i64 = 0 - 1
    pub open: bool = false
    pub client: bool = false
    pub buf: void* = null
    pub blen: int = 0
    pub bcap: int = 0
end

@en "Message"
@fa "پیام"
@ar "رسالة"
pub struct Message:
    pub kind: int = 0
    pub text: str = ""
end
