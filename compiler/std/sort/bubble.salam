package sort

@en "BubbleSort"
@fa "مرتب‌سازی_حبابی"
pub func BubbleSort<T>(v : Vector<T>):
    n : int = v.len()
    mut end_i : int = n - 1
    mut swapped : bool = true
    while swapped:
        swapped = false
        mut i : int = 0
        while i < end_i:
            if v.get(i + 1)[0] < v.get(i)[0]:
                Swap(v, i, i + 1)
                swapped = true
            end
            i += 1
        end
        end_i -= 1
    end
end
