package sort

@en "BubbleSort"
@fa "مرتب سازی حبابی"
@ar "ترتیب فقاعی"
pub func BubbleSort<T>(v : Vector<T>):
    n := v.len()
    mut end_i := n - 1
    mut swapped := true
    until swapped:
        swapped = false
        mut i := 0
        until i < end_i:
            if v.get(i + 1)[0] < v.get(i)[0]:
                Swap(v, i, i + 1)
                swapped = true
            end
            i += 1
        end
        end_i -= 1
    end
end
