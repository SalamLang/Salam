package sort

@en "CombSort"
@fa "مرتب سازی شانه ای"
@ar "ترتیب مشطی"
pub func CombSort<T>(v : Vector<T>):
    n := v.len()
    mut gap := n
    mut swapped := true
    until gap > 1 || swapped:
        gap = gap * 10 / 13
        if gap < 1: gap = 1 end
        swapped = false
        mut i := 0
        until i + gap < n:
            if v.get(i + gap)[0] < v.get(i)[0]:
                Swap(v, i, i + gap)
                swapped = true
            end
            i += 1
        end
    end
end
