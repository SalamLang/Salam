package sort

@en "GnomeSort"
@fa "مرتب‌سازی حلزونی"
@ar "ترتيب القزم"
pub func GnomeSort<T>(v : Vector<T>):
    n := v.len()
    mut i := 0
    until i < n:
        if i == 0:
            i = 1
        else:
            if v.get(i)[0] < v.get(i - 1)[0]:
                Swap(v, i, i - 1)
                i -= 1
            else:
                i += 1
            end
        end
    end
end
