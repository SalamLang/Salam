package sort

@en "GnomeSort"
@fa "مرتب‌سازی_حلزونی"
pub func GnomeSort<T>(v : Vector<T>):
    n : int = v.len()
    mut i : int = 0
    while i < n:
        if i == 0:
            i = 1
        else:
            if v.get(i)[0] < v.get(i - 1)[0]:
                Swap(v, i, i - 1)
                i = i - 1
            else:
                i = i + 1
            end
        end
    end
end
