package sort

@en "SelectionSort"
@fa "مرتب‌سازی_انتخابی"
pub func SelectionSort<T>(v : Vector<T>):
    n : int = v.len()
    mut i : int = 0
    while i < n - 1:
        mut m : int = i
        mut j : int = i + 1
        while j < n:
            if v.get(j)[0] < v.get(m)[0]: m = j end
            j = j + 1
        end
        if m != i: Swap(v, i, m) end
        i = i + 1
    end
end
