package sort

@en "SelectionSort"
@fa "مرتب سازی انتخابی"
@ar "ترتیب بالاختیار"
pub func SelectionSort<T>(v: Vector<T>):
    n := v.len()
    repeat n - 1 with i:
        mut m := i
        mut j := i + 1
        until j < n:
            if v.get(j)[0] < v.get(m)[0]: m = j end
            j += 1
        end
        if m != i: Swap(v, i, m) end
    end
end
