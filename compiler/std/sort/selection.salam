package sort

@en "SelectionSort"
@fa "مرتب سازی انتخابی"
@ar "ترتیب بالاختیار"
pub func SelectionSort<T>(v : Vector<T>):
    n := v.len()
    mut i := 0
    until i < n - 1:
        mut m := i
        mut j := i + 1
        until j < n:
            if v.get(j)[0] < v.get(m)[0]: m = j end
            j += 1
        end
        if m != i: Swap(v, i, m) end
        i += 1
    end
end
