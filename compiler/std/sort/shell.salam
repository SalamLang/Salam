package sort

@en "ShellSort"
@fa "مرتب‌سازی_شل"
pub func ShellSort<T>(v : Vector<T>):
    n : int = v.len()
    mut gap : int = 1
    while gap < n / 3: gap = gap * 3 + 1 end
    while gap >= 1:
        mut i : int = gap
        while i < n:
            key : T = v.get(i)[0]
            mut j : int = i
            mut go : bool = true
            while go:
                if j >= gap:
                    if key < v.get(j - gap)[0]:
                        v.set(j, v.get(j - gap)[0])
                        j = j - gap
                    else:
                        go = false
                    end
                else:
                    go = false
                end
            end
            v.set(j, key)
            i = i + 1
        end
        gap = gap / 3
    end
end
