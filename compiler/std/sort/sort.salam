@en "sort"
@fa "مرتب‌سازی"
package sort

import "collections"

@en "Sort"
@fa "مرتب"
pub func Sort<T>(v Vector<T>):
    IntroSort(v)
end

@en "SortDesc"
@fa "مرتب_نزولی"
pub func SortDesc<T>(v Vector<T>):
    IntroSort(v)
    Reverse(v)
end

@en "Sorted"
@fa "مرتب‌شده"
pub func Sorted<T>(v Vector<T>) Vector<T>:
    mut out Vector<T> = Vector {}
    mut i i32 = 0
    while i < v.len():
        out.push(v.get(i)[0])
        i = i + 1
    end
    IntroSort(out)
    ret out
end
