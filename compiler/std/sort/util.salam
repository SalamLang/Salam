package sort

@en "IsSorted"
@fa "مرتب است"
@ar "هل مرتب"
pub func IsSorted<T>(v : Vector<T>) : bool:
    mut i := 1
    until i < v.len():
        if v.get(i)[0] < v.get(i - 1)[0]: ret false end
        i += 1
    end
    ret true
end

@en "Reverse"
@fa "وارونه"
@ar "عكس"
pub func Reverse<T>(v : Vector<T>):
    mut a := 0
    mut b := v.len() - 1
    until a < b:
        Swap(v, a, b)
        a += 1
        b -= 1
    end
end

@en "Min"
@fa "کمینه"
@ar "أصغر"
pub func Min<T>(v : Vector<T>) : T:
    mut m := v.get(0)[0]
    mut i := 1
    until i < v.len():
        if v.get(i)[0] < m: m = v.get(i)[0] end
        i += 1
    end
    ret m
end

@en "Max"
@fa "بیشینه"
@ar "أكبر"
pub func Max<T>(v : Vector<T>) : T:
    mut m := v.get(0)[0]
    mut i := 1
    until i < v.len():
        if m < v.get(i)[0]: m = v.get(i)[0] end
        i += 1
    end
    ret m
end
