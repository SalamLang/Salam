@en "testing"
@fa "آزمایش"
@ar "اختبار"
package testing

import "conv"

mut _tpass : int = 0
mut _tfail : int = 0

func record(cond : bool, msg : str):
    if cond:
        _tpass += 1
    else:
        _tfail += 1
        !_ "FAIL: "
        !__ msg
    end
end

@en "Assert"
@fa "ادعا"
@ar "تأكيد"
pub func Assert(cond : bool): record(cond, "assertion failed") end

@en "AssertMsg"
@fa "ادعا با پیام"
@ar "تأكيد برسالة"
pub func AssertMsg(cond : bool, msg : str): record(cond, msg) end

@en "AssertTrue"
@fa "ادعای درست"
@ar "تأكيد صحيح"
pub func AssertTrue(cond : bool): record(cond, "expected true") end

@en "AssertFalse"
@fa "ادعای نادرست"
@ar "تأكيد خاطئ"
pub func AssertFalse(cond : bool): record(cond == false, "expected false") end

@en "AssertEqInt"
@fa "ادعای برابری عدد"
@ar "تأكيد تساوي عدد"
pub func AssertEqInt(got : int, want : int):
    record(got == want, "ints differ: got ".concat(conv.FormatInt(got as i64)).concat(" want ").concat(conv.FormatInt(want as i64)))
end

@en "AssertEqInt64"
@fa "ادعای برابری عدد۶۴"
@ar "تأكيد تساوي عدد٦٤"
pub func AssertEqInt64(got : i64, want : i64):
    record(got == want, "ints differ: got ".concat(conv.FormatInt(got)).concat(" want ").concat(conv.FormatInt(want)))
end

@en "AssertEqFloat"
@fa "ادعای برابری اعشار"
@ar "تأكيد تساوي عشري"
pub func AssertEqFloat(got : f64, want : f64, eps : f64):
    mut diff : f64 = got - want
    if diff < 0.0: diff = 0.0 - diff end
    record(diff <= eps, "floats differ: got ".concat(conv.FormatFloat(got)).concat(" want ").concat(conv.FormatFloat(want)))
end

@en "AssertContains"
@fa "ادعای شامل بودن"
@ar "تأكيد يحتوي"
pub func AssertContains(hay : str, needle : str):
    record(hay.find(needle) >= 0, "'".concat(hay).concat("' does not contain '").concat(needle).concat("'"))
end

@en "AssertEqStr"
@fa "ادعای برابری رشته"
@ar "تأكيد تساوي نص"
pub func AssertEqStr(got : str, want : str):
    record(got == want, "strings differ: got '".concat(got).concat("' want '").concat(want).concat("'"))
end

@en "AssertEqBool"
@fa "ادعای برابری منطقی"
@ar "تأكيد تساوي منطقي"
pub func AssertEqBool(got : bool, want : bool):
    record(got == want, "bools differ")
end

@en "AssertNeInt"
@fa "ادعای نابرابری عدد"
@ar "تأكيد عدم تساوي عدد"
pub func AssertNeInt(a : int, b : int):
    record(a != b, "ints unexpectedly equal")
end

@en "AssertNeStr"
@fa "ادعای نابرابری رشته"
@ar "تأكيد عدم تساوي نص"
pub func AssertNeStr(a : str, b : str):
    record((a == b) == false, "strings unexpectedly equal")
end

@en "AssertNil"
@fa "ادعای خالی بودن"
@ar "تأكيد فراغ"
pub func AssertNil(p : void*): record(p == null, "expected nil") end

@en "AssertNotNil"
@fa "ادعای خالی نبودن"
@ar "تأكيد عدم فراغ"
pub func AssertNotNil(p : void*): record((p == null) == false, "expected non-nil") end

@en "Reset"
@fa "بازنشانی"
@ar "إعادة تعيين"
pub func Reset():
    _tpass = 0
    _tfail = 0
end

@en "Passed"
@fa "موفق"
@ar "نجح"
pub func Passed() : int: ret _tpass end

@en "Failed"
@fa "ناموفق"
@ar "فشل"
pub func Failed() : int: ret _tfail end

@en "Summary"
@fa "خلاصه"
@ar "ملخص"
pub func Summary() : int:
    println ("--")
    print ("tests: ")
    print (_tpass)
    print (" passed, ")
    print (_tfail)
    println (" failed")
    ret _tfail
end
