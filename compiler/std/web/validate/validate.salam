@en "validate"
@fa "اعتبارسنجی"
package validate

import "web"
import "regex"

@en "Required"
@fa "الزامی"
pub func Required(value : str) : bool:
    ret len(value) > 0
end

@en "Length"
@fa "طول"
pub func Length(value : str, min_len : int, max_len : int) : bool:
    l : int = len(value)
    ret l >= min_len && l <= max_len
end

@en "IsEmail"
@fa "ایمیل_است"
pub func IsEmail(value : str) : bool:
    if value.find("@") < 0:
        ret false
    end
    if value.find(".") < 0:
        ret false
    end
    ret true
end

@en "Matches"
@fa "تطابق_دارد"
pub func Matches(value : str, pattern : str) : bool:
    ret regex.MatchStr(pattern, value)
end

@en "Assert"
@fa "ادعا"
pub func Assert(ctx : i64, ok : bool, message : str):
    if ok:
        ret
    end
    web.Ctx_status(ctx, 400)
    web.Ctx_json(ctx, "{\"error\":\"" + message + "\"}")
end
