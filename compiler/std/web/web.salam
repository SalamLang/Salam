@en "ConnOf"
@fa "اتصال مربوط به"
@ar "اتصال السیاق"
pub func ConnOf(ctx: Context): tcp.Conn:
    ret tcp.ConnFromFd(salam_ctx_fd(ctx.h))
end

struct _KV:
    pub k: str = ""
    pub v: str = ""
end

struct _ReqCtx:
    pub fd: i64 = 0
    pub status: int = 200
    pub is_sent: bool = false
    pub method: str = ""
    pub path: str = ""
    pub query: str = ""
    pub body: str = ""
    pub resp_ct: str = ""
    pub resp_body: str = ""
    pub req_hdrs: Vector<_KV> = Vector {}
    pub path_params: Vector<_KV> = Vector {}
    pub resp_hdrs: Vector<_KV> = Vector {}
end
mut _reqctx_size := 0 as i64
func _reqctx_sizeof(): i64:
    if _reqctx_size == 0:
        v := Vector {} as Vector<_ReqCtx> v.push(_ReqCtx {})
        v.push(_ReqCtx {})
        _reqctx_size = (v.get(1) as i64) - (v.get(0) as i64)
    end
    ret _reqctx_size
end

func _rc(h: i64): _ReqCtx *:
    ret h as _ReqCtx *
end

func salam_ctx_new(fd: i64): i64:
    p := mem.Allocate(_reqctx_sizeof() as u64)
    c := p as _ReqCtx * c[0] = _ReqCtx { fd = fd }
    ret p as i64
end

func salam_ctx_free(h: i64):
    mem.Free(h as void *)
end

func salam_ctx_fd(h: i64): i64:
    ret _rc(h).fd
end

func salam_ctx_get(h: i64, idx: int): str:
    c := _rc(h)
    if idx == 0: ret c.method
    else idx == 1: ret c.path
    else idx == 2: ret c.query
    else idx == 3: ret c.body
    else idx == 4: ret c.resp_ct
    else idx == 5: ret c.resp_body
    else:
        ret ""
    end
end

func salam_ctx_set(h: i64, idx: int, val: str):
    c := _rc(h)
    if idx == 0: c.method = val
    else idx == 1: c.path = val
    else idx == 2: c.query = val
    else idx == 3: c.body = val
    else idx == 4: c.resp_ct = val
    else idx == 5: c.resp_body = val end
end

func salam_ctx_get_status(h: i64): int:
    ret _rc(h).status
end

func salam_ctx_set_status(h: i64, status: int):
    c := _rc(h)
    c.status = status
end

func salam_ctx_is_sent(h: i64): int:
    if _rc(h).is_sent: ret 1 end
    ret 0
end

func _ctx_mark_sent(h: i64):
    c := _rc(h)
    c.is_sent = true
end

func _kvl_get(l &: Vector<_KV>, key: str): str:
    mut i := 0
    until i < l.len():
        kv := l.get(i)[0]
        if kv.k == key: ret kv.v end
        i += 1
    end
    ret ""
end

func _kvl_set(l &: Vector<_KV>, key: str, val: str):
    mut i := 0
    until i < l.len():
        if l.get(i)[0].k == key:
            l.set(i, _KV { k = key, v = val })
            ret
        end
        i += 1
    end
    l.push(_KV { k = key, v = val })
end

func _kvl_clear(l &: Vector<_KV>):
    until l.len() > 0:
        l.pop()
    end
end

func salam_ctx_kv_get(h: i64, list: int, key: str): str:
    c := _rc(h)
    if list == 0: ret _kvl_get(c.req_hdrs, key)
    else list == 1: ret _kvl_get(c.path_params, key)
    else:
        ret _kvl_get(c.resp_hdrs, key)
    end
end

func salam_ctx_kv_add(h: i64, list: int, key: str, val: str):
    c := _rc(h)
    if list == 0: _kvl_set(c.req_hdrs, key, val)
else list == 1: _kvl_set(c.path_params, key, val)
else:
    _kvl_set(c.resp_hdrs, key, val)
end
end

func salam_ctx_kv_clear(h: i64, list: int):
    c := _rc(h)
    if list == 0: _kvl_clear(c.req_hdrs)
else list == 1: _kvl_clear(c.path_params)
else:
    _kvl_clear(c.resp_hdrs)
end
end

func salam_ctx_kv_n(h: i64, list: int): int:
    c := _rc(h)
    if list == 0: ret c.req_hdrs.len()
    else list == 1: ret c.path_params.len()
    else:
        ret c.resp_hdrs.len()
    end
end

func salam_ctx_kv_key(h: i64, list: int, idx: int): str:
    c := _rc(h)
    if list == 0: ret c.req_hdrs.get(idx)[0].k
    else list == 1: ret c.path_params.get(idx)[0].k
    else:
        ret c.resp_hdrs.get(idx)[0].k
    end
end

func salam_ctx_kv_val(h: i64, list: int, idx: int): str:
    c := _rc(h)
    if list == 0: ret c.req_hdrs.get(idx)[0].v
    else list == 1: ret c.path_params.get(idx)[0].v
    else:
        ret c.resp_hdrs.get(idx)[0].v
    end
end

@en "Route"
@fa "مسیر مسیریابی"
@ar "مسار توجیه"
pub struct Route:
    pub method: str = ""
    pub pattern: str = ""
    pub fn: i64 = 0
end

@en "Router"
@fa "مسیریاب"
@ar "موجه"
pub struct Router:
    pub routes: Vector<Route> = Vector {}
    pub static_prefix: str = ""
    pub static_dir: str = ""
    pub has_static: bool = false
end

@en "NewRouter"
@fa "مسیریاب جدید"
@ar "موجه جدید"
pub func NewRouter(): Router:
    ret Router {}
end

@en "Get"
@fa "دریافت"
@ar "جلب"
pub func Get(r &: Router, path: str, fn: i64): r.routes.push(Route { method = "GET", pattern = path, fn = fn }) end

@en "Post"
@fa "ارسال"
@ar "إرسال"
pub func Post(r &: Router, path: str, fn: i64): r.routes.push(Route { method = "POST", pattern = path, fn = fn }) end

@en "Put"
@fa "قراردادن"
@ar "وضع"
pub func Put(r &: Router, path: str, fn: i64): r.routes.push(Route { method = "PUT", pattern = path, fn = fn }) end

@en "Delete"
@fa "حذف"
@ar "حذف"
pub func Delete(r &: Router, path: str, fn: i64): r.routes.push(Route { method = "DELETE", pattern = path, fn = fn }) end

@en "Route"
@fa "مسیر مسیریابی"
@ar "مسار توجیه"
pub func Route(r &: Router, method: str, path: str, fn: i64):
    r.routes.push(Route { method = method, pattern = path, fn = fn })
end

@en "Static"
@fa "ایستا"
@ar "ثابت"
pub func Static(r &: Router, prefix: str, dir: str):
    r.static_prefix = prefix
    r.static_dir = dir
    r.has_static = true
end

@en "FreeRouter"
@fa "آزادسازی مسیریاب"
@ar "تحریر الموجه"
pub func FreeRouter(_r: Router): ret end

@en "Server"
@fa "سرور"
@ar "خادم"
pub struct Server:
    pub port: int = 0
    pub router: Router = Router {}
    pub hide_tokens: bool = false
end

@en "NewServer"
@fa "سرور جدید"
@ar "خادم جدید"
pub func NewServer(port: int): Server:
    ret Server { port = port }
end

@en "Use"
@fa "استفاده"
@ar "استخدام"
pub func Use(s &: Server, r: Router):
    s.router = r
end

@en "HideTokens"
@fa "پنهان سازی توکن"
@ar "إخفاء الرموز"
pub func HideTokens(s &: Server):
    s.hide_tokens = true
end

func _net_listen(port: int): i64:
    ret net.Listen(port).fd
end

func _net_accept(lfd: i64): i64:
    ret net.Accept(net.SocketFromFd(lfd)).fd
end

func _net_recv_req(fd: i64): str:
    ret net.Recv(net.SocketFromFd(fd), 32768)
end

func _net_send_all(fd: i64, data: str):
    s := net.SocketFromFd(fd)
    total := data.len()
    mut sent := 0
    until sent < total:
        n := net.Send(s, data.substr(sent, total - sent))
        if n <= 0:
            ret
        end
        sent += n
    end
end

func _net_close(fd: i64):
    net.Close(net.SocketFromFd(fd))
end

func _send_file(fd: i64, path: str, ct: str, server_hdr: str): int:
    f := fopen(path, "rb")
    if f == null:
        ret 0
    end
    defer fclose(f)
    fseek(f, 0, 2)
    sz := ftell(f)
    fseek(f, 0, 0)
    if sz <= 0 || sz > 16777216:
        ret 0
    end
    buf := mem.Allocate(sz as u64)
    defer mem.Free(buf)
    got := fread(buf, 1 as u64, sz as u64, f)
    mut hdr := "HTTP/1.1 200 OK\r\nContent-Length: "
    hdr = hdr.concat(conv.FormatInt(sz))
    hdr = hdr.concat("\r\nContent-Type: ")
    hdr = hdr.concat(ct)
    hdr = hdr.concat("\r\nConnection: close\r\nServer: ")
    hdr = hdr.concat(server_hdr)
    hdr = hdr.concat("\r\n\r\n")
    _net_send_all(fd, hdr)
    net.SendBytes(net.SocketFromFd(fd), buf, got as int)
    mem.Free(buf)
    ret 1
end

@en "Run"
@fa "اجرا"
@ar "تشغیل"
pub func Run(s: Server):
    _reqctx_sizeof()
    _current_router = s.router
    _hide_tokens = s.hide_tokens
    port := s.port
    lfd := _net_listen(port)
    if lfd < 0:
        ret
    end
    until 1 == 1:
        cfd := _net_accept(lfd)
        if cfd >= 0:
            salam_spawn_fn_i64(funcptr(_web_conn_handler), cfd)
        end
    end
end
mut _current_router := NewRouter()
mut _hide_tokens := false
