@en "MimeExt"
@fa "پسوند مایم"
@ar "امتداد المایم"
pub func MimeExt(ext: str): str:
    if ext == "html" || ext == "htm": ret "text/html; charset=utf-8"
    else ext == "css": ret "text/css"
    else ext == "js": ret "application/javascript"
    else ext == "json": ret "application/json"
    else ext == "png": ret "image/png"
    else ext == "jpg" || ext == "jpeg": ret "image/jpeg"
    else ext == "gif": ret "image/gif"
    else ext == "svg": ret "image/svg+xml"
    else ext == "ico": ret "image/x-icon"
    else ext == "txt": ret "text/plain; charset=utf-8"
    else ext == "pdf": ret "application/pdf"
    else ext == "xml": ret "application/xml"
    else ext == "woff": ret "font/woff"
    else ext == "woff2": ret "font/woff2"
    else:
        ret "application/octet-stream"
    end
end

@en "MimeType"
@fa "رده مایم"
@ar "فئة المایم"
pub func MimeType(p: str): str:
    e := filepath.Ext(p)
    if e.len() == 0: ret "application/octet-stream" end
    ret MimeExt(e.substr(1, e.len() - 1))
end

@en "StatusText"
@fa "متن وضعیت"
@ar "نص الحالة"
pub func StatusText(code: int): str:
    if code == 200: ret "OK"
    else code == 201: ret "Created"
    else code == 204: ret "No Content"
    else code == 301: ret "Moved Permanently"
    else code == 302: ret "Found"
    else code == 304: ret "Not Modified"
    else code == 400: ret "Bad Request"
    else code == 401: ret "Unauthorized"
    else code == 403: ret "Forbidden"
    else code == 404: ret "Not Found"
    else code == 405: ret "Method Not Allowed"
    else code == 409: ret "Conflict"
    else code == 422: ret "Unprocessable Entity"
    else code == 429: ret "Too Many Requests"
    else code == 500: ret "Internal Server Error"
    else code == 502: ret "Bad Gateway"
    else code == 503: ret "Service Unavailable"
    else:
        ret "Unknown"
    end
end

@en "UrlDecode"
@fa "رمزگشایی نشانی"
@ar "فک ترمیز العنوان"
pub func UrlDecode(s: str): str:
    ret encoding.URLDecode(s)
end

func _query_parse(req: str, key: str): str:
    if req.len() == 0: ret "" end
    decoded := UrlDecode(req)
    mut rest := decoded
    until rest.len() > 0:
        amp := rest.find("&")
        mut pair := ""
        if amp >= 0:
            pair = rest.substr(0, amp)
            rest = rest.substr(amp + 1, rest.len() - amp - 1)
        else:
            pair = rest
            rest = ""
        end
        eq := pair.find("=")
        if eq >= 0:
            if pair.substr(0, eq) == key:
                ret pair.substr(eq + 1, pair.len() - eq - 1)
            end
        end
    end
    ret ""
end

func _server_header(hide: bool): str:
    if hide: ret "Salam" end
    ret "Salam/".concat(SERVER_VERSION)
end

func _parse_http(ctx: i64, req: str):
    sp1 := req.find(" ")
    if sp1 < 0: ret end
    salam_ctx_set(ctx, 0, req.substr(0, sp1))
    after_method := req.substr(sp1 + 1, req.len() - sp1 - 1)
    sp2 := after_method.find(" ")
    if sp2 < 0: ret end
    pathquery := after_method.substr(0, sp2)
    qmark := pathquery.find("?")
    if qmark >= 0:
        salam_ctx_set(ctx, 1, pathquery.substr(0, qmark))
        salam_ctx_set(ctx, 2, pathquery.substr(qmark + 1, pathquery.len() - qmark - 1))
    else:
        salam_ctx_set(ctx, 1, pathquery)
        salam_ctx_set(ctx, 2, "")
    end
    first_crlf := req.find("\r\n")
    if first_crlf < 0: ret end
    mut pos := first_crlf + 2
    until pos < req.len():
        if pos + 1 < req.len() && req.substr(pos, 2) == "\r\n":
            pos += 2
            break
        end
        line_end := str.IndexFrom(req, "\r\n", pos)
        if line_end < 0:
            pos = req.len()
            break
        end
        line := req.substr(pos, line_end - pos)
        colon := line.find(":")
        if colon >= 0:
            hk := line.substr(0, colon)
            hv := str.TrimLeft(line.substr(colon + 1, line.len() - colon - 1))
            salam_ctx_kv_add(ctx, 0, hk, hv)
        end
        pos = line_end + 2
    end
    body_sep := str.IndexFrom(req, "\r\n\r\n", 0)
    if body_sep >= 0:
        body_start := body_sep + 4
        if body_start < req.len():
            salam_ctx_set(ctx, 3, req.substr(body_start, req.len() - body_start))
        end
    end
end

func _match_path(pattern: str, path: str, ctx: i64): bool:
    mut pi := 0
    mut pp := 0
    plen := pattern.len()
    pathlen := path.len()
    until pi < plen || pp < pathlen:
        if pi < plen && pattern.substr(pi, 1) == "*":
            ret true
        end
        if pi < plen && pattern.substr(pi, 1) == ":":
            mut ne := pi + 1
            until ne < plen && pattern.substr(ne, 1) != "/":
                ne += 1
            end
            pname := pattern.substr(pi + 1, ne - pi - 1)
            mut ve := pp
            until ve < pathlen && path.substr(ve, 1) != "/":
                ve += 1
            end
            pval := path.substr(pp, ve - pp)
            salam_ctx_kv_add(ctx, 1, pname, pval)
            pi = ne
            pp = ve
        else:
            if pi >= plen || pp >= pathlen:
                break
            end
            if pattern.substr(pi, 1) != path.substr(pp, 1):
                ret false
            end
            pi += 1
            pp += 1
        end
    end
    until pi < plen && pattern.substr(pi, 1) == "/": pi = pi + 1 end
    until pp < pathlen && path.substr(pp, 1) == "/": pp = pp + 1 end
    ret pi == plen && pp == pathlen
end

func _build_response(ctx: i64, hide: bool): str:
    status := salam_ctx_get_status(ctx)
    ct := salam_ctx_get(ctx, 4)
    body := salam_ctx_get(ctx, 5)
    mut resp := "HTTP/1.1 "
    resp = resp.concat(conv.FormatInt(status as i64))
    resp = resp.concat(" ")
    resp = resp.concat(StatusText(status))
    resp = resp.concat("\r\nContent-Length: ")
    resp = resp.concat(conv.FormatInt(body.len() as i64))
    resp = resp.concat("\r\nConnection: close\r\nServer: ")
    resp = resp.concat(_server_header(hide))
    resp = resp.concat("\r\n")
    if ct.len() > 0:
        resp = resp.concat("Content-Type: ")
        resp = resp.concat(ct)
        resp = resp.concat("\r\n")
    end
    nhdr := salam_ctx_kv_n(ctx, 2)
    mut i := 0
    until i < nhdr:
        resp = resp.concat(salam_ctx_kv_key(ctx, 2, i))
        resp = resp.concat(": ")
        resp = resp.concat(salam_ctx_kv_val(ctx, 2, i))
        resp = resp.concat("\r\n")
        i += 1
    end
    resp = resp.concat("\r\n")
    resp = resp.concat(body)
    ret resp
end

func _dispatch(r: Router, ctx: i64): bool:
    method := salam_ctx_get(ctx, 0)
    path := salam_ctx_get(ctx, 1)
    n := r.routes.len()
    mut i := 0
    until i < n:
        route := r.routes.get(i)[0]
        if route.method == method:
            salam_ctx_kv_clear(ctx, 1)
            if _match_path(route.pattern, path, ctx):
                callhandler(route.fn, ctx)
                ret true
            end
        end
        i += 1
    end
    ret false
end

func _web_conn_handler(fd: i64):
    req := _net_recv_req(fd)
    if req.len() == 0:
        _net_close(fd)
        ret
    end
    ctx := salam_ctx_new(fd)
    _parse_http(ctx, req)
    r := _current_router
    hide := _hide_tokens
    shdr := _server_header(hide)
    if r.has_static:
        prefix := r.static_prefix
        path := salam_ctx_get(ctx, 1)
        if path.len() >= prefix.len() && path.substr(0, prefix.len()) == prefix:
            dir := r.static_dir
            rel := path.substr(prefix.len(), path.len() - prefix.len())
            full := dir.concat(rel)
            if _send_file(fd, full, MimeType(full), shdr) == 1:
                _ctx_mark_sent(ctx)
            end
        end
    end
    if salam_ctx_is_sent(ctx) == 0:
        dispatched := _dispatch(r, ctx)
        if dispatched == false:
            salam_ctx_set_status(ctx, 404)
            salam_ctx_set(ctx, 4, "text/plain; charset=utf-8")
            salam_ctx_set(ctx, 5, "404 Not Found")
        end
    end
    if salam_ctx_is_sent(ctx) == 0:
        resp := _build_response(ctx, hide)
        _net_send_all(fd, resp)
    end
    _net_close(fd)
    salam_ctx_free(ctx)
end
