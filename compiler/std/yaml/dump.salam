package yaml

@en "DumpWith"
@fa "برونریزی سفارشی"
@ar "تفريغ مخصص"
pub func DumpWith(text: str, unit: str): str:
    c := Parse(text)
    mut sb := str.NewBuilder()
    defer str.BufFree(sb)
    _dump_block(c, 0, sb, unit, 0)
    out := str.BufStr(sb)
    ret out
end

@en "Dump"
@fa "برونریزی"
@ar "تفريغ"
pub func Dump(text: str): str:
    ret DumpWith(text, "  ")
end

@en "DumpTabs"
@fa "برونریزی تب"
@ar "تفريغ بتاب"
pub func DumpTabs(text: str): str:
    ret DumpWith(text, "\t")
end
