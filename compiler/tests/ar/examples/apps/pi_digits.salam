// لغة: العربية
ثابت عدد := 200
ثابت طول := 700

دالة الرئیسیة:
    متغير رقم: صحیح[701]
    كرر طول مع i:
        رقم[i] = 2000
    نهاية

    اطبع "باي إلى", عدد, "رقم (خوارزمية سبيغوت غير المحدودة):"

    متغير ک := طول
    متغير باقی := 0
    متغير أول := صواب
    بينما ک > 0:
        متغير د := 0
        متغير فهرس := ک
        بينما فهرس > 0:
            د = د + رقم[فهرس] * 10000
            ب := 2 * فهرس - 1
            رقم[فهرس] = د % ب
            د = د / ب
            فهرس = فهرس - 1
            إذا فهرس > 0:
                د = د * فهرس
            نهاية
        نهاية
        قیمة := باقی + د / 10000
        متغير مجموعة: صحیح[4]
        مجموعة[0] = قیمة / 1000
        مجموعة[1] = (قیمة / 100) % 10
        مجموعة[2] = (قیمة / 10) % 10
        مجموعة[3] = قیمة % 10
        كرر 4 مع ج:
            اكتب مجموعة[ج]
            إذا أول:
                اكتب "."
                أول = خطأ
            نهاية
        نهاية
        باقی = د % 10000
        ک = ک - 14
    نهاية
    اطبع ""
نهاية
