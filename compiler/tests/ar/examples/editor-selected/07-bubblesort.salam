//! وضع: برنامج | عنوان: الترتيب الفقاعي
// لغة: العربية
دالة الرئیسیة:
    متغير م := [5, 2, 8, 1, 9, 3] بوصفه صحیح[6]
    كرر 6 مع i:
        كرر 5 - i مع ج:
            إذا م[ج] > م[ج + 1]:
                ت := م[ج]
                م[ج] = م[ج + 1]
                م[ج + 1] = ت
            نهاية
        نهاية
    نهاية
    متغير سطر := ""
    كرر 6 مع ک: سطر = سطر + م[ک] + " " نهاية
    اطبع "مرتب:", سطر
نهاية
