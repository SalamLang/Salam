// لغة: العربية
دالة الرئیسیة:
    متغير عدّ := 0
    كرر 3 مع فهرس:
        عدّ += فهرس
    نهاية
    اطبع "المجموع:", عدّ

    متغير مستوى := 1
    إذا عدّ > 2:
        مستوى = 2
    نهاية
    اطبع "المستوى:", مستوى

    متغير ضربات := 9
    ضربات++
    اطبع "الضربات:", ضربات

    تحیة := "سلام"
    اطبع "غير قابل للتغيير:", تحیة

    ثابت حد := 100
    اطبع "الثابت:", حد
نهاية
