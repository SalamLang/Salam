// لغة: العربية
بنية قراءة:
    عام حساس: نص
    عام قیمة: متنوع<صحیح, عشري64, نص>
نهاية

دالة شرح(م: متنوع<صحیح, عشري64, نص>): نص:
    أرجع طابق م:
        صحیح ن => "صحیح " + ن
        عشري64 ع => "عشري " + ع
        نص خ => "خطأ: " + خ
    نهاية
نهاية

دالة الرئیسیة:
    متغير عینة := 21 بوصفه متنوع<صحیح, عشري64, نص>
    اطبع شرح(عینة)

    عینة = 21.5
    اطبع شرح(عینة)

    عینة = "الحساس متوقف"
    اطبع شرح(عینة)

    قراءات := [
        قراءة { حساس = "الحرارة", قیمة = 21.5 }, قراءة { حساس = "الرطوبة", قیمة = 55 }, قراءة { حساس = "الضغط", قیمة = "الحساس متوقف" }
    ]
    متغير ش := 0
    بينما ش < 3:
        ك := قراءات[ش]
        اطبع ك.حساس + ": " + شرح(ك.قیمة)
        ش = ش + 1
    نهاية
نهاية
