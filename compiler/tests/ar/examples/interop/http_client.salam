package main

import http
import json
import str

func section(title: str):
    println ""
    println "== ".concat(title).concat(" ==")
end

func main:
    section("طلب GET")
    r := http.Get("https://httpbin.org/get")
    println "الحالة: ".concat(str.FromInt(r.status as i64))
    if http.Ok(r):
        println "ناجح: نعم"
    else:
        println "ناجح: لا"
    end
    println "origin: ".concat(json.Get(r.body, "origin"))

    section("GET مع ترويسات مخصصة")
    mut reqHeaders := http.NewHeaders()
    reqHeaders.put("X-Demo", "salam")
    reqHeaders.put("Accept", "application/json")
    hr := http.GetWith("https://httpbin.org/headers", reqHeaders)
    println "نوع المحتوى: ".concat(http.GetHeader(hr, "Content-Type"))
    if str.Contains(hr.body, "salam"):
        println "الخادم أعاد ترويسة X-Demo"
    end

    section("قراءة كل ترويسات الاستجابة")
    all := http.Headers(hr)
    println "عدد الترويسات: ".concat(str.FromInt(all.size() as i64))

    section("إرسال جسم JSON عبر POST")
    body := "{\"name\": \"Salam\", \"lang\": \"ar\"}"
    mut jsonHeaders := http.NewHeaders()
    jsonHeaders.put("Content-Type", "application/json")
    p := http.PostWith("https://httpbin.org/post", body, jsonHeaders)
    println "الحالة: ".concat(str.FromInt(p.status as i64))
    echoed := json.Get(p.body, "json")
    println "الاسم الذي استقبله الخادم: ".concat(json.Get(echoed, "name"))

    section("PUT / PATCH / DELETE / OPTIONS / HEAD")
    put := http.Put("https://httpbin.org/put", "x=1")
    println "حالة PUT: ".concat(str.FromInt(put.status as i64))
    patch := http.Patch("https://httpbin.org/patch", "y=2")
    println "حالة PATCH: ".concat(str.FromInt(patch.status as i64))
    del := http.Delete("https://httpbin.org/delete")
    println "حالة DELETE: ".concat(str.FromInt(del.status as i64))
    opt := http.Options("https://httpbin.org/get")
    println "حالة OPTIONS: ".concat(str.FromInt(opt.status as i64))
    head := http.Head("https://httpbin.org/get")
    println "حالة HEAD: ".concat(str.FromInt(head.status as i64))
    println "حجم جسم HEAD: ".concat(str.FromInt(str.Len(head.body) as i64))

    section("بناء رابط طلب مع معاملات استعلام")
    mut params := http.NewHeaders()
    params.put("q", "سلام لانج")
    params.put("page", "2")
    url := http.WithQuery("https://httpbin.org/get", params)
    println url
    qr := http.Get(url)
    println "الحالة: ".concat(str.FromInt(qr.status as i64))

    section("قراءة كوكيز الاستجابة")
    cset := http.Get("https://httpbin.org/cookies/set?token=abc123")
    cookies := http.CookieMap(cset)
    println "كوكي token: ".concat(cookies.get("token"))

    section("جلسة زحف بسيطة (scraper)")
    mut session := http.NewClient()
    session.SetHeader("User-Agent", "SalamBot/1.0")
    login := session.Get("https://httpbin.org/cookies/set?session_id=xyz789")
    println "حالة تسجيل الدخول: ".concat(str.FromInt(login.status as i64))
    dashboard := session.Get("https://httpbin.org/cookies")
    if str.Contains(dashboard.body, "xyz789"):
        println "تم إرسال كوكي الجلسة تلقائياً في الطلب التالي"
    end
    println dashboard.body

    section("استخراج عنوان الصفحة <title>")
    page := http.Get("https://example.com/")
    title start := str.Find(page.body, "<title>")
    title end := str.Find(page.body, "</title>")
    if title start >= 0 && title end > title start:
        title := page.body.substr(title start + 7, title end - title start - 7)
        println "عنوان الصفحة: ".concat(title)
    end
end
