// لغة: العربية
استيراد قاعدة بیانات.ردیس

دالة الرئيسية:
    ك := ردیس.اتصال("127.0.0.1", 6379)
    إذا ردیس.صالح(ك):
        اطبع "تم الاتصال بردیس، بينغ:", ردیس.بینغ(ك)

        ردیس.تعیین(ك, "salam:example:greeting", "مرحبا من سلام")
        اطبع ردیس.جلب(ك, "salam:example:greeting")

        ردیس.إزالة(ك, "salam:example:visits")
        ردیس.زیادة(ك, "salam:example:visits")
        ردیس.زیادة(ك, "salam:example:visits")
        n := ردیس.زیادة(ك, "salam:example:visits")
        اطبع "عدد الزیارات:", n

        ردیس.إزالة(ك, "salam:example:fruits")
        ردیس.إضافة لنهایة القائمة(ك, "salam:example:fruits", "تفاح")
        ردیس.إضافة لنهایة القائمة(ك, "salam:example:fruits", "موز")
        ردیس.إضافة لنهایة القائمة(ك, "salam:example:fruits", "كرز")
        الفواكه := ردیس.مدى القائمة(ك, "salam:example:fruits", 0, 0 - 1)
        اطبع "الفواكه:"
        كرر الفواكه.طول() مع i:
            اطبع "  -", الفواكه.احصل(i)[0]
        نهاية

        ردیس.إزالة(ك, "salam:example:greeting")
        ردیس.إزالة(ك, "salam:example:visits")
        ردیس.إزالة(ك, "salam:example:fruits")
        ردیس.إغلاق(ك)
    وإلا:
        اطبع "تعذر الاتصال بردیس:", ردیس.خطأ(ك)
    نهاية
نهاية
