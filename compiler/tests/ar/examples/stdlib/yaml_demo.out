صالح: true
اسم التطبیق: Salam
نسخة التطبیق: 3
وضع التصحیح: false
عدد الخوادم: 2
مضیف الخادم الأول: alpha.example.com
منفذ الخادم الثانی: 8081
--- کنص جيسون ---
{"app": {"name": "Salam", "version": 3, "debug": false}, "servers": [{"host": "alpha.example.com", "port": 8080}, {"host": "beta.example.com", "port": 8081}]}
--- يامل بصیغة معاد تنسیقها ---
app:
  name: Salam
  version: 3
  debug: false
servers:
  -
    host: alpha.example.com
    port: 8080
  -
    host: beta.example.com
    port: 8081
