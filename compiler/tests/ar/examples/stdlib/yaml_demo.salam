// لغة: العربية
استيراد يامل

دالة الرئیسیة:
    الإعدادات := "app:\n  name: Salam\n  version: 3\n  debug: false\nservers:\n  - host: alpha.example.com\n    port: 8080\n  - host: beta.example.com\n    port: 8081\n"

    اطبع "صالح:", يامل.صالح(الإعدادات)
    اطبع "اسم التطبیق:", يامل.جلب(الإعدادات, "app.name")
    اطبع "نسخة التطبیق:", يامل.جلب عدد صحیح(الإعدادات, "app.version")
    اطبع "وضع التصحیح:", يامل.جلب منطقی(الإعدادات, "app.debug")
    اطبع "عدد الخوادم:", يامل.طول(الإعدادات, "servers")
    اطبع "مضیف الخادم الأول:", يامل.جلب(الإعدادات, "servers[0].host")
    اطبع "منفذ الخادم الثانی:", يامل.جلب عدد صحیح(الإعدادات, "servers[1].port")

    اطبع "--- کنص جيسون ---"
    اطبع يامل.لجيسون(الإعدادات)

    اطبع "--- يامل بصیغة معاد تنسیقها ---"
    اطبع يامل.تفريغ(الإعدادات)
نهاية
