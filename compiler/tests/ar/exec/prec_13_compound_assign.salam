// لغة: العربية
دالة الرئيسية:
    ب := 3
    ج := 4

    متغير ه := 5
    ه += ب * ج
    اطبع(ه)

    متغير ز := 2
    ز *= ب + ج
    اطبع(ز)

    متغير ح := 100
    ح -= ب * ج
    اطبع(ح)

    متغير خ := 100
    خ /= ب - 1
    اطبع(خ)

    متغير م := 10
    م %= ب + 1
    اطبع(م)

    متغير ن := 2.0
    ن **= ب - 1
    اطبع(ن)
نهاية
