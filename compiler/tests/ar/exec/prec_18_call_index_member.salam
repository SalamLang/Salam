// لغة: العربية
بنية صندوق:
    عام عرض: صحیح
    عام طول: صحیح
نهاية

دالة مضاعف(قیمة: صحیح): صحیح:
    أرجع قیمة * 2
نهاية

دالة الرئیسیة:
    أ := 3
    ب := 4

    ص := صندوق { عرض = 5, طول = 6 }
    اطبع ص.عرض + ص.طول * 2
    اطبع مضاعف(أ) + ب
    اطبع مضاعف(أ + ب)

    أعداد := [10, 20, 30]
    اطبع أعداد[1] + أعداد[0] * 2
    اطبع -أعداد[0]
نهاية
