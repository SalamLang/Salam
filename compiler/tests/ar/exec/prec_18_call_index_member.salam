// لغة: العربية
بنية صندوق:
    عام عرض : صحيح
    عام طول : صحيح
نهاية

دالة مضاعف(قيمة : صحيح) : صحيح:
    أرجع قيمة * 2
نهاية

دالة الرئيسية:
    أ := 3
    ب := 4

    ص := صندوق { عرض = 5, طول = 6 }
    اطبع ص.عرض + ص.طول * 2
    اطبع مضاعف(أ) + ب
    اطبع مضاعف(أ + ب)

    أعداد := [10, 20, 30]
    اطبع أعداد[1] + أعداد[0] * 2
    اطبع-أعداد[0]
نهاية
