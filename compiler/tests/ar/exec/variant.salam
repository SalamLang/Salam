// لغة: العربية
بنية صندوق:
    عام علامة: نص
    عام قیمة: متنوع<صحیح, نص, منطقی>
نهاية

دالة شرح(م: متنوع<صحیح, نص, منطقی>): نص:
    أرجع طابق م:
        صحیح ن => "عدد:" + ن
        نص س => "نص:" + س
        منطقی ب => "منطقي:" + ب
    نهاية
نهاية

دالة الرئیسیة:
    متغير خ := 42 بوصفه متنوع<صحیح, نص, منطقی>
    اطبع شرح(خ)
    خ = "مرحبا"
    اطبع شرح(خ)
    خ = صواب
    اطبع شرح(خ)

    ص := صندوق { علامة = "أ", قیمة = 7 }
    اطبع ص.علامة + ":" + شرح(ص.قیمة)
نهاية
