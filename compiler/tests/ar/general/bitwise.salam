// لغة: العربية
دالة الرئیسیة:
    الف := 12
    ب := 10
    اطبع الف & ب, الف | ب, الف ^ ب
    اطبع الف << 2, الف >> 1, ~الف
    متغير عدد := 0
    عدد |= 5
    عدد &= 6
    عدد ^= 1
    عدد <<= 2
    عدد >>= 1
    اطبع عدد
    اطبع 1 | 2 & 3, 1 << 4 + 1
    متغير قناع := 0xFF
    قناع = قناع & 0x0F
    اطبع قناع, 0b1010 | 0b0101
نهاية
