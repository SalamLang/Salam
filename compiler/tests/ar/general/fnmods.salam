// لغة: العربية
ثابت عشرة = 10
متغير معامل : صحيح = 2

عام نقي دالة جمع_نقي(a : صحيح, b : صحيح) : صحيح: أرجع a + b نهاية

عام نقي دالة مقياس(x : صحيح) : صحيح: أرجع x * معامل + عشرة نهاية

عام مضمن دالة زيادة(x : صحيح) : صحيح:
    معامل = معامل + 1
    أرجع x + معامل
نهاية

غيرمضمن دالة ثلاثة(x : صحيح) : صحيح: أرجع x * 3 نهاية

عام مهجور دالة قديم(x : صحيح) : صحيح: أرجع x + 1 نهاية

دالة الرئيسية:
    اطبع(جمع_نقي(1, 2))
    اطبع(ثلاثة(2))
    اطبع(قديم(9))
    اطبع(مقياس(3))
    اطبع(زيادة(1))
نهاية
