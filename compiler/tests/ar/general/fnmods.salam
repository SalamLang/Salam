// لغة: العربية
ثابت عشرة = 10
متغير معامل : صحيح = 2

عام نقي دالة جمع_نقي(أ : صحيح, ب : صحيح) : صحيح: أرجع أ + ب نهاية

عام نقي دالة مقياس(قيمة : صحيح) : صحيح: أرجع قيمة * معامل + عشرة نهاية

عام مضمن دالة زيادة(قيمة : صحيح) : صحيح:
    معامل = معامل + 1
    أرجع قيمة + معامل
نهاية

غيرمضمن دالة ثلاثة(قيمة : صحيح) : صحيح: أرجع قيمة * 3 نهاية

عام مهجور دالة قديم(قيمة : صحيح) : صحيح: أرجع قيمة + 1 نهاية

دالة الرئيسية:
    اطبع(جمع_نقي(1, 2))
    اطبع(ثلاثة(2))
    اطبع(قديم(9))
    اطبع(مقياس(3))
    اطبع(زيادة(1))
نهاية
