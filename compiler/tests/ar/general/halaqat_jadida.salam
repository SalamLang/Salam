دالة الرئيسية:
    اسم := "سلام"
    متغير عد := 0
    عد = عد + 1
    اسماء := ["ا", "ب", "ج"]
    كل س في اسماء:
        إذا س != "ب":
            اطبع س
        نهاية
    نهاية
    كرر 2:
        اكتب "خ"
    نهاية
    اطبع ""
    كرر 1 إلى 5 خطوة 2 مع فهرس:
        إذا فهرس > 2:
            اكتب "ز"
        نهاية
    نهاية
    اطبع ""
    متغير ك := 0
    بينما ك < 3:
        اكتب "و"
        ك = ك + 1
    نهاية
    اطبع ""
    إذا عد == 1:
        اطبع اسم
    نهاية
نهاية
