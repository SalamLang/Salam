// لغة: العربية
واجهة توصيف:
    دالة تسمية() نص
    دالة نقطة() صحيح
نهاية

تنفيذ توصيف لكل صحيح:
    دالة تسمية() نص: أرجع "رقم" نهاية
    دالة نقطة() صحيح: أرجع هذا * 10 نهاية
نهاية

تنفيذ توصيف لكل منطقي:
    دالة تسمية() نص: أرجع "علم" نهاية
    دالة نقطة() صحيح:
        إذا هذا: أرجع 1 نهاية
        أرجع 0
    نهاية
نهاية

دالة عرض<ن: توصيف>(x ن):
    اطبع x.تسمية()
    اطبع x.نقطة()
نهاية

دالة الرئيسية:
    عرض(7)
    عرض(صواب)
    عرض(خطأ)
نهاية
