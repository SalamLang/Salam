// لغة: العربية
مضمن نقي دالة مربع(قيمة : صحيح) : صحيح: أرجع قيمة * قيمة نهاية

عام مضمن نقي دالة مساحة(عرض : عشري٦٤, ارتفاع : عشري٦٤) : عشري٦٤: أرجع عرض * ارتفاع نهاية

غيرمضمن نقي دالة مكعب(قيمة : صحيح) : صحيح: أرجع قيمة * قيمة * قيمة نهاية

نقي دالة مضروب(عدد : صحيح) : صحيح٦٤:
    إذا عدد <= 1: أرجع 1 نهاية
    أرجع (عدد بوصفه صحيح٦٤) * مضروب(عدد - 1)
نهاية

نقي دالة أكبر<ن>(أ : ن, ب : ن) : ن:
    إذا أ > ب: أرجع أ نهاية
    أرجع ب
نهاية

دالة الرئيسية:
    اطبع(مربع(6))
    اطبع(مساحة(2.5, 4.0))
    اطبع(مكعب(3))
    اطبع(مضروب(5))
    اطبع(أكبر(4, 9))
نهاية
