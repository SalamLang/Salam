// لغة: العربية
مضمن نقي دالة مربع(x : صحيح) : صحيح: أرجع x * x نهاية

عام مضمن نقي دالة مساحة(w : عشري٦٤, h : عشري٦٤) : عشري٦٤: أرجع w * h نهاية

غيرمضمن نقي دالة مكعب(x : صحيح) : صحيح: أرجع x * x * x نهاية

نقي دالة مضروب(n : صحيح) : صحيح٦٤:
    إذا n <= 1: أرجع 1 نهاية
    أرجع (n بوصفه صحيح٦٤) * مضروب(n - 1)
نهاية

نقي دالة أكبر<ن>(a : ن, b : ن) : ن:
    إذا a > b: أرجع a نهاية
    أرجع b
نهاية

دالة الرئيسية:
    اطبع(مربع(6))
    اطبع(مساحة(2.5, 4.0))
    اطبع(مكعب(3))
    اطبع(مضروب(5))
    اطبع(أكبر(4, 9))
نهاية
