// لغة: العربية
استيراد جیسون

دالة الرئیسیة:
    اطبع جیسون.نص جیسون("hi \"there\"")
    اطبع جیسون.عضو("name", "salam")
    اطبع جیسون.عضو عدد صحیح("age", 5)
    اطبع جیسون.عضو منطقی("ok", صواب)
    اطبع جیسون.عضو عدد عشری("pi", 3.5)
    اطبع جیسون.عضو خام("raw", "[1, 2, 3]")

    متغير علامات := متجه {} بوصفه متجه<نص> علامات.أضف(جیسون.نص جیسون("a"))
    علامات.أضف(جیسون.نص جیسون("b"))
    علامات_جیسون := جیسون.مصفوفة(علامات)
    اطبع علامات_جیسون

    متغير نقطة := متجه {} بوصفه متجه<نص> نقطة.أضف(جیسون.عضو عدد صحیح("x", 1))
    نقطة.أضف(جیسون.عضو عدد صحیح("y", 2))
    نقطة_جیسون := جیسون.کائن(نقطة)
    اطبع نقطة_جیسون

    متغير مستند := متجه {} بوصفه متجه<نص> مستند.أضف(جیسون.عضو("name", "salam"))
    مستند.أضف(جیسون.عضو عدد صحیح("version", 2))
    مستند.أضف(جیسون.عضو منطقی("active", صواب))
    مستند.أضف(جیسون.عضو خام("tags", علامات_جیسون))
    مستند.أضف(جیسون.عضو خام("point", نقطة_جیسون))
    مستند.أضف(جیسون.عضو خام("empty_obj", جیسون.کائن(متجه {} بوصفه متجه<نص>)))
    مستند.أضف(جیسون.عضو خام("empty_arr", جیسون.مصفوفة(متجه {} بوصفه متجه<نص>)))
    مستند_جیسون := جیسون.کائن(مستند)
    اطبع مستند_جیسون

    اطبع جیسون.صالح(مستند_جیسون)
    اطبع جیسون.صالح("{ not valid")
    اطبع جیسون.جلب(مستند_جیسون, "name")
    اطبع جیسون.جلب عدد صحیح(مستند_جیسون, "version")
    اطبع جیسون.یملک(مستند_جیسون, "active")
    اطبع جیسون.یملک(مستند_جیسون, "missing")

    اطبع جیسون.مسافة بادئة(مستند_جیسون)
    اطبع جیسون.مسافة بادئة مخصصة(مستند_جیسون, "    ")
    اطبع جیسون.مسافة بادئة أربعة(مستند_جیسون)
    اطبع جیسون.مسافة بادئة بتاب(مستند_جیسون)

    اطبع جیسون.تصغیر(جیسون.مسافة بادئة(مستند_جیسون)) == جیسون.تصغیر(مستند_جیسون)
نهاية
