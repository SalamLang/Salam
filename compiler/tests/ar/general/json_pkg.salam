// لغة: العربية
استيراد جيسون

دالة الرئيسية:
    اطبع جيسون.نص جيسون("hi \"there\"")
    اطبع جيسون.عضو("name", "salam")
    اطبع جيسون.عضو عدد صحیح("age", 5)
    اطبع جيسون.عضو منطقی("ok", صواب)
    اطبع جيسون.عضو عدد عشری("pi", 3.5)
    اطبع جيسون.عضو خام("raw", "[1, 2, 3]")

    متغير علامات := Vector {} بوصفه Vector<نص>
    علامات.push(جيسون.نص جيسون("a"))
    علامات.push(جيسون.نص جيسون("b"))
    علامات_جيسون := جيسون.مصفوفة(علامات)
    اطبع علامات_جيسون

    متغير نقطة := Vector {} بوصفه Vector<نص>
    نقطة.push(جيسون.عضو عدد صحیح("x", 1))
    نقطة.push(جيسون.عضو عدد صحیح("y", 2))
    نقطة_جيسون := جيسون.کائن(نقطة)
    اطبع نقطة_جيسون

    متغير مستند := Vector {} بوصفه Vector<نص>
    مستند.push(جيسون.عضو("name", "salam"))
    مستند.push(جيسون.عضو عدد صحیح("version", 2))
    مستند.push(جيسون.عضو منطقی("active", صواب))
    مستند.push(جيسون.عضو خام("tags", علامات_جيسون))
    مستند.push(جيسون.عضو خام("point", نقطة_جيسون))
    مستند.push(جيسون.عضو خام("empty_obj", جيسون.کائن(Vector {} بوصفه Vector<نص>)))
    مستند.push(جيسون.عضو خام("empty_arr", جيسون.مصفوفة(Vector {} بوصفه Vector<نص>)))
    مستند_جيسون := جيسون.کائن(مستند)
    اطبع مستند_جيسون

    اطبع جيسون.صالح(مستند_جيسون)
    اطبع جيسون.صالح("{ not valid")
    اطبع جيسون.جلب(مستند_جيسون, "name")
    اطبع جيسون.جلب عدد صحیح(مستند_جيسون, "version")
    اطبع جيسون.يملك(مستند_جيسون, "active")
    اطبع جيسون.يملك(مستند_جيسون, "missing")

    اطبع جيسون.مسافة بادئة(مستند_جيسون)
    اطبع جيسون.مسافة بادئة مخصصة(مستند_جيسون, "    ")
    اطبع جيسون.مسافة بادئة أربعة(مستند_جيسون)
    اطبع جيسون.مسافة بادئة بتاب(مستند_جيسون)

    اطبع جيسون.تصغیر(جيسون.مسافة بادئة(مستند_جيسون)) == جيسون.تصغیر(مستند_جيسون)
نهاية
