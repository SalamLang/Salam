استيراد regex

دالة الرئيسية:
    اطبع regex.مطابقةنص("[0-9]+", "abc123")
    اطبع regex.مطابقةنص("[0-9]+", "abcxyz")

    اطبع regex.بحثنص("wor", "hello world")
    اطبع regex.بحثنص("zzz", "hello world")

    نمط := regex.تجمیع("^[A-Za-z]+$")
    اطبع regex.مطابقة(نمط, "Hello")
    اطبع regex.مطابقة(نمط, "Hello123")

    اطبع regex.مطابقةنص("^abc$", "abc")
    اطبع regex.مطابقةنص("^abc$", "abcd")

    اطبع regex.مطابقةنص("[^0-9]+", "###")
    اطبع regex.مطابقةنص("^[^0-9]+$", "a1b")

    اطبع regex.مطابقةنص("colou?r", "color")
    اطبع regex.مطابقةنص("colou?r", "colour")
    اطبع regex.مطابقةنص("colou?r", "colouur")

    اطبع regex.مطابقةنص("go+gle", "gooogle")
    اطبع regex.مطابقةنص("go+gle", "ggle")

    اطبع regex.مطابقةنص("\\d\\d\\d", "room 404")
    اطبع regex.مطابقةنص("\\s", "a b")
    اطبع regex.مطابقةنص("\\w+", "_hi9")

    اطبع regex.مطابقةنص("a.c", "abc")
    اطبع regex.مطابقةنص("a.c", "ac")

    اطبع regex.مطابقةنص("a\\.b", "a.b")
    اطبع regex.مطابقةنص("a\\.b", "axb")

    اطبع regex.استبدالنص("[0-9]+", "item1 item2 item3", "#")
    اطبع regex.استبدالالکلنص("[0-9]+", "item1 item2 item3", "#")

    نمط۲ := regex.تجمیع("o")
    اطبع regex.استبدال(نمط۲, "foo", "0")
    اطبع regex.استبدالالکل(نمط۲, "foo", "0")

    اطبع regex.استبدالنص("zzz", "hello", "Q")
نهاية
