استيراد تعبیر نمطی

دالة الرئيسية:
    اطبع تعبیر نمطی.مطابقةنص("[0-9]+", "abc123")
    اطبع تعبیر نمطی.مطابقةنص("[0-9]+", "abcxyz")

    اطبع تعبیر نمطی.بحثنص("wor", "hello world")
    اطبع تعبیر نمطی.بحثنص("zzz", "hello world")

    نمط := تعبیر نمطی.تجمیع("^[A-Za-z]+$")
    اطبع تعبیر نمطی.مطابقة(نمط, "Hello")
    اطبع تعبیر نمطی.مطابقة(نمط, "Hello123")

    اطبع تعبیر نمطی.مطابقةنص("^abc$", "abc")
    اطبع تعبیر نمطی.مطابقةنص("^abc$", "abcd")

    اطبع تعبیر نمطی.مطابقةنص("[^0-9]+", "###")
    اطبع تعبیر نمطی.مطابقةنص("^[^0-9]+$", "a1b")

    اطبع تعبیر نمطی.مطابقةنص("colou?r", "color")
    اطبع تعبیر نمطی.مطابقةنص("colou?r", "colour")
    اطبع تعبیر نمطی.مطابقةنص("colou?r", "colouur")

    اطبع تعبیر نمطی.مطابقةنص("go+gle", "gooogle")
    اطبع تعبیر نمطی.مطابقةنص("go+gle", "ggle")

    اطبع تعبیر نمطی.مطابقةنص("\\d\\d\\d", "room 404")
    اطبع تعبیر نمطی.مطابقةنص("\\s", "a b")
    اطبع تعبیر نمطی.مطابقةنص("\\w+", "_hi9")

    اطبع تعبیر نمطی.مطابقةنص("a.c", "abc")
    اطبع تعبیر نمطی.مطابقةنص("a.c", "ac")

    اطبع تعبیر نمطی.مطابقةنص("a\\.b", "a.b")
    اطبع تعبیر نمطی.مطابقةنص("a\\.b", "axb")

    اطبع تعبیر نمطی.استبدالنص("[0-9]+", "item1 item2 item3", "#")
    اطبع تعبیر نمطی.استبدالالکلنص("[0-9]+", "item1 item2 item3", "#")

    نمط۲ := تعبیر نمطی.تجمیع("o")
    اطبع تعبیر نمطی.استبدال(نمط۲, "foo", "0")
    اطبع تعبیر نمطی.استبدالالکل(نمط۲, "foo", "0")

    اطبع تعبیر نمطی.استبدالنص("zzz", "hello", "Q")
نهاية
