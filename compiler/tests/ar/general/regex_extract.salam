استيراد regex

دالة استخرج_العنوان(نص_م: نص): نص:
    إذا !regex.مطابقةنص("<title>.*</title>", نص_م):
        أرجع ""
    نهاية
    خطوة1 := regex.استبدالنص(".*<title>", نص_م, "")
    أرجع regex.استبدالنص("</title>.*", خطوة1, "")
نهاية

دالة اطبع_الروابط(نص_م: نص):
    متغير باقي := نص_م
    متغير نشط := صواب
    بينما نشط:
        الفهرس := regex.بحثنص("href=\"", باقي)
        إذا الفهرس < 0:
            نشط = خطأ
        وإلا:
            بعد := الفهرس + 6
            ذيل := باقي.مقطع(بعد, باقي.طول() - بعد)
            نهايةالاقتباس := regex.بحثنص("\"", ذيل)
            إذا نهايةالاقتباس < 0:
                نشط = خطأ
            وإلا:
                اطبع ذيل.مقطع(0, نهايةالاقتباس)
                تقدم := بعد + نهايةالاقتباس + 1
                باقي = باقي.مقطع(تقدم, باقي.طول() - تقدم)
            نهاية
        نهاية
    نهاية
نهاية

دالة الرئيسية:
    الصفحة := "<html><head><title>Salam Lang Docs</title></head><body>hi</body></html>"
    اطبع استخرج_العنوان(الصفحة)

    بدون_عنوان := "<html><body>no title here</body></html>"
    اطبع استخرج_العنوان(بدون_عنوان)

    الروابط := "<a href=\"https://salamlang.org\">Home</a><a href=\"https://salamlang.org/docs\">Docs</a><a href=\"/about\">About</a>"
    اطبع_الروابط(الروابط)

    البريد := "contact: ada@example.com or grace@example.org"
    اطبع regex.مطابقةنص("\\w+@\\w+\\.\\w+", البريد)
    اطبع regex.بحثنص("@", البريد) > 0

    الأرقام_فقط := regex.استبدالالکلنص("[0-9]", "room 42, floor 7", "")
    اطبع الأرقام_فقط

    السيإسڤي := "name,age,city"
    اطبع regex.استبدالالکلنص(",", السيإسڤي, " | ")
نهاية
