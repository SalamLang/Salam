// لغة: العربية
دالة صنف(ن : صحيح) : نص:
    أرجع ن < 0 ? "سالب" : ن == 0 ? "صفر" : "موجب"
نهاية

دالة الرئيسية:
    س := 7
    اطبع س > 5 ؟ "كبير" : "صغير"
    اطبع صنف(-4), صنف(0), صنف(9)
    اطبع صواب ? خطأ ? 1 : 2 : 3
    متغير مجموع := 0
    كرر 6 مع عداد:
        مجموع += عداد % 2 == 0 ؟ عداد : 0
    نهاية
    اطبع مجموع
نهاية
