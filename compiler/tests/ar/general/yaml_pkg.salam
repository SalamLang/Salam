// لغة: العربية
استيراد يامل

دالة الرئیسیة:
    اطبع يامل.نص يامل("hi \"there\"")
    اطبع يامل.عضو("name", "salam")
    اطبع يامل.عضو عدد صحیح("age", 5)
    اطبع يامل.عضو منطقی("ok", صواب)
    اطبع يامل.عضو عدد عشری("pi", 3.5)
    اطبع يامل.عضو خام("raw", "[1, 2, 3]")

    متغير علامات := متجه {} بوصفه متجه<نص>
    علامات.أضف(يامل.نص يامل("a"))
    علامات.أضف(يامل.نص يامل("b"))
    علامات_يامل := يامل.مصفوفة(علامات)
    اطبع علامات_يامل

    متغير نقطة := متجه {} بوصفه متجه<نص>
    نقطة.أضف(يامل.عضو عدد صحیح("x", 1))
    نقطة.أضف(يامل.عضو عدد صحیح("y", 2))
    نقطة_يامل := يامل.کائن(نقطة)
    اطبع نقطة_يامل

    متغير مستند := متجه {} بوصفه متجه<نص>
    مستند.أضف(يامل.عضو("name", "salam"))
    مستند.أضف(يامل.عضو عدد صحیح("version", 2))
    مستند.أضف(يامل.عضو منطقی("active", صواب))
    مستند.أضف(يامل.عضو خام("tags", علامات_يامل))
    مستند.أضف(يامل.عضو خام("point", نقطة_يامل))
    مستند_يامل := يامل.کائن(مستند)
    اطبع مستند_يامل

    كتلة := "name: salam\nversion: 2\nactive: true\ntags:\n  - a\n  - b\npoint:\n  x: 1\n  y: 2\n"
    اطبع يامل.تحليل(كتلة)
    اطبع يامل.لجيسون(كتلة) == يامل.تحليل(كتلة)

    اطبع يامل.صالح(كتلة)
    اطبع يامل.صالح("{ not: valid")
    اطبع يامل.صالح("[1, 2")
    اطبع يامل.صالح("\"unterminated")

    اطبع يامل.جلب(كتلة, "name")
    اطبع يامل.جلب عدد صحیح(كتلة, "version")
    اطبع يامل.جلب منطقی(كتلة, "active")
    اطبع يامل.جلب(كتلة, "tags[0]")
    اطبع يامل.جلب(كتلة, "tags[1]")
    اطبع يامل.جلب عدد صحیح(كتلة, "point.x")
    اطبع يامل.جلب عدد صحیح(كتلة, "point.y")
    اطبع يامل.یملک(كتلة, "point.y")
    اطبع يامل.یملک(كتلة, "missing")
    اطبع يامل.نوع(كتلة, "tags")
    اطبع يامل.نوع(كتلة, "point")
    اطبع يامل.نوع(كتلة, "name")
    اطبع يامل.نوع(كتلة, "version")
    اطبع يامل.نوع(كتلة, "missing")
    اطبع يامل.طول(كتلة, "tags")

    متغير مطلوب := متجه {} بوصفه متجه<نص>
    مطلوب.أضف("name")
    مطلوب.أضف("version")
    اطبع يامل.یملک مفاتیح(كتلة, مطلوب)
    مطلوب.أضف("missing")
    اطبع يامل.یملک مفاتیح(كتلة, مطلوب)

    تدفق := "{a: 1, b: [1, 2, 3], c: {x: true, y: null}}"
    اطبع يامل.تحليل(تدفق)

    اقتباس := "title: 'it''s here'\nurl: \"http://x:80/a#b\"\n"
    اطبع يامل.تحليل(اقتباس)

    كتلة_نص := "desc: |\n  line one\n  line two\nfolded: >\n  a b\n  c d\n"
    اطبع يامل.تحليل(كتلة_نص)

    قائمة := "items:\n  - name: a\n    val: 1\n  - name: b\n    val: 2\n"
    اطبع يامل.تحليل(قائمة)
    اطبع يامل.جلب(قائمة, "items[1].name")
    اطبع يامل.جلب عدد صحیح(قائمة, "items[0].val")

    متعدد_المستندات := "a: 1\n---\nb: 2\n"
    مستندات := يامل.تقسیم المستندات(متعدد_المستندات)
    اطبع مستندات.طول()
    اطبع يامل.تحليل(مستندات.احصل(0)[0])
    اطبع يامل.تحليل(مستندات.احصل(1)[0])

    اطبع يامل.تفريغ(مستند_يامل)
    اطبع يامل.تفريغ مخصص(مستند_يامل, "    ")
    اطبع يامل.تفريغ بتاب(مستند_يامل)

    اطبع يامل.تحليل(يامل.تفريغ(كتلة)) == يامل.تحليل(كتلة)
نهاية
