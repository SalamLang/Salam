// لغة: العربية
دالة صانع الزيادة(ن : صحيح) : دالة (صحيح) صحيح:
    أرجع (قيمة : صحيح) => قيمة + ن
نهاية

دالة الرئيسية:
    مضاعف := (عدد : صحيح) => عدد * 2
    اطبع مضاعف(21)
    زيادة عشرة := صانع الزيادة(10)
    اطبع زيادة عشرة(5)
    متغير أساس := 100
    زد := () =>:
        أساس = أساس + 1
    نهاية
    زد()
    زد()
    اطبع أساس
نهاية
