// لغة: العربية
دالة صانع الزیادة(ن: صحیح): دالة (صحیح) صحیح:
    أرجع (قیمة: صحیح) => قیمة + ن
نهاية

دالة الرئیسیة:
    مضاعف := (عدد: صحیح) => عدد * 2
    اطبع مضاعف(21)
    زیادة عشرة := صانع الزیادة(10)
    اطبع زیادة عشرة(5)
    متغير أساس := 100
    زد := ():
        أساس = أساس + 1
    نهاية
    زد()
    زد()
    اطبع أساس
نهاية
