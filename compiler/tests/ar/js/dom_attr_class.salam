// لغة: العربية
استيراد دوم

دالة الرئيسية:
    عنصر := دوم.أنشئ("span")
    دوم.إلحاق(دوم.الجسم(), عنصر)
    دوم.تعیین‌السمة(عنصر, "data-role", "tag")
    اطبع دوم.جلب‌السمة(عنصر, "data-role")

    دوم.إضافة‌فئة(عنصر, "card")
    دوم.إضافة‌فئة(عنصر, "big")
    اطبع دوم.جلب‌السمة(عنصر, "class")

    دوم.تبدیل‌فئة(عنصر, "big")
    اطبع دوم.جلب‌السمة(عنصر, "class")

    دوم.تبدیل‌فئة(عنصر, "big")
    اطبع دوم.جلب‌السمة(عنصر, "class")

    دوم.إزالة‌فئة(عنصر, "card")
    اطبع دوم.جلب‌السمة(عنصر, "class")
نهاية
