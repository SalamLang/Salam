// لغة: العربية
استيراد دوم

متغير عدد النقرات := 0

دالة الرئيسية:
    زر := دوم.أنشئ("button")
    دوم.تعیین‌السمة(زر, "id", "btn")
    دوم.تعیین‌السمة(زر, "data-autofire", "click")
    دوم.إلحاق(دوم.الجسم(), زر)
    دوم.عند‌الحدث(زر, "click", () =>:
        عدد النقرات = عدد النقرات + 1
        اطبع "clicked"
    نهاية)
    اطبع "before"
    اطبع عدد النقرات
نهاية
