استيراد دوم

متغير عدد النقرات := 0

دالة الرئيسية:
    زر := dom.Create("button")
    dom.SetAttr(زر, "id", "btn")
    dom.SetAttr(زر, "data-autofire", "click")
    dom.Append(dom.Body(), زر)
    dom.OnEvent(زر, "click", () =>:
        عدد النقرات = عدد النقرات + 1
        اطبع "clicked"
    نهاية)
    اطبع "before"
    اطبع عدد النقرات
نهاية
