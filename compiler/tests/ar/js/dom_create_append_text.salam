// لغة: العربية
استيراد دوم

دالة الرئیسیة:
    صندوق := دوم.أنشئ("div")
    دوم.تعیین السمة(صندوق, "id", "box")
    دوم.تعیین النص(صندوق, "hello dom")
    دوم.إلحاق(دوم.الجسم(), صندوق)

    موجود := دوم.بالمعرف("box")
    اطبع دوم.جلب النص(موجود)

    دوم.تعیین إتش تی إم إل(موجود, "<b>bold</b>")
    اطبع موجود != دوم.الجسم()
نهاية
