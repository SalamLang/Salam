// لغة: العربية
استيراد دوم

دالة الرئیسیة:
    عنصر := دوم.أنشئ("div")
    دوم.تعیین السمة(عنصر, "id", "surface")
    دوم.تعیین السمة(عنصر, "data-autofire", "keydown")
    دوم.تعیین السمة(عنصر, "data-autofire-key", "Enter")
    دوم.تعیین السمة(عنصر, "data-autofire-x", "12")
    دوم.تعیین السمة(عنصر, "data-autofire-y", "34")
    دوم.إلحاق(دوم.الجسم(), عنصر)
    دوم.عند الحدث المفصل(
        عنصر, "keydown", (حدث: صحیح٦٤): اطبع دوم.مفتاح الحدث(حدث) اطبع دوم.الحدث الأفقی(حدث) اطبع دوم.الحدث العمودی(حدث) دوم.منع الافتراضی(حدث) اطبع "handled" نهاية
    )
    اطبع "ready"
نهاية
