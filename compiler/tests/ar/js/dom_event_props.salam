استيراد دوم

دالة الرئيسية:
    عنصر := دوم.أنشئ("div")
    دوم.تعیین‌السمة(عنصر, "id", "surface")
    دوم.تعیین‌السمة(عنصر, "data-autofire", "keydown")
    دوم.تعیین‌السمة(عنصر, "data-autofire-key", "Enter")
    دوم.تعیین‌السمة(عنصر, "data-autofire-x", "12")
    دوم.تعیین‌السمة(عنصر, "data-autofire-y", "34")
    دوم.إلحاق(دوم.الجسم(), عنصر)
    دوم.عند‌الحدث‌المفصل(عنصر, "keydown", (حدث : صحيح٦٤) =>:
        اطبع دوم.مفتاح‌الحدث(حدث)
        اطبع دوم.الحدث‌الأفقي(حدث)
        اطبع دوم.الحدث‌العمودي(حدث)
        دوم.منع‌الافتراضي(حدث)
        اطبع "handled"
    نهاية)
    اطبع "ready"
نهاية
