استيراد دوم

دالة الرئيسية:
    عنصر := dom.Create("div")
    dom.SetAttr(عنصر, "id", "surface")
    dom.SetAttr(عنصر, "data-autofire", "keydown")
    dom.SetAttr(عنصر, "data-autofire-key", "Enter")
    dom.SetAttr(عنصر, "data-autofire-x", "12")
    dom.SetAttr(عنصر, "data-autofire-y", "34")
    dom.Append(dom.Body(), عنصر)
    dom.OnEventE(عنصر, "keydown", (حدث : صحيح٦٤) =>:
        اطبع dom.EventKey(حدث)
        اطبع dom.EventX(حدث)
        اطبع dom.EventY(حدث)
        dom.PreventDefault(حدث)
        اطبع "handled"
    نهاية)
    اطبع "ready"
نهاية
