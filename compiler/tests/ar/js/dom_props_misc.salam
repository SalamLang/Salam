// لغة: العربية
استيراد دوم

دالة الرئيسية:
    دوم.تعیین‌العنوان("Salam Page")

    كائن := دوم.الجسم()
    دوم.تعیین‌الخاصیة‌العددیة(كائن, "score", 9.5)
    اطبع دوم.جلب‌الخاصیة‌العددیة(كائن, "score")
    دوم.تعیین‌الخاصیة‌النصیة(كائن, "label", "top")
    اطبع دوم.جلب‌الخاصیة‌النصیة(كائن, "label")
    دوم.تعیین‌الخاصیة‌المنطقیة(كائن, "active", صواب)
    اطبع دوم.جلب‌الخاصیة‌المنطقیة(كائن, "active")

    تأكید := دوم.تأكيد("proceed?")
    اطبع تأكید
    رد := دوم.طلب‌الإدخال("your name?")
    اطبع رد
نهاية
