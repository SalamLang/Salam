// لغة: العربية
استيراد دوم

دالة الرئیسیة:
    دوم.تعیین العنوان("Salam Page")

    کائن := دوم.الجسم()
    دوم.تعیین الخاصیة العددیة(کائن, "score", 9.5)
    اطبع دوم.جلب الخاصیة العددیة(کائن, "score")
    دوم.تعیین الخاصیة النصیة(کائن, "label", "top")
    اطبع دوم.جلب الخاصیة النصیة(کائن, "label")
    دوم.تعیین الخاصیة المنطقیة(کائن, "active", صواب)
    اطبع دوم.جلب الخاصیة المنطقیة(کائن, "active")

    تأکید := دوم.تأکید("proceed?")
    اطبع تأکید
    رد := دوم.طلب الإدخال("your name?")
    اطبع رد
نهاية
