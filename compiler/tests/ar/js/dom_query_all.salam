// لغة: العربية
استيراد دوم

دالة الرئیسیة:
    كرر 3 مع ن:
        عنصر := دوم.أنشئ("li")
        دوم.تعیین السمة(عنصر, "class", "row")
        دوم.تعیین النص(عنصر, "item")
        دوم.إلحاق(دوم.الجسم(), عنصر)
    نهاية
    الکل := دوم.استعلام الکل(".row")
    اطبع دوم.العدد(الکل)
    أول := دوم.العنصر رقم(الکل, 0)
    اطبع دوم.جلب النص(أول)
نهاية
