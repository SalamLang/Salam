استيراد دوم

دالة الرئيسية:
    كرر 3 مع ن:
        عنصر := dom.Create("li")
        dom.SetAttr(عنصر, "class", "row")
        dom.SetText(عنصر, "item")
        dom.Append(dom.Body(), عنصر)
    نهاية
    الكل := dom.QueryAll(".row")
    اطبع dom.CountOf(الكل)
    أول := dom.ItemAt(الكل, 0)
    اطبع dom.GetText(أول)
نهاية
