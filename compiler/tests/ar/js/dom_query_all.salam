استيراد دوم

دالة الرئيسية:
    كرر 3 مع ن:
        عنصر := دوم.أنشئ("li")
        دوم.تعیین‌السمة(عنصر, "class", "row")
        دوم.تعیین‌النص(عنصر, "item")
        دوم.إلحاق(دوم.الجسم(), عنصر)
    نهاية
    الكل := دوم.استعلام‌الكل(".row")
    اطبع دوم.العدد(الكل)
    أول := دوم.العنصر‌رقم(الكل, 0)
    اطبع دوم.جلب‌النص(أول)
نهاية
