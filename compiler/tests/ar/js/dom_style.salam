دالة الرئيسية:
    عنصر := dom.Create("div")
    dom.Append(dom.Body(), عنصر)
    dom.SetStyle(عنصر, "color", "red")
    dom.SetStyle(عنصر, "font-size", "12px")
    اطبع dom.GetStyle(عنصر, "color")
    اطبع dom.GetStyle(عنصر, "font-size")
    dom.SetStyle(عنصر, "color", "blue")
    اطبع dom.GetStyle(عنصر, "color")
