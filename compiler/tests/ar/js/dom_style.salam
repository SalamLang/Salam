// لغة: العربية
استيراد دوم

دالة الرئيسية:
    عنصر := دوم.أنشئ("div")
    دوم.إلحاق(دوم.الجسم(), عنصر)
    دوم.تعیین‌النمط(عنصر, "color", "red")
    دوم.تعیین‌النمط(عنصر, "font-size", "12px")
    اطبع دوم.جلب‌النمط(عنصر, "color")
    اطبع دوم.جلب‌النمط(عنصر, "font-size")
    دوم.تعیین‌النمط(عنصر, "color", "blue")
    اطبع دوم.جلب‌النمط(عنصر, "color")
نهاية
