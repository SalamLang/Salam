// لغة: العربية
واجهة توصيف:
    دالة تسمية() : نص
    دالة نقطة() : صحيح
نهاية

تنفيذ توصيف على صحيح:
    دالة تسمية() : نص: أرجع "number" نهاية
    دالة نقطة() : صحيح: أرجع هذا * 10 نهاية
نهاية

تنفيذ توصيف على منطقي:
    دالة تسمية() : نص: أرجع "flag" نهاية
    دالة نقطة() : صحيح:
        إذا هذا: أرجع 1 نهاية
        أرجع 0
    نهاية
نهاية

دالة عرض<ن: توصيف>(قيمة : ن):
    اطبع قيمة.تسمية()
    اطبع قيمة.نقطة()
نهاية

دالة الرئيسية:
    عرض(7)
    عرض(صواب)
    عرض(خطأ)
نهاية
