// لغة: العربية
واجهة توصیف:
    دالة تسمیة(): نص
    دالة نقطة(): صحیح
نهاية

تنفيذ توصیف على صحیح:
    دالة تسمیة(): نص: أرجع "number" نهاية
    دالة نقطة(): صحیح: أرجع هذا * 10 نهاية
نهاية

تنفيذ توصیف على منطقی:
    دالة تسمیة(): نص: أرجع "flag" نهاية
    دالة نقطة(): صحیح:
        إذا هذا: أرجع 1 نهاية
        أرجع 0
    نهاية
نهاية

دالة عرض<ن: توصیف>(قیمة: ن):
    اطبع قیمة.تسمیة()
    اطبع قیمة.نقطة()
نهاية

دالة الرئیسیة:
    عرض(7)
    عرض(صواب)
    عرض(خطأ)
نهاية
