// لغة: العربية
تعداد لون:
    أحمر
    أخضر
    أزرق
نهاية

دالة صنف(ک: لون): نص:
    أرجع طابق ک:
        أحمر => "دافئ"
        أخضر, أزرق => "بارد"
    نهاية
نهاية

دالة شرح(خ: صحیح): نص:
    قیمة := طابق خ:
        1 =>: أرجع 42 نهاية
        2 =>: أرجع "فرع-نص" نهاية
        وإلا =>: أرجع صواب نهاية
    نهاية
    أرجع طابق قیمة:
        صحیح عس => "عدد:" + عس
        نص نس => "نص:" + نس
        منطقی بس => "منطقي:" + بس
    نهاية
نهاية

دالة الرئیسیة:
    اطبع صنف(لون.أحمر)
    اطبع صنف(لون.أخضر)
    اطبع صنف(لون.أزرق)

    ص := طابق 2:
        1 => "واحد"
        2 => "اثنان"
        وإلا => "كثير"
    نهاية
    اطبع ص

    اطبع شرح(1)
    اطبع شرح(2)
    اطبع شرح(99)

    متغير ن := 0
    بينما ن < 3:
        طابق ن:
            0 =>: اطبع "صفر" نهاية
            وإلا =>:
                إذا ن == 2:
                    اكسر
                نهاية
                اطبع "آخر"
            نهاية
        نهاية
        ن = ن + 1
    نهاية
    اطبع "انتهى"
نهاية
