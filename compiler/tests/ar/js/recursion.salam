// لغة: العربية
دالة مضروب(ن: صحیح): صحیح:
    إذا ن <= 1:
        أرجع 1
    نهاية
    أرجع ن * مضروب(ن - 1)
نهاية

دالة فیبوناتشی(ن: صحیح): صحیح:
    إذا ن < 2:
        أرجع ن
    نهاية
    أرجع فیبوناتشی(ن - 1) + فیبوناتشی(ن - 2)
نهاية

دالة الرئیسیة:
    اطبع مضروب(6)
    اطبع فیبوناتشی(10)
نهاية
