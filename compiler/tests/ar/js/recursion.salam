// لغة: العربية
دالة مضروب(ن : صحيح) : صحيح:
    إذا ن <= 1:
        أرجع 1
    نهاية
    أرجع ن * مضروب(ن - 1)
نهاية

دالة فيبوناتشي(ن : صحيح) : صحيح:
    إذا ن < 2:
        أرجع ن
    نهاية
    أرجع فيبوناتشي(ن - 1) + فيبوناتشي(ن - 2)
نهاية

دالة الرئيسية:
    اطبع مضروب(6)
    اطبع فيبوناتشي(10)
نهاية
