// لغة: العربية
بنية متجه٢:
    عام أفقی: صحیح = 0
    عام رأسی: صحیح = 0
    عام دالة عامل + (آخر: متجه٢): متجه٢:
        أرجع متجه٢ { أفقی = هذا.أفقی + آخر.أفقی, رأسی = هذا.رأسی + آخر.رأسی }
    نهاية
    عام دالة عامل == (آخر: متجه٢): منطقی:
        أرجع هذا.أفقی == آخر.أفقی && هذا.رأسی == آخر.رأسی
    نهاية
نهاية

دالة الرئیسیة:
    أ := متجه٢ { أفقی = 3, رأسی = 4 }
    ب := متجه٢ { أفقی = 1, رأسی = 2 }
    ج := أ + ب
    اطبع ج.أفقی
    اطبع ج.رأسی
    أ٢ := متجه٢ { أفقی = 3, رأسی = 4 }
    اطبع أ == أ٢
    اطبع أ == ب
نهاية
