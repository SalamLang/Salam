بنية متجه٢:
    عام أفقي : صحيح = 0
    عام رأسي : صحيح = 0
    عام دالة عامل + (آخر : متجه٢) : متجه٢:
        أرجع متجه٢ { أفقي = هذا.أفقي + آخر.أفقي, رأسي = هذا.رأسي + آخر.رأسي }
    نهاية
    عام دالة عامل == (آخر : متجه٢) : منطقي:
        أرجع هذا.أفقي == آخر.أفقي && هذا.رأسي == آخر.رأسي
    نهاية
نهاية

دالة الرئيسية:
    أ := متجه٢ { أفقي = 3, رأسي = 4 }
    ب := متجه٢ { أفقي = 1, رأسي = 2 }
    ج := أ + ب
    اطبع ج.أفقي
    اطبع ج.رأسي
    أ٢ := متجه٢ { أفقي = 3, رأسي = 4 }
    اطبع أ == أ٢
    اطبع أ == ب
نهاية
