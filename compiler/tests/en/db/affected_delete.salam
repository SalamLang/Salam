import "db/mysql"
import "_linkmock.salam"
func main:
    db : mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY, v INTEGER)")
    mysql.Exec(db, "INSERT INTO t(v) VALUES (1),(2),(3),(4),(5)")
    mysql.Exec(db, "DELETE FROM t WHERE v <= 3")
    __ mysql.AffectedRows(db)
    mysql.Close(db)
end
