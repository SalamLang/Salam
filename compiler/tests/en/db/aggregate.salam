import "db/mysql"
import "_linkmock.salam"
func main:
    db mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(v INTEGER)")
    mysql.Exec(db, "INSERT INTO t(v) VALUES (10),(20),(30)")
    __ mysql.QueryInt(db, "SELECT SUM(v) FROM t")
    __ mysql.QueryInt(db, "SELECT MAX(v) FROM t")
    mysql.Close(db)
end
