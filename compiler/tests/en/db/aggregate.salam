import "db/mysql"
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(v INTEGER)")
    mysql.Exec(db, "INSERT INTO t(v) VALUES (10),(20),(30)")
    println mysql.QueryInt(db, "SELECT SUM(v) FROM t")
    println mysql.QueryInt(db, "SELECT MAX(v) FROM t")
    mysql.Close(db)
end
