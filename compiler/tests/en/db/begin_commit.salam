import "db/mysql"
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY)")
    mysql.Begin(db)
    mysql.Exec(db, "INSERT INTO t(id) VALUES (1),(2)")
    mysql.Commit(db)
    println mysql.QueryInt(db, "SELECT COUNT(*) FROM t")
    mysql.Close(db)
end
