import "db/mysql"
import "_linkmock.salam"
func main:
    db mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(a INTEGER, b TEXT, c REAL)")
    mysql.Exec(db, "INSERT INTO t VALUES (1, 'x', 2.0)")
    mut r mysql.Result = mysql.Query(db, "SELECT a, b, c FROM t")
    __ mysql.ColumnCount(r)
    mysql.Finish(r)
    mysql.Close(db)
end
