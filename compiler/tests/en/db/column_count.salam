import "db/mysql"
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(a INTEGER, b TEXT, c REAL)")
    mysql.Exec(db, "INSERT INTO t VALUES (1, 'x', 2.0)")
    r := mysql.Query(db, "SELECT a, b, c FROM t")
    println mysql.ColumnCount(r)
    mysql.Finish(r)
    mysql.Close(db)
end
