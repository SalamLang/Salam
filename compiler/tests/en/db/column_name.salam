import "db/mysql"
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER, label TEXT)")
    mysql.Exec(db, "INSERT INTO t VALUES (1, 'x')")
    r := mysql.Query(db, "SELECT id, label FROM t")
    println mysql.ColumnName(r, 0)
    println mysql.ColumnName(r, 1)
    mysql.Finish(r)
    mysql.Close(db)
end
