import "db/mysql"
import "_linkmock.salam"
func main:
    db mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(n TEXT)")
    name str = "O'Brien"
    mysql.Exec(db, "INSERT INTO t(n) VALUES ('" + mysql.Escape(db, name) + "')")
    __ mysql.QueryText(db, "SELECT n FROM t LIMIT 1")
    mysql.Close(db)
end
