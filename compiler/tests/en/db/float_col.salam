import "db/mysql"
import "_linkmock.salam"
func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(v REAL)")
    mysql.Exec(db, "INSERT INTO t VALUES (2.5)")
    mut r := mysql.Query(db, "SELECT v FROM t")
    mysql.Next(r)
    __ mysql.Float(r, 0)
    mysql.Finish(r)
    mysql.Close(db)
end
