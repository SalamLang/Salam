import "db/mysql"
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(v INTEGER)")
    mysql.Exec(db, "INSERT INTO t VALUES (-42)")
    mut r := mysql.Query(db, "SELECT v FROM t")
    mysql.Next(r)
    println mysql.Int(r, 0)
    mysql.Finish(r)
    mysql.Close(db)
end
