import "db/mysql"
import "_linkmock.salam"
func main:
    db : mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(v INTEGER)")
    mysql.Exec(db, "INSERT INTO t(v) VALUES (7)")
    mut r : mysql.Result = mysql.Query(db, "SELECT v FROM t")
    mysql.Next(r)
    __ mysql.IsNull(r, 0)
    mysql.Finish(r)
    mysql.Close(db)
end
