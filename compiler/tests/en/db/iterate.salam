import "db/mysql"
import "_linkmock.salam"
func main:
    db mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY, n TEXT)")
    mysql.Exec(db, "INSERT INTO t(n) VALUES ('ada'),('grace'),('linus')")
    mut r mysql.Result = mysql.Query(db, "SELECT id, n FROM t ORDER BY id")
    while mysql.Next(r):
        __ mysql.Int(r, 0), mysql.Text(r, 1)
    end
    mysql.Finish(r)
    mysql.Close(db)
end
