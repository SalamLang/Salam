import "db/mysql"
import "_linkmock.salam"
func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY, v INTEGER)")
    mysql.Exec(db, "INSERT INTO t(v) VALUES (1),(2),(3),(4)")
    mysql.Exec(db, "UPDATE t SET v = 0 WHERE v > 2")
    __ mysql.Changes(db)
    mysql.Close(db)
end
