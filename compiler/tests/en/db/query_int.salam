import "db/mysql"
import "_linkmock.salam"
func main:
    db : mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY, n TEXT)")
    mysql.Exec(db, "INSERT INTO t(n) VALUES ('a'),('b'),('c')")
    __ mysql.QueryInt(db, "SELECT COUNT(*) FROM t")
    mysql.Close(db)
end
