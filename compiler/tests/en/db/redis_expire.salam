import db.redis

func main:
    c := redis.Connect("127.0.0.1", 6379)
    redis.Del(c, "salam:test:ttl")

    redis.Set(c, "salam:test:ttl", "v")
    println redis.TTL(c, "salam:test:ttl")
    redis.Expire(c, "salam:test:ttl", 100)
    ttl := redis.TTL(c, "salam:test:ttl")
    println ttl > 0 && ttl <= 100

    redis.Del(c, "salam:test:ttl")
    println redis.TTL(c, "salam:test:ttl")

    redis.Close(c)
end
