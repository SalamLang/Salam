import db.redis

func main:
    c := redis.Connect("127.0.0.1", 6379)
    redis.Del(c, "salam:test:hash")

    redis.HSet(c, "salam:test:hash", "f1", "v1")
    redis.HSet(c, "salam:test:hash", "f2", "v2")
    println redis.HGet(c, "salam:test:hash", "f1")
    println redis.HExists(c, "salam:test:hash", "f2")
    println redis.HExists(c, "salam:test:hash", "f3")
    println redis.HLen(c, "salam:test:hash")

    m := redis.HGetAll(c, "salam:test:hash")
    println m.get("f1")
    println m.get("f2")

    println redis.HDel(c, "salam:test:hash", "f1")
    println redis.HLen(c, "salam:test:hash")

    redis.Del(c, "salam:test:hash")
    redis.Close(c)
end
