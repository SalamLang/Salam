import db.redis

func main:
    c := redis.Connect("127.0.0.1", 6379)
    redis.Del(c, "salam:test:num")

    redis.Set(c, "salam:test:num", "10")
    println redis.Incr(c, "salam:test:num")
    println redis.IncrBy(c, "salam:test:num", 5)
    println redis.Decr(c, "salam:test:num")

    redis.Del(c, "salam:test:num")
    redis.Close(c)
end
