import db.redis

func main:
    c := redis.Connect("127.0.0.1", 6379)
    redis.Del(c, "salam:test:list")

    redis.RPush(c, "salam:test:list", "a")
    redis.RPush(c, "salam:test:list", "b")
    redis.LPush(c, "salam:test:list", "z")
    println redis.LLen(c, "salam:test:list")

    items := redis.LRange(c, "salam:test:list", 0, -1)
    repeat items.len() with i:
        println items.get(i)[0]
    end

    println redis.LPop(c, "salam:test:list")
    println redis.RPop(c, "salam:test:list")
    println redis.LLen(c, "salam:test:list")

    redis.Del(c, "salam:test:list")
    redis.Close(c)
end
