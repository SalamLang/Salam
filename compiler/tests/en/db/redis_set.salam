import db.redis

func main:
    c := redis.Connect("127.0.0.1", 6379)
    redis.Del(c, "salam:test:set")

    redis.SAdd(c, "salam:test:set", "x")
    redis.SAdd(c, "salam:test:set", "y")
    println redis.SCard(c, "salam:test:set")
    println redis.SIsMember(c, "salam:test:set", "x")
    println redis.SIsMember(c, "salam:test:set", "q")

    println redis.SRem(c, "salam:test:set", "x")
    println redis.SCard(c, "salam:test:set")

    redis.Del(c, "salam:test:set")
    redis.Close(c)
end
