import db.redis

func main:
    c := redis.Connect("127.0.0.1", 6379)
    redis.Del(c, "salam:test:str")

    println redis.Exists(c, "salam:test:str")
    redis.Set(c, "salam:test:str", "hello")
    println redis.Get(c, "salam:test:str")
    println redis.Exists(c, "salam:test:str")
    println redis.StrLen(c, "salam:test:str")
    redis.Append(c, "salam:test:str", " world")
    println redis.Get(c, "salam:test:str")
    println redis.Type(c, "salam:test:str")
    println redis.Del(c, "salam:test:str")
    println redis.Exists(c, "salam:test:str")

    redis.Close(c)
end
