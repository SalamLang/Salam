import db.mysql
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY)")
    mysql.Exec(db, "INSERT INTO t(id) VALUES (1),(2),(3),(4),(5)")
    r := mysql.Query(db, "SELECT id FROM t")
    println mysql.RowCount(r)
    mysql.Finish(r)
    mysql.Close(db)
end
