import db.mysql
import "_linkmock.salam"

func main:
    db := mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(n TEXT)")
    mysql.Exec(db, "INSERT INTO t(n) VALUES (NULL)")
    mut r := mysql.Query(db, "SELECT n FROM t")
    mysql.Next(r)
    println mysql.Text(r, 0) == ""
    mysql.Finish(r)
    mysql.Close(db)
end
