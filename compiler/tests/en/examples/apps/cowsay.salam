package main

import str

func dashes(n: int): str: ret str.Repeat("-", n) end

func _spaces(n: int): str: ret str.Repeat(" ", n) end

func say(msg: str):
    w := str.Len(msg)
    println (" ").concat(dashes(w + 2))
    println ("< ").concat(msg).concat(" >")
    println (" ").concat(dashes(w + 2))
    println "        \\   ^__^"
    println "         \\  (oo)\\_______"
    println "            (__)\\       )\\/\\"
    println "                ||----w |"
    println "                ||     ||"
end

func main:
    say("Salam, World!")
    println ""
    say("I compile to C and moo.")
end
