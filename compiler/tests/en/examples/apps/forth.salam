package main

import str

mut stack: int[256]
mut sp := 0
mut dict_names: str[64]
mut dict_bodies: str[64]
mut ndict := 0

func push(v: int):
    stack[sp] = v
    sp = sp + 1
end

func pop(): int:
    sp = sp - 1
    ret stack[sp]
end

func define(name: str, body: str):
    dict_names[ndict] = name
    dict_bodies[ndict] = body
    ndict = ndict + 1
end

func lookup(name: str): str:
    repeat ndict with i:
        if str.Equals(dict_names[i], name): ret dict_bodies[i] end
    end
    ret ""
end

func is_number(t: str): bool:
    if str.IsEmpty(t): ret false end
    mut i := 0
    if char_code(t.substr(0, 1)) == 45 && str.Len(t) > 1: i = 1 end
    until i < str.Len(t):
        code := char_code(t.substr(i, 1))
        if code < 48 || code > 57: ret false end
        i = i + 1
    end
    ret true
end

func is_arith(t: str): bool:
    ret str.Equals(t, "+") || str.Equals(t, "-") || str.Equals(t, "*") || str.Equals(t, "/")
end

func is_stackop(t: str): bool:
    ret str.Equals(t, "dup") || str.Equals(t, "drop") || str.Equals(t, "swap")
end

func arith(t: str):
    b := pop()
    a := pop()
    if str.Equals(t, "+"): push(a + b)
    else str.Equals(t, "-"): push(a - b)
    else str.Equals(t, "*"): push(a * b)
    else:
        push(a / b)
    end
end

func stackop(t: str):
    if str.Equals(t, "dup"):
        v := pop()
        push(v)
        push(v)
    else str.Equals(t, "drop"):
        pop()
    else:
        b := pop()
        a := pop()
        push(b)
        push(a)
    end
end

func print_top():
    print str.FromInt(pop() as i64)
    print " "
end

func exec_token(t: str):
    if is_number(t): push(str.ToInt(t))
    else is_arith(t): arith(t)
    else is_stackop(t): stackop(t)
    else str.Equals(t, "."): print_top()
    else:
        body := lookup(t)
        if !str.IsEmpty(body): run(body) end
    end
end

func define_word(tokens: Vector<str>, start: int): int:
    name := tokens.get(start + 1)[0]
    mut body := ""
    mut j := start + 2
    until !str.Equals(tokens.get(j)[0], ";"):
        if !str.IsEmpty(body): body = body.concat(" ") end
        body = body.concat(tokens.get(j)[0])
        j = j + 1
    end
    define(name, body)
    ret j + 1
end

func run(line: str):
    tokens := str.Split(line, " ")
    defer tokens.free()
    mut i := 0
    until i < tokens.len():
        t := tokens.get(i)[0]
        if str.Equals(t, ":"): i = define_word(tokens, i)
        else:
            if !str.IsEmpty(t): exec_token(t) end
            i = i + 1
        end
    end
end

func main:
    print "5 square (=25)   : "
    run(": square dup * ; 5 square .")
    println ""
    print "cube of 3 (=27)  : "
    run(": cube dup dup * * ; 3 cube .")
    println ""
    print "mixed stack ops  : "
    run("10 20 swap - .")
    println ""
    print "nested words     : "
    run(": double dup + ; : quad double double ; 5 quad .")
    println ""
end
