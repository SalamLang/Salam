package main

import http
import str

func main:
    mut headers := http.NewHeaders()
    headers.put("X-Demo", "salam")
    headers.put("Accept", "application/json")
    r := http.GetWith("https://httpbin.org/headers", headers)
    print "GET status: "
    println str.FromInt(r.status as i64)
    if str.Contains(r.body, "salam"):
        println "  server echoed our X-Demo header"
    end
    mut jhead := http.NewHeaders()
    jhead.put("Content-Type", "application/json")
    json := "{\"name\": \"Salam\", \"year\": 2026}"
    p := http.PostWith("https://httpbin.org/post", json, jhead)
    print "POST status: "
    println str.FromInt(p.status as i64)
    if http.Ok(p):
        if str.Contains(p.body, "Salam"):
            println "  server echoed our JSON body"
        end
    end
    d := http.Request("DELETE", "https://httpbin.org/delete", http.NewHeaders(), "")
    print "DELETE status: "
    println str.FromInt(d.status as i64)
    g := http.Get("https://httpbin.org/json")
    println "--- response ---"
    print "Content-Type: "
    println http.GetHeader(g, "Content-Type")
    respHeaders := http.Headers(g)
    print "header count: "
    println str.FromInt(respHeaders.size() as i64)
    print "body bytes: "
    println str.FromInt(str.Len(http.Body(g)) as i64)
    print "raw bytes:  "
    println str.FromInt(str.Len(http.Raw(g)) as i64)
end
