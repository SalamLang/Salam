layout:
    title = "Design System Demo"
    header:
        background = "#222"
        color = "white"
        padding = "16px"
        heading: size = 1 content = "Our Components" end
    end
    include = "_layout_widgets.salam"
    Card: title = "Welcome" body = "Components keep your markup DRY." end
    Card: title = "Get Started" body = "Pick a plan and go."
        list:
            item: content = "Fast" end
            item: content = "Localized (en/fa)" end
        end
        Cta: label = "Sign up" href = "/signup" end
    end
end
