package main

import socket

func main:
    srv := socket.Listen(8080)
    if !socket.Ok(srv):
        println "failed to listen on port 8080"
        ret
    end
    defer socket.CloseServer(srv)
    println "websocket echo server listening on ws://localhost:8080/"
    running := true
    until running:
        mut c := socket.Accept(srv)
        if socket.IsOpen(c):
            println "client connected"
            mut m := socket.Receive(c)
            until socket.IsText(m):
                println "received: " + m.text
                socket.SendText(c, "echo: " + m.text)
                m = socket.Receive(c)
            end
            println "client disconnected"
        end
    end
end
