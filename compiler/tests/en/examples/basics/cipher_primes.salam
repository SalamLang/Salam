package main

import str

func caesar(text: str, k: int):
    mut out := ""
    repeat str.Len(text) with i:
        mut code := char_code(text.substr(i, 1))
        if code >= 97 && code <= 122:
            code = (code - 97 + k) % 26 + 97
        else:
            if code >= 65 && code <= 90:
                code = (code - 65 + k) % 26 + 65
            end
        end
        out = out.concat(char_from_code(code))
    end
    println out
end

func sieve(n: int):
    mut composite: int[1000]
    mut p := 2
    until p * p < n:
        if composite[p] == 0:
            mut m := p * p
            until m < n:
                composite[m] = 1
                m = m + p
            end
        end
        p = p + 1
    end
    mut line := ""
    mut i := 2
    until i < n:
        if composite[i] == 0:
            line = line.concat(str.FromInt(i as i64)).concat(" ")
        end
        i = i + 1
    end
    println line
end

func main:
    println "== Caesar / ROT13 =="
    print "ROT13('Hello, Salam!')  = "
    caesar("Hello, Salam!", 13)
    print "back again              = "
    caesar("Uryyb, Fnynz!", 13)
    println ""
    println "== Primes below 50 =="
    sieve(50)
end
