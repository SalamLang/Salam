package main

import str

func main:
    s := "Salam, World!"
    println s
    println str.FromInt(str.Len(s) as i64)
    println str.Substr(s, 0, 5)
    println str.FromInt(str.Find(s, "World") as i64)
    println str.Concat(s, " :)")
    println str.Trim("   padded   ")
    println str.Replace("a.b.c", ".", "/")
    fields := str.Split("12,34,56,78", ",")
    defer fields.free()
    println str.Join(fields, " + ")
    mut total := 0
    repeat fields.len() with i:
        total = total + str.ToInt(fields.get(i)[0])
    end
    print "sum = "
    println str.FromInt(total as i64)
    println str.FromFloat(str.ToFloat("3.14159") * 2.0)
end
