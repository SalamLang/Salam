//! mode: app | title: Palindrome number
func is palindrome(n: int): bool:
    mut x := n
    mut rev := 0
    until x > 0:
        rev = rev * 10 + x % 10
        x = x / 10
    end
    ret rev == n
end

func main:
    nums := [121, 123, 1221, 13] as int[4]
    repeat 4 with i:
        if is palindrome(nums[i]): println nums[i], "is a palindrome"
        else:
            println nums[i], "is not a palindrome"
        end
    end
end
