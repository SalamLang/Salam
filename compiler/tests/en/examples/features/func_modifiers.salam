inline func half(x: int): int: ret x / 2 end

noinline func slow triple(x: int): int: ret x * 3 end

pure func cube(x: int): int: ret x * x * x end

inline pure func square(x: int): int: ret x * x end

pure func factorial(n: int): i64:
    if n <= 1: ret 1 end
    ret (n as i64) * factorial(n - 1)
end

noret func _spin forever():
    until true:
    end
end

pub func Next(x: int): int: ret x + 1 end

pub inline pure func Area(w: f64, h: f64): f64: ret w * h end

pub noinline func Traced(x: int): int: ret x * 10 end

pub deprecated func LegacySum(a: int, b: int): int: ret a + b end

pub deprecated inline pure func LegacyScale(x: int): int: ret x * 100 end

pub func main:
    println half(10)
    println slow triple(4)
    println cube(3)
    println square(6)
    println factorial(5)
    println Next(41)
    println Area(2.5, 4.0)
    println Traced(7)
    println LegacySum(20, 22)
    println LegacyScale(3)
end
