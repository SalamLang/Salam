func main:
    mut count := 0
    repeat 3 with i:
        count += i
    end
    println "sum:", count

    mut level := 1
    if count > 2:
        level = 2
    end
    println "level:", level

    mut hits := 9
    hits++
    println "hits:", hits

    greeting := "salam"
    println "immutable binding:", greeting

    const LIMIT := 100
    println "const:", LIMIT
end
