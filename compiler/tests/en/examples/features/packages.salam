package main

import math
import str
import collections

func main:
    println "hypotenuse of 3,4:"
    println math.Sqrt(math.Pow(3.0, 2.0) + math.Pow(4.0, 2.0))
    csv := "ada,grace,linus,margaret"
    names := str.Split(csv, ",")
    defer names.free()
    println "names joined:"
    println str.Join(names, " & ")
    println str.Len(str.Join(names, ""))
    mut nums := Vector {} as Vector<int> defer nums.free()
    nums.push(10)
    nums.push(20)
    nums.push(30)
    println "sum and membership:"
    mut total := 0
    repeat nums.len() with i:
        total = total + nums.get(i)[0]
    end
    println total
    println collections.contains(nums, 20)
end
