// `Variant<A, B, ...>` is Salam's tagged union: one storage slot that can
// hold a value of any of its listed member types, plus a hidden tag field
// that remembers which one is currently active. Storage is sized to the
// largest member (like a C `union`), not to the sum of all of them, and the
// tag is what lets `match` narrow the value back to a concrete type safely.

struct Reading:
    pub sensor: str
    pub value: Variant<i32, f64, str>
end

func describe(v: Variant<i32, f64, str>): str:
    ret match v:
        i32 n => "int " + n
        f64 f => "float " + f
        str err => "error: " + err
    end
end

func main:
    mut sample := 21 as Variant<i32, f64, str>
    println describe(sample)

    sample = 21.5
    println describe(sample)

    sample = "sensor offline"
    println describe(sample)

    readings := [
        Reading { sensor = "temp", value = 21.5 }, Reading { sensor = "humidity", value = 55 }, Reading { sensor = "pressure", value = "sensor offline" }
    ]
    repeat 3 with i:
        r := readings[i]
        println r.sensor + ": " + describe(r.value)
    end
end
