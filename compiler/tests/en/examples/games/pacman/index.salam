layout:
    title = "Salam Pac-Man"
    style:
        content = "*{box-sizing:border-box}body{margin:0;min-height:100dvh;display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at top,#141433 0%,#05050f 70%);color:#e8e8ff;font-family:'Courier New',monospace;padding:10px 8px calc(12px + env(safe-area-inset-bottom));-webkit-tap-highlight-color:transparent}#wrap{text-align:center;width:100%;max-width:520px}h1{color:#ffd21f;letter-spacing:.28em;margin:6px 0 4px;font-size:clamp(19px,5.5vw,34px);text-shadow:0 0 18px rgba(255,210,31,.45)}#hud{font-size:clamp(12px,3.6vw,18px);margin:4px 0 10px;color:#7cf7c4;white-space:nowrap}#game{width:min(456px,100%);height:auto;display:block;margin:0 auto;border:3px solid #2b3f9e;border-radius:12px;box-shadow:0 0 34px rgba(43,63,158,.55);background:#050514;touch-action:none}#msg{color:#9aa0d8;font-size:clamp(11px,3.2vw,14px);margin-top:10px;padding:0 6px}"
    end
    style:
        content = "#pad{display:none;margin:14px auto 0;grid-template-areas:'. u .' 'l p r' '. d .';grid-template-columns:repeat(3,minmax(56px,72px));grid-template-rows:repeat(3,52px);gap:8px;justify-content:center}#pad button{font:inherit;font-size:20px;line-height:1;color:#e8e8ff;background:rgba(43,63,158,.30);border:2px solid #2b3f9e;border-radius:14px;touch-action:none;user-select:none;-webkit-user-select:none;cursor:pointer}#pad button:active{background:rgba(124,247,196,.35);border-color:#7cf7c4}#pad_up{grid-area:u}#pad_left{grid-area:l}#pad_pause{grid-area:p}#pad_right{grid-area:r}#pad_down{grid-area:d}@media (pointer:coarse){#pad{display:grid}}@media (max-height:760px) and (pointer:coarse){#pad{grid-template-rows:repeat(3,46px);gap:6px}h1{margin:2px 0}}"
    end
    style:
        content = "@media (max-width:820px),(pointer:coarse){body{padding:0;}#wrap{width:100%;max-width:100%;height:100vh;height:100dvh;display:flex;flex-direction:column;padding:6px;overflow-y:auto;}#wrap h1{margin:2px 0;font-size:clamp(16px,5vw,22px);}#hud{margin:2px 0;font-size:clamp(11px,3vw,14px);}#game{flex:1 1 auto;min-height:0;width:auto;height:auto;max-width:100%;max-height:100%;aspect-ratio:456/360;border-radius:0;margin:4px auto;}#pad{flex:0 0 auto;}#msg{flex:0 0 auto;margin-top:6px;}}@media ((max-width:820px) or (pointer:coarse)) and (max-height:600px){#wrap h1{font-size:14px;margin:0;}#hud{font-size:10px;margin:0;}#msg{font-size:9px;margin-top:3px;}}"
    end
    box:
        id = "wrap"
        heading: content = "SALAM PAC-MAN" end
        box: id = "hud" content = "Loading..." end
        canvas: id = "game" width = 456 height = 360 end
        box:
            id = "pad"
            button: id = "pad_up" content = "▲" end
            button: id = "pad_left" content = "◀" end
            button: id = "pad_pause" content = "❚❚" end
            button: id = "pad_right" content = "▶" end
            button: id = "pad_down" content = "▼" end
        end
        paragraph: id = "msg" content = "Loading..." end
    end
    script: src = "src/game.salam" end
end
