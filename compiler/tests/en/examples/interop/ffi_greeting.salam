extern:
    func printf(format: str, ...): int
    func getenv(name: str): str
    func strlen(s: str): u64
end

func main:
    if SALAM_OS_WINDOWS:
        user := getenv("USERNAME")
    else:
        user := getenv("USER")
    end
    printf("Hello! Your username variable is %d bytes.\n", strlen(user))
    printf("Pi is about %.2f and 7 * 6 = %d\n", 3.14159, 7 * 6)
end
