package main

import db.sqlite
import str

func seed(db: sqlite.Database):
    sqlite.Exec(db, "CREATE TABLE products(id INTEGER PRIMARY KEY, name TEXT, category TEXT, price REAL)")
    sqlite.Exec(db, "INSERT INTO products(name, category, price) VALUES ('Pen','stationery',1.5),('Notebook','stationery',3.0),('Mug','kitchen',6.5),('Kettle','kitchen',24.0)")
end

func main:
    if sqlite.Available() == false:
        println "SQLite unavailable"
    else:
        db := sqlite.Open(":memory:")
        seed(db)
        println "all products (name, price):"
        all := sqlite.Query(db, "SELECT name, price FROM products ORDER BY price")
        until sqlite.Next(all):
            print "  "
            print sqlite.Text(all, 0)
            print " = "
            println str.FromFloat(sqlite.Float(all, 1))
        end
        sqlite.Finish(all)
        print "number of products: "
        println str.FromInt(sqlite.QueryInt(db, "SELECT COUNT(*) FROM products") as i64)
        print "most expensive: "
        println sqlite.QueryText(db, "SELECT name FROM products ORDER BY price DESC LIMIT 1")
        print "total kitchen value: "
        println sqlite.QueryText(db, "SELECT SUM(price) FROM products WHERE category = 'kitchen'")
        println "stationery items:"
        st := sqlite.Query(db, "SELECT name FROM products WHERE category = 'stationery' ORDER BY name")
        until sqlite.Next(st):
            print "  - "
            println sqlite.Text(st, 0)
        end
        sqlite.Finish(st)
        q := sqlite.Prepare(db, "SELECT name, price FROM products WHERE price < ? ORDER BY price")
        sqlite.BindFloat(q, 1, 5.0)
        println "under 5.0:"
        until sqlite.Next(q):
            print "  "
            print sqlite.Text(q, 0)
            print " ("
            print str.FromFloat(sqlite.Float(q, 1))
            println ")"
        end
        sqlite.Finish(q)
        sqlite.Close(db)
    end
end
