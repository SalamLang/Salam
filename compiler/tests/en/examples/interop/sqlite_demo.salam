package main

import db.sqlite
import str

func main:
    if sqlite.Available():
        print "SQLite "
        println sqlite.Version()
        db := sqlite.Open("example.db")
        if sqlite.Ok(db):
            sqlite.Exec(db, "DROP TABLE IF EXISTS people")
            sqlite.Exec(db, "CREATE TABLE people(id INTEGER PRIMARY KEY, name TEXT, age INTEGER)")
            sqlite.Exec(db, "INSERT INTO people(name, age) VALUES ('Ada', 36), ('Grace', 45), ('Linus', 28)")
            println "people over 30, oldest first:"
            rows := sqlite.Query(db, "SELECT name, age FROM people WHERE age > 30 ORDER BY age DESC")
            until sqlite.Next(rows):
                print "  "
                print sqlite.Text(rows, 0)
                print " ("
                print str.FromInt(sqlite.Int(rows, 1) as i64)
                println ")"
            end
            sqlite.Finish(rows)
            sqlite.Close(db)
        else:
            println "could not open database"
        end
    else:
        println "SQLite is not available on this platform."
    end
end
