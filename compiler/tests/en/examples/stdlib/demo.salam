import mathx "math.salam"
enum Color:
    Red
    Green = 5
    Blue
end

struct Counter:
    pub value: int = 0
    pub func increment():
        this.value = this.value + 1
    end
    pub func get(): int:
        ret this.value
    end
end

func add(a: int, b: int): int:
    ret a + b
end

func add(a: f64, b: f64): f64:
    ret a + b
end

func main:
    c := Counter { value = 10 }
    c.increment()
    _f := add(1.5, 2.5)
    mut total := 0
    repeat 3 with i:
        total = total + add(i, c.get())
    end
    if total > 5:
        println "big", total, "square", mathx.Square(total)
    else:
        println "small"
    end
end
layout:
    title = "Demo"
    box:
        heading: size = 1 content = "Hello" end
    end
end
