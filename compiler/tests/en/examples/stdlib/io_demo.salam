package main

import os
import io
import str

func main:
    path := "io_example_out.txt"
    io.WriteFile(path, "the quick brown fox\njumps over\nthe lazy dog\n")
    text := io.ReadFile(path)
    lines := str.Split(str.Trim(text), "\n")
    defer lines.free()
    println "read lines:"
    println str.Join(lines, " | ")
    words := str.Split(lines.get(0)[0], " ")
    defer words.free()
    print "first line has "
    print str.FromInt(words.len() as i64)
    println " words"
    a := os.Args()
    defer a.free()
    print "called with "
    print str.FromInt((a.len() - 1) as i64)
    println " argument(s)"
    mut i := 1
    until i < a.len():
        println a.get(i)[0]
        i = i + 1
    end
    os.Remove(path)
end
