interface Shape:
    func area(): f64
    func name(): str
end

struct Circle:
    pub r: f64 = 0.0
    pub func area(): f64: ret 3.14159 * this.r * this.r end
    pub func name(): str: ret "circle" end
end

struct Rect:
    pub w: f64 = 0.0
    pub h: f64 = 0.0
    pub func area(): f64: ret this.w * this.h end
    pub func name(): str: ret "rect" end
end

func describe<T: Shape>(s: T):
    print s.name()
    print " area="
    println s.area()
end
func main:
    describe(Circle { r = 2.0 })
    describe(Rect { w = 3.0, h = 4.0 })
end
