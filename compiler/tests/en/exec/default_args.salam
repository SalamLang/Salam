const STEP : int = 5

struct Box:
    w : int = 1
    h : int = 1
    name : str = "box"
    func grow(by : int = 2) : int:
        ret this.w + by
    end
end

func area(w : int, h : int = 2) : int:
    ret w * h
end

func bump(x : int, by : int = STEP) : int:
    ret x + by
end

func main:
    println(area(3))
    println(area(3, 4))
    println(bump(10))
    println(bump(10, 1))
    b1 : Box = Box {}
    b2 : Box = Box { w = 4, h = 5, name = "wide" }
    b3 : Box = Box { w = 7 }
    println(b1.w, b1.h, b1.name)
    println(b2.w, b2.h, b2.name)
    println(b3.w, b3.h, b3.name)
    println(b3.grow())
    println(b3.grow(3))
end
