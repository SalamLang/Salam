const STEP := 5

struct Box:
    pub w : int = 1
    pub h : int = 1
    pub name : str = "box"
    pub func grow(delta : int = 2) : int:
        ret this.w + delta
    end
end

func area(w : int, h : int = 2) : int:
    ret w * h
end

func bump(x : int, delta : int = STEP) : int:
    ret x + delta
end

func main:
    println(area(3))
    println(area(3, 4))
    println(bump(10))
    println(bump(10, 1))
    b1 := Box {}
    b2 := Box { w = 4, h = 5, name = "wide" }
    b3 := Box { w = 7 }
    println(b1.w, b1.h, b1.name)
    println(b2.w, b2.h, b2.name)
    println(b3.w, b3.h, b3.name)
    println(b3.grow())
    println(b3.grow(3))
end
