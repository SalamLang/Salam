const STEP i32 = 5

struct Box:
    w i32 = 1
    h i32 = 1
    name str = "box"
    func grow(by i32 = 2) i32:
        ret this.w + by
    end
end

func area(w i32, h i32 = 2) i32:
    ret w * h
end

func bump(x i32, by i32 = STEP) i32:
    ret x + by
end

func main:
    println(area(3))
    println(area(3, 4))
    println(bump(10))
    println(bump(10, 1))
    b1 Box = Box {}
    b2 Box = Box { w = 4, h = 5, name = "wide" }
    b3 Box = Box { w = 7 }
    println(b1.w, b1.h, b1.name)
    println(b2.w, b2.h, b2.name)
    println(b3.w, b3.h, b3.name)
    println(b3.grow())
    println(b3.grow(3))
end
