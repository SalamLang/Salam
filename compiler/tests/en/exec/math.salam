import math

func main():
    println (math.Sqrt(16.0))
    println (math.Max(3, 7))
    println (math.Min(3, 7))
    println (math.Abs(0 - 5))
    println (math.Floor(3.9))
    println (math.Ceil(3.1))
    println (math.Pow(2.0, 8.0))
    println (math.Gcd(12, 18))
    println (math.Lcm(4, 6))
    println (math.Sign(0 - 3))
end
