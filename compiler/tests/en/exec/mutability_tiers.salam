struct Point:
    pub x: int
    pub y: int
end

func main:
    y1 := [1, 2, 3] as int[3]
    y1[0] = 10
    y1[1]++
    println y1[0]
    println y1[1]

    p := Point { x = 1, y = 2 }
    p.x = 99
    println p.x

    mut n := 5
    n = 6
    println n

    const c := [7, 8, 9] as int[3]
    println c[2]
end
