func main:
    b := 3
    c := 4

    mut e := 5
    e += b * c
    println e

    mut f := 2
    f *= b + c
    println f

    mut g := 100
    g -= b * c
    println g

    mut h := 100
    h /= b - 1
    println h

    mut k := 10
    k %= b + 1
    println k

    mut p := 2.0
    p **= b - 1
    println p
end
