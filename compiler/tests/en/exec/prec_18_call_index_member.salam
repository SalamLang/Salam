struct Box:
    pub w : int
    pub h : int
end

func doubleIt(v : int) : int:
    ret v * 2
end

func main:
    mut a := 3
    mut b := 4

    b1 := Box { w = 5, h = 6 }
    println(b1.w + b1.h * 2)
    println(doubleIt(a) + b)
    println(doubleIt(a + b))

    mut arr := [10, 20, 30]
    println(arr[1] + arr[0] * 2)
    println(-arr[0])
end
