func factf(n: f32):
    if n <= 1: ret 1 end
    ret n * factf(n - 1)
end

func factg(n):
    if n <= 1: ret 1 end
    ret n * factg(n - 1)
end

func five(): f32:
    one := 1
    if one > 2: ret 0.5 end
    ret 5
end

func big(): i64:
    ret 5
end

func main:
    repeat 1 to 8 with i:
        println factf(i)
    end
    println factg(5)
    println factg(6.0)
    println five()
    println 9000000000 + big()
end
