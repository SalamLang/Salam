func main:
    arr := [10, 20, 30, 40, 50] as int[5]
    mut s := arr[1:4]
    println len(s)
    println s[0], s[1], s[2]
    s[0] = 99
    println arr[1]
    println len(arr[:])
    pre := arr[:2]
    println len(pre), pre[0], pre[1]
    suf := arr[3:]
    println len(suf), suf[0], suf[1]
    sub := s[1:]
    println len(sub), sub[0]
end
