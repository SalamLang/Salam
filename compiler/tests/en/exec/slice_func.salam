func sum(s : int[:]) : int:
    mut t : int = 0
    for mut i : int = 0, i < len(s), i = i + 1:
        t = t + s[i]
    end
    ret t
end

func first_half(a : int[:]) : int[:]:
    ret a[:len(a) / 2]
end

func main:
    arr : int[6] = [1, 2, 3, 4, 5, 6]
    whole : auto = arr[:]
    __ sum(whole)
    __ sum(arr[2:5])
    fh : auto = first_half(whole)
    __ len(fh), fh[0], fh[1], fh[2]
    __ sum(fh)
end
