func sum(s : int[:]) : int:
    mut t := 0
    repeat 0 to len(s) - 1 with i:
        t = t + s[i]
    end
    ret t
end

func first half(a : int[:]) : int[:]:
    ret a[:len(a) / 2]
end

func main:
    arr := [1, 2, 3, 4, 5, 6] as int[6]
    whole := arr[:]
    println sum(whole)
    println sum(arr[2:5])
    fh := first half(whole)
    println len(fh), fh[0], fh[1], fh[2]
    println sum(fh)
end
