import str

func main():
    println (str.Upper("hello"))
    println (str.Lower("WORLD"))
    println (str.Reverse("salam"))
    println (str.Repeat("ab", 3))
    println (str.Title("hello world"))
    println (str.Count("aXbXcX", "X"))
    println (str.Contains("hello", "ell"))
    println (str.Replace("a.b.c", ".", "-"))
    println (str.StartsWith("foobar", "foo"))
    println (str.EqualFold("ABC", "abc"))
end
