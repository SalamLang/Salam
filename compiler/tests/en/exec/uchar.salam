func main:
    a := u"A"
    b := u"€"
    c := u"中"
    d := u"😀"
    e := u"A"
    f := u"\U0001F600"
    g := u"\\"
    h := u"\""
    println(a)
    println(b)
    println(c)
    println(d)
    println(e)
    println(f)
    println(g)
    println(h)
    println("letter: " + c)
    println(a + b)
    println(c + " <- CJK")
    s := u"ص"
    println(s)
end
