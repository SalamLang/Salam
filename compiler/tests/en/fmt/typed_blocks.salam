// LANG: en
struct Point:
    pub x: i32
    pub y: i32
end

interface Sized:
    func size(): i32
end

func dist(p: Point): i32:
    ret p.x + p.y
end

func main:
    p := Point { x = 1, y = 2 }
    inc := (n: i32) =>:
        ret n + 1
    end
    println dist(p), inc(4)
    println dist(p) > 2 ? "big" : "small"
end
