package modlib
pure func hidden boost(x : int) : int: ret x + 50 end
pub pure func PAdd(a : int, b : int) : int: ret a + b end
pub inline pure func PSquare(x : int) : int: ret x * x end
pub noinline func PTriple(x : int) : int: ret x * 3 end
pub deprecated func POld(x : int) : int: ret x - 1 end
pub inline func PBoosted(x : int) : int: ret hidden boost(x) end
pub pure func PPick<T>(a : T, b : T) : T:
    if a > b: ret a end
    ret b
end
