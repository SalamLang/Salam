package modlib
pure func hidden_boost(x i32) i32: ret x + 50 end
pub pure func PAdd(a i32, b i32) i32: ret a + b end
pub inline pure func PSquare(x i32) i32: ret x * x end
pub noinline func PTriple(x i32) i32: ret x * 3 end
pub deprecated func POld(x i32) i32: ret x - 1 end
pub inline func PBoosted(x i32) i32: ret hidden_boost(x) end
pub pure func PPick<T>(a T, b T) T:
    if a > b: ret a end
    ret b
end
