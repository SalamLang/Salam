func main:
    v := [
        100
        200
        300
    ] as int[3]
    println v[0] + v[1] + v[2]
    m := [
        [1, 0, 0]
        [0, 2, 0]
        [0, 0, 3]
    ] as int[3][3]
    println m[0][0] + m[1][1] + m[2][2]
    mixed := [
        1, 2
        3, 4
    ] as int[4]
    println mixed[0] + mixed[1] + mixed[2] + mixed[3]
end
