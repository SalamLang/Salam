func main:
    a := [
        10
        20
        30
    ] as int[3]
    __ a[0] + a[1] + a[2]
    b := [1, 2] as int[2]
    __ b[0] + b[1]
    c := [
        1, 2
        3, 4
    ] as int[4]
    __ c[0] + c[1] + c[2] + c[3]
    m := [
        [1, 2]
        [3, 4]
    ] as int[2][2]
    __ m[0][0] + m[1][1]
end
