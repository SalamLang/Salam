func main:
    a := 12
    b := 10
    println a & b, a | b, a ^ b
    println a << 2, a >> 1, ~a
    mut f := 0
    f |= 5
    f &= 6
    f ^= 1
    f <<= 2
    f >>= 1
    println f
    println 1 | 2 & 3, 1 << 4 + 1
    mut mask := 0xFF
    mask = mask & 0x0F
    println mask, 0b1010 | 0b0101
end
