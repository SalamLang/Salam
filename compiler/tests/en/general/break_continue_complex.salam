func main:
    mut s := 0
    mut last := -1
    repeat 100 with i:
        if i % 3 == 0: continue end
        if s > 10: break end
        s = s + i
        last = i
    end
    println s
    println last

    mut c := 0
    repeat 3 with i:
        repeat 3 with j:
            if j == 2: break end
            repeat 3 with k:
                if k == 1: continue end
                c = c + 1
            end
        end
    end
    println c

    mut found := 0
    mut fi := -1
    mut fj := -1
    repeat 5 with i:
        repeat 5 with j:
            if i * j == 6:
                found = 1
                fi = i
                fj = j
                break
            end
        end
        if found == 1: break end
    end
    println fi
    println fj

    mut processed := 0
    mut budget := 5
    repeat 20:
        budget = budget - 1
        if budget < 0: break end
        if budget % 2 == 0: continue end
        processed = processed + 1
    end
    println processed
end
