func main:
    mut s = 0
    mut last = -1
    for mut i = 0, i < 100, i = i + 1:
        if i % 3 == 0: continue end
        if s > 10: break end
        s = s + i
        last = i
    end
    __ s
    __ last

    mut c = 0
    for mut i = 0, i < 3, i = i + 1:
        for mut j = 0, j < 3, j = j + 1:
            if j == 2: break end
            for mut k = 0, k < 3, k = k + 1:
                if k == 1: continue end
                c = c + 1
            end
        end
    end
    __ c

    mut found = 0
    mut fi = -1
    mut fj = -1
    for mut i = 0, i < 5, i = i + 1:
        for mut j = 0, j < 5, j = j + 1:
            if i * j == 6:
                found = 1
                fi = i
                fj = j
                break
            end
        end
        if found == 1: break end
    end
    __ fi
    __ fj

    mut processed = 0
    mut budget = 5
    repeat 20:
        budget = budget - 1
        if budget < 0: break end
        if budget % 2 == 0: continue end
        processed = processed + 1
    end
    __ processed
end
