func main:
    mut count := 0
    repeat 4 with i:
        repeat 4 with j:
            if j == i: break end
            count = count + 1
        end
    end
    println count

    mut sum := 0
    repeat 3 with i:
        repeat 3 with j:
            if j == 1: continue end
            sum = sum + 1
        end
    end
    println sum

    mut outer := 0
    repeat 3:
        outer = outer + 1
        repeat 5:
            break
        end
    end
    println outer

    mut total := 0
    mut x := 0
    until x < 3:
        x = x + 1
        repeat 10 with y:
            if y == 2: break end
            total = total + 1
        end
    end
    println total

    mut outerhits := 0
    mut innerhits := 0
    repeat 3 with i:
        outerhits = outerhits + 1
        repeat 4 with j:
            if j % 2 == 0: continue end
            innerhits = innerhits + 1
        end
    end
    println outerhits
    println innerhits
end
