func main:
    mut a := 0
    repeat 10 with i:
        if i == 5: break end
        a = a + i
    end
    println a

    mut b := 0
    repeat 10 with i:
        if i % 2 == 0: continue end
        b = b + i
    end
    println b

    mut c := 0
    mut j := 0
    until j < 100:
        if j == 7: break end
        c = c + 1
        j = j + 1
    end
    println c

    mut d := 0
    mut k := 0
    until k < 10:
        k = k + 1
        if k % 2 == 0: continue end
        d = d + 1
    end
    println d

    mut e := 0
    repeat 10:
        e = e + 1
        if e == 3: break end
    end
    println e

    mut f := 0
    mut g := 0
    repeat 6:
        g = g + 1
        if g % 3 == 0: continue end
        f = f + 1
    end
    println f
end
