import "collections"

func main:
    mut v : collections.Vector<int> = Vector {}
    v.push(10)
    v.push(20)
    v.push(30)
    println v.len()
    println v[1]
    println v.get(2)[0]
    v.insert(1, 99)
    println v.get(1)[0]
    println v.remove_at(1)
    println v.len()
    mut vit = v.iter()
    mut vsum : int = 0
    while vit.has_next():
        vsum = vsum + vit.value()
        vit.next()
    end
    println vsum

    mut m : collections.HashMap<str, int> = HashMap {}
    m.put("a", 1)
    m.put("b", 2)
    m.put("a", 9)
    println m.get("a")
    println m.has("b")
    println m.has("z")
    println m.size()
    m.remove("a")
    println m.has("a")
    println m.size()
    mut total : int = 0
    mut mit = m.iter()
    while mit.has_next():
        total = total + mit.value()
        mit.next()
    end
    println total

    mut st : collections.Stack<int> = Stack {}
    st.push(1)
    st.push(2)
    st.push(3)
    println st.pop()
    println st.size()
    mut q : collections.Queue<int> = Queue {}
    q.enqueue(10)
    q.enqueue(20)
    println q.dequeue()
    println q.size()
    mut dq : collections.Deque<int> = Deque {}
    dq.push_back(1)
    dq.push_front(2)
    println dq.front_val()
    println dq.pop_back()

    mut pq : collections.PriorityQueue<int> = PriorityQueue {}
    pq.push(5)
    pq.push(1)
    pq.push(3)
    println pq.pop()
    println pq.pop()
    mut ll : collections.LinkedList<int> = LinkedList {}
    ll.push_back(1)
    ll.push_front(0)
    ll.push_back(2)
    println ll.size()
    println ll.get(1)
    println ll.pop_front()
    mut cl : collections.CircularList<int> = CircularList {}
    cl.add(10)
    cl.add(20)
    cl.add(30)
    println cl.current()
    cl.rotate(2)
    println cl.current()

    mut s : collections.Set<str> = Set {}
    s.add("a")
    s.add("b")
    s.add("a")
    println s.size()
    println s.has("a")
    mut c : collections.Counter<str> = Counter {}
    c.add("x")
    c.add("x")
    c.add("y")
    println c.count("x")
    println c.distinct()
    mut p : collections.Pair<int, str> = Pair { first = 7, second = "hi" }
    println p.first
    println p.second

    println collections.contains(v, 99)
    println collections.index_of(v, 30)
end
