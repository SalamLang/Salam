import collections

func main:
    mut v := Vector {} as collections.Vector<int> v.push(10)
    v.push(20)
    v.push(30)
    println v.len()
    println v[1]
    println v.get(2)[0]
    v.insert(1, 99)
    println v.get(1)[0]
    println v.remove_at(1)
    println v.len()
    mut vit := v.iter()
    mut vsum := 0
    until vit.has_next():
        vsum = vsum + vit.value()
        vit.next()
    end
    println vsum

    mut m := HashMap {} as collections.HashMap<str, int> m.put("a", 1)
    m.put("b", 2)
    m.put("a", 9)
    println m.get("a")
    println m.has("b")
    println m.has("z")
    println m.size()
    m.remove("a")
    println m.has("a")
    println m.size()
    mut total := 0
    mut mit := m.iter()
    until mit.has_next():
        total = total + mit.value()
        mit.next()
    end
    println total

    mut st := Stack {} as collections.Stack<int> st.push(1)
    st.push(2)
    st.push(3)
    println st.pop()
    println st.size()
    mut q := Queue {} as collections.Queue<int> q.enqueue(10)
    q.enqueue(20)
    println q.dequeue()
    println q.size()
    mut dq := Deque {} as collections.Deque<int> dq.push_back(1)
    dq.push_front(2)
    println dq.front_val()
    println dq.pop_back()

    mut pq := PriorityQueue {} as collections.PriorityQueue<int> pq.push(5)
    pq.push(1)
    pq.push(3)
    println pq.pop()
    println pq.pop()
    mut ll := LinkedList {} as collections.LinkedList<int> ll.push_back(1)
    ll.push_front(0)
    ll.push_back(2)
    println ll.size()
    println ll.get(1)
    println ll.pop_front()
    mut cl := CircularList {} as collections.CircularList<int> cl.add(10)
    cl.add(20)
    cl.add(30)
    println cl.current()
    cl.rotate(2)
    println cl.current()

    mut s := Set {} as collections.Set<str> s.add("a")
    s.add("b")
    s.add("a")
    println s.size()
    println s.has("a")
    mut c := Counter {} as collections.Counter<str> c.add("x")
    c.add("x")
    c.add("y")
    println c.count("x")
    println c.distinct()
    p := Pair { first = 7, second = "hi" } as collections.Pair<int, str> println p.first
    println p.second

    println collections.contains(v, 99)
    println collections.index_of(v, 30)
end
