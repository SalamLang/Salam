/* a plain block comment
   spanning several
   lines */
func main:
    /* block comment before a statement */
    __ 1
    __ /* inline block comment */ 2
    /* nested block comment:
       /* this inner comment is fully contained
          /* and a third level too */
       */
       still inside the outer comment, __ 999 must not run
    */
    __ 3
end
