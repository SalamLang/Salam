func main:
    mut a := 10
    a += 5
    println(a)
    a -= 3
    println(a)
    a *= 2
    println(a)
    a /= 4
    println(a)
    a %= 5
    println(a)

    mut u := 100 as u32
    u += 50
    u -= 20
    println(u)

    mut p := 2.0
    p **= 8
    println(p)

    mut n := 1000000000000 as i64
    n += 1
    println(n)
end
