struct Vec2:
    pub x : f64 = 0.0
    pub y : f64 = 0.0
    pub func operator + (other : Vec2) : Vec2:
        ret Vec2 { x = this.x + other.x, y = this.y + other.y }
    end
    pub func operator ** (other : Vec2) : Vec2:
        ret Vec2 { x = this.x * other.x, y = this.y * other.y }
    end
end

func main:
    mut a := Vec2 { x = 1.0, y = 2.0 }
    b := Vec2 { x = 3.0, y = 4.0 }
    a += b
    println a.x
    println a.y
    a **= b
    println a.x
    println a.y
end
