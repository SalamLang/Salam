// DEFINE: FEATURE X
if FEATURE X:
    const GREETING := "feature-on"
else:
    const GREETING := "feature-off"
end

func helper() : bool: ret true end

func main:
    println GREETING
    if defined(FEATURE X):
        println "defined: yes"
    else:
        println "defined: no"
    end
    if defined(FEATURE Y):
        println "unreachable"
    else:
        println "not defined: FEATURE_Y"
    end
    if helper():
        println "runtime branch works"
    end
end
