// DEFINE: FEATURE_X
if FEATURE_X:
    const GREETING := "feature-on"
else:
    const GREETING := "feature-off"
end

func helper(): bool: ret true end

func main:
    println GREETING
    if defined(FEATURE_X):
        println "defined: yes"
    else:
        println "defined: no"
    end
    if defined(FEATURE_Y):
        println "unreachable"
    else:
        println "not defined: FEATURE_Y"
    end
    if helper():
        println "runtime branch works"
    end
end
