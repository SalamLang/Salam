import (
    "config"
)

func main:
    mut text := "# global settings\n"
    text = text.concat("port = 8080\n")
    text = text.concat("name = \"my app\" # display name\n")
    text = text.concat("\n")
    text = text.concat("[db]\n")
    text = text.concat("host=localhost\n")
    text = text.concat("user = 'root'\n")
    text = text.concat("; comment line\n")
    text = text.concat("debug = on\n")
    mut cfg := config.ParseINI(text)
    __ config.Len(cfg)
    __ config.Get(cfg, "port")
    __ config.Get(cfg, "name")
    __ config.Get(cfg, "db.host")
    __ config.GetInt(cfg, "port", 0)
    __ config.GetBool(cfg, "db.debug", false)
    __ config.GetOr(cfg, "missing", "fallback")
    __ config.Has(cfg, "db.user")
    mut dbsec := config.Section(cfg, "db")
    __ config.Len(dbsec)
    __ config.Get(dbsec, "user")
    config.Set(cfg, "port", "9090")
    __ config.GetInt(cfg, "port", 0)
    removed := config.Remove(cfg, "name")
    __ removed
    __ config.Has(cfg, "name")
    mut envtext := "# env file\n"
    envtext = envtext.concat("export API_KEY=abc123\n")
    envtext = envtext.concat("QUOTED=\"a b\"\n")
    envtext = envtext.concat("NUM=7\n")
    envtext = envtext.concat("EMPTY=\n")
    mut envc := config.ParseEnv(envtext)
    __ config.Get(envc, "API_KEY")
    __ config.Get(envc, "QUOTED")
    __ config.GetInt(envc, "NUM", 0)
    __ config.Len(envc)
    print (config.FormatINI(cfg))
    print (config.FormatEnv(envc))
end
