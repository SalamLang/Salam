import "conv"

func main:
    println conv.FormatInt(0)
    println conv.FormatInt(12345)
    println conv.FormatInt(0 - 12345)
    println conv.FormatUint(18446744073709551615)
    println conv.FormatBool(true)
    println conv.FormatBool(false)
    println conv.ParseBool("yes")
    println conv.ParseInt(" -42abc")
    println conv.Atoi("99")
    println conv.ParseFloat("2.5")
    println conv.ParseFloat("-1.25e2")
    println conv.FormatFloat(3.14)
    println conv.FormatFloat(0.1)
    println conv.FormatFloat(1234567.0)
    println conv.FormatFloat(0.00001)
    println conv.FormatFloat(0.0 - 2.5)
    println conv.FormatFloatPrec(3.14159, 2)
    println conv.FormatFloatPrec(7.0, 3)
    println conv.FormatHex(48879 as u64)
    println conv.ParseHex("0xbeef")
    println conv.ParseHex("FF")
end
