import "conv"

func main:
    __ conv.FormatInt(0)
    __ conv.FormatInt(12345)
    __ conv.FormatInt(0 - 12345)
    __ conv.FormatUint(18446744073709551615)
    __ conv.FormatBool(true)
    __ conv.FormatBool(false)
    __ conv.ParseBool("yes")
    __ conv.ParseInt(" -42abc")
    __ conv.Atoi("99")
    __ conv.ParseFloat("2.5")
    __ conv.ParseFloat("-1.25e2")
    __ conv.FormatFloat(3.14)
    __ conv.FormatFloat(0.1)
    __ conv.FormatFloat(1234567.0)
    __ conv.FormatFloat(0.00001)
    __ conv.FormatFloat(0.0 - 2.5)
    __ conv.FormatFloatPrec(3.14159, 2)
    __ conv.FormatFloatPrec(7.0, 3)
    __ conv.FormatHex(48879 as u64)
    __ conv.ParseHex("0xbeef")
    __ conv.ParseHex("FF")
end
