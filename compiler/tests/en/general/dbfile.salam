import (
    "db/sqlite" "os"
)

func run():
    path str = "_dbfile_test.db"
    os.Remove(path)
    db sqlite.Database = sqlite.Open(path)
    sqlite.Exec(db, "CREATE TABLE kv(k TEXT PRIMARY KEY, v TEXT)")
    sqlite.Exec(db, "INSERT INTO kv VALUES ('greeting', 'hello'), ('lang', 'salam')")
    sqlite.Close(db)
    db2 sqlite.Database = sqlite.Open(path)
    __ sqlite.QueryText(db2, "SELECT v FROM kv WHERE k = 'greeting'")
    __ sqlite.QueryText(db2, "SELECT v FROM kv WHERE k = 'lang'")
    __ sqlite.QueryInt(db2, "SELECT COUNT(*) FROM kv")
    sqlite.Close(db2)
    os.Remove(path)
end

func main:
    if sqlite.Available():
        run()
    else:
        __ "hello"
        __ "salam"
        __ 2
    end
end
