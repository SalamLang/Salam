import db.sqlite
import os

func run():
    path := "_dbfile_test.db"
    os.Remove(path)
    db := sqlite.Open(path)
    sqlite.Exec(db, "CREATE TABLE kv(k TEXT PRIMARY KEY, v TEXT)")
    sqlite.Exec(db, "INSERT INTO kv VALUES ('greeting', 'hello'), ('lang', 'salam')")
    sqlite.Close(db)
    db2 := sqlite.Open(path)
    println sqlite.QueryText(db2, "SELECT v FROM kv WHERE k = 'greeting'")
    println sqlite.QueryText(db2, "SELECT v FROM kv WHERE k = 'lang'")
    println sqlite.QueryInt(db2, "SELECT COUNT(*) FROM kv")
    sqlite.Close(db2)
    os.Remove(path)
end

func main:
    if sqlite.Available():
        run()
    else:
        println "hello"
        println "salam"
        println 2
    end
end
