import "db/sqlite"
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE m(name TEXT, qty INTEGER, price REAL, note TEXT)")
    ins := sqlite.Prepare(db, "INSERT INTO m VALUES (?, ?, ?, ?)")
    sqlite.BindText(ins, 1, "apple")
    sqlite.BindInt(ins, 2, 5 as i64)
    sqlite.BindFloat(ins, 3, 1.25)
    sqlite.BindNull(ins, 4)
    sqlite.Next(ins)
    sqlite.Finish(ins)
    r := sqlite.Query(db, "SELECT name, qty, price, note FROM m")
    sqlite.Next(r)
    println sqlite.Text(r, 0)
    println sqlite.Int(r, 1)
    println sqlite.Float(r, 2)
    println sqlite.IsNull(r, 3)
    println sqlite.ColumnType(r, 0), sqlite.ColumnType(r, 1), sqlite.ColumnType(r, 2), sqlite.ColumnType(r, 3)
    sqlite.Finish(r)
    q := sqlite.Prepare(db, "SELECT qty FROM m WHERE name = ?")
    sqlite.BindText(q, 1, "apple")
    sqlite.Next(q)
    println sqlite.Int(q, 0)

    sqlite.Finish(q)
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println "apple"
        println 5
        println 1.25
        println true
        println 3, 1, 2, 5
        println 5
    end
end
