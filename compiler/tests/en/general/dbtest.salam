import "db/sqlite"
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE IF NOT EXISTS animals(id INTEGER PRIMARY KEY, name TEXT, legs INTEGER)")
    sqlite.Exec(db, "CREATE TABLE IF NOT EXISTS animals(id INTEGER PRIMARY KEY, name TEXT, legs INTEGER)")
    sqlite.Exec(db, "INSERT INTO animals(name, legs) VALUES ('ant', 6)")
    println sqlite.LastInsertId(db)
    ins := sqlite.Prepare(db, "INSERT INTO animals(name, legs) VALUES (?, ?)")
    sqlite.BindText(ins, 1, "spider")
    sqlite.BindInt(ins, 2, 8 as i64)
    sqlite.Next(ins)
    sqlite.Reset(ins)
    sqlite.BindText(ins, 1, "dog")
    sqlite.BindInt(ins, 2, 4 as i64)
    sqlite.Next(ins)
    sqlite.Finish(ins)
    println sqlite.LastInsertId(db)
    println sqlite.QueryInt(db, "SELECT COUNT(*) FROM animals")
    println sqlite.QueryText(db, "SELECT name FROM animals WHERE legs = 8")
    all := sqlite.Query(db, "SELECT name, legs FROM animals ORDER BY legs")
    println sqlite.ColumnCount(all)
    until sqlite.Next(all):
        println sqlite.Text(all, 0), sqlite.Int(all, 1)
    end
    sqlite.Finish(all)
    names := sqlite.Query(db, "SELECT name FROM animals ORDER BY name")
    until sqlite.Next(names):
        println sqlite.Text(names, 0)
    end
    sqlite.Finish(names)
    sqlite.Exec(db, "UPDATE animals SET legs = 0 WHERE legs > 5")
    println sqlite.Changes(db)
    sqlite.Exec(db, "DELETE FROM animals WHERE legs = 0")
    println sqlite.Changes(db)
    println sqlite.QueryInt(db, "SELECT COUNT(*) FROM animals")
    println sqlite.Exec(db, "DROP TABLE animals")
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println 1
        println 3
        println 3
        println "spider"
        println 2
        println "dog", 4
        println "ant", 6
        println "spider", 8
        println "ant"
        println "dog"
        println "spider"
        println 2
        println 2
        println 1
        println 0
    end
end
