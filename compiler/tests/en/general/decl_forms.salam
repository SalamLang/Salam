g_count : int = 3
g_name : auto = "salam"
func main:
    a : int = 10
    b : auto = 20
    s : auto = "hi"
    mut total : i64 = 0
    mut acc : auto = 0
    f : func (int) int = (n : int) => n * 2
    v : Vector<int> = Vector {}
    v.push(a)
    v.push(b)
    mut i : int = 0
    while i < v.len():
        acc = acc + v.get(i)[0]
        total = total + 1
        i = i + 1
    end
    println (g_count, g_name, a, b, s, f(a), acc, total)
end
