g_count := 3
g_name := "salam"
func main:
    a := 10
    b := 20
    s := "hi"
    mut total := 0 as i64
    mut acc := 0
    f := (n : int) => n * 2
    v := Vector {} as Vector<int>
    v.push(a)
    v.push(b)
    mut i := 0
    until i < v.len():
        acc = acc + v.get(i)[0]
        total = total + 1
        i = i + 1
    end
    println (g_count, g_name, a, b, s, f(a), acc, total)
end
