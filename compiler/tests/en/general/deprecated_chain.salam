pub deprecated func OldAdd(a i32, b i32) i32: ret a + b end

deprecated pure func OldCube(x i32) i32: ret x * x * x end

pub deprecated inline pure func OldScale(x i32) i32: ret x * 100 end

pub deprecated noinline func OldTriple(x i32) i32: ret x * 3 end

func main:
    println(OldAdd(1, 2))
    println(OldCube(3))
    println(OldScale(4))
    println(OldTriple(5))
end
