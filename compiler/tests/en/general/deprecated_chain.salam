pub deprecated func OldAdd(a : int, b : int) : int: ret a + b end

deprecated pure func OldCube(x : int) : int: ret x * x * x end

pub deprecated inline pure func OldScale(x : int) : int: ret x * 100 end

pub deprecated noinline func OldTriple(x : int) : int: ret x * 3 end

func main:
    println OldAdd(1, 2)
    println OldCube(3)
    println OldScale(4)
    println OldTriple(5)
end
