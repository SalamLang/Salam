func main:
    mut users := HashMap {} as HashMap<str, int>
    users.put("a", 10)
    users.put("b", 20)
    users.put("c", 30)
    mut total := 0
    mut count := 0
    each (key, value) in users:
        if key != "":
            total = total + value
            count = count + 1
        end
    end
    println (count, total)
end
