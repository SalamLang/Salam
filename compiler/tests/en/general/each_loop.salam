func main:
    names := ["ali", "reza", "hasan"]
    each name in names:
        if name != "reza":
            println name
        end
    end
    each (i, n) in names:
        println i, n
    end
    mut v := Vector {} as Vector<int> v.push(10)
    v.push(20)
    v.push(30)
    mut sum := 0
    each x in v:
        sum = sum + x
    end
    println sum
    each (i, x) in v:
        if x > 10:
            println i, x
        end
    end
    each n in [5, 6]:
        print n
    end
    println ""
end
