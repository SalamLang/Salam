import "encoding" "str" "math" "mem"

func main:
    println encoding.Base64Encode("Salam!")
    println encoding.Base64Decode("U2FsYW0h")
    println encoding.Base64Encode("")
    println encoding.Base64Decode(encoding.Base64Encode("hello world"))
    println encoding.HexEncode("ABC")
    println encoding.HexDecode("414243")
    println str.Find("hello", "ll")
    println str.LastIndex("a-b-a-b", "a")
    println str.Upper("mix")
    println str.Title("the quick fox")
    println str.EqualFold("Go", "GO")
    println str.EndsWith("report.txt", ".txt")
    println math.Max(3.5, 1.5)
    println math.MinI(3, 9)
    println math.Mod(10.0, 3.0)
    println math.AbsI(0 - 7)
    p := mem.AllocateZeroed(8 as u64) as int*
    println p[0]
    println p[1]
    mem.Free(p as void*)
end
