import (
    "encoding" "str" "math" "mem"
)

func main:
    __ encoding.Base64Encode("Salam!")
    __ encoding.Base64Decode("U2FsYW0h")
    __ encoding.Base64Encode("")
    __ encoding.Base64Decode(encoding.Base64Encode("hello world"))
    __ encoding.HexEncode("ABC")
    __ encoding.HexDecode("414243")
    __ str.Find("hello", "ll")
    __ str.LastIndex("a-b-a-b", "a")
    __ str.Upper("mix")
    __ str.Title("the quick fox")
    __ str.EqualFold("Go", "GO")
    __ str.EndsWith("report.txt", ".txt")
    __ math.Max(3.5, 1.5)
    __ math.MinI(3, 9)
    __ math.Mod(10.0, 3.0)
    __ math.AbsI(0 - 7)
    mut p i32* = mem.AllocateZeroed(8 as u64) as i32*
    __ p[0]
    __ p[1]
    mem.Free(p as void*)
end
