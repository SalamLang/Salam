extern:
    func printf(format : str, ...) : int
    func strlen(s : str) : u64
    func malloc(size : u64) : void*
    func free(ptr : void*)
end

func main:
    printf("sum=%d\n", 20 + 22)
    s := "salam"
    printf("len=%d\n", strlen(s))
    p := malloc(32 as u64)
    if p == null:
        printf("alloc=fail\n")
    else:
        printf("alloc=ok\n")
        free(p)
    end
end
