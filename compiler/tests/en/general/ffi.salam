extern "C":
    func printf(format str, ...) i32
    func strlen(s str) u64
    func malloc(size u64) void*
    func free(ptr void*)
end

func main:
    printf("sum=%d\n", 20 + 22)
    s str = "salam"
    printf("len=%d\n", strlen(s))
    mut p void* = malloc(32 as u64)
    if p == null:
        printf("alloc=fail\n")
    else:
        printf("alloc=ok\n")
        free(p)
    end
end
