extern:
    func printf(format: str, ...): int
    func atoi(s: str): int
    func toupper(c: int): int
    func tolower(c: int): int
    func strcmp(a: str, b: str): int
    func abs(n: int): int
end

func main:
    printf("atoi=%d\n", atoi("42"))
    printf("toupper=%d\n", toupper(97))
    printf("tolower=%d\n", tolower(90))
    printf("abs=%d\n", abs(0 - 7))
    printf("cmp_eq=%d\n", strcmp("hi", "hi"))
    if strcmp("a", "b") < 0:
        printf("cmp_lt=yes\n")
    else:
        printf("cmp_lt=no\n")
    end
end
