extern "C":
    func printf(format str, ...) i32
    func pow(base f64, exp f64) f64
    func sqrt(x f64) f64
    func floor(x f64) f64
    func ceil(x f64) f64
end

func main:
    printf("pow=%d\n", pow(2.0, 10.0) as i32)
    printf("sqrt=%d\n", sqrt(144.0) as i32)
    printf("floor=%d\n", floor(3.9) as i32)
    printf("ceil=%d\n", ceil(3.1) as i32)
end
