import os

extern "C":
    func salam_open(path : str, mode : str) : File*
    func exit(code : int)
end

func main:
    os.MkdirAll("tests/.work")
    path := "tests/.work/_fileio_test.txt"
    mut w := salam_open(path, "w")
    if w == null:
        println "open failed"
        exit(1)
    end
    w.write("alpha\n")
    w.write("beta\n")
    w.write("gamma\n")
    w.close()
    mut r := salam_open(path, "r")
    mut lines := Vector {} as Vector<str>
    defer lines.free()
    mut line := r.readline()
    until line.len() > 0:
        lines.push(line)
        line = r.readline()
    end
    r.close()
    println lines.len()
    mut i := 0
    until i < lines.len():
        println lines.get(i)[0]
        i = i + 1
    end
end
