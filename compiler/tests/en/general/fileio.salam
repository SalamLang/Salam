extern "C":
    func salam_open(path str, mode str) File*
    func exit(code i32)
end

func main:
    path str = "tests/.work/_fileio_test.txt"
    mut w File* = salam_open(path, "w")
    if w == null:
        __ "open failed"
        exit(1)
    end
    w.write("alpha\n")
    w.write("beta\n")
    w.write("gamma\n")
    w.close()
    mut r File* = salam_open(path, "r")
    mut lines Vector<str> = Vector {}
    defer lines.free()
    mut line str = r.readline()
    while line.len() > 0:
        lines.push(line)
        line = r.readline()
    end
    r.close()
    __ lines.len()
    mut i = 0
    while i < lines.len():
        __ lines.get(i)[0]
        i = i + 1
    end
end
