import filepath

func main:
    println filepath.Join("a", "b")
    println filepath.Join("a/", "/b")
    println filepath.Join("", "x")
    println filepath.Base("/x/y/z.txt")
    println filepath.Base("plain")
    println filepath.Base("/")
    println filepath.Dir("/x/y/z.txt")
    println filepath.Dir("plain")
    println filepath.Dir("/top")
    println filepath.Ext("a/b.tar.gz")
    println filepath.Ext("noext")
    println filepath.Stem("a/b.tar.gz")
    println filepath.IsAbs("/usr")
    println filepath.IsAbs("C:\\win")
    println filepath.IsAbs("rel/x")
    println filepath.Clean("a//b/./c/../d")
    println filepath.Clean("/a/../..")
    println filepath.Clean("../x")
    println filepath.Clean("./")
    println filepath.Normalize("a\\b\\c")
end
