import "filepath"

func main:
    __ filepath.Join("a", "b")
    __ filepath.Join("a/", "/b")
    __ filepath.Join("", "x")
    __ filepath.Base("/x/y/z.txt")
    __ filepath.Base("plain")
    __ filepath.Base("/")
    __ filepath.Dir("/x/y/z.txt")
    __ filepath.Dir("plain")
    __ filepath.Dir("/top")
    __ filepath.Ext("a/b.tar.gz")
    __ filepath.Ext("noext")
    __ filepath.Stem("a/b.tar.gz")
    __ filepath.IsAbs("/usr")
    __ filepath.IsAbs("C:\\win")
    __ filepath.IsAbs("rel/x")
    __ filepath.Clean("a//b/./c/../d")
    __ filepath.Clean("/a/../..")
    __ filepath.Clean("../x")
    __ filepath.Clean("./")
    __ filepath.Normalize("a\\b\\c")
end
