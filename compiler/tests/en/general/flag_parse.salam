import flag

func main:
    mut fs := flag.New("tool", "demo tool")
    flag.AddBool(fs, "verbose", "v", false, "enable verbose output")
    flag.AddStr(fs, "name", "n", "anon", "user name")
    flag.AddInt(fs, "count", "c", 1, "repeat count")
    flag.AddFloat(fs, "ratio", "", 0.5, "mix ratio")
    mut cargs := Vector {} as Vector<str>
    cargs.push("-v")
    cargs.push("--name=ali")
    cargs.push("-c")
    cargs.push("3")
    cargs.push("first")
    cargs.push("--")
    cargs.push("--not-a-flag")
    ok := flag.Parse(fs, cargs)
    println ok
    println flag.GetBool(fs, "verbose")
    println flag.GetStr(fs, "name")
    println flag.GetInt(fs, "count")
    println flag.GetFloat(fs, "ratio")
    println flag.WasSet(fs, "count")
    println flag.WasSet(fs, "ratio")
    rest := flag.Positional(fs)
    println rest.len()
    println rest.get(0)[0]
    println rest.get(1)[0]
    mut fs2 := flag.New("tool", "")
    mut cargs2 := Vector {} as Vector<str>
    cargs2.push("--bogus")
    ok2 := flag.Parse(fs2, cargs2)
    println ok2
    println flag.Error(fs2)
    mut fs3 := flag.New("tool", "")
    mut cargs3 := Vector {} as Vector<str>
    cargs3.push("-h")
    ok3 := flag.Parse(fs3, cargs3)
    println ok3
    println flag.HelpWanted(fs3)
    mut fs4 := flag.New("mytool", "does things")
    flag.AddStr(fs4, "out", "o", "a.txt", "output file")
    flag.AddBool(fs4, "quiet", "", false, "be quiet")
    print flag.Usage(fs4)
end
