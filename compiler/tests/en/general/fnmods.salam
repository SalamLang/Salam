extern:
    pure func fabs(x: f64): f64
end

pub const Ten := 10

mut factor := 2

noinline func triple(x: int): int: ret x * 3 end

noret func _spin forever():
    until true:
    end
end

pub noinline func Quad(x: int): int: ret x * 4 end

pub pure func AddP(a: int, b: int): int: ret a + b end

pub inline pure func SqP(x: f64): f64: ret x * x end

pub deprecated func OldApi(x: int): int: ret x + 1 end

pub pure func Scaled(x: int): int: ret x * factor + Ten end

pub pure func AbsF(x: f64): f64: ret fabs(x) end

pub inline func BumpFactor(x: int): int:
    factor = factor + 1
    ret x + factor
end

func main:
    println triple(2)
    println Quad(2)
    println AddP(1, 2)
    println SqP(3.0)
    println OldApi(9)
    println Scaled(3)
    println BumpFactor(1)
    println Scaled(3)
    println AbsF(0.0 - 2.5)
end
