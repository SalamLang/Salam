extern "C":
    pure func fabs(x f64) f64
end

pub const Ten = 10
mut factor i32 = 2

noinline func triple(x i32) i32: ret x * 3 end

pub noinline func Quad(x i32) i32: ret x * 4 end

pub pure func AddP(a i32, b i32) i32: ret a + b end

pub inline pure func SqP(x f64) f64: ret x * x end

pub deprecated func OldApi(x i32) i32: ret x + 1 end

noret func spin_forever():
    while true:
    end
end

pub pure func Scaled(x i32) i32: ret x * factor + Ten end

pub pure func AbsF(x f64) f64: ret fabs(x) end

pub inline func BumpFactor(x i32) i32:
    factor = factor + 1
    ret x + factor
end

func main:
    println(triple(2))
    println(Quad(2))
    println(AddP(1, 2))
    println(SqP(3.0))
    println(OldApi(9))
    println(Scaled(3))
    println(BumpFactor(1))
    println(Scaled(3))
    println(AbsF(0.0 - 2.5))
end
