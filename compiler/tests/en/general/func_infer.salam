func add(a, b):
    ret a + b
end

func twice(x):
    ret add(x, x)
end

func describe(n):
    if n > 100:
        ret "big"
    end
    ret "small"
end

pub func shout(msg):
    ret msg.concat("!")
end

func mixed(label: str, n): str:
    if n > 0:
        ret label.concat("+")
    end
    ret label.concat("-")
end

func main:
    println add(2, 3)
    println add(1.5, 2.25)
    println add("sa", "lam")
    println twice(21)
    println describe(200)
    println describe(7)
    println shout("hey")
    println mixed("q", 5)
    println mixed("q", 0 - 5)
end
