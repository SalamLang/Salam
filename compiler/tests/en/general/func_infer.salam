func add(a, b):
    ret a + b
end

func twice(x):
    ret add(x, x)
end

func describe(n):
    if n > 100:
        ret "big"
    end
    ret "small"
end

pub func shout(msg):
    ret msg.concat("!")
end

func mixed(label : str, n) : str:
    if n > 0:
        ret label.concat("+")
    end
    ret label.concat("-")
end

func main:
    __ add(2, 3)
    __ add(1.5, 2.25)
    __ add("sa", "lam")
    __ twice(21)
    __ describe(200)
    __ describe(7)
    __ shout("hey")
    __ mixed("q", 5)
    __ mixed("q", 0 - 5)
end
