struct Stack<T>:
    items T[8] = [0, 0, 0, 0, 0, 0, 0, 0]
    count i32 = 0
    func Push(x T):
        this.items[this.count] = x
        this.count = this.count + 1
    end
    func Pop() T:
        this.count = this.count - 1
        ret this.items[this.count]
    end
    func Size() i32:
        ret this.count
    end
end

func main:
    mut s Stack<i32> = Stack {}
    s.Push(10)
    s.Push(20)
    s.Push(30)
    __ s.Size()
    __ s.Pop()
    __ s.Pop()
    __ s.Size()
end
