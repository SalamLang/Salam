struct Stack<T>:
    pub items: T[8] = [0, 0, 0, 0, 0, 0, 0, 0]
    pub count: int = 0
    pub func Push(x: T):
        this.items[this.count] = x
        this.count = this.count + 1
    end
    pub func Pop(): T:
        this.count = this.count - 1
        ret this.items[this.count]
    end
    pub func Size(): int:
        ret this.count
    end
end

func main:
    mut s := Stack {} as Stack<int> s.Push(10)
    s.Push(20)
    s.Push(30)
    println s.Size()
    println s.Pop()
    println s.Pop()
    println s.Size()
end
