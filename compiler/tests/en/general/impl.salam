interface Describe:
    func label() str
    func score() i32
end

impl Describe for i32:
    func label() str: ret "number" end
    func score() i32: ret this * 10 end
end

impl Describe for bool:
    func label() str: ret "flag" end
    func score() i32:
        if this: ret 1 end
        ret 0
    end
end

func show<T: Describe> (x T):
    __ x.label()
    __ x.score()
end

func main:
    show(7)
    show(true)
    show(false)
end
