noinline pure func base(x i32) i32: ret x + 5 end

inline pure func twice_base(x i32) i32: ret base(x) * 2 end

pub inline pure func Halve(x f64) f64: ret x / 2.0 end

inline pure func chain(x i32) i32: ret twice_base(x) + 1 end

func main:
    println(base(5))
    println(twice_base(5))
    println(chain(5))
    println(Halve(9.0))
end
