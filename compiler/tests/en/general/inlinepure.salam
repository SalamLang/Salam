noinline pure func base(x : int) : int: ret x + 5 end

inline pure func twice base(x : int) : int: ret base(x) * 2 end

pub inline pure func Halve(x : f64) : f64: ret x / 2.0 end

inline pure func chain(x : int) : int: ret twice base(x) + 1 end

func main:
    println(base(5))
    println(twice base(5))
    println(chain(5))
    println(Halve(9.0))
end
