interface Shape:
    func area() i32
    func name() str
end
struct Sq:
    s i32 = 0
    func area() i32: ret this.s * this.s end
    func name() str: ret "sq" end
end
struct Rect:
    w i32 = 0
    h i32 = 0
    func area() i32: ret this.w * this.h end
    func name() str: ret "rect" end
end
interface Named:
    func name() str
end
func report<T: Shape, U: Named> (shape T, who U):
            __ who.name()
            __ shape.name()
            __ shape.area()
        end
        func describe<T: Shape> (x T):
                __ x.name()
                __ x.area()
            end
            func main:
                describe(Sq { s = 3 })
                describe(Rect { w = 2, h = 5 })
                report(Sq { s = 4 }, Rect { w = 1, h = 1 })
            end
