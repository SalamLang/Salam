interface Shape:
    func area(): int
    func name(): str
end

struct Sq:
    pub s: int = 0
    pub func area(): int: ret this.s * this.s end
    pub func name(): str: ret "sq" end
end

struct Rect:
    pub w: int = 0
    pub h: int = 0
    pub func area(): int: ret this.w * this.h end
    pub func name(): str: ret "rect" end
end
interface Named:
    func name(): str
end

func report<T: Shape, U: Named>(shape: T, who: U):
    println who.name()
    println shape.name()
    println shape.area()
end
func describe<T: Shape>(x: T):
    println x.name()
    println x.area()
end
func main:
    describe(Sq { s = 3 })
    describe(Rect { w = 2, h = 5 })
    report(Sq { s = 4 }, Rect { w = 1, h = 1 })
end
