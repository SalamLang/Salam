interface Animal:
    func name(): str
    func sound(): str
    func legs(): int
end

struct Dog:
    pub func name(): str: ret "dog" end
    pub func sound(): str: ret "woof" end
    pub func legs(): int: ret 4 end
end

struct Duck:
    pub func name(): str: ret "duck" end
    pub func sound(): str: ret "quack" end
    pub func legs(): int: ret 2 end
end

func introduce<T: Animal>(a: T):
    print a.name()
    print ":"
    println a.sound()
end
func main:
    introduce(Dog {})
    introduce(Duck {})
    farm := [
        Dog {}
        Duck {}
        Dog {}
    ] as dyn Animal[3]
    mut total := 0
    repeat 3 with i:
        total = total + farm[i].legs()
    end
    print "legs="
    println total
end
