interface Animal:
    func name() : str
    func sound() : str
    func legs() : int
end

struct Dog:
    func name() : str: ret "dog" end
    func sound() : str: ret "woof" end
    func legs() : int: ret 4 end
end

struct Duck:
    func name() : str: ret "duck" end
    func sound() : str: ret "quack" end
    func legs() : int: ret 2 end
end

func introduce<T: Animal> (a : T):
        _ a.name()
        _ ":"
        __ a.sound()
    end
    func main:
        introduce(Dog {})
        introduce(Duck {})
        farm : dyn Animal[3] = [
            Dog {}
            Duck {}
            Dog {}
        ]
        mut total : int = 0
        mut i : int = 0
        while i < 3:
            total = total + farm[i].legs()
            i = i + 1
        end
        _ "legs="
        __ total
    end
