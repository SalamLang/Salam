interface Command:
    func run(x : int) : int
end

struct Add:
    pub n : int = 0
    pub func run(x : int) : int: ret x + this.n end
end

struct Mul:
    pub n : int = 1
    pub func run(x : int) : int: ret x * this.n end
end

func main:
    steps := [
        Add { n = 3 }
        Mul { n = 4 }
        Add { n = 1 }
    ] as dyn Command[3]
    mut v := 2
    mut i := 0
    until i < 3:
        v = steps[i].run(v)
        i = i + 1
    end
    __ v
end
