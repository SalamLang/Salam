interface Command:
    func run(x: int): int
end

struct Add:
    pub n: int = 0
    pub func run(x: int): int: ret x + this.n end
end

struct Mul:
    pub n: int = 1
    pub func run(x: int): int: ret x * this.n end
end

func main:
    steps := [
        Add { n = 3 }
        Mul { n = 4 }
        Add { n = 1 }
    ] as dyn Command[3]
    mut v := 2
    repeat 3 with i:
        v = steps[i].run(v)
    end
    println v
end
