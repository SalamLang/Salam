interface Command:
    func run(x i32) i32
end

struct Add:
    n i32 = 0
    func run(x i32) i32: ret x + this.n end
end

struct Mul:
    n i32 = 1
    func run(x i32) i32: ret x * this.n end
end

func main:
    steps dyn Command[3] = [
        Add { n = 3 }
        Mul { n = 4 }
        Add { n = 1 }
    ]
    mut v i32 = 2
    mut i i32 = 0
    while i < 3:
        v = steps[i].run(v)
        i = i + 1
    end
    __ v
end
