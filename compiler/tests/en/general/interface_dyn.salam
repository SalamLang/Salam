interface Shape:
    func area() i32
    func name() str
end

struct Sq:
    s i32 = 0
    func area() i32: ret this.s * this.s end
    func name() str: ret "sq" end
end

struct Rect:
    w i32 = 0
    h i32 = 0
    func area() i32: ret this.w * this.h end
    func name() str: ret "rect" end
end

func describe(s dyn Shape):
    _ s.name()
    _ "="
    __ s.area()
end

func pick(flag bool) dyn Shape:
    if flag:
        ret Sq { s = 6 }
    end
    ret Rect { w = 2, h = 9 }
end

func main:
    a dyn Shape = Sq { s = 5 }
    describe(a)
    describe(pick(true))
    describe(pick(false))
    shapes dyn Shape[2] = [
        Sq { s = 3 }
        Rect { w = 4, h = 5 }
    ]
    describe(shapes[0])
    describe(shapes[1])
end
