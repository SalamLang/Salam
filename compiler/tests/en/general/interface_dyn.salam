interface Shape:
    func area() : int
    func name() : str
end

struct Sq:
    pub s : int = 0
    pub func area() : int: ret this.s * this.s end
    pub func name() : str: ret "sq" end
end

struct Rect:
    pub w : int = 0
    pub h : int = 0
    pub func area() : int: ret this.w * this.h end
    pub func name() : str: ret "rect" end
end

func describe(s : dyn Shape):
    _ s.name()
    _ "="
    __ s.area()
end

func pick(flag : bool) : dyn Shape:
    if flag:
        ret Sq { s = 6 }
    end
    ret Rect { w = 2, h = 9 }
end

func main:
    a := Sq { s = 5 } as dyn Shape
    describe(a)
    describe(pick(true))
    describe(pick(false))
    shapes := [
        Sq { s = 3 }
        Rect { w = 4, h = 5 }
    ] as dyn Shape[2]
    describe(shapes[0])
    describe(shapes[1])
end
