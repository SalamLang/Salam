interface Shape:
    func area() i32
    func name() str
end

struct Sq:
    s i32 = 0
    func area() i32: ret this.s * this.s end
    func name() str: ret "sq" end
end

struct Rect:
    w i32 = 0
    h i32 = 0
    func area() i32: ret this.w * this.h end
    func name() str: ret "rect" end
end

func main:
    shapes Vector<dyn Shape> = Vector {}
    defer shapes.free()
    shapes.push(Sq { s = 4 })
    shapes.push(Rect { w = 3, h = 6 })
    shapes.push(Sq { s = 2 })
    mut i i32 = 0
    mut total i32 = 0
    while i < shapes.len():
        _ shapes.get(i).name()
        _ "="
        __ shapes.get(i).area()
        total = total + shapes.get(i).area()
        shapes.get(i).free()
        i = i + 1
    end
    _ "total="
    __ total
end
