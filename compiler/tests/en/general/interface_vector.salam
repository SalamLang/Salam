interface Shape:
    func area() : int
    func name() : str
end

struct Sq:
    pub s : int = 0
    pub func area() : int: ret this.s * this.s end
    pub func name() : str: ret "sq" end
end

struct Rect:
    pub w : int = 0
    pub h : int = 0
    pub func area() : int: ret this.w * this.h end
    pub func name() : str: ret "rect" end
end

func main:
    shapes : Vector<dyn Shape> = Vector {}
    defer shapes.free()
    shapes.push(Sq { s = 4 })
    shapes.push(Rect { w = 3, h = 6 })
    shapes.push(Sq { s = 2 })
    mut i : int = 0
    mut total : int = 0
    while i < shapes.len():
        _ shapes.get(i).name()
        _ "="
        __ shapes.get(i).area()
        total = total + shapes.get(i).area()
        shapes.get(i).free()
        i = i + 1
    end
    _ "total="
    __ total
end
