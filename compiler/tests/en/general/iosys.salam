import "io" "os" "time"

func main:
    path := "_iosys_test.txt"
    os.Remove(path)
    io.WriteFile(path, "alpha\n")
    io.AppendFile(path, "beta\n")
    io.AppendFile(path, "gamma\n")
    lines := io.Lines(path)
    defer lines.free()
    println lines.len()
    println lines.get(0)[0]
    println lines.get(2)[0]
    println os.Exists(path)
    os.Remove(path)
    println os.Exists(path)
    println os.Cwd().len() > 0
    t0 := time.Now()
    time.Sleep(0)
    println time.Now() >= t0
end
