import json

func main:
    // --- encoding ---
    println json.Str("hi \"there\"")
    println json.Member("name", "salam")
    println json.MemberInt("age", 5)
    println json.MemberBool("ok", true)
    println json.MemberFloat("pi", 3.5)
    println json.MemberRaw("raw", "[1, 2, 3]")

    mut tags := Vector {} as Vector<str>
    tags.push(json.Str("a"))
    tags.push(json.Str("b"))
    tags_json := json.Array(tags)
    println tags_json

    mut point := Vector {} as Vector<str>
    point.push(json.MemberInt("x", 1))
    point.push(json.MemberInt("y", 2))
    point_json := json.Object(point)
    println point_json

    mut doc := Vector {} as Vector<str>
    doc.push(json.Member("name", "salam"))
    doc.push(json.MemberInt("version", 2))
    doc.push(json.MemberBool("active", true))
    doc.push(json.MemberRaw("tags", tags_json))
    doc.push(json.MemberRaw("point", point_json))
    doc.push(json.MemberRaw("empty_obj", json.Object(Vector {} as Vector<str>)))
    doc.push(json.MemberRaw("empty_arr", json.Array(Vector {} as Vector<str>)))
    doc_json := json.Object(doc)
    println doc_json

    // --- decoding ---
    println json.Valid(doc_json)
    println json.Valid("{ not valid")
    println json.Get(doc_json, "name")
    println json.GetInt(doc_json, "version")
    println json.Has(doc_json, "active")
    println json.Has(doc_json, "missing")

    // --- indent ---
    println json.Indent(doc_json)
    println json.IndentWith(doc_json, "    ")
    println json.Indent4(doc_json)
    println json.IndentTabs(doc_json)

    // --- minify normalizes away indentation ---
    println json.Minify(json.Indent(doc_json)) == json.Minify(doc_json)
end
