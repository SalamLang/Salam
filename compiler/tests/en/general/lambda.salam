struct Op:
    pub fn : func (int, int) int
    name : str
end

pub func apply(f : func (int) int, x : int) : int: ret f(x) end

func make_inc() : func (int) int: ret (n : int) => n + 100 end

func make_adder(n : int) : func (int) int: ret (x : int) => x + n end

func make_counter() : func () int:
    mut c = 0
    ret () =>: c = c + 1 ret c end
end

func main:
    inc : func (int) int = (n : int) => n + 1
    __ (inc(41))
    add : func (int, int) int = (a : int, b : int) =>: ret a + b end
    __ (add(20, 22))
    __ (apply((n : int) => n * 2, 21))
    o : Op = Op { fn = (x : int, y : int) => x * y, name = "mul" }
    __ (o.fn(6, 7))
    __ (o.name)
    __ (make_inc()(5))
    add10 : auto = make_adder(10)
    __ (add10(5))
    base : auto = 1000
    f : auto = (y : int) => y + base
    __ (f(7))
    g : auto = (a : int) =>:
        b : auto = 20
        h : auto = (cc : int) => a + b + cc
        ret h(3)
    end
    __ (g(100))
    cnt : auto = make_counter()
    __ (cnt())
    __ (cnt())
end
