struct Op:
    pub fn: func (int, int) int
    pub name: str
end

pub func apply(f: func (int) int, x: int): int: ret f(x) end

func make inc(): func (int) int: ret (n: int) => n + 100 end

func make adder(n: int): func (int) int: ret (x: int) => x + n end

func make counter(): func () int:
    mut c := 0
    ret (): c = c + 1 ret c end
end

func main:
    inc := (n: int) => n + 1
    println inc(41)
    add := (a: int, b: int): ret a + b end
    println add(20, 22)
    println apply((n: int) => n * 2, 21)
    o := Op { fn = (x: int, y: int) => x * y, name = "mul" }
    println o.fn(6, 7)
    println o.name
    println make inc()(5)
    add10 := make adder(10)
    println add10(5)
    base := 1000
    f := (y: int) => y + base
    println f(7)
    g := (a: int):
        b := 20
        h := (cc: int) => a + b + cc
        ret h(3)
    end
    println g(100)
    cnt := make counter()
    println cnt()
    println cnt()
end
