struct Op:
    fn func (i32, i32) i32
    name str
end

func apply(f func (i32) i32, x i32) i32: ret f(x) end

func make_inc() func (i32) i32: ret (n i32) => n + 100 end

func make_adder(n i32) func (i32) i32: ret (x i32) => x + n end

func make_counter() func () i32:
    mut c = 0
    ret () =>: c = c + 1 ret c end
end

func main:
    inc func (i32) i32 = (n i32) => n + 1
    __ (inc(41))
    add func (i32, i32) i32 = (a i32, b i32) =>: ret a + b end
    __ (add(20, 22))
    __ (apply((n i32) => n * 2, 21))
    o Op = Op { fn = (x i32, y i32) => x * y, name = "mul" }
    __ (o.fn(6, 7))
    __ (o.name)
    __ (make_inc()(5))
    add10 auto = make_adder(10)
    __ (add10(5))
    base auto = 1000
    f auto = (y i32) => y + base
    __ (f(7))
    g auto = (a i32) =>:
        b auto = 20
        h auto = (cc i32) => a + b + cc
        ret h(3)
    end
    __ (g(100))
    cnt auto = make_counter()
    __ (cnt())
    __ (cnt())
end
