import log

func main:
    log.ShowTime(false)
    log.ToStdout()
    log.SetLevel(0)
    log.Debug("dbg")
    log.Info("hello")
    log.SetPrefix("app")
    log.Warn("careful")
    log.SetLevel(2)
    log.Info("hidden")
    log.Error("boom")
    log.SetPrefix("")
    log.SetLevel(1)
    mut fargs := Vector {} as Vector<str> fargs.push("42")
    log.Infof("x={}", fargs)
    mut fields := Vector {} as Vector<str> fields.push(log.Field("user", "ali"))
    fields.push(log.FieldInt("n", 7))
    fields.push(log.FieldBool("ok", true))
    log.Info(log.KV("event", fields))
    println log.Field("k", "a b")
    println log.ParseLevel("warn")
    println log.LevelName(3)
    println log.GetLevel()
end
