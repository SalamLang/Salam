import (
    "log"
)

func main:
    log.ShowTime(false)
    log.ToStdout()
    log.SetLevel(0)
    log.Debug("dbg")
    log.Info("hello")
    log.SetPrefix("app")
    log.Warn("careful")
    log.SetLevel(2)
    log.Info("hidden")
    log.Error("boom")
    log.SetPrefix("")
    log.SetLevel(1)
    mut fargs Vector<str> = Vector {}
    fargs.push("42")
    log.Infof("x={}", fargs)
    mut fields Vector<str> = Vector {}
    fields.push(log.Field("user", "ali"))
    fields.push(log.FieldInt("n", 7))
    fields.push(log.FieldBool("ok", true))
    log.Info(log.KV("event", fields))
    __ log.Field("k", "a b")
    __ log.ParseLevel("warn")
    __ log.LevelName(3)
    __ log.GetLevel()
end
