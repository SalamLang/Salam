import "mem"

func main:
    mut p i32* = mem.Allocate(40 as u64) as i32*
    mut i = 0
    while i < 10:
        p[i] = i * i
        i = i + 1
    end
    mut sum = 0
    i = 0
    while i < 10:
        sum = sum + p[i]
        i = i + 1
    end
    __ sum
    p = mem.Reallocate(p as void*, 80 as u64) as i32*
    p[10] = 100
    __ p[10]
    mem.Free(p as void*)
end
