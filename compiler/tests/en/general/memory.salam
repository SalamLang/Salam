import "mem"

func main:
    mut p := mem.Allocate(40 as u64) as int*
    mut i := 0
    until i < 10:
        p[i] = i * i
        i = i + 1
    end
    mut sum := 0
    i = 0
    until i < 10:
        sum = sum + p[i]
        i = i + 1
    end
    println sum
    p = mem.Reallocate(p as void*, 80 as u64) as int*
    p[10] = 100
    println p[10]
    mem.Free(p as void*)
end
