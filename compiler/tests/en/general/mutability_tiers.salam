struct Point:
    pub x : int
    pub y : int
end

func main:
    y1 : int[3] = [1, 2, 3]
    y1[0] = 10
    y1[1]++
    println(y1[0])
    println(y1[1])

    p : Point = Point { x = 1, y = 2 }
    p.x = 99
    println(p.x)

    mut n : int = 5
    n = 6
    println(n)

    const c : int[3] = [7, 8, 9]
    println(c[2])
end
