import net
import sync

mut nloop wg := sync.NewWaitGroup()
func net server():
    srv := net.Listen(19201)
    sync.Done(nloop wg)
    if !net.Ok(srv):
        ret
    end
    c := net.Accept(srv)
    if net.Ok(c):
        data := net.Recv(c, 1024)
        net.Send(c, "got:" + data)
        net.Close(c)
    end
    net.Close(srv)
end

func main:
    sync.Add(nloop wg, 1 as i64)
    t := spawn(net server)
    sync.Wait(nloop wg)
    c := net.Connect("127.0.0.1", 19201)
    println net.Ok(c)
    net.Send(c, "world")
    resp := net.Recv(c, 1024)
    println resp
    net.Close(c)
    join(t)
end
