import (
    "net" "sync"
)

mut nloop_wg := sync.NewWaitGroup()
func net_server():
    srv := net.Listen(19201)
    sync.Done(nloop_wg)
    if !net.Ok(srv):
        ret
    end
    c := net.Accept(srv)
    if net.Ok(c):
        data := net.Recv(c, 1024)
        net.Send(c, "got:" + data)
        net.Close(c)
    end
    net.Close(srv)
end

func main:
    sync.Add(nloop_wg, 1 as i64)
    t := spawn(net_server)
    sync.Wait(nloop_wg)
    c := net.Connect("127.0.0.1", 19201)
    __ net.Ok(c)
    net.Send(c, "world")
    resp := net.Recv(c, 1024)
    __ resp
    net.Close(c)
    join(t)
end
