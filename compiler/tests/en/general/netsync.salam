import "net" "sync" "str"

func main:
    s := net.Connect("127.0.0.1", 1)
    println net.Ok(s)
    srv := net.Listen(0)
    println net.Ok(srv)
    net.Close(srv)
    m := sync.NewMutex()
    println sync.Lock(m)
    println sync.Unlock(m)
    sync.Destroy(m)
    println str.FromInt(42 as i64)
    println str.FromFloat(3.5)
end
