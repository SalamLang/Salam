import (
    "net" "sync" "str"
)

func main:
    s := net.Connect("127.0.0.1", 1)
    __ net.Ok(s)
    srv := net.Listen(0)
    __ net.Ok(srv)
    net.Close(srv)
    m := sync.NewMutex()
    __ sync.Lock(m)
    __ sync.Unlock(m)
    sync.Destroy(m)
    __ str.FromInt(42 as i64)
    __ str.FromFloat(3.5)
end
