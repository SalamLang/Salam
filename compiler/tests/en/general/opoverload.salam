struct Vector2:
    pub x : int = 0
    pub y : int = 0
    pub func operator + (other : Vector2) : Vector2:
        ret Vector2 { x = this.x + other.x, y = this.y + other.y }
    end
    pub func operator -(other : Vector2) : Vector2:
        ret Vector2 { x = this.x - other.x, y = this.y - other.y }
    end
    pub func operator -() : Vector2:
        ret Vector2 { x = -this.x, y = -this.y }
    end
    pub func operator == (other : Vector2) : bool:
        ret this.x == other.x && this.y == other.y
    end
end

struct Bag:
    pub data : int[4] = [0, 0, 0, 0]
    pub func operator [](i : int) : int:
        ret this.data[i]
    end
    pub func operator [] = (i : int, v : int):
        this.data[i] = v
    end
end

func main:
    a := Vector2 { x = 3, y = 4 }
    b := Vector2 { x = 1, y = 2 }
    c := a + b
    __ c.x
    __ c.y
    d := a - b
    __ d.x
    __ d.y
    e := -a
    __ e.x
    __ e.y
    a2 := Vector2 { x = 3, y = 4 }
    __ a == a2
    __ a == b
    __ a != b
    mut f := Vector2 { x = 1, y = 1 }
    f += b
    __ f.x
    __ f.y
    mut bag := Bag {}
    bag[0] = 10
    bag[1] = 20
    bag[2] = 30
    __ bag[0]
    __ bag[1]
    __ bag[2]
end
