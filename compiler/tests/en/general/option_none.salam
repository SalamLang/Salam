import "option"

func main:
    s := option.Some(7)
    n := option.None() as option.Option<int>
    println option.Unwrap(s), option.UnwrapOr(n, 42)
    println option.IsSome(n), option.IsNone(n)
    println option.Expect(s, "present")
    m := option.None() as option.Option<str>
    println option.UnwrapOr(m, "default")
end
