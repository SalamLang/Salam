import "option"

func main:
    s : option.Option<int> = option.Some(7)
    n : option.Option<int> = option.None()
    __ option.Unwrap(s), option.UnwrapOr(n, 42)
    __ option.IsSome(n), option.IsNone(n)
    __ option.Expect(s, "present")
    m : option.Option<str> = option.None()
    __ option.UnwrapOr(m, "default")
end
