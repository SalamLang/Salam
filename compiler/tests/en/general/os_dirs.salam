import (
    "os" "filepath" "io"
)

func main:
    base str = filepath.Join(os.TempDir(), "salam_dirtest")
    os.RemoveAll(base)
    __ os.MkdirAll(filepath.Join(base, "a/b/c"))
    __ os.IsDir(filepath.Join(base, "a/b/c"))
    io.WriteFile(filepath.Join(base, "a/f1.txt"), "one")
    io.WriteFile(filepath.Join(base, "a/b/f2.txt"), "two")
    __ os.CopyTree(filepath.Join(base, "a"), filepath.Join(base, "copy"))
    __ io.ReadFile(filepath.Join(base, "copy/f1.txt"))
    __ io.ReadFile(filepath.Join(base, "copy/b/f2.txt"))
    dirs Vector<str> = os.ListDirs(base)
    __ dirs.len()
    __ os.RemoveAll(base)
    __ os.Exists(base)
end
