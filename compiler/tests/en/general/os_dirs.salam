import "os" "filepath" "io"

func main:
    base := filepath.Join(os.TempDir(), "salam_dirtest")
    os.RemoveAll(base)
    println os.MkdirAll(filepath.Join(base, "a/b/c"))
    println os.IsDir(filepath.Join(base, "a/b/c"))
    io.WriteFile(filepath.Join(base, "a/f1.txt"), "one")
    io.WriteFile(filepath.Join(base, "a/b/f2.txt"), "two")
    println os.CopyTree(filepath.Join(base, "a"), filepath.Join(base, "copy"))
    println io.ReadFile(filepath.Join(base, "copy/f1.txt"))
    println io.ReadFile(filepath.Join(base, "copy/b/f2.txt"))
    dirs := os.ListDirs(base)
    println dirs.len()
    println os.RemoveAll(base)
    println os.Exists(base)
end
