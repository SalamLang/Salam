import math
import str

func main:
    println math.Sqrt(81.0)
    println math.MaxI(7, 3)
    println str.Compare("a", "a")
    parts := str.Split("x-y-z", "-")
    defer parts.free()
    mut joined := ""
    repeat parts.len() with ji:
        if ji > 0: joined = joined.concat("+") end
        joined = joined.concat(parts.get(ji)[0])
    end
    println joined
    mut v := Vector {} as Vector<int> defer v.free()
    v.push(2)
    v.push(4)
    v.push(6)
    mut sum := 0
    repeat v.len() with si:
        sum = sum + v.get(si)[0]
    end
    println sum
end
