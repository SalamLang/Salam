import math
import str
import collections

func main:
    println math.Sqrt(81.0)
    println math.MaxI(7, 3)
    println str.Compare("a", "a")
    parts := str.Split("x-y-z", "-")
    defer parts.free()
    mut joined := ""
    mut ji := 0
    until ji < parts.len():
        if ji > 0: joined = joined.concat("+") end
        joined = joined.concat(parts.get(ji)[0])
        ji = ji + 1
    end
    println joined
    mut v := Vector {} as Vector<int>
    defer v.free()
    v.push(2)
    v.push(4)
    v.push(6)
    mut sum := 0
    mut si := 0
    until si < v.len():
        sum = sum + v.get(si)[0]
        si = si + 1
    end
    println sum
end
