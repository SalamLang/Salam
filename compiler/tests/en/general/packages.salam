import (
    "math" strutil "str" "collections"
)

func main:
    __ math.Sqrt(81.0)
    __ math.MaxI(7, 3)
    __ strutil.Compare("a", "a")
    parts : Vector<str> = strutil.Split("x-y-z", "-")
    defer parts.free()
    mut joined : str = ""
    mut ji : int = 0
    while ji < parts.len():
        if ji > 0: joined = joined.concat("+") end
        joined = joined.concat(parts.get(ji)[0])
        ji = ji + 1
    end
    __ joined
    mut v : Vector<int> = Vector {}
    defer v.free()
    v.push(2)
    v.push(4)
    v.push(6)
    mut sum : int = 0
    mut si : int = 0
    while si < v.len():
        sum = sum + v.get(si)[0]
        si = si + 1
    end
    __ sum
end
