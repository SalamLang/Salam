import "path"

func main:
    __ path.Join("a", "b")
    __ path.Join("a/", "/b")
    __ path.Join("", "x")
    __ path.Base("/x/y/z.txt")
    __ path.Base("plain")
    __ path.Base("/")
    __ path.Dir("/x/y/z.txt")
    __ path.Dir("plain")
    __ path.Dir("/top")
    __ path.Ext("a/b.tar.gz")
    __ path.Ext("noext")
    __ path.Stem("a/b.tar.gz")
    __ path.IsAbs("/usr")
    __ path.IsAbs("C:\\win")
    __ path.IsAbs("rel/x")
    __ path.Clean("a//b/./c/../d")
    __ path.Clean("/a/../..")
    __ path.Clean("../x")
    __ path.Clean("./")
    __ path.Normalize("a\\b\\c")
end
