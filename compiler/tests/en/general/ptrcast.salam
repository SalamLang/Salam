import "mem"

struct Node:
    pub a : int = 0
    pub b : i64 = 0
    pub tag : str = ""
end

func main:
    p : void* = mem.Allocate(64 as u64)
    mut n : Node* = p as Node*
    n[0] = Node { a = 3, b = 99, tag = "hi" }
    n.a = n.a + 4
    h : i64 = p as i64
    p2 : void* = h as void*
    n2 : Node* = p2 as Node*
    println (n2.a, n2.b, n2.tag)
    n3 : Node* = h as Node*
    println (n3.a == 7, n3.tag == "hi")
    mem.Free(p)
end
