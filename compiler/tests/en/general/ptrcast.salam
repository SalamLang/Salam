extern "C":
    func salam_alloc(size u64) void*
    func salam_free(ptr void*)
end
struct Node:
    a i32 = 0
    b i64 = 0
    tag str = ""
end

func main:
    p void* = salam_alloc(64 as u64)
    mut n Node* = p as Node*
    n[0] = Node { a = 3, b = 99, tag = "hi" }
    n.a = n.a + 4
    h i64 = p as i64
    p2 void* = h as void*
    n2 Node* = p2 as Node*
    println (n2.a, n2.b, n2.tag)
    n3 Node* = h as Node*
    println (n3.a == 7, n3.tag == "hi")
    salam_free(p)
end
