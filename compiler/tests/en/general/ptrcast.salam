import "mem"

struct Node:
    pub a : int = 0
    pub b : i64 = 0
    pub tag : str = ""
end

func main:
    p := mem.Allocate(64 as u64)
    mut n := p as Node*
    n[0] = Node { a = 3, b = 99, tag = "hi" }
    n.a = n.a + 4
    h := p as i64
    p2 := h as void*
    n2 := p2 as Node*
    println (n2.a, n2.b, n2.tag)
    n3 := h as Node*
    println (n3.a == 7, n3.tag == "hi")
    mem.Free(p)
end
