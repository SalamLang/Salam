pure func add(a: int, b: int): int: ret a + b end

pure func addmul(a: int, b: int): int: ret add(a, b) * 2 end

pure func fib(n: int): int:
    if n < 2: ret n end
    ret fib(n - 1) + fib(n - 2)
end

pure func biggest<T>(a: T, b: T): T:
    if a > b: ret a end
    ret b
end

func main:
    println add(2, 3)
    println addmul(2, 3)
    println fib(10)
    println biggest(4, 9)
    println biggest(1.5, 0.5)
end
