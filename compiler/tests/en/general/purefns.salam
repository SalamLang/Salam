pure func add(a i32, b i32) i32: ret a + b end

pure func addmul(a i32, b i32) i32: ret add(a, b) * 2 end

pure func fib(n i32) i32:
    if n < 2: ret n end
    ret fib(n - 1) + fib(n - 2)
end

pure func biggest<T>(a T, b T) T:
    if a > b: ret a end
    ret b
end

func main:
    println(add(2, 3))
    println(addmul(2, 3))
    println(fib(10))
    println(biggest(4, 9))
    println(biggest(1.5, 0.5))
end
