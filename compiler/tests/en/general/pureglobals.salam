import math

pub const Bias := 100
mut shift := 5

pure func hyp(a : f64, b : f64) : f64:
    ret math.Sqrt(a * a + b * b)
end

pure func fact(n : int) : i64:
    if n <= 1:
        ret 1
    end
    ret (n as i64) * fact(n - 1)
end

pure func biggest<T>(a : T, b : T) : T:
    if a > b:
        ret a
    end
    ret b
end

pure func shifted(x : int) : int:
    ret x + shift + Bias
end

deprecated func legacy(x : int) : int: ret x - 1 end

noret func _forever():
    until true:
    end
end

func main:
    println(hyp(3.0, 4.0))
    println(fact(6))
    println(biggest(4, 9))
    println(biggest(2.5, 1.5))
    println(shifted(7))
    shift = 6
    println(shifted(7))
    println(legacy(10))
end
