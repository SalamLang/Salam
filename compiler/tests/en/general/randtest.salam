import "rand"
func main:
    rand.Seed(7)
    seq_a : i64 = rand.Int()
    seq_b : i64 = rand.Int()
    rand.Seed(7)
    seq_c : i64 = rand.Int()
    seq_d : i64 = rand.Int()
    __ seq_a == seq_c
    __ seq_b == seq_d
    rand.Seed(1)
    diff_x : i64 = rand.Int()
    rand.Seed(2)
    diff_y : i64 = rand.Int()
    __ diff_x != diff_y
    rand.SeedAuto()
    after_auto : i64 = rand.Int()
    __ after_auto >= 0
    rand.Seed(42)
    i1 : i64 = rand.Int()
    i2 : i64 = rand.Int()
    __ i1 >= 0
    __ i2 >= 0
    __ i1 != i2
    i32a : int = rand.Int32()
    i32b : int = rand.Int32()
    __ i32a >= 0
    __ i32b >= 0
    __ i32a != i32b
    n1 : i64 = rand.IntN(100)
    __ n1 >= 0
    __ n1 < 100
    n2 : i64 = rand.IntN(1)
    __ n2 == 0
    r1 : i64 = rand.IntRange(10, 20)
    __ r1 >= 10
    __ r1 <= 20
    r2 : i64 = rand.IntRange(0, 0)
    __ r2 == 0
    r3 : int = rand.Int32Range(1, 6)
    __ r3 >= 1
    __ r3 <= 6
    r4 : int = rand.Int32Range(5, 5)
    __ r4 == 5
    w1 : i64 = rand.IntWithLength(1)
    __ w1 >= 0
    __ w1 <= 9
    w5 : i64 = rand.IntWithLength(5)
    __ w5 >= 10000
    __ w5 <= 99999
    w3 : i64 = rand.IntWithLength(3)
    __ w3 >= 100
    __ w3 <= 999
    f1 : f64 = rand.Float()
    f2 : f64 = rand.Float()
    __ f1 >= 0.0
    __ f1 < 1.0
    __ f2 >= 0.0
    __ f2 < 1.0
    fr1 : f64 = rand.FloatRange(5.0, 10.0)
    __ fr1 >= 5.0
    __ fr1 < 10.0
    fr2 : f64 = rand.FloatRange(0.0 - 1.0, 0.0)
    __ fr2 >= 0.0 - 1.0
    __ fr2 < 0.0
    b1 : bool = rand.Bool()
    b2 : bool = rand.Bool()
    __ b1 == true || b1 == false
    __ b2 == true || b2 == false
    __ rand.BoolP(0.0) == false
    __ rand.BoolP(1.0) == true
    __ rand.BoolP(0.0) == false
    __ rand.BoolP(1.0) == true
    __ rand.Bytes(8).len() == 8
    __ rand.Bytes(1).len() == 1
    __ rand.Bytes(32).len() == 32
    __ rand.TextFrom(5, "abc").len() == 5
    __ rand.TextFrom(4, "X") == "XXXX"
    __ rand.TextFrom(1, "Z") == "Z"
    __ rand.Alpha(8).len() == 8
    __ rand.Alpha(1).len() == 1
    __ rand.Alpha(20).len() == 20
    __ rand.AlphaUpper(6).len() == 6
    __ rand.AlphaUpper(10).len() == 10
    __ rand.AlphaMixed(5).len() == 5
    __ rand.AlphaMixed(15).len() == 15
    __ rand.Digit(4).len() == 4
    __ rand.Digit(6).len() == 6
    d1 : str = rand.Digit(1)
    __ d1 >= "0"
    __ d1 <= "9"
    __ rand.Alnum(12).len() == 12
    __ rand.Alnum(3).len() == 3
    __ rand.Text(16).len() == 16
    __ rand.Text(1).len() == 1
    __ rand.Text(100).len() == 100
    __ rand.HexBytes(8).len() == 16
    __ rand.HexBytes(4).len() == 8
    __ rand.HexBytes(1).len() == 2
    h1 : str = rand.Hash()
    h2 : str = rand.Hash()
    __ h1.len() == 32
    __ h2.len() == 32
    __ h1 != h2
    h160a : str = rand.Hash160()
    h160b : str = rand.Hash160()
    __ h160a.len() == 40
    __ h160b.len() == 40
    __ h160a != h160b
    h256a : str = rand.Hash256()
    h256b : str = rand.Hash256()
    __ h256a.len() == 64
    __ h256b.len() == 64
    __ h256a != h256b
    u1 : str = rand.UUID()
    __ u1.len() == 36
    __ u1.substr(8, 1) == "-"
    __ u1.substr(13, 1) == "-"
    __ u1.substr(18, 1) == "-"
    __ u1.substr(23, 1) == "-"
    __ u1.substr(14, 1) == "4"
    ychar : str = u1.substr(19, 1)
    __ ychar == "8" || ychar == "9" || ychar == "a" || ychar == "b"
    u2 : str = rand.UUID()
    __ u2.len() == 36
    __ u1 != u2
    mut opts : Vector<str> = Vector {}
    defer opts.free()
    opts.push("red")
    opts.push("green")
    opts.push("blue")
    pick : str = rand.ChoiceStr(opts)
    __ pick == "red" || pick == "green" || pick == "blue"
    mut one_s : Vector<str> = Vector {}
    defer one_s.free()
    one_s.push("only")
    __ rand.ChoiceStr(one_s) == "only"
    __ rand.ChoiceStr(one_s) == "only"
    mut nums : Vector<int> = Vector {}
    defer nums.free()
    nums.push(10)
    nums.push(20)
    nums.push(30)
    pn : int = rand.ChoiceInt(nums)
    __ pn == 10 || pn == 20 || pn == 30
    mut one_i : Vector<int> = Vector {}
    defer one_i.free()
    one_i.push(99)
    __ rand.ChoiceInt(one_i) == 99
    __ rand.ChoiceInt(one_i) == 99
    cc : str = rand.ChoiceChar("Salam")
    __ cc.len() == 1
    __ rand.ChoiceChar("Q") == "Q"
    __ rand.ChoiceChar("Q") == "Q"
    mut sv : Vector<str> = Vector {}
    defer sv.free()
    sv.push("a")
    sv.push("b")
    sv.push("c")
    sv.push("d")
    shuffled_s : Vector<str> = rand.ShuffleStr(sv)
    defer shuffled_s.free()
    __ shuffled_s.len() == 4
    mut single_s : Vector<str> = Vector {}
    defer single_s.free()
    single_s.push("solo")
    sh1 : Vector<str> = rand.ShuffleStr(single_s)
    defer sh1.free()
    __ sh1.len() == 1
    __ sh1.get(0)[0] == "solo"
    mut iv : Vector<int> = Vector {}
    defer iv.free()
    iv.push(1)
    iv.push(2)
    iv.push(3)
    iv.push(4)
    shuffled_i : Vector<int> = rand.ShuffleInt(iv)
    defer shuffled_i.free()
    __ shuffled_i.len() == 4
    s : int = shuffled_i.get(0)[0] + shuffled_i.get(1)[0] + shuffled_i.get(2)[0] + shuffled_i.get(3)[0]
    __ s == 10
    mut single_i : Vector<int> = Vector {}
    defer single_i.free()
    single_i.push(77)
    sh2 : Vector<int> = rand.ShuffleInt(single_i)
    defer sh2.free()
    __ sh2.len() == 1
    __ sh2.get(0)[0] == 77
end
