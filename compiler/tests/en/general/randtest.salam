import "rand"
func main:
    rand.Seed(7)
    seq_a := rand.Int()
    seq_b := rand.Int()
    rand.Seed(7)
    seq_c := rand.Int()
    seq_d := rand.Int()
    println seq_a == seq_c
    println seq_b == seq_d
    rand.Seed(1)
    diff_x := rand.Int()
    rand.Seed(2)
    diff_y := rand.Int()
    println diff_x != diff_y
    rand.SeedAuto()
    after_auto := rand.Int()
    println after_auto >= 0
    rand.Seed(42)
    i1 := rand.Int()
    i2 := rand.Int()
    println i1 >= 0
    println i2 >= 0
    println i1 != i2
    i32a := rand.Int32()
    i32b := rand.Int32()
    println i32a >= 0
    println i32b >= 0
    println i32a != i32b
    n1 := rand.IntN(100)
    println n1 >= 0
    println n1 < 100
    n2 := rand.IntN(1)
    println n2 == 0
    r1 := rand.IntRange(10, 20)
    println r1 >= 10
    println r1 <= 20
    r2 := rand.IntRange(0, 0)
    println r2 == 0
    r3 := rand.Int32Range(1, 6)
    println r3 >= 1
    println r3 <= 6
    r4 := rand.Int32Range(5, 5)
    println r4 == 5
    w1 := rand.IntWithLength(1)
    println w1 >= 0
    println w1 <= 9
    w5 := rand.IntWithLength(5)
    println w5 >= 10000
    println w5 <= 99999
    w3 := rand.IntWithLength(3)
    println w3 >= 100
    println w3 <= 999
    f1 := rand.Float()
    f2 := rand.Float()
    println f1 >= 0.0
    println f1 < 1.0
    println f2 >= 0.0
    println f2 < 1.0
    fr1 := rand.FloatRange(5.0, 10.0)
    println fr1 >= 5.0
    println fr1 < 10.0
    fr2 := rand.FloatRange(0.0 - 1.0, 0.0)
    println fr2 >= 0.0 - 1.0
    println fr2 < 0.0
    b1 := rand.Bool()
    b2 := rand.Bool()
    println b1 == true || b1 == false
    println b2 == true || b2 == false
    println rand.BoolP(0.0) == false
    println rand.BoolP(1.0) == true
    println rand.BoolP(0.0) == false
    println rand.BoolP(1.0) == true
    println rand.Bytes(8).len() == 8
    println rand.Bytes(1).len() == 1
    println rand.Bytes(32).len() == 32
    println rand.TextFrom(5, "abc").len() == 5
    println rand.TextFrom(4, "X") == "XXXX"
    println rand.TextFrom(1, "Z") == "Z"
    println rand.Alpha(8).len() == 8
    println rand.Alpha(1).len() == 1
    println rand.Alpha(20).len() == 20
    println rand.AlphaUpper(6).len() == 6
    println rand.AlphaUpper(10).len() == 10
    println rand.AlphaMixed(5).len() == 5
    println rand.AlphaMixed(15).len() == 15
    println rand.Digit(4).len() == 4
    println rand.Digit(6).len() == 6
    d1 := rand.Digit(1)
    println d1 >= "0"
    println d1 <= "9"
    println rand.Alnum(12).len() == 12
    println rand.Alnum(3).len() == 3
    println rand.Text(16).len() == 16
    println rand.Text(1).len() == 1
    println rand.Text(100).len() == 100
    println rand.HexBytes(8).len() == 16
    println rand.HexBytes(4).len() == 8
    println rand.HexBytes(1).len() == 2
    h1 := rand.Hash()
    h2 := rand.Hash()
    println h1.len() == 32
    println h2.len() == 32
    println h1 != h2
    h160a := rand.Hash160()
    h160b := rand.Hash160()
    println h160a.len() == 40
    println h160b.len() == 40
    println h160a != h160b
    h256a := rand.Hash256()
    h256b := rand.Hash256()
    println h256a.len() == 64
    println h256b.len() == 64
    println h256a != h256b
    u1 := rand.UUID()
    println u1.len() == 36
    println u1.substr(8, 1) == "-"
    println u1.substr(13, 1) == "-"
    println u1.substr(18, 1) == "-"
    println u1.substr(23, 1) == "-"
    println u1.substr(14, 1) == "4"
    ychar := u1.substr(19, 1)
    println ychar == "8" || ychar == "9" || ychar == "a" || ychar == "b"
    u2 := rand.UUID()
    println u2.len() == 36
    println u1 != u2
    mut opts := Vector {} as Vector<str>
    defer opts.free()
    opts.push("red")
    opts.push("green")
    opts.push("blue")
    pick := rand.ChoiceStr(opts)
    println pick == "red" || pick == "green" || pick == "blue"
    mut one_s := Vector {} as Vector<str>
    defer one_s.free()
    one_s.push("only")
    println rand.ChoiceStr(one_s) == "only"
    println rand.ChoiceStr(one_s) == "only"
    mut nums := Vector {} as Vector<int>
    defer nums.free()
    nums.push(10)
    nums.push(20)
    nums.push(30)
    pn := rand.ChoiceInt(nums)
    println pn == 10 || pn == 20 || pn == 30
    mut one_i := Vector {} as Vector<int>
    defer one_i.free()
    one_i.push(99)
    println rand.ChoiceInt(one_i) == 99
    println rand.ChoiceInt(one_i) == 99
    cc := rand.ChoiceChar("Salam")
    println cc.len() == 1
    println rand.ChoiceChar("Q") == "Q"
    println rand.ChoiceChar("Q") == "Q"
    mut sv := Vector {} as Vector<str>
    defer sv.free()
    sv.push("a")
    sv.push("b")
    sv.push("c")
    sv.push("d")
    shuffled_s := rand.ShuffleStr(sv)
    defer shuffled_s.free()
    println shuffled_s.len() == 4
    mut single_s := Vector {} as Vector<str>
    defer single_s.free()
    single_s.push("solo")
    sh1 := rand.ShuffleStr(single_s)
    defer sh1.free()
    println sh1.len() == 1
    println sh1.get(0)[0] == "solo"
    mut iv := Vector {} as Vector<int>
    defer iv.free()
    iv.push(1)
    iv.push(2)
    iv.push(3)
    iv.push(4)
    shuffled_i := rand.ShuffleInt(iv)
    defer shuffled_i.free()
    println shuffled_i.len() == 4
    s := shuffled_i.get(0)[0] + shuffled_i.get(1)[0] + shuffled_i.get(2)[0] + shuffled_i.get(3)[0]
    println s == 10
    mut single_i := Vector {} as Vector<int>
    defer single_i.free()
    single_i.push(77)
    sh2 := rand.ShuffleInt(single_i)
    defer sh2.free()
    println sh2.len() == 1
    println sh2.get(0)[0] == 77
end
