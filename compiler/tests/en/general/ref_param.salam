func increment(x & : int):
    x = x + 1
end

func swap(a & : int, b & : int):
    tmp := a
    a = b
    b = tmp
end

func add_to(v & : i64, amount : i64):
    v = v + amount
end

func main:
    mut n := 10
    increment(n)
    println n
    mut x := 3
    mut y := 7
    swap(x, y)
    println x
    println y
    mut total := 100 as i64
    add_to(total, 42)
    println total
end
