func increment(x & : int):
    x = x + 1
end

func swap(a & : int, b & : int):
    tmp : int = a
    a = b
    b = tmp
end

func add_to(v & : i64, amount : i64):
    v = v + amount
end

func main:
    mut n : int = 10
    increment(n)
    __ (n)
    mut x : int = 3
    mut y : int = 7
    swap(x, y)
    __ (x)
    __ (y)
    mut total : i64 = 100
    add_to(total, 42)
    __ (total)
end
