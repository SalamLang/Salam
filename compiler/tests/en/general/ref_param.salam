func increment(x & i32):
    x = x + 1
end

func swap(a & i32, b & i32):
    tmp i32 = a
    a = b
    b = tmp
end

func add_to(v & i64, amount i64):
    v = v + amount
end

func main:
    mut n i32 = 10
    increment(n)
    __ (n)
    mut x i32 = 3
    mut y i32 = 7
    swap(x, y)
    __ (x)
    __ (y)
    mut total i64 = 100
    add_to(total, 42)
    __ (total)
end
