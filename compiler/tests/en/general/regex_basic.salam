import regex

func main:
    println regex.MatchStr("[0-9]+", "abc123")
    println regex.MatchStr("[0-9]+", "abcxyz")

    println regex.FindStr("wor", "hello world")
    println regex.FindStr("zzz", "hello world")

    re := regex.Compile("^[A-Za-z]+$")
    println regex.Match(re, "Hello")
    println regex.Match(re, "Hello123")

    println regex.MatchStr("^abc$", "abc")
    println regex.MatchStr("^abc$", "abcd")

    println regex.MatchStr("[^0-9]+", "###")
    println regex.MatchStr("^[^0-9]+$", "a1b")

    println regex.MatchStr("colou?r", "color")
    println regex.MatchStr("colou?r", "colour")
    println regex.MatchStr("colou?r", "colouur")

    println regex.MatchStr("go+gle", "gooogle")
    println regex.MatchStr("go+gle", "ggle")

    println regex.MatchStr("\\d\\d\\d", "room 404")
    println regex.MatchStr("\\s", "a b")
    println regex.MatchStr("\\w+", "_hi9")

    println regex.MatchStr("a.c", "abc")
    println regex.MatchStr("a.c", "ac")

    println regex.MatchStr("a\\.b", "a.b")
    println regex.MatchStr("a\\.b", "axb")

    println regex.ReplaceStr("[0-9]+", "item1 item2 item3", "#")
    println regex.ReplaceAllStr("[0-9]+", "item1 item2 item3", "#")

    re2 := regex.Compile("o")
    println regex.Replace(re2, "foo", "0")
    println regex.ReplaceAll(re2, "foo", "0")

    println regex.ReplaceStr("zzz", "hello", "Q")
end
