import regex

func extractTitle(html: str): str:
    if !regex.MatchStr("<title>.*</title>", html):
        ret ""
    end
    step1 := regex.ReplaceStr(".*<title>", html, "")
    ret regex.ReplaceStr("</title>.*", step1, "")
end

func printHrefs(html: str):
    mut rest := html
    mut going := true
    until going:
        idx := regex.FindStr("href=\"", rest)
        if idx < 0:
            going = false
        else:
            afterAttr := idx + 6
            tail := rest.substr(afterAttr, rest.len() - afterAttr)
            endq := regex.FindStr("\"", tail)
            if endq < 0:
                going = false
            else:
                println tail.substr(0, endq)
                adv := afterAttr + endq + 1
                rest = rest.substr(adv, rest.len() - adv)
            end
        end
    end
end

func main:
    page := "<html><head><title>Salam Lang Docs</title></head><body>hi</body></html>"
    println extractTitle(page)

    noTitle := "<html><body>no title here</body></html>"
    println extractTitle(noTitle)

    links := "<a href=\"https://salamlang.org\">Home</a><a href=\"https://salamlang.org/docs\">Docs</a><a href=\"/about\">About</a>"
    printHrefs(links)

    email := "contact: ada@example.com or grace@example.org"
    println regex.MatchStr("\\w+@\\w+\\.\\w+", email)
    firstAt := regex.FindStr("@", email)
    println firstAt > 0

    digitsOnly := regex.ReplaceAllStr("[0-9]", "room 42, floor 7", "")
    println digitsOnly

    csv := "name,age,city"
    println regex.ReplaceAllStr(",", csv, " | ")
end
