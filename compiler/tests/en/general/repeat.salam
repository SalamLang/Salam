func main:
    repeat 3:
        println "a"
    end
    n := 2
    repeat n + 1:
        print "b"
    end
    println ""
    m := 0 - 1
    repeat m:
        println "skip"
    end
    repeat 2:
        repeat 2:
            print "*"
        end
    end
    println ""
    repeat 5:
        print "once"
        break
    end
    println ""
end
