func main:
    repeat 3:
        println "a"
    end
    n : int = 2
    repeat n + 1:
        print "b"
    end
    println ""
    repeat -1:
        println "skip"
    end
    repeat 2:
        repeat 2:
            print "*"
        end
    end
    println ""
    repeat 5:
        print "once"
        break
    end
    println ""
end
