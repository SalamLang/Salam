func main:
    a := 2
    b := 4
    stride := 5

    repeat a to b:
        repeat 1 to 3:
            print "*"
        end
        println ""
    end

    mut n := 0
    repeat 1 to 1000:
        n += 1
        if n == 3:
            break
        end
    end
    println n

    mut hits := 0
    repeat 0 to 20 by stride:
        hits += 1
    end
    println hits
end
