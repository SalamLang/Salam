func main:
    a : int = 2
    b : int = 4
    stride : int = 5

    repeat a to b:
        repeat 1 to 3:
            print "*"
        end
        println ""
    end

    mut n : int = 0
    repeat 1 to 1000:
        n += 1
        if n == 3:
            break
        end
    end
    println n

    mut hits : int = 0
    repeat 0 to 20 every stride:
        hits += 1
    end
    println hits
end
