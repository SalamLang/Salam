func main:
    repeat 3:
        _ "hi"
    end
    __ ""
    repeat 5 with i:
        _ i
    end
    __ ""
    repeat 3 to 5 with i:
        _ i
    end
    __ ""
    repeat 3 to 10 by 2 with i:
        _ i
        _ " "
    end
    __ ""
    repeat 9 to 3 with i:
        _ i
    end
    __ ""
    repeat 9 to 3 by 2 with i:
        _ i
        _ " "
    end
    __ ""
    lo := 2
    hi := 8
    stride := 3
    repeat lo to hi by stride with i:
        _ i
        _ " "
    end
    __ ""
    repeat hi to lo with i:
        _ i
    end
    __ ""
end
