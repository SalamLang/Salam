func main:
    repeat 3:
        print "hi"
    end
    println ""
    repeat 5 with i:
        print i
    end
    println ""
    repeat 3 to 5 with i:
        print i
    end
    println ""
    repeat 3 to 10 by 2 with i:
        print i
        print " "
    end
    println ""
    repeat 9 to 3 with i:
        print i
    end
    println ""
    repeat 9 to 3 by 2 with i:
        print i
        print " "
    end
    println ""
    lo := 2
    hi := 8
    stride := 3
    repeat lo to hi by stride with i:
        print i
        print " "
    end
    println ""
    repeat hi to lo with i:
        print i
    end
    println ""
end
