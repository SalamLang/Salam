func main:
    mut arr := [10, 20, 30, 40, 50] as int[5]
    mut s := arr[1:4]
    __ len(s)
    __ s[0], s[1], s[2]
    s[0] = 99
    __ arr[1]
    __ len(arr[:])
    pre := arr[:2]
    __ len(pre), pre[0], pre[1]
    suf := arr[3:]
    __ len(suf), suf[0], suf[1]
    sub := s[1:]
    __ len(sub), sub[0]
end
