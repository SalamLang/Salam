import (
    "socket" "str"
)

func main:
    req str = "GET /chat HTTP/1.1\r\nHost: example.com\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\nSec-WebSocket-Version: 13\r\n\r\n"
    resp str = socket.HandshakeResponse(req)
    __ str.Contains(resp, "101 Switching Protocols")
    __ str.Contains(resp, "Upgrade: websocket")
    __ str.Contains(resp, "Sec-WebSocket-Accept: s3pPLMBiTxaQ9kYGzzhZRbK+xOo=")
    bad str = "GET / HTTP/1.1\r\nHost: example.com\r\n\r\n"
    __ socket.HandshakeResponse(bad) == ""
    req2 str = socket.HandshakeRequest("localhost", "/ws", "dGhlIHNhbXBsZSBub25jZQ==")
    __ str.Contains(req2, "GET /ws HTTP/1.1")
    __ str.Contains(req2, "Host: localhost")
    __ str.Contains(req2, "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==")
    __ str.Contains(req2, "Sec-WebSocket-Version: 13")
end
