import "socket" "str"

func main:
    req := "GET /chat HTTP/1.1\r\nHost: example.com\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\nSec-WebSocket-Version: 13\r\n\r\n"
    resp := socket.HandshakeResponse(req)
    println str.Contains(resp, "101 Switching Protocols")
    println str.Contains(resp, "Upgrade: websocket")
    println str.Contains(resp, "Sec-WebSocket-Accept: s3pPLMBiTxaQ9kYGzzhZRbK+xOo=")
    bad := "GET / HTTP/1.1\r\nHost: example.com\r\n\r\n"
    println socket.HandshakeResponse(bad) == ""
    req2 := socket.HandshakeRequest("localhost", "/ws", "dGhlIHNhbXBsZSBub25jZQ==")
    println str.Contains(req2, "GET /ws HTTP/1.1")
    println str.Contains(req2, "Host: localhost")
    println str.Contains(req2, "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==")
    println str.Contains(req2, "Sec-WebSocket-Version: 13")
end
