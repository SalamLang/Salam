import (
    "socket" "sync" "str"
)

mut srv_wg : sync.WaitGroup = sync.NewWaitGroup()
func ws_server():
    srv : socket.Server = socket.Listen(19210)
    sync.Done(srv_wg)
    if !socket.Ok(srv):
        ret
    end
    mut c : socket.Conn = socket.Accept(srv)
    if socket.IsOpen(c):
        mut m : socket.Message = socket.Receive(c)
        while socket.IsText(m):
            socket.SendText(c, "echo:" + m.text)
            m = socket.Receive(c)
        end
    end
    socket.CloseServer(srv)
end

func main:
    sync.Add(srv_wg, 1 as i64)
    t : i64 = spawn(ws_server)
    sync.Wait(srv_wg)
    mut c : socket.Conn = socket.Dial("127.0.0.1", 19210, "/")
    __ socket.IsOpen(c)
    socket.SendText(c, "hello")
    __ socket.ReceiveText(c)
    big : str = str.Repeat("ab", 100)
    socket.SendText(c, big)
    reply : str = socket.ReceiveText(c)
    __ str.Len(reply)
    __ str.StartsWith(reply, "echo:ab")
    socket.Ping(c, "hi")
    m : socket.Message = socket.Receive(c)
    __ socket.IsPong(m)
    __ m.text
    socket.Close(c)
    join(t)
end
