import socket
import sync
import str

mut srv_wg := sync.NewWaitGroup()
func ws_server():
    srv := socket.Listen(19210)
    sync.Done(srv_wg)
    if !socket.Ok(srv):
        ret
    end
    mut c := socket.Accept(srv)
    if socket.IsOpen(c):
        mut m := socket.Receive(c)
        until socket.IsText(m):
            socket.SendText(c, "echo:" + m.text)
            m = socket.Receive(c)
        end
    end
    socket.CloseServer(srv)
end

func main:
    sync.Add(srv_wg, 1 as i64)
    t := spawn(ws_server)
    sync.Wait(srv_wg)
    mut c := socket.Dial("127.0.0.1", 19210, "/")
    println socket.IsOpen(c)
    socket.SendText(c, "hello")
    println socket.ReceiveText(c)
    big := str.Repeat("ab", 100)
    socket.SendText(c, big)
    reply := socket.ReceiveText(c)
    println str.Len(reply)
    println str.StartsWith(reply, "echo:ab")
    socket.Ping(c, "hi")
    m := socket.Receive(c)
    println socket.IsPong(m)
    println m.text
    socket.Close(c)
    join(t)
end
