import socket

func main:
    println socket.Sha1Hex("")
    println socket.Sha1Hex("abc")
    println socket.Sha1Hex("The quick brown fox jumps over the lazy dog")
    println socket.Sha1Hex("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
    println socket.Sha1Base64("abc")
    println socket.AcceptKey("dGhlIHNhbXBsZSBub25jZQ==")
end
