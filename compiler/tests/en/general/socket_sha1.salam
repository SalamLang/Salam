import (
    "socket"
)

func main:
    __ socket.Sha1Hex("")
    __ socket.Sha1Hex("abc")
    __ socket.Sha1Hex("The quick brown fox jumps over the lazy dog")
    __ socket.Sha1Hex("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
    __ socket.Sha1Base64("abc")
    __ socket.AcceptKey("dGhlIHNhbXBsZSBub25jZQ==")
end
