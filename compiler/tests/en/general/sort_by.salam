import "sort"
import "collections"

func main:
    mut v collections.Vector<i32> = Vector {}
    v.push(3)
    v.push(1)
    v.push(2)
    // SortedBy returns a sorted copy; v is left untouched.
    s collections.Vector<i32> = sort.SortedBy(v, (a i32, b i32) => a < b)
    __ s.get(0)[0], s.get(1)[0], s.get(2)[0]
    __ v.get(0)[0], v.get(1)[0], v.get(2)[0]
    sort.SortBy(v, (a i32, b i32) => a > b)
    __ v.get(0)[0], v.get(1)[0], v.get(2)[0]
end
