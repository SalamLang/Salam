import sort
import collections

func main:
    mut v := Vector {} as collections.Vector<int> v.push(3)
    v.push(1)
    v.push(2)

    s := sort.SortedBy(v, (a: int, b: int) => a < b)
    println s.get(0)[0], s.get(1)[0], s.get(2)[0]
    println v.get(0)[0], v.get(1)[0], v.get(2)[0]
    sort.SortBy(v, (a: int, b: int) => a > b)
    println v.get(0)[0], v.get(1)[0], v.get(2)[0]
end
