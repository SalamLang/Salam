import "sort"
import "collections"

func main:
    mut v : collections.Vector<int> = Vector {}
    v.push(3)
    v.push(1)
    v.push(2)

    s : collections.Vector<int> = sort.SortedBy(v, (a : int, b : int) => a < b)
    __ s.get(0)[0], s.get(1)[0], s.get(2)[0]
    __ v.get(0)[0], v.get(1)[0], v.get(2)[0]
    sort.SortBy(v, (a : int, b : int) => a > b)
    __ v.get(0)[0], v.get(1)[0], v.get(2)[0]
end
