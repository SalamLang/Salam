import "collections"
import "sort"

func fill(v collections.Vector<i32>):
    v.clear()
    v.push(5)
    v.push(2)
    v.push(8)
    v.push(1)
    v.push(9)
    v.push(3)
    v.push(7)
    v.push(4)
    v.push(6)
    v.push(0)
    v.push(2)
    v.push(8)
end

func main:
    mut v collections.Vector<i32> = Vector {}

    fill(v)
    sort.BubbleSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.SelectionSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.InsertionSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.BinaryInsertionSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.GnomeSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.CocktailSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.OddEvenSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.PancakeSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.ShellSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.CombSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.MergeSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.QuickSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.HeapSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.IntroSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.Sort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.CountingSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.RadixSort(v)
    println sort.IsSorted(v)
    fill(v)
    sort.BucketSort(v)
    println sort.IsSorted(v)

    // exact ordering after a sort
    fill(v)
    sort.Sort(v)
    mut i i32 = 0
    while i < v.len():
        print v.get(i)[0]
        print " "
        i = i + 1
    end
    println ""

    // descending
    fill(v)
    sort.SortDesc(v)
    println v.get(0)[0]
    println v.get(v.len() - 1)[0]

    // negatives via radix & counting
    mut w collections.Vector<i32> = Vector {}
    w.push(0 - 3)
    w.push(5)
    w.push(0 - 10)
    w.push(2)
    w.push(0 - 3)
    w.push(7)
    sort.RadixSort(w)
    println sort.IsSorted(w)
    println w.get(0)[0]
    println w.get(5)[0]
    sort.CountingSort(w)
    println sort.IsSorted(w)

    // search utilities on sorted data
    fill(v)
    sort.Sort(v)
    println sort.BinarySearch(v, 7)
    println sort.BinarySearch(v, 100)
    println sort.LowerBound(v, 2)
    println sort.UpperBound(v, 2)
    println sort.Min(v)
    println sort.Max(v)

    // comparator sort: descending order
    fill(v)
    sort.SortBy(v, (a i32, b i32) => b < a)
    println v.get(0)[0]
    println sort.IsSortedBy(v, (a i32, b i32) => b < a)

    // stable comparator sort, ascending
    fill(v)
    sort.StableSortBy(v, (a i32, b i32) => a < b)
    println sort.IsSorted(v)

    // strings
    mut s collections.Vector<str> = Vector {}
    s.push("pear")
    s.push("apple")
    s.push("fig")
    s.push("banana")
    sort.Sort(s)
    println s.get(0)
    println s.get(3)
    println sort.IsSorted(s)

    // sorted copy leaves original untouched
    fill(v)
    mut cp collections.Vector<i32> = sort.Sorted(v)
    println sort.IsSorted(cp)
    println sort.IsSorted(v)
    println v.get(0)[0]
end
