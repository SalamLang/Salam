import "db/sqlite"
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(alpha INTEGER, beta TEXT)")
    sqlite.Exec(db, "INSERT INTO t VALUES (1, 'x')")
    r := sqlite.Query(db, "SELECT alpha, beta FROM t")
    println sqlite.ColumnName(r, 0)
    println sqlite.ColumnName(r, 1)
    sqlite.Finish(r)
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println "alpha"
        println "beta"
    end
end
