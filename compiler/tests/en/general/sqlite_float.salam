import db.sqlite
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(v REAL)")
    sqlite.Exec(db, "INSERT INTO t VALUES (3.5)")
    r := sqlite.Query(db, "SELECT v FROM t")
    sqlite.Next(r)
    println sqlite.Float(r, 0)
    sqlite.Finish(r)
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println 3.5
    end
end
