import "db/sqlite"
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(v INTEGER)")
    sqlite.Exec(db, "INSERT INTO t VALUES (10000000000)")
    r := sqlite.Query(db, "SELECT v FROM t")
    sqlite.Next(r)
    println sqlite.Int64(r, 0)
    sqlite.Finish(r)
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println 10000000000
    end
end
