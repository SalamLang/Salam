import "db/sqlite"
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(v INTEGER)")
    sqlite.Exec(db, "INSERT INTO t(v) VALUES (NULL), (7)")
    r := sqlite.Query(db, "SELECT v FROM t ORDER BY rowid")
    sqlite.Next(r)
    println sqlite.IsNull(r, 0)
    sqlite.Next(r)
    println sqlite.IsNull(r, 0)
    sqlite.Finish(r)
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println true
        println false
    end
end
