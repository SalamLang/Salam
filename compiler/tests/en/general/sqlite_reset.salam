import "db/sqlite"
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(v INTEGER)")
    ins := sqlite.Prepare(db, "INSERT INTO t VALUES (?)")
    sqlite.BindInt(ins, 1, 1 as i64)
    sqlite.Next(ins)
    sqlite.Reset(ins)
    sqlite.BindInt(ins, 1, 2 as i64)
    sqlite.Next(ins)
    sqlite.Finish(ins)
    __ sqlite.QueryInt(db, "SELECT COUNT(*) FROM t")
    __ sqlite.QueryInt(db, "SELECT SUM(v) FROM t")
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        __ 2
        __ 3
    end
end
