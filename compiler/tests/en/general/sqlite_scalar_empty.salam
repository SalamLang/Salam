import db.sqlite
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(v INTEGER)")
    println sqlite.QueryInt(db, "SELECT v FROM t")
    println sqlite.QueryText(db, "SELECT 'x' FROM t") == ""
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println 0
        println true
    end
end
