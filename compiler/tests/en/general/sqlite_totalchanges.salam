import db.sqlite
func run():
    db := sqlite.Open(":memory:")
    sqlite.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY)")
    sqlite.Exec(db, "INSERT INTO t(id) VALUES (1)")
    sqlite.Exec(db, "INSERT INTO t(id) VALUES (2)")
    println sqlite.Changes(db)
    println sqlite.TotalChanges(db)
    sqlite.Close(db)
end

func main:
    if sqlite.Available():
        run()
    else:
        println 1
        println 2
    end
end
