    sqlite.Exec(db, "INSERT INTO t(id) VALUES (1)")
    sqlite.Begin(db)
    sqlite.Exec(db, "INSERT INTO t(id) VALUES (2), (3)")
    sqlite.Rollback(db)
    __ sqlite.QueryInt(db, "SELECT COUNT(*) FROM t")
    sqlite.Close(db)
end
func main:
    if sqlite.Available():
        run()
