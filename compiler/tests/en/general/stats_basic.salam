import (
    "stats" "fmt"
)

func main:
    mut v Vector<f64> = Vector {}
    v.push(3.0)
    v.push(1.0)
    v.push(2.0)
    __ stats.Sum(v)
    __ stats.Mean(v)
    __ stats.Min(v)
    __ stats.Max(v)
    __ stats.Median(v)
    mut v4 Vector<f64> = Vector {}
    v4.push(4.0)
    v4.push(1.0)
    v4.push(3.0)
    v4.push(2.0)
    __ stats.Median(v4)
    mut w Vector<f64> = Vector {}
    w.push(2.0)
    w.push(4.0)
    w.push(4.0)
    w.push(4.0)
    w.push(5.0)
    w.push(5.0)
    w.push(7.0)
    w.push(9.0)
    __ stats.PopVariance(w)
    __ stats.PopStdev(w)
    __ fmt.FloatPrec(stats.Variance(w), 4)
    __ fmt.FloatPrec(stats.Stdev(w), 4)
    mut g Vector<f64> = Vector {}
    g.push(1.0)
    g.push(100.0)
    __ fmt.FloatPrec(stats.Geomean(g), 2)
    __ stats.Percentile(v4, 0.0)
    __ stats.Percentile(v4, 25.0)
    __ stats.Percentile(v4, 50.0)
    __ stats.Percentile(v4, 100.0)
    mut e Vector<f64> = Vector {}
    __ stats.Mean(e)
    __ stats.Stdev(e)
end
