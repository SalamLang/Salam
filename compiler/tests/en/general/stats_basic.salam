import stats
import fmt

func main:
    mut v := Vector {} as Vector<f64>
    v.push(3.0)
    v.push(1.0)
    v.push(2.0)
    println stats.Sum(v)
    println stats.Mean(v)
    println stats.Min(v)
    println stats.Max(v)
    println stats.Median(v)
    mut v4 := Vector {} as Vector<f64>
    v4.push(4.0)
    v4.push(1.0)
    v4.push(3.0)
    v4.push(2.0)
    println stats.Median(v4)
    mut w := Vector {} as Vector<f64>
    w.push(2.0)
    w.push(4.0)
    w.push(4.0)
    w.push(4.0)
    w.push(5.0)
    w.push(5.0)
    w.push(7.0)
    w.push(9.0)
    println stats.PopVariance(w)
    println stats.PopStdev(w)
    println fmt.FloatPrec(stats.Variance(w), 4)
    println fmt.FloatPrec(stats.Stdev(w), 4)
    mut g := Vector {} as Vector<f64>
    g.push(1.0)
    g.push(100.0)
    println fmt.FloatPrec(stats.Geomean(g), 2)
    println stats.Percentile(v4, 0.0)
    println stats.Percentile(v4, 25.0)
    println stats.Percentile(v4, 50.0)
    println stats.Percentile(v4, 100.0)
    e := Vector {} as Vector<f64>
    println stats.Mean(e)
    println stats.Stdev(e)
end
