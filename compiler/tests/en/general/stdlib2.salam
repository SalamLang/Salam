import "csv" "json" "regex" "str"

func main:
    println regex.MatchStr("[0-9]+", "abc123")
    println regex.FindStr("l+", "hello")
    re := regex.Compile("o")
    println regex.Replace(re, "world", "0")
    doc := "{ \"name\": \"ada\", \"age\": 36, \"ok\": true }"
    println json.Valid(doc)
    println json.Valid("{ bad }")
    println json.Get(doc, "name")
    println json.Get(doc, "age")
    println json.Minify(doc)
    rec := csv.ReadLine("a,\"b,c\",\"d\"\"e\"")
    defer rec.free()
    println rec.len()
    println rec.get(1)[0]
    println rec.get(2)[0]
    println str.Replace("a.b.c.d", ".", "-")
end
