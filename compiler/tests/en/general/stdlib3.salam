import fmt
import str
import math
import collections

func main:
    println fmt.PadLeft("hi", 5).concat("|")
    println fmt.PadRight("hi", 5).concat("|")
    println fmt.Center("ab", 6).concat("|")
    println str.Repeat("ab", 3)
    mut a := Vector {} as Vector<str>
    defer a.free()
    a.push("Ada")
    a.push("36")
    println fmt.Sprintf("{} is {}", a)
    println str.Upper("hello")
    println str.Lower("HELLO")
    println str.Reverse("salam")
    println str.Contains("hello world", "o w")
    println str.StartsWith("salam", "sal")
    println str.EndsWith("salam", "lam")
    println str.Count("a.b.c.d", ".")
    println str.Equals("abc", "abc")
    println math.Round(2.6)
    println math.Log2(8.0)
    println math.Gcd(12, 18)
    println math.Lcm(4, 6)
    println math.ClampI(15, 0, 10)
    println math.Max(2.5, 1.5)
    println math.Sign(0.0 - 3.0)
    mut v := Vector {} as Vector<str>
    defer v.free()
    v.push("x")
    v.push("y")
    v.push("z")
    println collections.index_of(v, "y")
    println collections.contains(v, "q")
    r := collections.reverse(v)
    defer r.free()
    mut joined := ""
    mut ji := 0
    until ji < r.len():
        joined = joined.concat(r.get(ji)[0])
        ji = ji + 1
    end
    println joined
end
