import (
    "str" "math" "encoding" "collections" "json" "fmt"
)

func main:
    __ str.Clone("copy")
    __ str.TrimLeft("  hi ").concat("|")
    __ str.TrimRight("  hi ").concat("|")
    __ str.TrimPrefix("foobar", "foo")
    __ str.TrimSuffix("foobar", "bar")
    __ str.IndexFrom("abcabc", "bc", 2)
    fields := str.Fields("  one two   three ")
    __ fields.len()
    __ fields.get(2)[0]
    __ str.CharAt("hi", 1)
    __ str.CharCount("hi")
    chars := str.Chars("ab")
    __ chars.len()
    __ str.IsDigit(char_code("7"))
    __ str.IsAlpha(char_code("7"))
    __ str.IsUpper(char_code("A"))
    __ math.IsNaN(math.NaN())
    __ math.IsInf(math.Inf())
    __ math.IsInf(5.0)
    __ math.Tanh(100.0)
    __ math.Pow10(3)
    __ math.Lerp(0.0, 10.0, 0.25)
    __ math.Factorial(10)
    __ math.GcdI64(48, 18)
    __ math.MinI64(3, 7)
    __ math.MaxI64(3, 7)
    __ encoding.URLEncode("a b&c")
    __ encoding.URLDecode("a%20b%26c")
    __ encoding.URLDecode("a+b")
    __ encoding.HexVal("f")
    mut nums := Vector {} as Vector<int>
    nums.push(3)
    nums.push(1)
    nums.push(3)
    copied := collections.clone(nums)
    __ copied.len()
    part := collections.slice(nums, 1, 2)
    __ part.get(0)[0]
    collections.swap(nums, 0, 1)
    __ nums.get(0)[0]
    __ collections.count_of(nums, 3)
    __ collections.last_index_of(nums, 3)
    mut sink := Vector {} as Vector<int>
    collections.extend(sink, nums)
    __ sink.len()
    __ json.MemberInt("n", 5)
    __ json.MemberBool("b", true)
    __ json.Str("quote\"here")
    mut members := Vector {} as Vector<str>
    members.push(json.MemberInt("a", 1))
    members.push(json.MemberRaw("b", "[1, 2]"))
    __ json.Object(members)
    __ fmt.FloatPrec(3.14159, 3)
    __ fmt.Hex(255 as u64)
    __ fmt.Uint(7 as u64)
end
