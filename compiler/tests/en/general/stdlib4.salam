import str
import math
import encoding
import collections
import json
import fmt

func main:
    println str.Clone("copy")
    println str.TrimLeft("  hi ").concat("|")
    println str.TrimRight("  hi ").concat("|")
    println str.TrimPrefix("foobar", "foo")
    println str.TrimSuffix("foobar", "bar")
    println str.IndexFrom("abcabc", "bc", 2)
    fields := str.Fields("  one two   three ")
    println fields.len()
    println fields.get(2)[0]
    println str.CharAt("hi", 1)
    println str.CharCount("hi")
    chars := str.Chars("ab")
    println chars.len()
    println str.IsDigit(char_code("7"))
    println str.IsAlpha(char_code("7"))
    println str.IsUpper(char_code("A"))
    println math.IsNaN(math.NaN())
    println math.IsInf(math.Inf())
    println math.IsInf(5.0)
    println math.Tanh(100.0)
    println math.Pow10(3)
    println math.Lerp(0.0, 10.0, 0.25)
    println math.Factorial(10)
    println math.GcdI64(48, 18)
    println math.MinI64(3, 7)
    println math.MaxI64(3, 7)
    println encoding.URLEncode("a b&c")
    println encoding.URLDecode("a%20b%26c")
    println encoding.URLDecode("a+b")
    println encoding.HexVal("f")
    mut nums := Vector {} as Vector<int>
    nums.push(3)
    nums.push(1)
    nums.push(3)
    copied := collections.clone(nums)
    println copied.len()
    part := collections.slice(nums, 1, 2)
    println part.get(0)[0]
    collections.swap(nums, 0, 1)
    println nums.get(0)[0]
    println collections.count_of(nums, 3)
    println collections.last_index_of(nums, 3)
    mut sink := Vector {} as Vector<int>
    collections.extend(sink, nums)
    println sink.len()
    println json.MemberInt("n", 5)
    println json.MemberBool("b", true)
    println json.Str("quote\"here")
    mut members := Vector {} as Vector<str>
    members.push(json.MemberInt("a", 1))
    members.push(json.MemberRaw("b", "[1, 2]"))
    println json.Object(members)
    println json.Indent(json.Object(members))
    println json.IndentWith(json.Object(members), "    ")
    println json.IndentTabs(json.Object(members))
    println fmt.FloatPrec(3.14159, 3)
    println fmt.Hex(255 as u64)
    println fmt.Uint(7 as u64)
end
