struct Counter:
    value : int = 0
    step : int = 1
    func _describe() : str: ret "count=" end
    pub func bump():
        this.value = this.value + this.step
    end
    pub func get() : int: ret value end
    pub func label() : str: ret this._describe() end
end

func main:
    mut c := Counter { value = 5, step = 3 }
    c.bump()
    c.bump()
    __ c.get()
    __ c.label()
end
