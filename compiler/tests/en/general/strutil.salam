func main:
    s := "hello world"
    println s.len()
    println s.substr(0, 5)
    println s.find("world")
    println s.find("xyz")
    println "  trim me  ".trim()
    println "a,b,c,d".split(",").len()
    parts := "10 20 30".split(" ")
    defer parts.free()
    mut total := 0
    repeat parts.len() with i:
        total = total + parts.get(i)[0].to_int()
    end
    println total
    println "3.5".to_float() + 1.5
    println "foo".concat("bar")
end
