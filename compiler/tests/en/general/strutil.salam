func main:
    s str = "hello world"
    __ s.len()
    __ s.substr(0, 5)
    __ s.find("world")
    __ s.find("xyz")
    __ "  trim me  ".trim()
    __ "a,b,c,d".split(",").len()
    parts Vector<str> = "10 20 30".split(" ")
    defer parts.free()
    mut total = 0
    mut i = 0
    while i < parts.len():
        total = total + parts.get(i)[0].to_int()
        i = i + 1
    end
    __ total
    __ "3.5".to_float() + 1.5
    __ "foo".concat("bar")
end
