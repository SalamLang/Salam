import tcp
import sync

mut srv_wg := sync.NewWaitGroup()
func echo_server():
    srv := tcp.Bind(19202)
    sync.Done(srv_wg)
    if !tcp.Ok(srv):
        ret
    end
    c := tcp.Accept(srv)
    if tcp.ConnOk(c):
        msg := tcp.Read(c, 1024)
        tcp.Write(c, "echo:" + msg)
        tcp.Close(c)
    end
    tcp.CloseServer(srv)
end

func main:
    sync.Add(srv_wg, 1 as i64)
    t := spawn(echo_server)
    sync.Wait(srv_wg)
    c := tcp.Dial("127.0.0.1", 19202)
    println tcp.ConnOk(c)
    tcp.Write(c, "hello")
    resp := tcp.Read(c, 1024)
    println resp
    tcp.Close(c)
    join(t)
end
