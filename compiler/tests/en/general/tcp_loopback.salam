import tcp
import sync

mut srv wg := sync.NewWaitGroup()
func echo server():
    srv := tcp.Bind(19202)
    sync.Done(srv wg)
    if !tcp.Ok(srv):
        ret
    end
    c := tcp.Accept(srv)
    if tcp.ConnOk(c):
        msg := tcp.Read(c, 1024)
        tcp.Write(c, "echo:" + msg)
        tcp.Close(c)
    end
    tcp.CloseServer(srv)
end

func main:
    sync.Add(srv wg, 1 as i64)
    t := spawn(echo server)
    sync.Wait(srv wg)
    c := tcp.Dial("127.0.0.1", 19202)
    println tcp.ConnOk(c)
    tcp.Write(c, "hello")
    resp := tcp.Read(c, 1024)
    println resp
    tcp.Close(c)
    join(t)
end
