import tcp
import net
import sync
import str

mut whttp wg := sync.NewWaitGroup()
func http server():
    srv := tcp.Bind(19203)
    sync.Done(whttp wg)
    if !tcp.Ok(srv):
        ret
    end
    c := tcp.Accept(srv)
    if tcp.ConnOk(c):
        _req := tcp.Read(c, 1024)
        tcp.WriteHTTP(c, "200 OK", "text/plain", "salam-tcp-http")
        tcp.Close(c)
    end
    tcp.CloseServer(srv)
end

func main:
    sync.Add(whttp wg, 1 as i64)
    t := spawn(http server)
    sync.Wait(whttp wg)
    sock := net.Connect("127.0.0.1", 19203)
    println net.Ok(sock)
    net.Send(sock, "GET / HTTP/1.0\r\n\r\n")
    resp := net.Recv(sock, 4096)
    net.Close(sock)
    join(t)
    println str.Contains(resp, "HTTP/1.1")
    println str.Contains(resp, "text/plain")
    println str.Contains(resp, "salam-tcp-http")
end
