import (
    "tcp" "net" "sync" "str"
)

mut whttp_wg sync.WaitGroup = sync.NewWaitGroup()
func http_server():
    srv tcp.Server = tcp.Bind(19203)
    sync.Done(whttp_wg)
    if !tcp.Ok(srv):
        ret
    end
    c tcp.Conn = tcp.Accept(srv)
    if tcp.ConnOk(c):
        _req str = tcp.Read(c, 1024)
        tcp.WriteHTTP(c, "200 OK", "text/plain", "salam-tcp-http")
        tcp.Close(c)
    end
    tcp.CloseServer(srv)
end

func main:
    sync.Add(whttp_wg, 1 as i64)
    t i64 = spawn(http_server)
    sync.Wait(whttp_wg)
    sock net.Socket = net.Connect("127.0.0.1", 19203)
    __ net.Ok(sock)
    net.Send(sock, "GET / HTTP/1.0\r\n\r\n")
    resp str = net.Recv(sock, 4096)
    net.Close(sock)
    join(t)
    __ str.Contains(resp, "HTTP/1.1")
    __ str.Contains(resp, "text/plain")
    __ str.Contains(resp, "salam-tcp-http")
end
