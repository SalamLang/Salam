import template

func main:
    mut ctx := template.NewContext()
    ctx.put("name", "World")
    ctx.put("admin", "true")
    ctx.put("html", "<b>&</b>")
    ctx.put("empty", "")
    println template.Render("Hello {{name}}!", ctx)
    println template.Render("{{#if admin}}yes{{else}}no{{/if}}", ctx)
    println template.Render("{{#if missing}}A{{else}}B{{/if}}", ctx)
    println template.Render("{{#if empty}}A{{else}}B{{/if}}", ctx)
    println template.Render("{{#if admin}}[{{#if missing}}X{{else}}Y{{/if}}]{{/if}}", ctx)
    println template.Render("a{{unknown}}b", ctx)
    println template.Render("{{! a comment }}ok", ctx)
    println template.Render("plain text", ctx)
    println template.RenderHTML("<p>{{html}}</p>", ctx)
    println template.Render("{{ name }} trimmed", ctx)
    println template.EscapeHTML("a<b & 'c'")
    println template.Var("x")
end
