import (
    "template"
)

func main:
    mut ctx HashMap<str, str> = template.NewContext()
    ctx.put("name", "World")
    ctx.put("admin", "true")
    ctx.put("html", "<b>&</b>")
    ctx.put("empty", "")
    __ template.Render("Hello {{name}}!", ctx)
    __ template.Render("{{#if admin}}yes{{else}}no{{/if}}", ctx)
    __ template.Render("{{#if missing}}A{{else}}B{{/if}}", ctx)
    __ template.Render("{{#if empty}}A{{else}}B{{/if}}", ctx)
    __ template.Render("{{#if admin}}[{{#if missing}}X{{else}}Y{{/if}}]{{/if}}", ctx)
    __ template.Render("a{{unknown}}b", ctx)
    __ template.Render("{{! a comment }}ok", ctx)
    __ template.Render("plain text", ctx)
    __ template.RenderHTML("<p>{{html}}</p>", ctx)
    __ template.Render("{{ name }} trimmed", ctx)
    __ template.EscapeHTML("a<b & 'c'")
    __ template.Var("x")
end
