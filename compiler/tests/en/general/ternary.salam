func classify(n : i32) : str:
    ret n < 0 ? "neg" : n == 0 ? "zero" : "pos"
end

func main:
    x := 7
    println x > 5 ? "big" : "small"
    println classify(-4), classify(0), classify(9)
    println true ? false ? 1 : 2 : 3
    mut total := 0
    repeat 6 with i:
        total += i % 2 == 0 ? i : 0
    end
    println total
end
