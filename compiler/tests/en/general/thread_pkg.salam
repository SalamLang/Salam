import "thread" "sync"

mut thread_wg := sync.NewWaitGroup()
mut thread_result := 0 as i64
func bg_task():
    thread_result = 99
    sync.Done(thread_wg)
end

func main:
    bad := thread.New(0 as i64)
    println thread.Valid(bad)
    sync.Add(thread_wg, 1 as i64)
    h := spawn(bg_task)
    t := thread.New(h)
    println thread.Valid(t)
    sync.Wait(thread_wg)
    thread.Join(t)
    println thread_result
end
