import (
    "thread" "sync"
)
mut thread_wg sync.WaitGroup = sync.NewWaitGroup()
mut thread_result i64 = 0
func bg_task():
    thread_result = 99
    sync.Done(thread_wg)
end

func main:
    bad thread.Thread = thread.New(0 as i64)
    __ thread.Valid(bad)
    sync.Add(thread_wg, 1 as i64)
    h i64 = spawn(bg_task)
    t thread.Thread = thread.New(h)
    __ thread.Valid(t)
    sync.Wait(thread_wg)
    thread.Join(t)
    __ thread_result
end
