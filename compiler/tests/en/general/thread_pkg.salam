import thread
import sync

mut thread wg := sync.NewWaitGroup()
mut thread result := 0 as i64
func bg task():
    thread result = 99
    sync.Done(thread wg)
end

func main:
    bad := thread.New(0 as i64)
    println thread.Valid(bad)
    sync.Add(thread wg, 1 as i64)
    h := spawn(bg task)
    t := thread.New(h)
    println thread.Valid(t)
    sync.Wait(thread wg)
    thread.Join(t)
    println thread result
end
