import "sync"
import "mem"
mut total i64* = null
mut lock sync.Mutex = sync.NewMutex()
mut wg sync.WaitGroup = sync.NewWaitGroup()
func worker():
    mut c i64* = total
    mut i = 0
    while i < 5000:
        sync.Lock(lock)
        c[0] = c[0] + 1
        sync.Unlock(lock)
        i = i + 1
    end
    sync.Done(wg)
end

func main:
    total = mem.Allocate(8 as u64) as i64*
    total[0] = 0
    sync.Add(wg, 3 as i64)
    t1 i64 = spawn(worker)
    t2 i64 = spawn(worker)
    t3 i64 = spawn(worker)
    sync.Wait(wg)
    join(t1)
    join(t2)
    join(t3)
    __ total[0]
    mem.Free(total as void*)
end
