import time
import os
import str

func main:
    ns := time.NowNanos()
    ns_ok := ns > 1600000000000000000
    println ns_ok
    ms := time.NowMillis()
    ms_ok := ms > 1600000000000
    println ms_ok
    t0 := time.NowNanos()
    t1 := time.NowNanos()
    mono_ok := t1 >= t0
    println mono_ok
    println time.ElapsedMs(1000000, 3500000)
    r := os.RunCapture("echo cap")
    println r.code
    println str.Trim(r.out)
    r2 := os.RunCapture("exit 7")
    println r2.code
end
