import time
import os
import str

func main:
    ns := time.NowNanos()
    ns ok := ns > 1600000000000000000
    println ns ok
    ms := time.NowMillis()
    ms ok := ms > 1600000000000
    println ms ok
    t0 := time.NowNanos()
    t1 := time.NowNanos()
    mono ok := t1 >= t0
    println mono ok
    println time.ElapsedMs(1000000, 3500000)
    r := os.RunCapture("echo cap")
    println r.code
    println str.Trim(r.out)
    r2 := os.RunCapture("exit 7")
    println r2.code
end
