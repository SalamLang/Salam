import (
    "time" "os" "str"
)

func main:
    ns i64 = time.NowNanos()
    ns_ok bool = ns > 1600000000000000000
    __ ns_ok
    ms i64 = time.NowMillis()
    ms_ok bool = ms > 1600000000000
    __ ms_ok
    t0 i64 = time.NowNanos()
    t1 i64 = time.NowNanos()
    mono_ok bool = t1 >= t0
    __ mono_ok
    __ time.ElapsedMs(1000000, 3500000)
    r os.CmdResult = os.RunCapture("echo cap")
    __ r.code
    __ str.Trim(r.out)
    r2 os.CmdResult = os.RunCapture("exit 7")
    __ r2.code
end
