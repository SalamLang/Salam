import (
    "time" "os" "str"
)

func main:
    ns := time.NowNanos()
    ns_ok := ns > 1600000000000000000
    __ ns_ok
    ms := time.NowMillis()
    ms_ok := ms > 1600000000000
    __ ms_ok
    t0 := time.NowNanos()
    t1 := time.NowNanos()
    mono_ok := t1 >= t0
    __ mono_ok
    __ time.ElapsedMs(1000000, 3500000)
    r := os.RunCapture("echo cap")
    __ r.code
    __ str.Trim(r.out)
    r2 := os.RunCapture("exit 7")
    __ r2.code
end
