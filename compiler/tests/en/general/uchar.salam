func main:
    a uchar = u"A"
    b auto = u"€"
    c auto = u"中"
    d auto = u"😀"
    e uchar = u"A"
    f auto = u"\U0001F600"
    g auto = u"\\"
    h auto = u"\""
    println(a)
    println(b)
    println(c)
    println(d)
    println(e)
    println(f)
    println(g)
    println(h)
    println("letter: " + c)
    println(a + b)
    println(c + " <- CJK")
    s str = u"ص"
    println(s)
end
