func main:
    mut i := 1
    until i < 10:
        print i
        i = i + 1
    end
    println ""
    mut n := 10
    mut steps := 0
    until n != 1:
        if n % 2 == 0:
            n = n / 2
        else:
            n = 3 * n + 1
        end
        steps = steps + 1
    end
    println n, steps
    mut k := 0
    until true:
        k = k + 1
        if k == 4:
            break
        end
        continue
    end
    println k
end
