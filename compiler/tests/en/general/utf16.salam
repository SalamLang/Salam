import "text"
import "mem"

func check(s : str):
    w := text.ToUtf16(s)
    back := text.FromUtf16(w)
    if back == s:
        __ "ok"
    else:
        __ "FAIL"
    end
    mem.Free(w)
end

func main:
    check("Hello, world!")
    check("¡Hola Mundo!")
    check("Γειά σου Κόσμε!")
    check("Привет, мир!")
    check("こんにちは世界！")
    check("你好世界！")
    check("नमस्ते दुनिया!")
    check("👋🌎!")

    w := text.ToUtf16("A你👋")
    _ "len="
    __ text.Utf16Len("A你👋")
    __ text.Utf16UnitAt(w, 0)
    __ text.Utf16UnitAt(w, 1)
    __ text.Utf16UnitAt(w, 2)
    __ text.Utf16UnitAt(w, 3)
    __ text.Utf16UnitAt(w, 4)
    mem.Free(w)
end
