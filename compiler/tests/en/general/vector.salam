func main:
    mut v Vector<i32> = Vector {}
    defer v.free()
    mut i = 0
    while i < 5:
        v.push(i * 10)
        i = i + 1
    end
    __ v.len()
    __ v.cap()
    mut sum = 0
    i = 0
    while i < v.len():
        sum = sum + v.get(i)[0]
        i = i + 1
    end
    __ sum
    v.set(10, 999)
    __ v.len()
    __ v.get(10)[0]
    __ v.pop()
    __ v.len()
end
