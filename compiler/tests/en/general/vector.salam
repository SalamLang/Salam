func main:
    mut v := Vector {} as Vector<int>
    defer v.free()
    mut i := 0
    until i < 5:
        v.push(i * 10)
        i = i + 1
    end
    println v.len()
    println v.cap()
    mut sum := 0
    i = 0
    until i < v.len():
        sum = sum + v.get(i)[0]
        i = i + 1
    end
    println sum
    v.set(10, 999)
    println v.len()
    println v.get(10)[0]
    println v.pop()
    println v.len()
end
