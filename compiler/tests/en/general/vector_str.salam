func main:
    mut names := Vector {} as Vector<str>
    defer names.free()
    names.push("ali")
    names.push("sara")
    names.push("reza")
    __ names.len()
    mut counts := HashMap {} as HashMap<str, int>
    mut i := 0
    until i < names.len():
        nm := names.get(i)[0]
        counts.put(nm, i + 1)
        i = i + 1
    end
    __ counts.get("sara")
    __ names.get(0)[0]
    __ names.pop()
    __ names.len()
end
