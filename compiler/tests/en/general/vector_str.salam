func main:
    mut names := Vector {} as Vector<str> defer names.free()
    names.push("ali")
    names.push("sara")
    names.push("reza")
    println names.len()
    mut counts := HashMap {} as HashMap<str, int> mut i := 0
    until i < names.len():
        nm := names.get(i)[0]
        counts.put(nm, i + 1)
        i = i + 1
    end
    println counts.get("sara")
    println names.get(0)[0]
    println names.pop()
    println names.len()
end
