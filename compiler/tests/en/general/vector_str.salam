func main:
    mut names : Vector<str> = Vector {}
    defer names.free()
    names.push("ali")
    names.push("sara")
    names.push("reza")
    __ names.len()
    mut counts : HashMap<str, int> = HashMap {}
    mut i = 0
    while i < names.len():
        nm : str = names.get(i)[0]
        counts.put(nm, i + 1)
        i = i + 1
    end
    __ counts.get("sara")
    __ names.get(0)[0]
    __ names.pop()
    __ names.len()
end
