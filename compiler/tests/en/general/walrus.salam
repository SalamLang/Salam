g name := "salam"
g limit := 40 as i64
func main:
    name := "Ali"
    age := 20
    pi := 3.14
    flag := true
    big := 0 - 1 as i64
    small := 200 as u8
    nums := [] as int[]
    names := [] as str[]
    filled := [7, 8, 9]
    mut counter := 0
    counter = counter + 1
    counter += 2
    mut total := 0 as i64
    total = total + (counter as i64)
    println (name, age, pi, flag)
    println (big, small)
    println (len(nums), len(names), len(filled), filled[2])
    println (counter, total)
    println (g name, g limit)
end
