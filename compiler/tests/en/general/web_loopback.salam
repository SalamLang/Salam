import (
    "web" "net" "str" "time"
)

func home_h(ctx : i64):
    web.Ctx_html(ctx, "web-ok")
end

func json_h(ctx : i64):
    web.Ctx_json(ctx, "42")
end

func param_h(ctx : i64):
    id : str = web.Ctx_param(ctx, "id")
    web.Ctx_text(ctx, "id=" + id)
end

func run_web():
    mut r : web.Router = web.NewRouter()
    web.Get(r, "/", funcptr(home_h))
    web.Get(r, "/json", funcptr(json_h))
    web.Get(r, "/item/:id", funcptr(param_h))
    s : web.Server = web.NewServer(19204)
    web.Use(s, r)
    web.Run(s)
end

func get_resp(path : str) : str:
    sock : net.Socket = net.Connect("127.0.0.1", 19204)
    if !net.Ok(sock):
        ret ""
    end
    net.Send(sock, "GET " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    resp : str = net.Recv(sock, 8192)
    net.Close(sock)
    ret resp
end

func main:
    _t : i64 = spawn(run_web)
    time.Sleep(150)
    r1 : str = get_resp("/")
    __ str.Contains(r1, "web-ok")
    __ str.Contains(r1, "text/html")
    r2 : str = get_resp("/json")
    __ str.Contains(r2, "42")
    __ str.Contains(r2, "application/json")
    r3 : str = get_resp("/item/99")
    __ str.Contains(r3, "id=99")
    r4 : str = get_resp("/missing")
    __ str.Contains(r4, "404")
end
