import web
import net
import str
import time

func home h(ctx : i64):
    web.Ctx html(ctx, "web-ok")
end

func json h(ctx : i64):
    web.Ctx json(ctx, "42")
end

func param h(ctx : i64):
    id := web.Ctx param(ctx, "id")
    web.Ctx text(ctx, "id=" + id)
end

func run web():
    mut r := web.NewRouter()
    web.Get(r, "/", funcptr(home h))
    web.Get(r, "/json", funcptr(json h))
    web.Get(r, "/item/:id", funcptr(param h))
    s := web.NewServer(19204)
    web.Use(s, r)
    web.Run(s)
end

func get resp(path : str) : str:
    mut sock := net.Connect("127.0.0.1", 19204)
    mut tries := 0
    until !net.Ok(sock) && tries < 200:
        time.Sleep(10)
        sock = net.Connect("127.0.0.1", 19204)
        tries = tries + 1
    end
    if !net.Ok(sock):
        ret ""
    end
    net.Send(sock, "GET " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    resp := net.Recv(sock, 8192)
    net.Close(sock)
    ret resp
end

func main:
    _t := spawn(run web)
    r1 := get resp("/")
    println str.Contains(r1, "web-ok")
    println str.Contains(r1, "text/html")
    r2 := get resp("/json")
    println str.Contains(r2, "42")
    println str.Contains(r2, "application/json")
    r3 := get resp("/item/99")
    println str.Contains(r3, "id=99")
    r4 := get resp("/missing")
    println str.Contains(r4, "404")
end
