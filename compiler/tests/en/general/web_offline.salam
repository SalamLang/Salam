import web

func h_dummy(_ctx : i64): ret end

func main:
    r0 := web.NewRouter()
    println r0.routes.len() == 0
    mut r := web.NewRouter()
    web.Get(r, "/", funcptr(h_dummy))
    web.Post(r, "/items", funcptr(h_dummy))
    println r.routes.len() == 2
    println r.has_static == false
    web.Static(r, "/static/", "./public")
    println r.has_static == true
    println r.static_prefix == "/static/"
    s := web.NewServer(8080)
    println s.port == 8080
    println s.hide_tokens == false
end
