import (
    "web" "net" "str" "time"
)

func get_h(ctx i64): web.Ctx_text(ctx, "GET-ok") end

func post_h(ctx i64): web.Ctx_text(ctx, "POST-ok") end

func put_h(ctx i64):
    web.Ctx_text(ctx, "PUT-ok id=" + web.Ctx_param(ctx, "id"))
end

func del_h(ctx i64):
    web.Ctx_text(ctx, "DELETE-ok id=" + web.Ctx_param(ctx, "id"))
end

func run_web():
    mut r web.Router = web.NewRouter()
    web.Get(r, "/res", funcptr(get_h))
    web.Post(r, "/res", funcptr(post_h))
    web.Put(r, "/res/:id", funcptr(put_h))
    web.Delete(r, "/res/:id", funcptr(del_h))
    s web.Server = web.NewServer(19206)
    web.Use(s, r)
    web.Run(s)
end

func req(method str, path str) str:
    sock net.Socket = net.Connect("127.0.0.1", 19206)
    if !net.Ok(sock):
        ret ""
    end
    net.Send(sock, method + " " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    resp str = net.Recv(sock, 8192)
    net.Close(sock)
    ret resp
end

func main:
    _t i64 = spawn(run_web)
    time.Sleep(150)

    __ str.Contains(req("GET", "/res"), "GET-ok")
    __ str.Contains(req("POST", "/res"), "POST-ok")

    __ str.Contains(req("PUT", "/res/7"), "PUT-ok id=7")
    __ str.Contains(req("DELETE", "/res/9"), "DELETE-ok id=9")

    __ str.Contains(req("PUT", "/res"), "404")
    __ str.Contains(req("GET", "/res/7"), "404")
end
