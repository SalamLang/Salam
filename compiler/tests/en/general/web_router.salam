import web
import net
import str
import time

func get h(ctx : i64): web.Ctx text(ctx, "GET-ok") end

func post h(ctx : i64): web.Ctx text(ctx, "POST-ok") end

func put h(ctx : i64):
    web.Ctx text(ctx, "PUT-ok id=" + web.Ctx param(ctx, "id"))
end

func del h(ctx : i64):
    web.Ctx text(ctx, "DELETE-ok id=" + web.Ctx param(ctx, "id"))
end

func run web():
    mut r := web.NewRouter()
    web.Get(r, "/res", funcptr(get h))
    web.Post(r, "/res", funcptr(post h))
    web.Put(r, "/res/:id", funcptr(put h))
    web.Delete(r, "/res/:id", funcptr(del h))
    s := web.NewServer(19206)
    web.Use(s, r)
    web.Run(s)
end

func req(method : str, path : str) : str:
    mut sock := net.Connect("127.0.0.1", 19206)
    mut tries := 0
    until !net.Ok(sock) && tries < 200:
        time.Sleep(10)
        sock = net.Connect("127.0.0.1", 19206)
        tries = tries + 1
    end
    if !net.Ok(sock):
        ret ""
    end
    net.Send(sock, method + " " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    resp := net.Recv(sock, 8192)
    net.Close(sock)
    ret resp
end

func main:
    _t := spawn(run web)

    println str.Contains(req("GET", "/res"), "GET-ok")
    println str.Contains(req("POST", "/res"), "POST-ok")

    println str.Contains(req("PUT", "/res/7"), "PUT-ok id=7")
    println str.Contains(req("DELETE", "/res/9"), "DELETE-ok id=9")

    println str.Contains(req("PUT", "/res"), "404")
    println str.Contains(req("GET", "/res/7"), "404")
end
