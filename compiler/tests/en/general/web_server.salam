import (
    "web" "web/validate" "web/middleware" "net" "str" "time"
)
func echo_h(ctx i64):
    body str = web.Ctx_body(ctx)
    web.Ctx_text(ctx, "got:" + body)
end

func query_h(ctx i64):
    name str = web.Ctx_query(ctx, "name")
    web.Ctx_text(ctx, "hi " + name)
end

func secure_h(ctx i64):
    middleware.Secure(ctx)
    web.Ctx_text(ctx, "secure")
end

func redirect_h(ctx i64):
    web.Ctx_redirect(ctx, "/dest")
end

func signup_h(ctx i64):
    email str = web.Ctx_form(ctx, "email")
    if validate.IsEmail(email):
        web.Ctx_text(ctx, "email-ok")
    else:
        web.Ctx_status(ctx, 400)
        web.Ctx_text(ctx, "bad-email")
    end
end

func created_h(ctx i64):
    web.Ctx_status(ctx, 201)
    web.Ctx_json(ctx, "{\"ok\":true}")
end

func run_web():
    mut r web.Router = web.NewRouter()
    web.Post(r, "/echo", funcptr(echo_h))
    web.Get(r, "/q", funcptr(query_h))
    web.Get(r, "/sec", funcptr(secure_h))
    web.Get(r, "/go", funcptr(redirect_h))
    web.Post(r, "/signup", funcptr(signup_h))
    web.Get(r, "/create", funcptr(created_h))
    s web.Server = web.NewServer(19205)
    web.Use(s, r)
    web.Run(s)
end

func send_raw(req str) str:
    sock net.Socket = net.Connect("127.0.0.1", 19205)
    if !net.Ok(sock):
        ret ""
    end
    net.Send(sock, req)
    resp str = net.Recv(sock, 8192)
    net.Close(sock)
    ret resp
end

func post(path str, body str) str:
    req str = "POST " + path + " HTTP/1.0\r\nHost: localhost\r\nContent-Length: " + str.FromInt(len(body) as i64) + "\r\n\r\n" + body
    ret send_raw(req)
end

func get(path str) str:
    ret send_raw("GET " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
end

func main:
    _t i64 = spawn(run_web)
    time.Sleep(150)

    r1 str = post("/echo", "hello")
    __ str.Contains(r1, "got:hello")

    r2 str = get("/q?name=Sara")
    __ str.Contains(r2, "hi Sara")

    r3 str = get("/sec")
    __ str.Contains(r3, "X-Frame-Options: DENY")
    __ str.Contains(r3, "secure")

    r4 str = get("/go")
    __ str.Contains(r4, "302")
    __ str.Contains(r4, "Location: /dest")

    r5 str = post("/signup", "email=a@b.com")
    __ str.Contains(r5, "email-ok")
    r6 str = post("/signup", "email=nope")
    __ str.Contains(r6, "400")
    __ str.Contains(r6, "bad-email")

    r7 str = get("/create")
    __ str.Contains(r7, "201")
    __ str.Contains(r7, "application/json")
end
