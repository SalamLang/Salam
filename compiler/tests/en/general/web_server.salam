import web
import web.validate
import web.middleware
import net
import str
import time

func echo_h(ctx: i64):
    body := web.Ctx_body(ctx)
    web.Ctx_text(ctx, "got:" + body)
end

func query_h(ctx: i64):
    name := web.Ctx_query(ctx, "name")
    web.Ctx_text(ctx, "hi " + name)
end

func secure_h(ctx: i64):
    middleware.Secure(ctx)
    web.Ctx_text(ctx, "secure")
end

func redirect_h(ctx: i64):
    web.Ctx_redirect(ctx, "/dest")
end

func signup_h(ctx: i64):
    email := web.Ctx_form(ctx, "email")
    if validate.IsEmail(email):
        web.Ctx_text(ctx, "email-ok")
    else:
        web.Ctx_status(ctx, 400)
        web.Ctx_text(ctx, "bad-email")
    end
end

func created_h(ctx: i64):
    web.Ctx_status(ctx, 201)
    web.Ctx_json(ctx, "{\"ok\":true}")
end

func run_web():
    mut r := web.NewRouter()
    web.Post(r, "/echo", funcptr(echo_h))
    web.Get(r, "/q", funcptr(query_h))
    web.Get(r, "/sec", funcptr(secure_h))
    web.Get(r, "/go", funcptr(redirect_h))
    web.Post(r, "/signup", funcptr(signup_h))
    web.Get(r, "/create", funcptr(created_h))
    s := web.NewServer(19205)
    web.Use(s, r)
    web.Run(s)
end

func send_raw(req: str): str:
    mut sock := net.Connect("127.0.0.1", 19205)
    mut tries := 0
    until !net.Ok(sock) && tries < 200:
        time.Sleep(10)
        sock = net.Connect("127.0.0.1", 19205)
        tries = tries + 1
    end
    if !net.Ok(sock):
        ret ""
    end
    net.Send(sock, req)
    resp := net.Recv(sock, 8192)
    net.Close(sock)
    ret resp
end

func post(path: str, body: str): str:
    req := "POST " + path + " HTTP/1.0\r\nHost: localhost\r\nContent-Length: " + str.FromInt(len(body) as i64) + "\r\n\r\n" + body
    ret send_raw(req)
end

func get(path: str): str:
    ret send_raw("GET " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
end

func main:
    _t := spawn(run_web)

    r1 := post("/echo", "hello")
    println str.Contains(r1, "got:hello")

    r2 := get("/q?name=Sara")
    println str.Contains(r2, "hi Sara")

    r3 := get("/sec")
    println str.Contains(r3, "X-Frame-Options: DENY")
    println str.Contains(r3, "secure")

    r4 := get("/go")
    println str.Contains(r4, "302")
    println str.Contains(r4, "Location: /dest")

    r5 := post("/signup", "email=a@b.com")
    println str.Contains(r5, "email-ok")
    r6 := post("/signup", "email=nope")
    println str.Contains(r6, "400")
    println str.Contains(r6, "bad-email")

    r7 := get("/create")
    println str.Contains(r7, "201")
    println str.Contains(r7, "application/json")
end
