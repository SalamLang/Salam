import web

func main:
    println web.UrlDecode("a%20b") == "a b"
    println web.UrlDecode("a+b") == "a b"
    println web.UrlDecode("100%25") == "100%"
    println web.UrlDecode("name=Ali%20Reza") == "name=Ali Reza"
    println web.UrlDecode("plain") == "plain"

    println web.MimeExt("html") == "text/html; charset=utf-8"
    println web.MimeExt("css") == "text/css"
    println web.MimeExt("js") == "application/javascript"
    println web.MimeExt("png") == "image/png"
    println web.MimeExt("unknownext") == "application/octet-stream"

    println web.MimeType("/assets/site.css") == "text/css"
    println web.MimeType("/img/logo.png") == "image/png"
    println web.MimeType("archive.tar.gz") == "application/octet-stream"
    println web.MimeType("noextension") == "application/octet-stream"

    println web.StatusText(200) == "OK"
    println web.StatusText(201) == "Created"
    println web.StatusText(404) == "Not Found"
    println web.StatusText(500) == "Internal Server Error"
    println web.StatusText(799) == "Unknown"

    println web.SERVER_VERSION == "0.2.0"
end
