import "web/validate"
func main:
    println validate.Required("hello") == true
    println validate.Required("") == false

    println validate.Length("abc", 1, 5) == true
    println validate.Length("abc", 3, 3) == true
    println validate.Length("", 1, 5) == false
    println validate.Length("toolong", 1, 5) == false

    println validate.IsEmail("user@example.com") == true
    println validate.IsEmail("no-at-sign.com") == false
    println validate.IsEmail("no-dot@example") == false
    println validate.IsEmail("") == false
end
