import "web/validate"
func main:
    __ validate.Required("hello") == true
    __ validate.Required("") == false

    __ validate.Length("abc", 1, 5) == true
    __ validate.Length("abc", 3, 3) == true
    __ validate.Length("", 1, 5) == false
    __ validate.Length("toolong", 1, 5) == false

    __ validate.IsEmail("user@example.com") == true
    __ validate.IsEmail("no-at-sign.com") == false
    __ validate.IsEmail("no-dot@example") == false
    __ validate.IsEmail("") == false
end
