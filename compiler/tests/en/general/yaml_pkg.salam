import yaml

func main:
    // --- encoding (flow-style builders) ---
    println yaml.Str("hi \"there\"")
    println yaml.Member("name", "salam")
    println yaml.MemberInt("age", 5)
    println yaml.MemberBool("ok", true)
    println yaml.MemberFloat("pi", 3.5)
    println yaml.MemberRaw("raw", "[1, 2, 3]")

    mut tags := Vector {} as Vector<str>
    tags.push(yaml.Str("a"))
    tags.push(yaml.Str("b"))
    tags_yaml := yaml.Array(tags)
    println tags_yaml

    mut point := Vector {} as Vector<str>
    point.push(yaml.MemberInt("x", 1))
    point.push(yaml.MemberInt("y", 2))
    point_yaml := yaml.Object(point)
    println point_yaml

    mut doc := Vector {} as Vector<str>
    doc.push(yaml.Member("name", "salam"))
    doc.push(yaml.MemberInt("version", 2))
    doc.push(yaml.MemberBool("active", true))
    doc.push(yaml.MemberRaw("tags", tags_yaml))
    doc.push(yaml.MemberRaw("point", point_yaml))
    doc_yaml := yaml.Object(doc)
    println doc_yaml

    // --- decoding block-style YAML ---
    block := "name: salam\nversion: 2\nactive: true\ntags:\n  - a\n  - b\npoint:\n  x: 1\n  y: 2\n"
    println yaml.Parse(block)
    println yaml.ToJSON(block) == yaml.Parse(block)

    // --- validation ---
    println yaml.Valid(block)
    println yaml.Valid("{ not: valid")
    println yaml.Valid("[1, 2")
    println yaml.Valid("\"unterminated")

    // --- queries ---
    println yaml.Get(block, "name")
    println yaml.GetInt(block, "version")
    println yaml.GetBool(block, "active")
    println yaml.Get(block, "tags[0]")
    println yaml.Get(block, "tags[1]")
    println yaml.GetInt(block, "point.x")
    println yaml.GetInt(block, "point.y")
    println yaml.Has(block, "point.y")
    println yaml.Has(block, "missing")
    println yaml.TypeOf(block, "tags")
    println yaml.TypeOf(block, "point")
    println yaml.TypeOf(block, "name")
    println yaml.TypeOf(block, "version")
    println yaml.TypeOf(block, "missing")
    println yaml.Len(block, "tags")

    mut req := Vector {} as Vector<str>
    req.push("name")
    req.push("version")
    println yaml.HasKeys(block, req)
    req.push("missing")
    println yaml.HasKeys(block, req)

    // --- flow style ---
    flowdoc := "{a: 1, b: [1, 2, 3], c: {x: true, y: null}}"
    println yaml.Parse(flowdoc)

    // --- quoted scalars ---
    qdoc := "title: 'it''s here'\nurl: \"http://x:80/a#b\"\n"
    println yaml.Parse(qdoc)

    // --- block scalars ---
    bsdoc := "desc: |\n  line one\n  line two\nfolded: >\n  a b\n  c d\n"
    println yaml.Parse(bsdoc)

    // --- list of maps ---
    lom := "items:\n  - name: a\n    val: 1\n  - name: b\n    val: 2\n"
    println yaml.Parse(lom)
    println yaml.Get(lom, "items[1].name")
    println yaml.GetInt(lom, "items[0].val")

    // --- multi-document ---
    multi := "a: 1\n---\nb: 2\n"
    docs := yaml.SplitDocuments(multi)
    println docs.len()
    println yaml.Parse(docs.get(0)[0])
    println yaml.Parse(docs.get(1)[0])

    // --- dump (canonical block-style output) ---
    println yaml.Dump(doc_yaml)
    println yaml.DumpWith(doc_yaml, "    ")
    println yaml.DumpTabs(doc_yaml)

    // --- round-trip: dump then parse back equals original parse ---
    println yaml.Parse(yaml.Dump(block)) == yaml.Parse(block)
end
