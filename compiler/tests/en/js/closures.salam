func make adder(n : int) : func (int) int:
    ret (value : int) => value + n
end

func main:
    double := (count : int) => count * 2
    println double(21)
    add10 := make adder(10)
    println add10(5)
    mut base := 100
    bump := () =>:
        base = base + 1
    end
    bump()
    bump()
    println base
end
