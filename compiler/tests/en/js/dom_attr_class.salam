import dom

func main:
    el := dom.Create("span")
    dom.Append(dom.Body(), el)
    dom.SetAttr(el, "data-role", "tag")
    println dom.GetAttr(el, "data-role")

    dom.AddClass(el, "card")
    dom.AddClass(el, "big")
    println dom.GetAttr(el, "class")

    dom.ToggleClass(el, "big")
    println dom.GetAttr(el, "class")

    dom.ToggleClass(el, "big")
    println dom.GetAttr(el, "class")

    dom.RemoveClass(el, "card")
    println dom.GetAttr(el, "class")
end
