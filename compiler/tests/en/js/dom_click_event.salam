import dom

mut clicks := 0

func main:
    btn := dom.Create("button")
    dom.SetAttr(btn, "id", "btn")
    dom.SetAttr(btn, "data-autofire", "click")
    dom.Append(dom.Body(), btn)
    dom.OnEvent(
        btn, "click", (): clicks = clicks + 1 println "clicked" end
    )
    println "before"
    println clicks
end
