import dom

func main:
    el := dom.Create("div")
    dom.SetAttr(el, "id", "surface")
    dom.SetAttr(el, "data-autofire", "keydown")
    dom.SetAttr(el, "data-autofire-key", "Enter")
    dom.SetAttr(el, "data-autofire-x", "12")
    dom.SetAttr(el, "data-autofire-y", "34")
    dom.Append(dom.Body(), el)
    dom.OnEventE(
        el, "keydown", (ev: i64): println dom.EventKey(ev) println dom.EventX(ev) println dom.EventY(ev) dom.PreventDefault(ev) println "handled" end
    )
    println "ready"
end
