import dom

func main:
    dom.SetTitle("Salam Page")

    obj := dom.Body()
    dom.SetNum(obj, "score", 9.5)
    println dom.GetNum(obj, "score")
    dom.SetStr(obj, "label", "top")
    println dom.GetStr(obj, "label")
    dom.SetBool(obj, "active", true)
    println dom.GetBool(obj, "active")

    ok := dom.Confirm("proceed?")
    println ok
    answer := dom.Prompt("your name?")
    println answer
end
