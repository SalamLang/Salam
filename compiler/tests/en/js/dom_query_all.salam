import dom

func main:
    repeat 3 with n:
        item := dom.Create("li")
        dom.SetAttr(item, "class", "row")
        dom.SetText(item, "item")
        dom.Append(dom.Body(), item)
    end
    all := dom.QueryAll(".row")
    println dom.CountOf(all)
    first := dom.ItemAt(all, 0)
    println dom.GetText(first)
end
