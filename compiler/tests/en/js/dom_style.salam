import dom

func main:
    el := dom.Create("div")
    dom.Append(dom.Body(), el)
    dom.SetStyle(el, "color", "red")
    dom.SetStyle(el, "font-size", "12px")
    println dom.GetStyle(el, "color")
    println dom.GetStyle(el, "font-size")
    dom.SetStyle(el, "color", "blue")
    println dom.GetStyle(el, "color")
end
