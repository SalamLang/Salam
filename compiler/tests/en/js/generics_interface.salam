interface Describable:
    func label(): str
    func score(): int
end

impl Describable on int:
    func label(): str: ret "number" end
    func score(): int: ret this * 10 end
end

impl Describable on bool:
    func label(): str: ret "flag" end
    func score(): int:
        if this: ret 1 end
        ret 0
    end
end

func show<T: Describable>(value: T):
    println value.label()
    println value.score()
end

func main:
    show(7)
    show(true)
    show(false)
end
