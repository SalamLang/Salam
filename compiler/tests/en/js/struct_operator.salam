struct Vector2:
    pub x : int = 0
    pub y : int = 0
    pub func operator + (other : Vector2) : Vector2:
        ret Vector2 { x = this.x + other.x, y = this.y + other.y }
    end
    pub func operator == (other : Vector2) : bool:
        ret this.x == other.x && this.y == other.y
    end
end

func main:
    a := Vector2 { x = 3, y = 4 }
    b := Vector2 { x = 1, y = 2 }
    c := a + b
    println c.x
    println c.y
    a2 := Vector2 { x = 3, y = 4 }
    println a == a2
    println a == b
end
