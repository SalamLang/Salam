struct Box:
    pub label: str
    pub value: Variant<i32, str, bool>
end

func describe(v: Variant<i32, str, bool>): str:
    ret match v:
        i32 n => "int:" + n
        str s => "str:" + s
        bool b => "bool:" + b
    end
end

func main:
    mut x := 42 as Variant<i32, str, bool>
    println describe(x)
    x = "hello"
    println describe(x)
    x = true
    println describe(x)

    b := Box { label = "a", value = 7 }
    println b.label + ":" + describe(b.value)
end
