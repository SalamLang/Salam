func main:
    mut a : i32 = 10
    a += 5
    println(a)
    a -= 3
    println(a)
    a *= 2
    println(a)
    a /= 4
    println(a)
    a %= 5
    println(a)

    mut u : u32 = 100
    u += 50
    u -= 20
    println(u)

    mut p : f64 = 2.0
    p **= 8
    println(p)

    mut n : i64 = 1000000000000
    n += 1
    println(n)
end
