interface Shape:
    func area() : f64
    func name() : str
end

struct Circle:
    pub r : f64 = 0.0
    pub func area() : f64: ret 3.14159 * this.r * this.r end
    pub func name() : str: ret "circle" end
end

struct Rect:
    pub w : f64 = 0.0
    pub h : f64 = 0.0
    pub func area() : f64: ret this.w * this.h end
    pub func name() : str: ret "rect" end
end

func describe(s : dyn Shape):
    __ s.name() + " area=" + s.area()
end

func main:
    mut c := Circle { r = 2.0 } as dyn Shape
    mut r := Rect { w = 3.0, h = 4.0 } as dyn Shape
    describe(c)
    describe(r)
    __ c.area()
end
