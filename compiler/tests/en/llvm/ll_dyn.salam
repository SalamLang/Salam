interface Shape:
    func area() f64
    func name() str
end
struct Circle:
    r f64 = 0.0
    func area() f64: ret 3.14159 * this.r * this.r end
    func name() str: ret "circle" end
end
struct Rect:
    w f64 = 0.0
    h f64 = 0.0
    func area() f64: ret this.w * this.h end
    func name() str: ret "rect" end
end

func describe(s dyn Shape):
    __ s.name() + " area=" + s.area()
end

func main:
    mut c dyn Shape = Circle { r = 2.0 }
    mut r dyn Shape = Rect { w = 3.0, h = 4.0 }
    describe(c)
    describe(r)
    __ c.area()
end
