inline pure func square(x i32) i32: ret x * x end

noinline func triple(x i32) i32: ret x * 3 end

pure func fib(n i32) i32:
    if n < 2: ret n end
    ret fib(n - 1) + fib(n - 2)
end

pub inline pure func area(w f64, h f64) f64: ret w * h end

pub deprecated func old_next(x i32) i32: ret x + 1 end

func main:
    println(square(6))
    println(triple(4))
    println(fib(10))
    println(area(2.5, 4.0))
    println(old_next(41))
end
