inline pure func square(x : int) : int: ret x * x end

noinline func triple(x : int) : int: ret x * 3 end

pure func fib(n : int) : int:
    if n < 2: ret n end
    ret fib(n - 1) + fib(n - 2)
end

pub inline pure func area(w : f64, h : f64) : f64: ret w * h end

pub deprecated func old next(x : int) : int: ret x + 1 end

func main:
    println square(6)
    println triple(4)
    println fib(10)
    println area(2.5, 4.0)
    println old next(41)
end
