extern "C":
    func malloc(size u64) void*
    func free(ptr void*)
end
interface Hashable:
    func hash() u64
end
impl Hashable for i32:
    func hash() u64:
        ret (this * 2654435761) as u64
    end
end
struct Map<K: Hashable, V>:
    keys K* = null
    vals V* = null
    used i32* = null
    cap i32 = 0
    count i32 = 0
    func init(c i32):
        this.cap = c
        this.keys = malloc((c as u64) * sizeof(K)) as K*
        this.vals = malloc((c as u64) * sizeof(V)) as V*
        this.used = malloc((c as u64) * sizeof(i32)) as i32*
        for mut i i32 = 0; i < c; i = i + 1:
            mut up i32* = (this.used as i64 + (i as i64) * 4) as i32*
            up[0] = 0
        end
    end
    func slot(k K) i32:
        mut h i32 = (k.hash() as i32) % this.cap
        if h < 0: h = h + this.cap end
        ret h
    end
    func put(k K, v V):
        mut i i32 = this.slot(k)
        mut kp K* = (this.keys as i64 + (i as i64) * (sizeof(K) as i64)) as K*
        mut vp V* = (this.vals as i64 + (i as i64) * (sizeof(V) as i64)) as V*
        mut up i32* = (this.used as i64 + (i as i64) * 4) as i32*
        kp[0] = k
        vp[0] = v
        up[0] = 1
    end
    func get(k K) V:
        mut i i32 = this.slot(k)
        mut vp V* = (this.vals as i64 + (i as i64) * (sizeof(V) as i64)) as V*
        ret vp[0]
    end
end
func main:
    mut m Map<i32, i32> = Map {}
    m.init(16)
    m.put(3, 30)
    m.put(7, 70)
    m.put(11, 110)
    __ m.get(3)
    __ m.get(7)
    __ m.get(11)
end
