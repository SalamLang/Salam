extern:
    func malloc(size : u64) : void*
    func free(ptr : void*)
end
interface Hashable:
    func hash() : u64
end
impl Hashable on int:
    func hash() : u64:
        ret (this * 2654435761) as u64
    end
end

struct Map<K: Hashable, V>:
        pub keys : K* = null
        pub vals : V* = null
        pub used : int* = null
        pub cap : int = 0
        pub count : int = 0
        pub func init(c : int):
            this.cap = c
            this.keys = malloc((c as u64) * sizeof(K)) as K*
            this.vals = malloc((c as u64) * sizeof(V)) as V*
            this.used = malloc((c as u64) * sizeof(int)) as int*
            repeat c with i:
                mut up := (this.used as i64 + (i as i64) * 4) as int*
                up[0] = 0
            end
        end
        pub func slot(k : K) : int:
            mut h := (k.hash() as int) % this.cap
            if h < 0: h = h + this.cap end
            ret h
        end
        pub func put(k : K, v : V):
            i := this.slot(k)
            mut kp := (this.keys as i64 + (i as i64) * (sizeof(K) as i64)) as K*
            mut vp := (this.vals as i64 + (i as i64) * (sizeof(V) as i64)) as V*
            mut up := (this.used as i64 + (i as i64) * 4) as int*
            kp[0] = k
            vp[0] = v
            up[0] = 1
        end
        pub func get(k : K) : V:
            i := this.slot(k)
            vp := (this.vals as i64 + (i as i64) * (sizeof(V) as i64)) as V*
            ret vp[0]
        end
    end
    func main:
        mut m := Map {} as Map<int, int>
        m.init(16)
        m.put(3, 30)
        m.put(7, 70)
        m.put(11, 110)
        println m.get(3)
        println m.get(7)
        println m.get(11)
    end
