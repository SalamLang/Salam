func main:
    mut i : i32 = 1
    while i < 5:
        i++
    end
    println(i)

    mut a : i32 = 10
    println(a++)
    println(a)
    println(++a)
    println(a)
    println(a--)
    println(a)
    println(--a)
    println(a)

    mut s : i32 = 0
    for mut k = 0, k < 5, k++:
        s += k
    end
    println(s)

    mut f : f64 = 1.5
    f++
    f--
    f++
    println(f)

    mut arr = [1, 2, 3]
    arr[0]++
    arr[2]--
    println(arr[0])
    println(arr[2])

    mut n : i32 = 3
    println(n++ + 10)
    println(n)
end
