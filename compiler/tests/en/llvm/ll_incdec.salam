func main:
    mut i := 1
    until i < 5:
        i++
    end
    println i

    mut a := 10
    println a++
    println a
    println++a
    println a
    println a--
    println a
    println--a
    println a

    mut s := 0
    repeat 5 with k:
        s += k
    end
    println s

    mut f := 1.5
    f++
    f--
    f++
    println f

    mut arr := [1, 2, 3]
    arr[0]++
    arr[2]--
    println arr[0]
    println arr[2]

    mut n := 3
    println n++ + 10
    println n
end
