func apply(f func (i32) i32, x i32) i32:
    ret f(x)
end
func adder(base i32) func (i32) i32:
    ret (x i32) =>:
        ret x + base
    end
end
func main:
    sq func (i32) i32 = (a i32) =>: ret a * a end
    __ sq(6)
    __ apply(sq, 7)
    add10 func (i32) i32 = adder(10)
    __ add10(5)
    __ add10(20)
    mut k i32 = 100
    addk func (i32) i32 = (a i32) =>: ret a + k end
    __ addk(1)
end
