func apply(f : func (int) int, x : int) : int:
    ret f(x)
end

func adder(base : int) : func (int) int:
    ret (x : int) =>:
        ret x + base
    end
end

func main:
    sq : func (int) int = (a : int) =>: ret a * a end
    __ sq(6)
    __ apply(sq, 7)
    add10 : func (int) int = adder(10)
    __ add10(5)
    __ add10(20)
    mut k : int = 100
    addk : func (int) int = (a : int) =>: ret a + k end
    __ addk(1)
end
