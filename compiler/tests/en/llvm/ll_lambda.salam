func apply(f : func (int) int, x : int) : int:
    ret f(x)
end

func adder(base : int) : func (int) int:
    ret (x : int) =>:
        ret x + base
    end
end

func main:
    sq := (a : int) =>: ret a * a end
    println sq(6)
    println apply(sq, 7)
    add10 := adder(10)
    println add10(5)
    println add10(20)
    k := 100
    addk := (a : int) =>: ret a + k end
    println addk(1)
end
