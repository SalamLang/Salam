func apply(f : func (int) int, x : int) : int:
    ret f(x)
end

func adder(base : int) : func (int) int:
    ret (x : int) =>:
        ret x + base
    end
end

func main:
    sq := (a : int) =>: ret a * a end
    __ sq(6)
    __ apply(sq, 7)
    add10 := adder(10)
    __ add10(5)
    __ add10(20)
    mut k := 100
    addk := (a : int) =>: ret a + k end
    __ addk(1)
end
