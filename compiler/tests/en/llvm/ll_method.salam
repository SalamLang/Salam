struct Counter:
    pub value: int = 0
    pub step: int = 1
    pub func bump():
        this.value = this.value + this.step
    end
    pub func get(): int:
        ret value
    end
end

func main:
    mut c := Counter { value = 5, step = 3 }
    c.bump()
    c.bump()
    println c.get()
    println c.value
end
