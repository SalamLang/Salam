struct Counter:
    value : int = 0
    step : int = 1
    func bump():
        this.value = this.value + this.step
    end
    func get() : int:
        ret value
    end
end

func main:
    mut c : Counter = Counter { value = 5, step = 3 }
    c.bump()
    c.bump()
    __ c.get()
    __ c.value
end
