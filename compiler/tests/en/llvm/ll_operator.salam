struct Vec2:
    pub x : int = 0
    pub y : int = 0
    pub func operator + (o : Vec2) : Vec2:
        ret Vec2 { x = x + o.x, y = y + o.y }
    end
    pub func operator -() : Vec2:
        ret Vec2 { x = 0 - x, y = 0 - y }
    end
    pub func operator == (o : Vec2) : bool:
        ret x == o.x
    end
    pub func operator [](i : int) : int:
        if i == 0:
            ret x
        end
        ret y
    end
end

func main:
    mut a := Vec2 { x = 1, y = 2 }
    mut b := Vec2 { x = 10, y = 20 }
    mut c := a + b
    __ c.x
    __ c.y
    mut d := -a
    __ d.x
    __ d.y
    __ a == b
    __ a != b
    __ c[0]
    __ c[1]
end
