struct Box:
    v i32 = 0
end
func incr(x & i32):
    x = x + 1
end
func swap(a & i32, b & i32):
    mut t i32 = a
    a = b
    b = t
end
func grow(box & Box):
    box.v = box.v * 2
end
func main:
    mut n i32 = 5
    incr(n)
    incr(n)
    __ n
    mut p i32 = 1
    mut q i32 = 9
    swap(p, q)
    __ p
    __ q
    mut b Box = Box { v = 21 }
    grow(b)
    __ b.v
end
