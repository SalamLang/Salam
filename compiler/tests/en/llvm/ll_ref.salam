struct Box:
    pub v: int = 0
end

func incr(x &: int):
    x = x + 1
end

func swap(a &: int, b &: int):
    t := a
    a = b
    b = t
end

func grow(box &: Box):
    box.v = box.v * 2
end

func main:
    mut n := 5
    incr(n)
    incr(n)
    println n
    mut p := 1
    mut q := 9
    swap(p, q)
    println p
    println q
    mut b := Box { v = 21 }
    grow(b)
    println b.v
end
