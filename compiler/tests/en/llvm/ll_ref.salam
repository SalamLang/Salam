struct Box:
    v : int = 0
end

func incr(x & : int):
    x = x + 1
end

func swap(a & : int, b & : int):
    mut t : int = a
    a = b
    b = t
end

func grow(box & : Box):
    box.v = box.v * 2
end

func main:
    mut n : int = 5
    incr(n)
    incr(n)
    __ n
    mut p : int = 1
    mut q : int = 9
    swap(p, q)
    __ p
    __ q
    mut b : Box = Box { v = 21 }
    grow(b)
    __ b.v
end
