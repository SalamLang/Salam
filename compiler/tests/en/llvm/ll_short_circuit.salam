func noisy() bool:
    __ "side"
    ret true
end

func main:
    x i32 = 0
    // Right operand must be skipped when the left already decides the result,
    // matching the C backend and interpreter (no "side"/"and"/"bad" printed).
    if x != 0 && noisy():
        __ "and"
    end
    if x == 0 || noisy():
        __ "or"
    end
    // Guard against division by zero: 10 / x must never be evaluated here.
    if x != 0 && 10 / x > 0:
        __ "bad"
    end
    __ "done"
end
