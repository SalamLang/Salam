func sum(s : int[:]) : int:
    mut t := 0
    repeat 0 to len(s) - 1 with i:
        t = t + s[i]
    end
    ret t
end

func main:
    mut arr := [10, 20, 30, 40, 50] as int[5]
    mut s := arr[1:4]
    __ len(s)
    __ s[0], s[1], s[2]
    s[0] = 99
    __ arr[1]
    __ len(arr[:])
    pre := arr[:2]
    __ len(pre), pre[0], pre[1]
    __ sum(arr[:])
    __ sum(s)
end
