func sum(s i32[:]) i32:
    mut t i32 = 0
    for mut i i32 = 0; i < len(s); i = i + 1:
        t = t + s[i]
    end
    ret t
end

func main:
    mut arr i32[5] = [10, 20, 30, 40, 50]
    mut s auto = arr[1:4]
    __ len(s)
    __ s[0], s[1], s[2]
    s[0] = 99
    __ arr[1]
    __ len(arr[:])
    pre auto = arr[:2]
    __ len(pre), pre[0], pre[1]
    __ sum(arr[:])
    __ sum(s)
end
