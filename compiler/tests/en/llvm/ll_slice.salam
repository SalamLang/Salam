func sum(s : int[:]) : int:
    mut t := 0
    repeat 0 to len(s) - 1 with i:
        t = t + s[i]
    end
    ret t
end

func main:
    arr := [10, 20, 30, 40, 50] as int[5]
    mut s := arr[1:4]
    println len(s)
    println s[0], s[1], s[2]
    s[0] = 99
    println arr[1]
    println len(arr[:])
    pre := arr[:2]
    println len(pre), pre[0], pre[1]
    println sum(arr[:])
    println sum(s)
end
