struct Vec2:
    pub x : int = 0
    pub y : int = 0
end

func add(a : Vec2, b : Vec2) : Vec2:
    mut r : Vec2 = Vec2 { x = a.x + b.x, y = a.y + b.y }
    ret r
end

func main:
    mut a : Vec2 = Vec2 { x = 1, y = 2 }
    mut b : Vec2 = Vec2 { x = 30, y = 40 }
    mut c : Vec2 = add(a, b)
    __ c.x
    __ c.y
end
