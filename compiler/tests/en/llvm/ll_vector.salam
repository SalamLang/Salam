extern "C":
    func malloc(size u64) void*
    func realloc(ptr void*, size u64) void*
end

struct Vec<T>:
    data T* = null
    len i32 = 0
    cap i32 = 0
    func push(x T):
        if this.len >= this.cap:
            mut nc i32 = this.cap * 2
            if nc < 4: nc = 4 end
            this.data = realloc(this.data as void*, (nc as u64) * sizeof(T)) as T*
            this.cap = nc
        end
        mut p T* = (this.data as i64 + (this.len as i64) * (sizeof(T) as i64)) as T*
        p[0] = x
        this.len = this.len + 1
    end
    func get(i i32) T:
        mut p T* = (this.data as i64 + (i as i64) * (sizeof(T) as i64)) as T*
        ret p[0]
    end
    func length() i32:
        ret this.len
    end
end

func main:
    mut v Vec<i32> = Vec {}
    v.push(10)
    v.push(20)
    v.push(30)
    v.push(40)
    __ v.length()
    __ v.get(0)
    __ v.get(2)
    __ v.get(3)
    mut sum i32 = 0
    for mut i i32 = 0; i < v.length(); i = i + 1:
        sum = sum + v.get(i)
    end
    __ sum
end
