extern:
    func malloc(size : u64) : void*
    func realloc(ptr : void*, size : u64) : void*
end

struct Vec<T>:
    pub data : T* = null
    pub len : int = 0
    pub cap : int = 0
    pub func push(x : T):
        if this.len >= this.cap:
            mut nc := this.cap * 2
            if nc < 4: nc = 4 end
            this.data = realloc(this.data as void*, (nc as u64) * sizeof(T)) as T*
            this.cap = nc
        end
        mut p := (this.data as i64 + (this.len as i64) * (sizeof(T) as i64)) as T*
        p[0] = x
        this.len = this.len + 1
    end
    pub func get(i : int) : T:
        p := (this.data as i64 + (i as i64) * (sizeof(T) as i64)) as T*
        ret p[0]
    end
    pub func count() : int:
        ret this.len
    end
end

func main:
    mut v := Vec {} as Vec<int>
    v.push(10)
    v.push(20)
    v.push(30)
    v.push(40)
    println v.count()
    println v.get(0)
    println v.get(2)
    println v.get(3)
    mut sum := 0
    repeat v.count() with i:
        sum = sum + v.get(i)
    end
    println sum
end
