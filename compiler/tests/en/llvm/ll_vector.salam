extern "C":
    func malloc(size : u64) : void*
    func realloc(ptr : void*, size : u64) : void*
end

struct Vec<T>:
    pub data : T* = null
    pub len : int = 0
    pub cap : int = 0
    pub func push(x : T):
        if this.len >= this.cap:
            mut nc : int = this.cap * 2
            if nc < 4: nc = 4 end
            this.data = realloc(this.data as void*, (nc as u64) * sizeof(T)) as T*
            this.cap = nc
        end
        mut p : T* = (this.data as i64 + (this.len as i64) * (sizeof(T) as i64)) as T*
        p[0] = x
        this.len = this.len + 1
    end
    pub func get(i : int) : T:
        mut p : T* = (this.data as i64 + (i as i64) * (sizeof(T) as i64)) as T*
        ret p[0]
    end
    pub func length() : int:
        ret this.len
    end
end

func main:
    mut v : Vec<int> = Vec {}
    v.push(10)
    v.push(20)
    v.push(30)
    v.push(40)
    __ v.length()
    __ v.get(0)
    __ v.get(2)
    __ v.get(3)
    mut sum : int = 0
    for mut i : int = 0, i < v.length(), i = i + 1:
        sum = sum + v.get(i)
    end
    __ sum
end
