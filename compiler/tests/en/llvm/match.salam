enum Color:
    red
    green
    blue
end

func classify(c: Color): str:
    ret match c:
        red => "warm"
        green, blue => "cool"
    end
end

func describe(x: i32): str:
    v := match x:
        1: ret 42 end
        2: ret "str-branch" end
        else: ret true end
    end
    ret match v:
        i32 n => "int:" + n
        str s => "str:" + s
        bool b => "bool:" + b
    end
end

func main:
    println classify(Color.red)
    println classify(Color.green)
    println classify(Color.blue)

    y := match 2:
        1 => "one"
        2 => "two"
        else => "many"
    end
    println y

    println describe(1)
    println describe(2)
    println describe(99)

    mut n := 0
    until n < 3:
        match n:
            0: println "zero" end
            else:
                if n == 2:
                    break
                end
                println "other"
            end
        end
        n = n + 1
    end
    println "done"
end
