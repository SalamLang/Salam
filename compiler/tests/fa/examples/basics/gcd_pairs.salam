// زبان: فارسی
واردکردن ورودی خروجی

تابع بمم(الف: صحیح, ب: صحیح): صحیح:
    متغیر ایکس := الف
    متغیر ایگرگ := ب

    تاوقتی ایگرگ != 0:
        ت := ایگرگ
        ایگرگ = ایکس % ایگرگ
        ایکس = ت
    تمام

    بازگشت ایکس
تمام

تابع اصلی:
    تکرار 10 با i:
        بنویس "عدد اول: "

        الف := ورودی خروجی.بخوان().به صحیح()
        بنویس "عدد دوم: "

        ب := ورودی خروجی.بخوان().به صحیح()
        چاپ "ب.م.م", الف, "و", ب, "=", بمم(الف, ب)
    تمام
تمام
