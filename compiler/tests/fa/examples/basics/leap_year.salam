// زبان: فارسی
تابع کبیسه است(سال: صحیح): منطقی:
    اگر سال % 400 == 0: بازگشت درست تمام
    اگر سال % 100 == 0: بازگشت نادرست تمام
    بازگشت سال % 4 == 0
تمام

تابع اصلی:
    سالها := [1900, 2000, 2012, 2021, 2024] بعنوان صحیح[5]
    تکرار 5 با i:
        اگر کبیسه است(سالها[i]): چاپ سالها[i], "کبیسه است"
        وگرنه:
            چاپ سالها[i], "کبیسه نیست"
        تمام
    تمام
تمام
