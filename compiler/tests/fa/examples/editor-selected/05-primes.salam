//! حالت: برنامه | عنوان: اعداد اول
// زبان: فارسی
تابع اول است(ن: صحیح): منطقی:
    اگر ن < 2: بازگشت نادرست تمام
    متغیر i := 2
    تاوقتی i * i <= ن:
        اگر ن % i == 0: بازگشت نادرست تمام
        i = i + 1
    تمام
    بازگشت درست
تمام

تابع اصلی:
    متغیر خط := ""
    تکرار 2 تا 30 با ن:
        اگر اول است(ن): خط = خط + ن + " " تمام
    تمام
    چاپ "اعداد اول تا ۳۰:", خط
تمام
