//! حالت: برنامه | عنوان: ساختار: مستطیل
// زبان: فارسی
ساختار مستطیل:
    طول: اعشار۶۴ = 0.0
    عرض: اعشار۶۴ = 0.0
    عمومی تابع مساحت(): اعشار۶۴: بازگشت این.طول * این.عرض تمام
    عمومی تابع محیط(): اعشار۶۴: بازگشت 2.0 * (این.طول + این.عرض) تمام
تمام

تابع اصلی:
    ر := مستطیل { طول = 4.0, عرض = 3.0 }
    چاپ "مساحت =", ر.مساحت()
    چاپ "محیط =", ر.محیط()
تمام
