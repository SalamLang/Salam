//! حالت: برنامه | عنوان: روزهای هفته
// زبان: فارسی
شمارش روز: دوشنبه, سه_شنبه, چهارشنبه, پنجشنبه, جمعه, شنبه, یکشنبه تمام

تابع آخرهفته_است(ر: روز): منطقی: بازگشت ر == روز.شنبه یا ر == روز.یکشنبه تمام

تابع اصلی:
    ر := روز.شنبه
    چاپ "شماره‌ی روز =", ر بعنوان صحیح
    اگر آخرهفته_است(ر): چاپ "آخر هفته است"
    وگرنه:
        چاپ "روز کاری است"
    تمام
تمام
