// زبان: فارسی
ساختار خوانش:
    عمومی حسگر: رشته
    عمومی مقدار: گوناگون<صحیح, اعشار64, رشته>
تمام

تابع شرح(م: گوناگون<صحیح, اعشار64, رشته>): رشته:
    بازگشت تطبیق م:
        صحیح ن => "صحیح " + ن
        اعشار64 ع => "اعشار " + ع
        رشته خ => "خطا: " + خ
    تمام
تمام

تابع اصلی:
    متغیر نمونه := 21 بعنوان گوناگون<صحیح, اعشار64, رشته>
    چاپ شرح(نمونه)

    نمونه = 21.5
    چاپ شرح(نمونه)

    نمونه = "حسگر خاموش است"
    چاپ شرح(نمونه)

    خوانشها := [
        خوانش { حسگر = "دما", مقدار = 21.5 },
        خوانش { حسگر = "رطوبت", مقدار = 55 },
        خوانش { حسگر = "فشار", مقدار = "حسگر خاموش است" }
    ]
    متغیر ش := 0
    تاوقتی ش < 3:
        ک := خوانشها[ش]
        چاپ ک.حسگر + ": " + شرح(ک.مقدار)
        ش = ش + 1
    تمام
تمام
