    بوم.خط به(زمینه, پرچم_ایکس[مرحله] + 30.0, زمین_ایگرگ - 60.0)
    بوم.خط به(زمینه, پرچم_ایکس[مرحله] + 4.0, زمین_ایگرگ - 50.0)
    بوم.پرکن(زمینه)

    تکرار تعداد_سکه[مرحله] با ک:
