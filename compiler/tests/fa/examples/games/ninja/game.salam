            بوم.پرکن(زمینه)
        تمام
    تمام

    بوم.سبک پرشدگی(زمینه, "#cccccc")
    بوم.پرکردن مستطیل(زمینه, پرچم_ایکس[مرحله], زمین_ایگرگ - 70.0, 4.0, 70.0)
