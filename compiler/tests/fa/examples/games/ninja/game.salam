        بوم.پرکردن مستطیل(زمینه, 0.0, 0.0, عرض_بوم, ارتفاع_بوم)
        بوم.ترازبندی متن(زمینه, "center")
        بوم.قلم(زمینه, "bold 22px Vazirmatn, Tahoma, sans-serif")
        متغیر عنوان := "باختید"
        متغیر رنگ_عنوان := "#ff8080"
        اگر وضعیت == 1:
            عنوان = "مرحله تمام شد!"
            رنگ_عنوان = "#7cf7a0"
        تمام
        اگر وضعیت == 3:
            عنوان = "بازی تمام شد!"
            رنگ_عنوان = "#ffd54f"
        تمام
        بوم.سبک پرشدگی(زمینه, رنگ_عنوان)
        بوم.پرکردن متن(زمینه, عنوان, عرض_بوم * 0.5, ارتفاع_بوم * 0.5 - 10.0)
        بوم.قلم(زمینه, "13px Vazirmatn, Tahoma, sans-serif")
        بوم.سبک پرشدگی(زمینه, "#fff2e0")
        بوم.پرکردن متن(زمینه, "برای ادامه Enter را بزنید یا ضربه بزنید", عرض_بوم * 0.5, ارتفاع_بوم * 0.5 + 18.0)
