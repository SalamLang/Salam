// زبان: فارسی
واردکردن دام
واردکردن وب.بوم
واردکردن ریاضی

تاو := 6.283185307179586

نام_شکل := [
    "دایره", "بیضی", "مثلث", "مربع", "مستطیل", "لوزی", "پنج‌ضلعی", "شش‌ضلعی", "هفت‌ضلعی", "هشت‌ضلعی", "ستاره"
] بعنوان رشته[11]
اضلاع_شکل := [0, 0, 3, 4, 4, 4, 5, 6, 7, 8, 5] بعنوان صحیح[11]
چندضلعی_شاخص := [2, 3, 4, 5, 6, 7, 8, 9] بعنوان صحیح[8]
رنگ_ها := [
    "#ff6b6b", "#ffb35c", "#ffe066", "#7cf7a0", "#6ee7f5", "#7c9bff", "#c792ff", "#ff8ad1", "#f4f6ff"
] بعنوان رشته[9]

گزینه_متن: رشته[4]
گزینه_عنصر: صحیح۶۴[4]

متغیر زمینه := 0 بعنوان صحیح۶۴
متغیر هود := 0 بعنوان صحیح۶۴
متغیر جان_جعبه := 0 بعنوان صحیح۶۴
متغیر سوال_جعبه := 0 بعنوان صحیح۶۴
متغیر نوار_داخلی := 0 بعنوان صحیح۶۴
متغیر پیام := 0 بعنوان صحیح۶۴
متغیر ناحیه_بازی := 0 بعنوان صحیح۶۴
متغیر پوشش := 0 بعنوان صحیح۶۴
متغیر پیام_پایان := 0 بعنوان صحیح۶۴

عرض_بوم := 260.0
ارتفاع_بوم := 190.0

متغیر امتیاز := 0
متغیر بهترین := 0
متغیر جان := 3
متغیر دور := 0
متغیر رکورد_متوالی := 0
متغیر بهترین_متوالی := 0

متغیر شکل_جاری := 0
متغیر حالت_سوال := 0
متغیر رنگ_جاری := "#ffffff"
متغیر چرخش_جاری := 0.0
متغیر پاسخ_درست := 0

متغیر بازی_فعال := نادرست
متغیر زمان_کل := 7000.0
متغیر زمان_باقی := 7000.0

تابع نمایش_هود():
    متغیر قلب := ""
    تکرار جان با ن:
        قلب = قلب + "❤"
    تمام
    دام.تنظیم متن(هود, "امتیاز: " + امتیاز + "   بهترین: " + بهترین + "   دور: " + دور)
    دام.تنظیم متن(جان_جعبه, قلب)
تمام

تابع رسم_چندضلعی(شعاع: اعشار۶۴, تعداد: صحیح, چرخش: اعشار۶۴):
    بوم.شروع مسیر(زمینه)
    تکرار تعداد با ن:
        زاویه := چرخش + (ن بعنوان اعشار۶۴) * تاو / (تعداد بعنوان اعشار۶۴)
        ایکس := عرض_بوم * 0.5 + شعاع * ریاضی.کسینوس(زاویه)
        ایگرگ := ارتفاع_بوم * 0.5 + شعاع * ریاضی.سینوس(زاویه)
        اگر ن == 0:
            بوم.برو به(زمینه, ایکس, ایگرگ)
        وگرنه:
            بوم.خط به(زمینه, ایکس, ایگرگ)
        تمام
    تمام
    بوم.بستن مسیر(زمینه)
    بوم.پرکن(زمینه)
تمام

تابع رسم_ستاره(شعاع_بیرون: اعشار۶۴, شعاع_درون: اعشار۶۴, چرخش: اعشار۶۴):
    بوم.شروع مسیر(زمینه)
    تکرار 10 با ن:
        شعاع := ن % 2 == 0 ? شعاع_بیرون : شعاع_درون
        زاویه := چرخش + (ن بعنوان اعشار۶۴) * تاو / 10.0
        ایکس := عرض_بوم * 0.5 + شعاع * ریاضی.کسینوس(زاویه)
        ایگرگ := ارتفاع_بوم * 0.5 + شعاع * ریاضی.سینوس(زاویه)
        اگر ن == 0:
            بوم.برو به(زمینه, ایکس, ایگرگ)
        وگرنه:
            بوم.خط به(زمینه, ایکس, ایگرگ)
        تمام
    تمام
    بوم.بستن مسیر(زمینه)
    بوم.پرکن(زمینه)
تمام

تابع رسم_لوزی(نیم_عرض: اعشار۶۴, نیم_ارتفاع: اعشار۶۴):
    مرکز_ایکس := عرض_بوم * 0.5
    مرکز_ایگرگ := ارتفاع_بوم * 0.5
    بوم.شروع مسیر(زمینه)
    بوم.برو به(زمینه, مرکز_ایکس, مرکز_ایگرگ - نیم_ارتفاع)
    بوم.خط به(زمینه, مرکز_ایکس + نیم_عرض, مرکز_ایگرگ)
    بوم.خط به(زمینه, مرکز_ایکس, مرکز_ایگرگ + نیم_ارتفاع)
    بوم.خط به(زمینه, مرکز_ایکس - نیم_عرض, مرکز_ایگرگ)
    بوم.بستن مسیر(زمینه)
    بوم.پرکن(زمینه)
تمام

تابع رسم_بیضی(شعاع_ایکس: اعشار۶۴, شعاع_ایگرگ: اعشار۶۴):
    بوم.ذخیره وضعیت(زمینه)
    بوم.جابجایی مختصات(زمینه, عرض_بوم * 0.5, ارتفاع_بوم * 0.5)
    بوم.مقیاس(زمینه, شعاع_ایکس / شعاع_ایگرگ, 1.0)
    بوم.شروع مسیر(زمینه)
    بوم.کمان(زمینه, 0.0, 0.0, شعاع_ایگرگ, 0.0, تاو)
    بوم.پرکن(زمینه)
    بوم.بازگردانی وضعیت(زمینه)
تمام

تابع رسم_دایره(شعاع: اعشار۶۴):
    بوم.شروع مسیر(زمینه)
    بوم.کمان(زمینه, عرض_بوم * 0.5, ارتفاع_بوم * 0.5, شعاع, 0.0, تاو)
    بوم.پرکن(زمینه)
تمام

تابع رسم_مستطیل(نیم_عرض: اعشار۶۴, نیم_ارتفاع: اعشار۶۴):
    بوم.پرکردن مستطیل(
        زمینه, عرض_بوم * 0.5 - نیم_عرض, ارتفاع_بوم * 0.5 - نیم_ارتفاع, نیم_عرض * 2.0, نیم_ارتفاع * 2.0
    )
تمام

تابع رسم():
    بوم.سبک پرشدگی(زمینه, "#0b0f2a")
    بوم.پرکردن مستطیل(زمینه, 0.0, 0.0, عرض_بوم, ارتفاع_بوم)
    بوم.سبک پرشدگی(زمینه, رنگ_جاری)
    اگر شکل_جاری == 0:
        رسم_دایره(58.0)
    وگرنه اگر شکل_جاری == 1:
        رسم_بیضی(72.0, 46.0)
    وگرنه اگر شکل_جاری == 2:
        رسم_چندضلعی(62.0, 3, چرخش_جاری - ریاضی.پی * 0.5)
    وگرنه اگر شکل_جاری == 3:
        رسم_مستطیل(50.0, 50.0)
    وگرنه اگر شکل_جاری == 4:
        رسم_مستطیل(68.0, 40.0)
    وگرنه اگر شکل_جاری == 5:
        رسم_لوزی(52.0, 68.0)
    وگرنه اگر شکل_جاری == 6:
        رسم_چندضلعی(60.0, 5, چرخش_جاری - ریاضی.پی * 0.5)
    وگرنه اگر شکل_جاری == 7:
        رسم_چندضلعی(58.0, 6, چرخش_جاری)
    وگرنه اگر شکل_جاری == 8:
        رسم_چندضلعی(58.0, 7, چرخش_جاری - ریاضی.پی * 0.5)
    وگرنه اگر شکل_جاری == 9:
        رسم_چندضلعی(58.0, 8, چرخش_جاری)
    وگرنه:
        رسم_ستاره(60.0, 26.0, چرخش_جاری - ریاضی.پی * 0.5)
    تمام
تمام

تابع نمایش_گزینه_ها():
    تکرار 4 با ن:
        دام.تنظیم متن(گزینه_عنصر[ن], گزینه_متن[ن])
        دام.حذف کلاس(گزینه_عنصر[ن], "درست")
        دام.حذف کلاس(گزینه_عنصر[ن], "غلط")
    تمام
تمام

تابع دور_جدید():
    دور = دور + 1
    حالت_سوال = دام.تصادفی صحیح(2) بعنوان صحیح
    اگر حالت_سوال == 0:
        شکل_جاری = دام.تصادفی صحیح(11) بعنوان صحیح
    وگرنه:
        شکل_جاری = چندضلعی_شاخص[دام.تصادفی صحیح(8) بعنوان صحیح]
    تمام
    رنگ_جاری = رنگ_ها[دام.تصادفی صحیح(9) بعنوان صحیح]
    اگر شکل_جاری == 3 || شکل_جاری == 4 || شکل_جاری == 5:
        چرخش_جاری = 0.0
    وگرنه:
        چرخش_جاری = ریاضی.رادیان(دام.تصادفی صحیح(360) بعنوان اعشار۶۴)
    تمام
    پاسخ_درست = دام.تصادفی صحیح(4) بعنوان صحیح
    اگر حالت_سوال == 0:
        دام.تنظیم متن(سوال_جعبه, "نام این شکل چیست؟")
        متغیر ش := 0
        متغیر تلاش := 0
        تاوقتی ش < 4 && تلاش < 300:
            تلاش = تلاش + 1
            اگر ش == پاسخ_درست:
                گزینه_متن[ش] = نام_شکل[شکل_جاری]
                ش = ش + 1
                ادامه
            تمام
            ک := دام.تصادفی صحیح(11) بعنوان صحیح
            اگر ک == شکل_جاری: ادامه تمام
            متغیر تکراری := نادرست
            تکرار ش با م:
                اگر گزینه_متن[م] == نام_شکل[ک]: تکراری = درست تمام
            تمام
            اگر تکراری: ادامه تمام
            گزینه_متن[ش] = نام_شکل[ک]
            ش = ش + 1
        تمام
    وگرنه:
        دام.تنظیم متن(سوال_جعبه, "این شکل چند ضلع دارد؟")
        درست_عدد := اضلاع_شکل[شکل_جاری]
        متغیر ش := 0
        متغیر تلاش := 0
        تاوقتی ش < 4 && تلاش < 300:
            تلاش = تلاش + 1
            اگر ش == پاسخ_درست:
                گزینه_متن[ش] = "" + درست_عدد
                ش = ش + 1
                ادامه
            تمام
            ک := 3 + (دام.تصادفی صحیح(6) بعنوان صحیح)
            اگر ک == درست_عدد: ادامه تمام
            متغیر تکراری := نادرست
            تکرار ش با م:
                اگر گزینه_متن[م] == "" + ک: تکراری = درست تمام
            تمام
            اگر تکراری: ادامه تمام
            گزینه_متن[ش] = "" + ک
            ش = ش + 1
        تمام
    تمام
تمام

تابع دور_جدید_و_نمایش():
    اگر جان <= 0: بازگشت تمام
    دور_جدید()
    نمایش_گزینه_ها()
    زمان_کل = 7000.0 - (دور بعنوان اعشار۶۴) * 150.0
    اگر زمان_کل < 3000.0: زمان_کل = 3000.0 تمام
    زمان_باقی = زمان_کل
    دام.تنظیم متن(پیام, "شکل را بشناس!")
    بازی_فعال = درست
تمام

تابع پایان_بازی():
    بازی_فعال = نادرست
    اگر امتیاز > بهترین:
        بهترین = امتیاز
        دام.تنظیم عدد ذخیره("salam shapequiz best", بهترین بعنوان صحیح۶۴)
    تمام
    دام.تنظیم متن(پیام_پایان, "امتیاز نهایی: " + امتیاز + "   بهترین رکورد پیاپی: " + بهترین_متوالی)
    دام.تنظیم سبک(ناحیه_بازی, "display", "none")
    دام.تنظیم سبک(پوشش, "display", "block")
    نمایش_هود()
تمام

تابع کلیک_گزینه(ن: صحیح):
    اگر !بازی_فعال: بازگشت تمام
    بازی_فعال = نادرست
    اگر ن == پاسخ_درست:
        رکورد_متوالی = رکورد_متوالی + 1
        اگر رکورد_متوالی > بهترین_متوالی: بهترین_متوالی = رکورد_متوالی تمام
        امتیاز = امتیاز + 10 + رکورد_متوالی * 2
        دام.افزودن کلاس(گزینه_عنصر[ن], "درست")
        دام.صدا(880.0, 90.0)
        دام.تنظیم متن(پیام, "درسته! 🎉")
    وگرنه:
        رکورد_متوالی = 0
        جان = جان - 1
        دام.افزودن کلاس(گزینه_عنصر[ن], "غلط")
        دام.افزودن کلاس(گزینه_عنصر[پاسخ_درست], "درست")
        دام.صدا(180.0, 220.0)
        دام.تنظیم متن(پیام, "اشتباه بود! پاسخ درست: " + گزینه_متن[پاسخ_درست])
    تمام
    نمایش_هود()
    اگر جان <= 0:
        پایان_بازی()
        بازگشت
    تمام
    دام.تنظیم مهلت(
        (): دور_جدید_و_نمایش() تمام, 900
    )
تمام

تابع زمان_تمام():
    اگر !بازی_فعال: بازگشت تمام
    بازی_فعال = نادرست
    رکورد_متوالی = 0
    جان = جان - 1
    دام.افزودن کلاس(گزینه_عنصر[پاسخ_درست], "درست")
    دام.صدا(140.0, 260.0)
    دام.تنظیم متن(پیام, "زمان تمام شد! پاسخ درست: " + گزینه_متن[پاسخ_درست])
    نمایش_هود()
    اگر جان <= 0:
        پایان_بازی()
        بازگشت
    تمام
    دام.تنظیم مهلت(
        (): دور_جدید_و_نمایش() تمام, 900
    )
تمام

تابع شروع_بازی():
    امتیاز = 0
    جان = 3
    دور = 0
    رکورد_متوالی = 0
    دام.تنظیم سبک(پوشش, "display", "none")
    دام.تنظیم سبک(ناحیه_بازی, "display", "block")
    نمایش_هود()
    دور_جدید_و_نمایش()
تمام

تابع فریم(دلتا: اعشار۶۴):
    اگر بازی_فعال:
        زمان_باقی = زمان_باقی - دلتا
        اگر زمان_باقی <= 0.0:
            زمان_باقی = 0.0
            زمان_تمام()
        تمام
    تمام
    متغیر درصد := (زمان_باقی / زمان_کل) * 100.0
    اگر درصد < 0.0: درصد = 0.0 تمام
    دام.تنظیم سبک(نوار_داخلی, "width", درصد + "%")
    رسم()
تمام

تابع اصلی:
    زمینه = بوم.زمینه عنصر(دام.با شناسه("game"))
    هود = دام.با شناسه("hud")
    جان_جعبه = دام.با شناسه("lives")
    سوال_جعبه = دام.با شناسه("question")
    نوار_داخلی = دام.با شناسه("bar inner")
    پیام = دام.با شناسه("msg")
    ناحیه_بازی = دام.با شناسه("play area")
    پوشش = دام.با شناسه("overlay")
    پیام_پایان = دام.با شناسه("final msg")
    بهترین = دام.دریافت عدد ذخیره("salam shapequiz best") بعنوان صحیح
    تکرار 4 با ن:
        گزینه_عنصر[ن] = دام.با شناسه("opt" + ن)
        دام.هنگام رویداد(
            گزینه_عنصر[ن], "click", (): کلیک_گزینه(ن) تمام
        )
    تمام
    دام.هنگام رویداد(
        دام.با شناسه("again"), "click", (): شروع_بازی() تمام
    )
    شروع_بازی()
    دام.چرخه فریم(
        (دلتا: اعشار۶۴): فریم(دلتا) تمام
    )
تمام
