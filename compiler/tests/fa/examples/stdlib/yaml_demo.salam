// زبان: فارسی
واردکردن یامل

تابع اصلی:
    پیکربندی := "app:\n  name: Salam\n  version: 3\n  debug: false\nservers:\n  - host: alpha.example.com\n    port: 8080\n  - host: beta.example.com\n    port: 8081\n"

    چاپ "معتبر:", یامل.معتبر(پیکربندی)
    چاپ "نام برنامه:", یامل.دریافت(پیکربندی, "app.name")
    چاپ "نسخه برنامه:", یامل.دریافت عدد(پیکربندی, "app.version")
    چاپ "حالت اشکال‌زدایی:", یامل.دریافت منطقی(پیکربندی, "app.debug")
    چاپ "تعداد سرورها:", یامل.طول(پیکربندی, "servers")
    چاپ "میزبان سرور اول:", یامل.دریافت(پیکربندی, "servers[0].host")
    چاپ "درگاه سرور دوم:", یامل.دریافت عدد(پیکربندی, "servers[1].port")

    چاپ "--- به صورت جیسون ---"
    چاپ یامل.به جیسون(پیکربندی)

    چاپ "--- یامل بازقالب‌بندی‌شده ---"
    چاپ یامل.برونریزی(پیکربندی)
تمام
