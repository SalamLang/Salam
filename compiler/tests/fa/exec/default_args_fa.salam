// زبان: فارسی
ثابت گام : صحیح = 5

ساختار جعبه:
    پهنا : صحیح = 1
    بلندی : صحیح = 1
    نام : رشته = "جعبه"
    عمومی تابع رشد(مقدار : صحیح = 2) : صحیح:
        بازگشت این.پهنا + مقدار
    پایان
پایان

تابع مساحت(پهنا : صحیح, بلندی : صحیح = 2) : صحیح:
    بازگشت پهنا * بلندی
پایان

تابع افزایش(پایه : صحیح, مقدار : صحیح = گام) : صحیح:
    بازگشت پایه + مقدار
پایان

تابع اصلی:
    چاپ(مساحت(3))
    چاپ(مساحت(3, 4))
    چاپ(افزایش(10))
    چاپ(افزایش(10, 1))
    اول : جعبه = جعبه {}
    دوم : جعبه = جعبه { پهنا = 4, بلندی = 5, نام = "پهن" }
    چاپ(اول.پهنا, اول.بلندی, اول.نام)
    چاپ(دوم.پهنا, دوم.بلندی, دوم.نام)
    چاپ(اول.رشد())
    چاپ(اول.رشد(3))
پایان
