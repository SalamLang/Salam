// زبان: فارسی
ثابت گام صحیح۳۲ = 5

ساختار جعبه:
    پهنا صحیح۳۲ = 1
    بلندی صحیح۳۲ = 1
    نام رشته = "جعبه"
    تابع رشد(مقدار صحیح۳۲ = 2) صحیح۳۲:
        بازگشت این.پهنا + مقدار
    پایان
پایان

تابع مساحت(پهنا صحیح۳۲, بلندی صحیح۳۲ = 2) صحیح۳۲:
    بازگشت پهنا * بلندی
پایان

تابع افزایش(پایه صحیح۳۲, مقدار صحیح۳۲ = گام) صحیح۳۲:
    بازگشت پایه + مقدار
پایان

تابع اصلی:
    چاپ(مساحت(3))
    چاپ(مساحت(3, 4))
    چاپ(افزایش(10))
    چاپ(افزایش(10, 1))
    اول جعبه = جعبه {}
    دوم جعبه = جعبه { پهنا = 4, بلندی = 5, نام = "پهن" }
    چاپ(اول.پهنا, اول.بلندی, اول.نام)
    چاپ(دوم.پهنا, دوم.بلندی, دوم.نام)
    چاپ(اول.رشد())
    چاپ(اول.رشد(3))
پایان
