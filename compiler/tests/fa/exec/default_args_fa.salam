// زبان: فارسی
ثابت گام i32 = 5

ساختار جعبه:
    پهنا i32 = 1
    بلندی i32 = 1
    نام str = "جعبه"
    تابع رشد(مقدار i32 = 2) i32:
        بازگشت این.پهنا + مقدار
    پایان
پایان

تابع مساحت(پهنا i32, بلندی i32 = 2) i32:
    بازگشت پهنا * بلندی
پایان

تابع افزایش(پایه i32, مقدار i32 = گام) i32:
    بازگشت پایه + مقدار
پایان

تابع اصلی:
    چاپ(مساحت(3))
    چاپ(مساحت(3, 4))
    چاپ(افزایش(10))
    چاپ(افزایش(10, 1))
    اول جعبه = جعبه {}
    دوم جعبه = جعبه { پهنا = 4, بلندی = 5, نام = "پهن" }
    چاپ(اول.پهنا, اول.بلندی, اول.نام)
    چاپ(دوم.پهنا, دوم.بلندی, دوم.نام)
    چاپ(اول.رشد())
    چاپ(اول.رشد(3))
پایان
