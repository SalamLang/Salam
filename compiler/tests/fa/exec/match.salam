// زبان: فارسی
شمارش رنگ:
    قرمز
    سبز
    آبی
تمام

تابع دسته(ک: رنگ): رشته:
    بازگشت تطبیق ک:
        قرمز => "گرم"
        سبز, آبی => "خنک"
    تمام
تمام

تابع شرح(خ: صحیح): رشته:
    مقدار := تطبیق خ:
        1 =>: بازگشت 42 تمام
        2 =>: بازگشت "شاخه-رشته" تمام
        وگرنه =>: بازگشت درست تمام
    تمام
    بازگشت تطبیق مقدار:
        صحیح عس => "عدد:" + عس
        رشته رس => "رشته:" + رس
        منطقی بس => "منطقی:" + بس
    تمام
تمام

تابع اصلی:
    چاپ دسته(رنگ.قرمز)
    چاپ دسته(رنگ.سبز)
    چاپ دسته(رنگ.آبی)

    ی := تطبیق 2:
        1 => "یک"
        2 => "دو"
        وگرنه => "بسیار"
    تمام
    چاپ ی

    چاپ شرح(1)
    چاپ شرح(2)
    چاپ شرح(99)

    متغیر ن := 0
    تاوقتی ن < 3:
        تطبیق ن:
            0 =>: چاپ "صفر" تمام
            وگرنه =>:
                اگر ن == 2:
                    بشکن
                تمام
                چاپ "دیگر"
            تمام
        تمام
        ن = ن + 1
    تمام
    چاپ "تمام شد"
تمام
