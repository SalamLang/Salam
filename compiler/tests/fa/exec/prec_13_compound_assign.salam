// زبان: فارسی
تابع اصلی:
    ب := 3
    ج := 4

    متغیر ه := 5
    ه += ب * ج
    چاپ(ه)

    متغیر ز := 2
    ز *= ب + ج
    چاپ(ز)

    متغیر ح := 100
    ح -= ب * ج
    چاپ(ح)

    متغیر خ := 100
    خ /= ب - 1
    چاپ(خ)

    متغیر م := 10
    م %= ب + 1
    چاپ(م)

    متغیر ن := 2.0
    ن **= ب - 1
    چاپ(ن)
تمام
