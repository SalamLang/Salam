// زبان: فارسی
ساختار جعبه:
    عمومی پهنا : صحیح
    عمومی بلندی : صحیح
پایان

تابع دوبرابر(مقدار : صحیح) : صحیح:
    بازگشت مقدار * 2
پایان

تابع اصلی:
    متغیر الف := 3
    متغیر ب := 4

    یک := جعبه { پهنا = 5, بلندی = 6 }
    چاپ(یک.پهنا + یک.بلندی * 2)
    چاپ(دوبرابر(الف) + ب)
    چاپ(دوبرابر(الف + ب))

    متغیر اعداد := [10, 20, 30]
    چاپ(اعداد[1] + اعداد[0] * 2)
    چاپ(-اعداد[0])
پایان
