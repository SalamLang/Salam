// زبان: فارسی
تابع دسته(ن : صحیح) : رشته:
    بازگشت ن < 0 ? "منفی" : ن == 0 ? "صفر" : "مثبت"
تمام

تابع اصلی:
    ط := 7
    چاپ ط > 5 ؟ "بزرگ" : "کوچک"
    چاپ دسته(-4), دسته(0), دسته(9)
    چاپ درست ? نادرست ? 1 : 2 : 3
    متغیر مجموع := 0
    تکرار 6 با شمارنده:
        مجموع += شمارنده % 2 == 0 ؟ شمارنده : 0
    تمام
    چاپ مجموع
تمام
