// زبان: فارسی
تابع اصلی:
    الف := 12
    ب := 10
    چاپ الف & ب, الف | ب, الف ^ ب
    چاپ الف << 2, الف >> 1, ~الف
    متغیر ف := 0
    ف |= 5
    ف &= 6
    ف ^= 1
    ف <<= 2
    ف >>= 1
    چاپ ف
    چاپ 1 | 2 & 3, 1 << 4 + 1
    متغیر نقاب := 0xFF
    نقاب = نقاب & 0x0F
    چاپ نقاب, 0b1010 | 0b0101
تمام
