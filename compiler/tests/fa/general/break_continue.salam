// زبان: فارسی
تابع اصلی:
    متغیر مجموع : صحیح = 0
    متغیر نمایه : صحیح = 0
    تاوقتی نمایه < 20:
        نمایه = نمایه + 1
        اگر نمایه % 2 == 0:
            ادامه
        پایان
        اگر نمایه > 9:
            بشکن
        پایان
        مجموع = مجموع + نمایه
    پایان
    چاپ مجموع
پایان
