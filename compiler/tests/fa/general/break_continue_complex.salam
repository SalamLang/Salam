// زبان: فارسی
تابع اصلی:
    متغیر مجموع : صحیح = 0
    متغیر آخرین : صحیح = -1
    برای متغیر نمایه = 0, نمایه < 100, نمایه = نمایه + 1:
        اگر نمایه % 3 == 0: ادامه پایان
        اگر مجموع > 10: بشکن پایان
        مجموع = مجموع + نمایه
        آخرین = نمایه
    پایان
    چاپ مجموع
    چاپ آخرین

    متغیر شمارنده : صحیح = 0
    برای متغیر نمایه = 0, نمایه < 3, نمایه = نمایه + 1:
        برای متغیر نمایه۲ = 0, نمایه۲ < 3, نمایه۲ = نمایه۲ + 1:
            اگر نمایه۲ == 2: بشکن پایان
            برای متغیر نمایه۳ = 0, نمایه۳ < 3, نمایه۳ = نمایه۳ + 1:
                اگر نمایه۳ == 1: ادامه پایان
                شمارنده = شمارنده + 1
            پایان
        پایان
    پایان
    چاپ شمارنده

    متغیر یافت_شد : صحیح = 0
    متغیر یافت_نمایه : صحیح = -1
    متغیر یافت_نمایه۲ : صحیح = -1
    برای متغیر نمایه = 0, نمایه < 5, نمایه = نمایه + 1:
        برای متغیر نمایه۲ = 0, نمایه۲ < 5, نمایه۲ = نمایه۲ + 1:
            اگر نمایه * نمایه۲ == 6:
                یافت_شد = 1
                یافت_نمایه = نمایه
                یافت_نمایه۲ = نمایه۲
                بشکن
            پایان
        پایان
        اگر یافت_شد == 1: بشکن پایان
    پایان
    چاپ یافت_نمایه
    چاپ یافت_نمایه۲

    متغیر پردازش_شده : صحیح = 0
    متغیر بودجه : صحیح = 5
    تکرار 20:
        بودجه = بودجه - 1
        اگر بودجه < 0: بشکن پایان
        اگر بودجه % 2 == 0: ادامه پایان
        پردازش_شده = پردازش_شده + 1
    پایان
    چاپ پردازش_شده
پایان
