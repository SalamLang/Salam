// زبان: فارسی
تابع اصلی:
    متغیر مجموع := 0
    متغیر آخرین := -1
    تکرار 100 با نمایه:
        اگر نمایه % 3 == 0: ادامه تمام
        اگر مجموع > 10: بشکن تمام
        مجموع = مجموع + نمایه
        آخرین = نمایه
    تمام
    چاپ مجموع
    چاپ آخرین

    متغیر شمارنده := 0
    تکرار 3 با نمایه:
        تکرار 3 با نمایه۲:
            اگر نمایه۲ == 2: بشکن تمام
            تکرار 3 با نمایه۳:
                اگر نمایه۳ == 1: ادامه تمام
                شمارنده = شمارنده + 1
            تمام
        تمام
    تمام
    چاپ شمارنده

    متغیر یافت شد := 0
    متغیر یافت نمایه := -1
    متغیر یافت نمایه۲ := -1
    تکرار 5 با نمایه:
        تکرار 5 با نمایه۲:
            اگر نمایه * نمایه۲ == 6:
                یافت شد = 1
                یافت نمایه = نمایه
                یافت نمایه۲ = نمایه۲
                بشکن
            تمام
        تمام
        اگر یافت شد == 1: بشکن تمام
    تمام
    چاپ یافت نمایه
    چاپ یافت نمایه۲

    متغیر پردازش شده := 0
    متغیر بودجه := 5
    تکرار 20:
        بودجه = بودجه - 1
        اگر بودجه < 0: بشکن تمام
        اگر بودجه % 2 == 0: ادامه تمام
        پردازش شده = پردازش شده + 1
    تمام
    چاپ پردازش شده
تمام
