// زبان: فارسی
تابع اصلی:
    متغیر مجموع := 0
    متغیر آخرین := -1
    تکرار 100 با نمایه:
        اگر نمایه % 3 == 0: ادامه پایان
        اگر مجموع > 10: بشکن پایان
        مجموع = مجموع + نمایه
        آخرین = نمایه
    پایان
    چاپ مجموع
    چاپ آخرین

    متغیر شمارنده := 0
    تکرار 3 با نمایه:
        تکرار 3 با نمایه۲:
            اگر نمایه۲ == 2: بشکن پایان
            تکرار 3 با نمایه۳:
                اگر نمایه۳ == 1: ادامه پایان
                شمارنده = شمارنده + 1
            پایان
        پایان
    پایان
    چاپ شمارنده

    متغیر یافت_شد := 0
    متغیر یافت_نمایه := -1
    متغیر یافت_نمایه۲ := -1
    تکرار 5 با نمایه:
        تکرار 5 با نمایه۲:
            اگر نمایه * نمایه۲ == 6:
                یافت_شد = 1
                یافت_نمایه = نمایه
                یافت_نمایه۲ = نمایه۲
                بشکن
            پایان
        پایان
        اگر یافت_شد == 1: بشکن پایان
    پایان
    چاپ یافت_نمایه
    چاپ یافت_نمایه۲

    متغیر پردازش_شده := 0
    متغیر بودجه := 5
    تکرار 20:
        بودجه = بودجه - 1
        اگر بودجه < 0: بشکن پایان
        اگر بودجه % 2 == 0: ادامه پایان
        پردازش_شده = پردازش_شده + 1
    پایان
    چاپ پردازش_شده
پایان
