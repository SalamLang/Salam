// زبان: فارسی
تابع اصلی:
    متغیر شمارنده : صحیح = 0
    برای متغیر نمایه = 0, نمایه < 4, نمایه = نمایه + 1:
        برای متغیر نمایه۲ = 0, نمایه۲ < 4, نمایه۲ = نمایه۲ + 1:
            اگر نمایه۲ == نمایه: بشکن پایان
            شمارنده = شمارنده + 1
        پایان
    پایان
    چاپ شمارنده

    متغیر مجموع : صحیح = 0
    برای متغیر نمایه = 0, نمایه < 3, نمایه = نمایه + 1:
        برای متغیر نمایه۲ = 0, نمایه۲ < 3, نمایه۲ = نمایه۲ + 1:
            اگر نمایه۲ == 1: ادامه پایان
            مجموع = مجموع + 1
        پایان
    پایان
    چاپ مجموع

    متغیر بیرونی : صحیح = 0
    تکرار 3:
        بیرونی = بیرونی + 1
        تکرار 5:
            بشکن
        پایان
    پایان
    چاپ بیرونی

    متغیر جمع_کل : صحیح = 0
    متغیر مقدار : صحیح = 0
    تاوقتی مقدار < 3:
        مقدار = مقدار + 1
        برای متغیر نمایه۳ = 0, نمایه۳ < 10, نمایه۳ = نمایه۳ + 1:
            اگر نمایه۳ == 2: بشکن پایان
            جمع_کل = جمع_کل + 1
        پایان
    پایان
    چاپ جمع_کل

    متغیر اصابت_بیرونی : صحیح = 0
    متغیر اصابت_درونی : صحیح = 0
    برای متغیر نمایه = 0, نمایه < 3, نمایه = نمایه + 1:
        اصابت_بیرونی = اصابت_بیرونی + 1
        برای متغیر نمایه۲ = 0, نمایه۲ < 4, نمایه۲ = نمایه۲ + 1:
            اگر نمایه۲ % 2 == 0: ادامه پایان
            اصابت_درونی = اصابت_درونی + 1
        پایان
    پایان
    چاپ اصابت_بیرونی
    چاپ اصابت_درونی
پایان
