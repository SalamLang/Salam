// زبان: فارسی
تابع اصلی:
    متغیر شمارنده := 0
    تکرار 4 با نمایه:
        تکرار 4 با نمایه۲:
            اگر نمایه۲ == نمایه: بشکن پایان
            شمارنده = شمارنده + 1
        پایان
    پایان
    چاپ شمارنده

    متغیر مجموع := 0
    تکرار 3 با نمایه:
        تکرار 3 با نمایه۲:
            اگر نمایه۲ == 1: ادامه پایان
            مجموع = مجموع + 1
        پایان
    پایان
    چاپ مجموع

    متغیر بیرونی := 0
    تکرار 3:
        بیرونی = بیرونی + 1
        تکرار 5:
            بشکن
        پایان
    پایان
    چاپ بیرونی

    متغیر جمع_کل := 0
    متغیر مقدار := 0
    تاوقتی مقدار < 3:
        مقدار = مقدار + 1
        تکرار 10 با نمایه۳:
            اگر نمایه۳ == 2: بشکن پایان
            جمع_کل = جمع_کل + 1
        پایان
    پایان
    چاپ جمع_کل

    متغیر اصابت_بیرونی := 0
    متغیر اصابت_درونی := 0
    تکرار 3 با نمایه:
        اصابت_بیرونی = اصابت_بیرونی + 1
        تکرار 4 با نمایه۲:
            اگر نمایه۲ % 2 == 0: ادامه پایان
            اصابت_درونی = اصابت_درونی + 1
        پایان
    پایان
    چاپ اصابت_بیرونی
    چاپ اصابت_درونی
پایان
