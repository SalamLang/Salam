// زبان: فارسی
تابع اصلی:
    متغیر شمارنده := 0
    تکرار 4 با نمایه:
        تکرار 4 با نمایه۲:
            اگر نمایه۲ == نمایه: بشکن تمام
            شمارنده = شمارنده + 1
        تمام
    تمام
    چاپ شمارنده

    متغیر مجموع := 0
    تکرار 3 با نمایه:
        تکرار 3 با نمایه۲:
            اگر نمایه۲ == 1: ادامه تمام
            مجموع = مجموع + 1
        تمام
    تمام
    چاپ مجموع

    متغیر بیرونی := 0
    تکرار 3:
        بیرونی = بیرونی + 1
        تکرار 5:
            بشکن
        تمام
    تمام
    چاپ بیرونی

    متغیر جمع کل := 0
    متغیر مقدار := 0
    تاوقتی مقدار < 3:
        مقدار = مقدار + 1
        تکرار 10 با نمایه۳:
            اگر نمایه۳ == 2: بشکن تمام
            جمع کل = جمع کل + 1
        تمام
    تمام
    چاپ جمع کل

    متغیر اصابت بیرونی := 0
    متغیر اصابت درونی := 0
    تکرار 3 با نمایه:
        اصابت بیرونی = اصابت بیرونی + 1
        تکرار 4 با نمایه۲:
            اگر نمایه۲ % 2 == 0: ادامه تمام
            اصابت درونی = اصابت درونی + 1
        تمام
    تمام
    چاپ اصابت بیرونی
    چاپ اصابت درونی
تمام
