// زبان: فارسی
تابع اصلی:
    متغیر الف := 0
    تکرار 10 با نمایه:
        اگر نمایه == 5: بشکن پایان
        الف = الف + نمایه
    پایان
    چاپ الف

    متغیر ب := 0
    تکرار 10 با نمایه:
        اگر نمایه % 2 == 0: ادامه پایان
        ب = ب + نمایه
    پایان
    چاپ ب

    متغیر پ := 0
    متغیر نمایه۲ := 0
    تاوقتی نمایه۲ < 100:
        اگر نمایه۲ == 7: بشکن پایان
        پ = پ + 1
        نمایه۲ = نمایه۲ + 1
    پایان
    چاپ پ

    متغیر ت := 0
    متغیر نمایه۳ := 0
    تاوقتی نمایه۳ < 10:
        نمایه۳ = نمایه۳ + 1
        اگر نمایه۳ % 2 == 0: ادامه پایان
        ت = ت + 1
    پایان
    چاپ ت

    متغیر ث := 0
    تکرار 10:
        ث = ث + 1
        اگر ث == 3: بشکن پایان
    پایان
    چاپ ث

    متغیر ج := 0
    متغیر چ := 0
    تکرار 6:
        چ = چ + 1
        اگر چ % 3 == 0: ادامه پایان
        ج = ج + 1
    پایان
    چاپ ج
پایان
