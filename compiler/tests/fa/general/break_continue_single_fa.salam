// زبان: فارسی
تابع اصلی:
    متغیر a i32 = 0
    برای متغیر i = 0; i < 10; i = i + 1:
        اگر i == 5: بشکن پایان
        a = a + i
    پایان
    چاپ a

    متغیر b i32 = 0
    برای متغیر i = 0; i < 10; i = i + 1:
        اگر i % 2 == 0: ادامه پایان
        b = b + i
    پایان
    چاپ b

    متغیر c i32 = 0
    متغیر j i32 = 0
    تاوقتی j < 100:
        اگر j == 7: بشکن پایان
        c = c + 1
        j = j + 1
    پایان
    چاپ c

    متغیر d i32 = 0
    متغیر k i32 = 0
    تاوقتی k < 10:
        k = k + 1
        اگر k % 2 == 0: ادامه پایان
        d = d + 1
    پایان
    چاپ d

    متغیر e i32 = 0
    تکرار 10:
        e = e + 1
        اگر e == 3: بشکن پایان
    پایان
    چاپ e

    متغیر f i32 = 0
    متغیر g i32 = 0
    تکرار 6:
        g = g + 1
        اگر g % 3 == 0: ادامه پایان
        f = f + 1
    پایان
    چاپ f
پایان
