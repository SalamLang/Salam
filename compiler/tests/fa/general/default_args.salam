// زبان: فارسی
ثابت قدم := 5

ساختار جعبه:
    عمومی پهنا: صحیح = 1
    عمومی بلندی: صحیح = 1
    عمومی نام: رشته = "جعبه"
    عمومی تابع رشد(مقدار: صحیح = 2): صحیح:
        بازگشت این.پهنا + مقدار
    تمام
تمام

تابع مساحت(پهنا: صحیح, بلندی: صحیح = 2): صحیح:
    بازگشت پهنا * بلندی
تمام

تابع افزایش(پایه: صحیح, مقدار: صحیح = قدم): صحیح:
    بازگشت پایه + مقدار
تمام

تابع اصلی:
    چاپ مساحت(3)
    چاپ مساحت(3, 4)
    چاپ افزایش(10)
    چاپ افزایش(10, 1)
    اول := جعبه {}
    دوم := جعبه { پهنا = 4, بلندی = 5, نام = "پهن" }
    چاپ اول.پهنا, اول.بلندی, اول.نام
    چاپ دوم.پهنا, دوم.بلندی, دوم.نام
    چاپ اول.رشد()
    چاپ اول.رشد(3)
تمام
