تابع اصلی:
    نام := "سلام"
    متغیر شمار := 0
    شمار = شمار + 1
    نامها := ["الف", "ب", "پ"]
    هر ن در نامها:
        اگر ن != "ب":
            چاپ ن
        پایان
    پایان
    تکرار 2:
        بنویس "خ"
    پایان
    چاپ ""
    تکرار 1 تا 5 گام 2 با شاخص:
        اگر شاخص > 2:
            بنویس "ز"
        پایان
    پایان
    چاپ ""
    متغیر ک := 0
    تاوقتی ک < 3:
        بنویس "و"
        ک = ک + 1
    پایان
    چاپ ""
    اگر شمار == 1:
        چاپ نام
    پایان
پایان
