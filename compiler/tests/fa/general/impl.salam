// زبان: فارسی
واسط توصیف:
    تابع برچسب(): رشته
    تابع امتیاز(): صحیح
تمام

پیاده‌سازی توصیف بر صحیح:
    تابع برچسب(): رشته: بازگشت "عدد" تمام
    تابع امتیاز(): صحیح: بازگشت این * 10 تمام
تمام

پیاده‌سازی توصیف بر منطقی:
    تابع برچسب(): رشته: بازگشت "پرچم" تمام
    تابع امتیاز(): صحیح:
        اگر این: بازگشت 1 تمام
        بازگشت 0
    تمام
تمام

تابع نمایش<ت: توصیف>(مقدار: ت):
    چاپ مقدار.برچسب()
    چاپ مقدار.امتیاز()
تمام

تابع اصلی:
    نمایش(7)
    نمایش(درست)
    نمایش(نادرست)
تمام
