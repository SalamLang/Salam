// زبان: فارسی
واردکردن جیسون

تابع اصلی:
    چاپ جیسون.رشته جیسون("hi \"there\"")
    چاپ جیسون.عضو("name", "salam")
    چاپ جیسون.عضو عدد("age", 5)
    چاپ جیسون.عضو منطقی("ok", درست)
    چاپ جیسون.عضو اعشار("pi", 3.5)
    چاپ جیسون.عضو خام("raw", "[1, 2, 3]")

    متغیر برچسبها := وکتور {} بعنوان وکتور<رشته> برچسبها.بیفزا(جیسون.رشته جیسون("a"))
    برچسبها.بیفزا(جیسون.رشته جیسون("b"))
    برچسبها_جیسون := جیسون.آرایه(برچسبها)
    چاپ برچسبها_جیسون

    متغیر نقطه := وکتور {} بعنوان وکتور<رشته> نقطه.بیفزا(جیسون.عضو عدد("x", 1))
    نقطه.بیفزا(جیسون.عضو عدد("y", 2))
    نقطه_جیسون := جیسون.شیء(نقطه)
    چاپ نقطه_جیسون

    متغیر سند := وکتور {} بعنوان وکتور<رشته> سند.بیفزا(جیسون.عضو("name", "salam"))
    سند.بیفزا(جیسون.عضو عدد("version", 2))
    سند.بیفزا(جیسون.عضو منطقی("active", درست))
    سند.بیفزا(جیسون.عضو خام("tags", برچسبها_جیسون))
    سند.بیفزا(جیسون.عضو خام("point", نقطه_جیسون))
    سند.بیفزا(جیسون.عضو خام("empty_obj", جیسون.شیء(وکتور {} بعنوان وکتور<رشته>)))
    سند.بیفزا(جیسون.عضو خام("empty_arr", جیسون.آرایه(وکتور {} بعنوان وکتور<رشته>)))
    سند_جیسون := جیسون.شیء(سند)
    چاپ سند_جیسون

    چاپ جیسون.معتبر(سند_جیسون)
    چاپ جیسون.معتبر("{ not valid")
    چاپ جیسون.دریافت(سند_جیسون, "name")
    چاپ جیسون.دریافت عدد(سند_جیسون, "version")
    چاپ جیسون.دارد(سند_جیسون, "active")
    چاپ جیسون.دارد(سند_جیسون, "missing")

    چاپ جیسون.تورفتگی(سند_جیسون)
    چاپ جیسون.تورفتگی سفارشی(سند_جیسون, "    ")
    چاپ جیسون.تورفتگی چهار(سند_جیسون)
    چاپ جیسون.تورفتگی تب(سند_جیسون)

    چاپ جیسون.فشرده سازی(جیسون.تورفتگی(سند_جیسون)) == جیسون.فشرده سازی(سند_جیسون)
تمام
