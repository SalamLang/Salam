// زبان: فارسی
@en "Square"
@fa "مربع"
ساختار Square:
    @en "side"
    @fa "ضلع"
    side صحیح۳۲ = 0
    @en "Area"
    @fa "مساحت"
    تابع Area() صحیح۳۲: بازگشت این.side * این.side پایان
پایان
@en "TEN"
@fa "ده"
ثابت TEN = 10
@en "twice"
@fa "دوبرابر"
تابع twice(n صحیح۳۲) صحیح۳۲: بازگشت n * 2 پایان

تابع اصلی:
    متغیر s مربع = مربع { ضلع = 5 }
    چاپ s.مساحت()
    چاپ دوبرابر(ده)
پایان
