// LANG: fa
@en "Square"
@fa "مربع"
struct Square:
    @en "side"
    @fa "ضلع"
    side i32 = 0
    @en "Area"
    @fa "مساحت"
    func Area() i32: ret this.side * this.side end
end
@en "TEN"
@fa "ده"
const TEN = 10
@en "twice"
@fa "دوبرابر"
func twice(n i32) i32: ret n * 2 end
تابع اصلی:
    mut s مربع = مربع { ضلع = 5 }
    چاپ s.مساحت()
    چاپ دوبرابر(ده)
پایان
