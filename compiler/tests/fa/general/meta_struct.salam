// زبان: فارسی
@en "Point"
@fa "نقطه"
ساختار Point:
    @en "x"
    @fa "ایکس"
    pub x : صحیح = 0
    @en "y"
    @fa "وای"
    pub y : صحیح = 0
    @en "Sum"
    @fa "جمع"
    عمومی تابع Sum() : صحیح: بازگشت این.x + این.y پایان
پایان

تابع اصلی:
    متغیر p : Point = Point { ایکس = 3, وای = 4 }
    چاپ p.ایکس
    چاپ p.جمع()
    چاپ lang()
پایان
