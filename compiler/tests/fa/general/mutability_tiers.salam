// زبان: فارسی
ساختار نقطه:
    عمومی افقی: صحیح
    عمومی عمودی: صحیح
تمام

تابع اصلی:
    اعداد := [1, 2, 3] بعنوان صحیح[3]
    اعداد[0] = 10
    اعداد[1]++
    چاپ اعداد[0]
    چاپ اعداد[1]

    پ := نقطه { افقی = 1, عمودی = 2 }
    پ.افقی = 99
    چاپ پ.افقی

    متغیر عدد := 5
    عدد = 6
    چاپ عدد

    ثابت ث := [7, 8, 9] بعنوان صحیح[3]
    چاپ ث[2]
تمام
