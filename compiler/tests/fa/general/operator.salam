// زبان: فارسی
ساختار نقطه:
    عمومی ایکس: صحیح = 0
    عمومی وای: صحیح = 0
    عمومی تابع عملگر + (دیگری: نقطه): نقطه:
        بازگشت نقطه { ایکس = این.ایکس + دیگری.ایکس, وای = این.وای + دیگری.وای }
    تمام
تمام

تابع اصلی:
    الف := نقطه { ایکس = 3, وای = 4 }
    ب := نقطه { ایکس = 1, وای = 2 }
    ج := الف + ب
    چاپ ج.ایکس, ج.وای
تمام
