// زبان: فارسی
ساختار نقطه:
    عمومی x : صحیح = 0
    عمومی y : صحیح = 0
    عمومی تابع عملگر + (دیگری : نقطه) : نقطه:
        بازگشت نقطه { x = این.x + دیگری.x, y = این.y + دیگری.y }
    پایان
پایان

تابع اصلی:
    الف : نقطه = نقطه { x = 3, y = 4 }
    ب : نقطه = نقطه { x = 1, y = 2 }
    ج : نقطه = الف + ب
    چاپ ج.x, ج.y
پایان
