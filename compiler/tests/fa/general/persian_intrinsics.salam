// زبان: فارسی
تابع اصلی:
    متغیر اعداد := وکتور {} بعنوان وکتور<صحیح>
    اعداد.بیفزا(10)
    اعداد.بیفزا(20)
    اعداد.بیفزا(30)
    اعداد.بنشان(1, 99)
    چاپ "طول", اعداد.طول()
    چاپ "نخست", اعداد.بگیر(0)[0]
    چاپ "میانه", اعداد.بگیر(1)[0]
    چاپ "آخر", اعداد.دربیاور()
    متغیر امتیاز := نگاشت {} بعنوان نگاشت<رشته, صحیح>
    امتیاز.درج("الف", 3)
    امتیاز.درج("ب", 7)
    چاپ "اندازه", امتیاز.اندازه()
    چاپ "دارد-الف", امتیاز.دارد("الف")
    چاپ "بگیر-ب", امتیاز.بگیر("ب")
    چاپ "حذف", امتیاز.حذف("الف")
    چاپ "اندازه", امتیاز.اندازه()
    متغیر مجموع := 0
    متغیر پیمایه := امتیاز.پیمایش()
    تاوقتی پیمایه.دارد_بعدی():
        مجموع = مجموع + پیمایه.مقدار()
        پیمایه.بعدی()
    پایان
    چاپ "جمع", مجموع
    ثابت متن := "salam,donya"
    چاپ "طول-متن", متن.طول()
    چاپ "بخش", متن.زیررشته(0, 5)
    چاپ "یافتن", متن.بیاب("donya")
    چاپ "پیوست", متن.پیوست("!")
    متغیر بخش‌ها := متن.بشکاف(",")
    چاپ "تعداد-بخش", بخش‌ها.طول()
    چاپ "عدد", "۴۲ ".پیراست()
    چاپ "به‌صحیح", "42".به_صحیح() + 1
پایان
