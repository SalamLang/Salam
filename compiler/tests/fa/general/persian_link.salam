// زبان: فارسی
اگر SALAM_OS_WINDOWS:
    پیوند پویا "winsqlite3"
وگرنه:
    پیوند پویا "sqlite3"
پایان
خارجی "C":
    تابع sqlite3_libversion() : رشته
پایان

تابع اصلی:
    مقدار : رشته = sqlite3_libversion()
    اگر مقدار != "":
        چاپ ("sqlite linked")
    وگرنه:
        چاپ ("no")
    پایان
پایان
