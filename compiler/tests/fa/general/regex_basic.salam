واردکردن regex

تابع اصلی:
    چاپ regex.تطبیقرشته("[0-9]+", "abc123")
    چاپ regex.تطبیقرشته("[0-9]+", "abcxyz")

    چاپ regex.یافتنرشته("wor", "hello world")
    چاپ regex.یافتنرشته("zzz", "hello world")

    الگو := regex.کامپایل("^[A-Za-z]+$")
    چاپ regex.تطبیق(الگو, "Hello")
    چاپ regex.تطبیق(الگو, "Hello123")

    چاپ regex.تطبیقرشته("^abc$", "abc")
    چاپ regex.تطبیقرشته("^abc$", "abcd")

    چاپ regex.تطبیقرشته("[^0-9]+", "###")
    چاپ regex.تطبیقرشته("^[^0-9]+$", "a1b")

    چاپ regex.تطبیقرشته("colou?r", "color")
    چاپ regex.تطبیقرشته("colou?r", "colour")
    چاپ regex.تطبیقرشته("colou?r", "colouur")

    چاپ regex.تطبیقرشته("go+gle", "gooogle")
    چاپ regex.تطبیقرشته("go+gle", "ggle")

    چاپ regex.تطبیقرشته("\\d\\d\\d", "room 404")
    چاپ regex.تطبیقرشته("\\s", "a b")
    چاپ regex.تطبیقرشته("\\w+", "_hi9")

    چاپ regex.تطبیقرشته("a.c", "abc")
    چاپ regex.تطبیقرشته("a.c", "ac")

    چاپ regex.تطبیقرشته("a\\.b", "a.b")
    چاپ regex.تطبیقرشته("a\\.b", "axb")

    چاپ regex.جایگزینیرشته("[0-9]+", "item1 item2 item3", "#")
    چاپ regex.جایگزینیهمهرشته("[0-9]+", "item1 item2 item3", "#")

    الگو۲ := regex.کامپایل("o")
    چاپ regex.جایگزینی(الگو۲, "foo", "0")
    چاپ regex.جایگزینیهمه(الگو۲, "foo", "0")

    چاپ regex.جایگزینیرشته("zzz", "hello", "Q")
تمام
