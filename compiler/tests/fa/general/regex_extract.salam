واردکردن regex

تابع عنوان_را_بگیر(متن: رشته): رشته:
    اگر !regex.تطبیقرشته("<title>.*</title>", متن):
        بازگشت ""
    تمام
    گام۱ := regex.جایگزینیرشته(".*<title>", متن, "")
    بازگشت regex.جایگزینیرشته("</title>.*", گام۱, "")
تمام

تابع پیوندها_را_چاپ(متن: رشته):
    متغیر باقی := متن
    متغیر فعال := درست
    تاوقتی فعال:
        شاخص := regex.یافتنرشته("href=\"", باقی)
        اگر شاخص < 0:
            فعال = نادرست
        وگرنه:
            بعد := شاخص + 6
            دنباله := باقی.زیررشته(بعد, باقی.طول() - بعد)
            پایان := regex.یافتنرشته("\"", دنباله)
            اگر پایان < 0:
                فعال = نادرست
            وگرنه:
                چاپ دنباله.زیررشته(0, پایان)
                جلو := بعد + پایان + 1
                باقی = باقی.زیررشته(جلو, باقی.طول() - جلو)
            تمام
        تمام
    تمام
تمام

تابع اصلی:
    برگه := "<html><head><title>Salam Lang Docs</title></head><body>hi</body></html>"
    چاپ عنوان_را_بگیر(برگه)

    بدون_عنوان := "<html><body>no title here</body></html>"
    چاپ عنوان_را_بگیر(بدون_عنوان)

    پیوندها := "<a href=\"https://salamlang.org\">Home</a><a href=\"https://salamlang.org/docs\">Docs</a><a href=\"/about\">About</a>"
    پیوندها_را_چاپ(پیوندها)

    ایمیل := "contact: ada@example.com or grace@example.org"
    چاپ regex.تطبیقرشته("\\w+@\\w+\\.\\w+", ایمیل)
    چاپ regex.یافتنرشته("@", ایمیل) > 0

    فقط_ارقام := regex.جایگزینیهمهرشته("[0-9]", "room 42, floor 7", "")
    چاپ فقط_ارقام

    سیاسوی := "name,age,city"
    چاپ regex.جایگزینیهمهرشته(",", سیاسوی, " | ")
تمام
