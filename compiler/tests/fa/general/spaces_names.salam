// زبان: فارسی
ساختار شخص:
    عمومی نام کامل : رشته
    عمومی سن فعلی : صحیح
تمام

تابع جمع دو عدد(عدد اول : صحیح, عدد دوم : صحیح) : صحیح:
    بازگشت عدد اول + عدد دوم
تمام

تابع اصلی:
    نام من := "ali"
    نام_من := "underscore"
    چاپ نام من, نام_من
    متغیر شمارنده اصلی := 0
    شمارنده اصلی += 5
    شمارنده اصلی += 3
    چاپ "counter", شمارنده اصلی
    چاپ "sum", جمع دو عدد(10, 20)
    فرد := شخص { نام کامل = "sara", سن فعلی = 30 }
    چاپ "person", فرد.نام کامل, فرد.سن فعلی
تمام
