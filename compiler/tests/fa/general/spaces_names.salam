// زبان: فارسی
ساختار شخص:
    نام کامل رشته
    سن فعلی صحیح۳۲
پایان
تابع جمع دو عدد(عدد اول صحیح۳۲, عدد دوم صحیح۳۲) صحیح۳۲:
    بازگشت عدد اول + عدد دوم
پایان
تابع اصلی:
    متغیر نام من رشته = "ali"
    نام_من رشته = "underscore"
    چاپ نام من, نام_من
    متغیر شمارنده اصلی صحیح۳۲ = 0
    شمارنده اصلی += 5
    شمارنده اصلی += 3
    چاپ "counter", شمارنده اصلی
    چاپ "sum", جمع دو عدد(10, 20)
    متغیر فرد شخص = شخص { نام کامل = "sara", سن فعلی = 30 }
    چاپ "person", فرد.نام کامل, فرد.سن فعلی
پایان
