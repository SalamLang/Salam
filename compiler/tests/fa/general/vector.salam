// زبان: فارسی
تابع اصلی:
    متغیر بردار := Vector {} بعنوان Vector<صحیح>
    تعلیق بردار.free()
    متغیر نمایه := 0
    تاوقتی نمایه < 4:
        بردار.push(نمایه * 10)
        نمایه = نمایه + 1
    پایان
    چاپ بردار.len()
    متغیر مجموع := 0
    نمایه = 0
    تاوقتی نمایه < بردار.len():
        مجموع = مجموع + بردار.get(نمایه)[0]
        نمایه = نمایه + 1
    پایان
    چاپ مجموع
پایان
