// زبان: فارسی
تابع اصلی:
    متغیر بردار := وکتور {} بعنوان وکتور<صحیح>
    تعلیق بردار.آزادکن()
    متغیر نمایه := 0
    تاوقتی نمایه < 4:
        بردار.بیفزا(نمایه * 10)
        نمایه = نمایه + 1
    تمام
    چاپ بردار.طول()
    متغیر مجموع := 0
    نمایه = 0
    تاوقتی نمایه < بردار.طول():
        مجموع = مجموع + بردار.بگیر(نمایه)[0]
        نمایه = نمایه + 1
    تمام
    چاپ مجموع
تمام
