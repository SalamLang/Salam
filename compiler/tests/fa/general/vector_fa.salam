// زبان: فارسی
تابع اصلی:
    متغیر و Vector<i32> = Vector {}
    متغیر i i32 = 0
    تاوقتی i < 4:
        و.push(i * 10)
        i = i + 1
    پایان
    چاپ و.len()
    متغیر مجموع i32 = 0
    i = 0
    تاوقتی i < و.len():
        مجموع = مجموع + و.get(i)[0]
        i = i + 1
    پایان
    چاپ مجموع
    و.free()
پایان
