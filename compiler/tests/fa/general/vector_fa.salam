// زبان: فارسی
تابع اصلی:
    متغیر بردار : Vector<صحیح> = Vector {}
    تعلیق بردار.free()
    متغیر i : صحیح = 0
    تاوقتی i < 4:
        بردار.push(i * 10)
        i = i + 1
    پایان
    چاپ بردار.len()
    متغیر مجموع : صحیح = 0
    i = 0
    تاوقتی i < بردار.len():
        مجموع = مجموع + بردار.get(i)[0]
        i = i + 1
    پایان
    چاپ مجموع
پایان
