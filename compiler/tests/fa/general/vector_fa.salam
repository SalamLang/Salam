// زبان: فارسی
تابع اصلی:
    متغیر بردار Vector<صحیح۳۲> = Vector {}
    متغیر i صحیح۳۲ = 0
    تاوقتی i < 4:
        بردار.push(i * 10)
        i = i + 1
    پایان
    چاپ بردار.len()
    متغیر مجموع صحیح۳۲ = 0
    i = 0
    تاوقتی i < بردار.len():
        مجموع = مجموع + بردار.get(i)[0]
        i = i + 1
    پایان
    چاپ مجموع
    بردار.free()
پایان
