// زبان: فارسی
واردکردن وب
واردکردن شبکه
واردکردن رشته
واردکردن زمان

تابع دریافت کن(زمینه : صحیح۶۴): وب.متن زمینه(زمینه, "GET-ok") تمام

تابع ارسال کن(زمینه : صحیح۶۴): وب.متن زمینه(زمینه, "POST-ok") تمام

تابع جاگذار کن(زمینه : صحیح۶۴):
    وب.متن زمینه(زمینه, "PUT-ok id=" + وب.پارامتر زمینه(زمینه, "id"))
تمام

تابع حذف کن(زمینه : صحیح۶۴):
    وب.متن زمینه(زمینه, "DELETE-ok id=" + وب.پارامتر زمینه(زمینه, "id"))
تمام

تابع اجرای وب():
    متغیر مسیریاب := وب.مسیریاب جدید()
    وب.دریافت(مسیریاب, "/res", funcptr(دریافت کن))
    وب.ارسال(مسیریاب, "/res", funcptr(ارسال کن))
    وب.قراردادن(مسیریاب, "/res/:id", funcptr(جاگذار کن))
    وب.حذف(مسیریاب, "/res/:id", funcptr(حذف کن))
    کارساز := وب.سرور جدید(19216)
    وب.استفاده(کارساز, مسیریاب)
    وب.اجرا(کارساز)
تمام

تابع درخواست(روش : رشته, مسیر : رشته) : رشته:
    متغیر سوکت := شبکه.اتصال("127.0.0.1", 19216)
    متغیر تلاش := 0 بعنوان صحیح۶۴
    تاوقتی !شبکه.معتبر(سوکت) و تلاش < 200:
        زمان.خواب(10)
        سوکت = شبکه.اتصال("127.0.0.1", 19216)
        تلاش = تلاش + 1
    تمام
    اگر !شبکه.معتبر(سوکت):
        بازگشت ""
    تمام
    شبکه.ارسال(سوکت, روش + " " + مسیر + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    پاسخ := شبکه.دریافت(سوکت, 8192)
    شبکه.بستن(سوکت)
    بازگشت پاسخ
تمام

تابع اصلی:
    _نخ := spawn(اجرای وب)

    چاپ رشته.شامل است(درخواست("GET", "/res"), "GET-ok")
    چاپ رشته.شامل است(درخواست("POST", "/res"), "POST-ok")

    چاپ رشته.شامل است(درخواست("PUT", "/res/7"), "PUT-ok id=7")
    چاپ رشته.شامل است(درخواست("DELETE", "/res/9"), "DELETE-ok id=9")

    چاپ رشته.شامل است(درخواست("PUT", "/res"), "404")
    چاپ رشته.شامل است(درخواست("GET", "/res/7"), "404")
تمام
