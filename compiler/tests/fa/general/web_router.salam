// زبان: فارسی
واردکردن (
    "web" "net" "str" "time"
)

تابع دریافت_کن(زمینه : صحیح۶۴): web.Ctx_text(زمینه, "GET-ok") پایان

تابع ارسال_کن(زمینه : صحیح۶۴): web.Ctx_text(زمینه, "POST-ok") پایان

تابع جاگذار_کن(زمینه : صحیح۶۴):
    web.Ctx_text(زمینه, "PUT-ok id=" + web.Ctx_param(زمینه, "id"))
پایان

تابع حذف_کن(زمینه : صحیح۶۴):
    web.Ctx_text(زمینه, "DELETE-ok id=" + web.Ctx_param(زمینه, "id"))
پایان

تابع اجرای_وب():
    متغیر مسیریاب : web.Router = web.NewRouter()
    web.Get(مسیریاب, "/res", funcptr(دریافت_کن))
    web.Post(مسیریاب, "/res", funcptr(ارسال_کن))
    web.Put(مسیریاب, "/res/:id", funcptr(جاگذار_کن))
    web.Delete(مسیریاب, "/res/:id", funcptr(حذف_کن))
    کارساز : web.Server = web.NewServer(19216)
    web.Use(کارساز, مسیریاب)
    web.Run(کارساز)
پایان

تابع درخواست(روش : رشته, مسیر : رشته) : رشته:
    متغیر سوکت : net.Socket = net.Connect("127.0.0.1", 19216)
    متغیر تلاش : صحیح۶۴ = 0
    تاوقتی !net.Ok(سوکت) و تلاش < 200:
        time.Sleep(10)
        سوکت = net.Connect("127.0.0.1", 19216)
        تلاش = تلاش + 1
    پایان
    اگر !net.Ok(سوکت):
        بازگشت ""
    پایان
    net.Send(سوکت, روش + " " + مسیر + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    پاسخ : رشته = net.Recv(سوکت, 8192)
    net.Close(سوکت)
    بازگشت پاسخ
پایان

تابع اصلی:
    _نخ : صحیح۶۴ = spawn(اجرای_وب)

    چاپ str.Contains(درخواست("GET", "/res"), "GET-ok")
    چاپ str.Contains(درخواست("POST", "/res"), "POST-ok")

    چاپ str.Contains(درخواست("PUT", "/res/7"), "PUT-ok id=7")
    چاپ str.Contains(درخواست("DELETE", "/res/9"), "DELETE-ok id=9")

    چاپ str.Contains(درخواست("PUT", "/res"), "404")
    چاپ str.Contains(درخواست("GET", "/res/7"), "404")
پایان
