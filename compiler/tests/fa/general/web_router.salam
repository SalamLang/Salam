// زبان: فارسی
واردکردن "web" "net" "str" "time"

تابع دریافت کن(زمینه : صحیح۶۴): web.Ctx_text(زمینه, "GET-ok") تمام

تابع ارسال کن(زمینه : صحیح۶۴): web.Ctx_text(زمینه, "POST-ok") تمام

تابع جاگذار کن(زمینه : صحیح۶۴):
    web.Ctx_text(زمینه, "PUT-ok id=" + web.Ctx_param(زمینه, "id"))
تمام

تابع حذف کن(زمینه : صحیح۶۴):
    web.Ctx_text(زمینه, "DELETE-ok id=" + web.Ctx_param(زمینه, "id"))
تمام

تابع اجرای وب():
    متغیر مسیریاب := web.NewRouter()
    web.Get(مسیریاب, "/res", funcptr(دریافت کن))
    web.Post(مسیریاب, "/res", funcptr(ارسال کن))
    web.Put(مسیریاب, "/res/:id", funcptr(جاگذار کن))
    web.Delete(مسیریاب, "/res/:id", funcptr(حذف کن))
    کارساز := web.NewServer(19216)
    web.Use(کارساز, مسیریاب)
    web.Run(کارساز)
تمام

تابع درخواست(روش : رشته, مسیر : رشته) : رشته:
    متغیر سوکت := net.Connect("127.0.0.1", 19216)
    متغیر تلاش := 0 بعنوان صحیح۶۴
    تاوقتی !net.Ok(سوکت) و تلاش < 200:
        time.Sleep(10)
        سوکت = net.Connect("127.0.0.1", 19216)
        تلاش = تلاش + 1
    تمام
    اگر !net.Ok(سوکت):
        بازگشت ""
    تمام
    net.Send(سوکت, روش + " " + مسیر + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    پاسخ := net.Recv(سوکت, 8192)
    net.Close(سوکت)
    بازگشت پاسخ
تمام

تابع اصلی:
    _نخ := spawn(اجرای وب)

    چاپ str.Contains(درخواست("GET", "/res"), "GET-ok")
    چاپ str.Contains(درخواست("POST", "/res"), "POST-ok")

    چاپ str.Contains(درخواست("PUT", "/res/7"), "PUT-ok id=7")
    چاپ str.Contains(درخواست("DELETE", "/res/9"), "DELETE-ok id=9")

    چاپ str.Contains(درخواست("PUT", "/res"), "404")
    چاپ str.Contains(درخواست("GET", "/res/7"), "404")
تمام
