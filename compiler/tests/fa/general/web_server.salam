// زبان: فارسی
واردکردن وب
واردکردن وب.اعتبارسنجی
واردکردن وب.میان افزار
واردکردن شبکه
واردکردن رشته
واردکردن زمان

تابع بازتاب کن(زمینه: صحیح۶۴):
    بدنه := وب.بدنه زمینه(زمینه)
    وب.متن زمینه(زمینه, "got:" + بدنه)
تمام

تابع پرسمان کن(زمینه: صحیح۶۴):
    نام := وب.پرسمان زمینه(زمینه, "name")
    وب.متن زمینه(زمینه, "hi " + نام)
تمام

تابع امن کن(زمینه: صحیح۶۴):
    میان افزار.امن(زمینه)
    وب.متن زمینه(زمینه, "secure")
تمام

تابع هدایت کن(زمینه: صحیح۶۴):
    وب.تغییرمسیر زمینه(زمینه, "/dest")
تمام

تابع ثبت نام کن(زمینه: صحیح۶۴):
    ایمیل := وب.فرم زمینه(زمینه, "email")
    اگر اعتبارسنجی.ایمیل است(ایمیل):
        وب.متن زمینه(زمینه, "email-ok")
    وگرنه:
        وب.وضعیت زمینه(زمینه, 400)
        وب.متن زمینه(زمینه, "bad-email")
    تمام
تمام

تابع اجرای وب():
    متغیر مسیریاب := وب.مسیریاب جدید()
    وب.ارسال(مسیریاب, "/echo", funcptr(بازتاب کن))
    وب.دریافت(مسیریاب, "/q", funcptr(پرسمان کن))
    وب.دریافت(مسیریاب, "/sec", funcptr(امن کن))
    وب.دریافت(مسیریاب, "/go", funcptr(هدایت کن))
    وب.ارسال(مسیریاب, "/signup", funcptr(ثبت نام کن))
    کارساز := وب.سرور جدید(19215)
    وب.استفاده(کارساز, مسیریاب)
    وب.اجرا(کارساز)
تمام

تابع ارسال خام(درخواست: رشته): رشته:
    متغیر سوکت := شبکه.اتصال("127.0.0.1", 19215)
    متغیر تلاش := 0 بعنوان صحیح۶۴
    تاوقتی !شبکه.معتبر(سوکت) و تلاش < 200:
        زمان.خواب(10)
        سوکت = شبکه.اتصال("127.0.0.1", 19215)
        تلاش = تلاش + 1
    تمام
    اگر !شبکه.معتبر(سوکت):
        بازگشت ""
    تمام
    شبکه.ارسال(سوکت, درخواست)
    پاسخ := شبکه.دریافت(سوکت, 8192)
    شبکه.بستن(سوکت)
    بازگشت پاسخ
تمام

تابع پست(مسیر: رشته, بدنه: رشته): رشته:
    درخواست := "POST " + مسیر + " HTTP/1.0\r\nHost: localhost\r\nContent-Length: " + رشته.از عدد(len(بدنه) بعنوان صحیح۶۴) + "\r\n\r\n" + بدنه
    بازگشت ارسال خام(درخواست)
تمام

تابع گرفتن(مسیر: رشته): رشته:
    بازگشت ارسال خام("GET " + مسیر + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
تمام

تابع اصلی:
    _نخ := spawn(اجرای وب)

    نتیجه۱ := پست("/echo", "hello")
    چاپ رشته.شامل است(نتیجه۱, "got:hello")

    نتیجه۲ := گرفتن("/q?name=Sara")
    چاپ رشته.شامل است(نتیجه۲, "hi Sara")

    نتیجه۳ := گرفتن("/sec")
    چاپ رشته.شامل است(نتیجه۳, "X-Frame-Options: DENY")
    چاپ رشته.شامل است(نتیجه۳, "secure")

    نتیجه۴ := گرفتن("/go")
    چاپ رشته.شامل است(نتیجه۴, "302")
    چاپ رشته.شامل است(نتیجه۴, "Location: /dest")

    نتیجه۵ := پست("/signup", "email=a@b.com")
    چاپ رشته.شامل است(نتیجه۵, "email-ok")
    نتیجه۶ := پست("/signup", "email=nope")
    چاپ رشته.شامل است(نتیجه۶, "400")
    چاپ رشته.شامل است(نتیجه۶, "bad-email")
تمام
