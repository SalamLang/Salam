// زبان: فارسی
واردکردن وب
واردکردن وب.اعتبارسنجی
واردکردن وب.میان‌افزار
واردکردن شبکه
واردکردن رشته
واردکردن زمان

تابع بازتاب کن(زمینه : صحیح۶۴):
    بدنه := web.Ctx body(زمینه)
    web.Ctx text(زمینه, "got:" + بدنه)
تمام

تابع پرسمان کن(زمینه : صحیح۶۴):
    نام := web.Ctx query(زمینه, "name")
    web.Ctx text(زمینه, "hi " + نام)
تمام

تابع امن کن(زمینه : صحیح۶۴):
    middleware.Secure(زمینه)
    web.Ctx text(زمینه, "secure")
تمام

تابع هدایت کن(زمینه : صحیح۶۴):
    web.Ctx redirect(زمینه, "/dest")
تمام

تابع ثبت نام کن(زمینه : صحیح۶۴):
    ایمیل := web.Ctx form(زمینه, "email")
    اگر validate.IsEmail(ایمیل):
        web.Ctx text(زمینه, "email-ok")
    وگرنه:
        web.Ctx status(زمینه, 400)
        web.Ctx text(زمینه, "bad-email")
    تمام
تمام

تابع اجرای وب():
    متغیر مسیریاب := web.NewRouter()
    web.Post(مسیریاب, "/echo", funcptr(بازتاب کن))
    web.Get(مسیریاب, "/q", funcptr(پرسمان کن))
    web.Get(مسیریاب, "/sec", funcptr(امن کن))
    web.Get(مسیریاب, "/go", funcptr(هدایت کن))
    web.Post(مسیریاب, "/signup", funcptr(ثبت نام کن))
    کارساز := web.NewServer(19215)
    web.Use(کارساز, مسیریاب)
    web.Run(کارساز)
تمام

تابع ارسال خام(درخواست : رشته) : رشته:
    متغیر سوکت := net.Connect("127.0.0.1", 19215)
    متغیر تلاش := 0 بعنوان صحیح۶۴
    تاوقتی !net.Ok(سوکت) و تلاش < 200:
        time.Sleep(10)
        سوکت = net.Connect("127.0.0.1", 19215)
        تلاش = تلاش + 1
    تمام
    اگر !net.Ok(سوکت):
        بازگشت ""
    تمام
    net.Send(سوکت, درخواست)
    پاسخ := net.Recv(سوکت, 8192)
    net.Close(سوکت)
    بازگشت پاسخ
تمام

تابع پست(مسیر : رشته, بدنه : رشته) : رشته:
    درخواست := "POST " + مسیر + " HTTP/1.0\r\nHost: localhost\r\nContent-Length: " + str.FromInt(len(بدنه) بعنوان صحیح۶۴) + "\r\n\r\n" + بدنه
    بازگشت ارسال خام(درخواست)
تمام

تابع گرفتن(مسیر : رشته) : رشته:
    بازگشت ارسال خام("GET " + مسیر + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
تمام

تابع اصلی:
    _نخ := spawn(اجرای وب)

    نتیجه۱ := پست("/echo", "hello")
    چاپ str.Contains(نتیجه۱, "got:hello")

    نتیجه۲ := گرفتن("/q?name=Sara")
    چاپ str.Contains(نتیجه۲, "hi Sara")

    نتیجه۳ := گرفتن("/sec")
    چاپ str.Contains(نتیجه۳, "X-Frame-Options: DENY")
    چاپ str.Contains(نتیجه۳, "secure")

    نتیجه۴ := گرفتن("/go")
    چاپ str.Contains(نتیجه۴, "302")
    چاپ str.Contains(نتیجه۴, "Location: /dest")

    نتیجه۵ := پست("/signup", "email=a@b.com")
    چاپ str.Contains(نتیجه۵, "email-ok")
    نتیجه۶ := پست("/signup", "email=nope")
    چاپ str.Contains(نتیجه۶, "400")
    چاپ str.Contains(نتیجه۶, "bad-email")
تمام
