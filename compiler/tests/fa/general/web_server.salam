// زبان: فارسی
واردکردن (
    "web" "web/validate" "web/middleware" "net" "str" "time"
)

تابع بازتاب_کن(زمینه : صحیح۶۴):
    بدنه := web.Ctx_body(زمینه)
    web.Ctx_text(زمینه, "got:" + بدنه)
پایان

تابع پرسمان_کن(زمینه : صحیح۶۴):
    نام := web.Ctx_query(زمینه, "name")
    web.Ctx_text(زمینه, "hi " + نام)
پایان

تابع امن_کن(زمینه : صحیح۶۴):
    middleware.Secure(زمینه)
    web.Ctx_text(زمینه, "secure")
پایان

تابع هدایت_کن(زمینه : صحیح۶۴):
    web.Ctx_redirect(زمینه, "/dest")
پایان

تابع ثبت_نام_کن(زمینه : صحیح۶۴):
    ایمیل := web.Ctx_form(زمینه, "email")
    اگر validate.IsEmail(ایمیل):
        web.Ctx_text(زمینه, "email-ok")
    وگرنه:
        web.Ctx_status(زمینه, 400)
        web.Ctx_text(زمینه, "bad-email")
    پایان
پایان

تابع اجرای_وب():
    متغیر مسیریاب := web.NewRouter()
    web.Post(مسیریاب, "/echo", funcptr(بازتاب_کن))
    web.Get(مسیریاب, "/q", funcptr(پرسمان_کن))
    web.Get(مسیریاب, "/sec", funcptr(امن_کن))
    web.Get(مسیریاب, "/go", funcptr(هدایت_کن))
    web.Post(مسیریاب, "/signup", funcptr(ثبت_نام_کن))
    کارساز := web.NewServer(19215)
    web.Use(کارساز, مسیریاب)
    web.Run(کارساز)
پایان

تابع ارسال_خام(درخواست : رشته) : رشته:
    متغیر سوکت := net.Connect("127.0.0.1", 19215)
    متغیر تلاش := 0 بعنوان صحیح۶۴
    تاوقتی !net.Ok(سوکت) و تلاش < 200:
        time.Sleep(10)
        سوکت = net.Connect("127.0.0.1", 19215)
        تلاش = تلاش + 1
    پایان
    اگر !net.Ok(سوکت):
        بازگشت ""
    پایان
    net.Send(سوکت, درخواست)
    پاسخ := net.Recv(سوکت, 8192)
    net.Close(سوکت)
    بازگشت پاسخ
پایان

تابع پست(مسیر : رشته, بدنه : رشته) : رشته:
    درخواست := "POST " + مسیر + " HTTP/1.0\r\nHost: localhost\r\nContent-Length: " + str.FromInt(len(بدنه) بعنوان صحیح۶۴) + "\r\n\r\n" + بدنه
    بازگشت ارسال_خام(درخواست)
پایان

تابع گرفتن(مسیر : رشته) : رشته:
    بازگشت ارسال_خام("GET " + مسیر + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
پایان

تابع اصلی:
    _نخ := spawn(اجرای_وب)

    نتیجه۱ := پست("/echo", "hello")
    چاپ str.Contains(نتیجه۱, "got:hello")

    نتیجه۲ := گرفتن("/q?name=Sara")
    چاپ str.Contains(نتیجه۲, "hi Sara")

    نتیجه۳ := گرفتن("/sec")
    چاپ str.Contains(نتیجه۳, "X-Frame-Options: DENY")
    چاپ str.Contains(نتیجه۳, "secure")

    نتیجه۴ := گرفتن("/go")
    چاپ str.Contains(نتیجه۴, "302")
    چاپ str.Contains(نتیجه۴, "Location: /dest")

    نتیجه۵ := پست("/signup", "email=a@b.com")
    چاپ str.Contains(نتیجه۵, "email-ok")
    نتیجه۶ := پست("/signup", "email=nope")
    چاپ str.Contains(نتیجه۶, "400")
    چاپ str.Contains(نتیجه۶, "bad-email")
پایان
