// زبان: فارسی
واردکردن (
    "web" "web/validate" "web/middleware" "net" "str" "time"
)

تابع echo_h(ctx صحیح۶۴):
    body رشته = web.Ctx_body(ctx)
    web.Ctx_text(ctx, "got:" + body)
پایان

تابع query_h(ctx صحیح۶۴):
    name رشته = web.Ctx_query(ctx, "name")
    web.Ctx_text(ctx, "hi " + name)
پایان

تابع secure_h(ctx صحیح۶۴):
    middleware.Secure(ctx)
    web.Ctx_text(ctx, "secure")
پایان

تابع redirect_h(ctx صحیح۶۴):
    web.Ctx_redirect(ctx, "/dest")
پایان

تابع signup_h(ctx صحیح۶۴):
    email رشته = web.Ctx_form(ctx, "email")
    اگر validate.IsEmail(email):
        web.Ctx_text(ctx, "email-ok")
    وگرنه:
        web.Ctx_status(ctx, 400)
        web.Ctx_text(ctx, "bad-email")
    پایان
پایان

تابع run_web():
    متغیر r web.Router = web.NewRouter()
    web.Post(r, "/echo", funcptr(echo_h))
    web.Get(r, "/q", funcptr(query_h))
    web.Get(r, "/sec", funcptr(secure_h))
    web.Get(r, "/go", funcptr(redirect_h))
    web.Post(r, "/signup", funcptr(signup_h))
    s web.Server = web.NewServer(19215)
    web.Use(s, r)
    web.Run(s)
پایان

تابع send_raw(req رشته) رشته:
    sock net.Socket = net.Connect("127.0.0.1", 19215)
    اگر !net.Ok(sock):
        بازگشت ""
    پایان
    net.Send(sock, req)
    resp رشته = net.Recv(sock, 8192)
    net.Close(sock)
    بازگشت resp
پایان

تابع post(path رشته, body رشته) رشته:
    req رشته = "POST " + path + " HTTP/1.0\r\nHost: localhost\r\nContent-Length: " + str.FromInt(len(body) بعنوان صحیح۶۴) + "\r\n\r\n" + body
    بازگشت send_raw(req)
پایان

تابع get(path رشته) رشته:
    بازگشت send_raw("GET " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
پایان

تابع اصلی:
    _t صحیح۶۴ = spawn(run_web)
    time.Sleep(150)

    r1 رشته = post("/echo", "hello")
    چاپ str.Contains(r1, "got:hello")

    r2 رشته = get("/q?name=Sara")
    چاپ str.Contains(r2, "hi Sara")

    r3 رشته = get("/sec")
    چاپ str.Contains(r3, "X-Frame-Options: DENY")
    چاپ str.Contains(r3, "secure")

    r4 رشته = get("/go")
    چاپ str.Contains(r4, "302")
    چاپ str.Contains(r4, "Location: /dest")

    r5 رشته = post("/signup", "email=a@b.com")
    چاپ str.Contains(r5, "email-ok")
    r6 رشته = post("/signup", "email=nope")
    چاپ str.Contains(r6, "400")
    چاپ str.Contains(r6, "bad-email")
پایان
