// زبان: فارسی
واردکردن وب

تابع اصلی:
    چاپ وب.رمزگشایی نشانی("a%20b") == "a b"
    چاپ وب.رمزگشایی نشانی("a+b") == "a b"
    چاپ وب.رمزگشایی نشانی("100%25") == "100%"
    چاپ وب.رمزگشایی نشانی("name=Ali%20Reza") == "name=Ali Reza"
    چاپ وب.رمزگشایی نشانی("plain") == "plain"

    چاپ وب.پسوند مایم("html") == "text/html; charset=utf-8"
    چاپ وب.پسوند مایم("css") == "text/css"
    چاپ وب.پسوند مایم("js") == "application/javascript"
    چاپ وب.پسوند مایم("png") == "image/png"
    چاپ وب.پسوند مایم("unknownext") == "application/octet-stream"

    چاپ وب.گونه مایم("/assets/site.css") == "text/css"
    چاپ وب.گونه مایم("/img/logo.png") == "image/png"
    چاپ وب.گونه مایم("archive.tar.gz") == "application/octet-stream"
    چاپ وب.گونه مایم("noextension") == "application/octet-stream"

    چاپ وب.متن وضعیت(200) == "OK"
    چاپ وب.متن وضعیت(201) == "Created"
    چاپ وب.متن وضعیت(404) == "Not Found"
    چاپ وب.متن وضعیت(500) == "Internal Server Error"
    چاپ وب.متن وضعیت(799) == "Unknown"

    چاپ وب.نسخه سرور == "0.2.4"
تمام
