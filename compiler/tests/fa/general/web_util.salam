// زبان: فارسی
واردکردن "web"
تابع اصلی:
    چاپ web.UrlDecode("a%20b") == "a b"
    چاپ web.UrlDecode("a+b") == "a b"
    چاپ web.UrlDecode("100%25") == "100%"
    چاپ web.UrlDecode("name=Ali%20Reza") == "name=Ali Reza"
    چاپ web.UrlDecode("plain") == "plain"

    چاپ web.MimeExt("html") == "text/html; charset=utf-8"
    چاپ web.MimeExt("css") == "text/css"
    چاپ web.MimeExt("js") == "application/javascript"
    چاپ web.MimeExt("png") == "image/png"
    چاپ web.MimeExt("unknownext") == "application/octet-stream"

    چاپ web.MimeType("/assets/site.css") == "text/css"
    چاپ web.MimeType("/img/logo.png") == "image/png"
    چاپ web.MimeType("archive.tar.gz") == "application/octet-stream"
    چاپ web.MimeType("noextension") == "application/octet-stream"

    چاپ web.StatusText(200) == "OK"
    چاپ web.StatusText(201) == "Created"
    چاپ web.StatusText(404) == "Not Found"
    چاپ web.StatusText(500) == "Internal Server Error"
    چاپ web.StatusText(799) == "Unknown"

    چاپ web.SERVER_VERSION == "0.2.0"
پایان
