// زبان: فارسی
واردکردن وب.اعتبارسنجی

تابع اصلی:
    چاپ اعتبارسنجی.الزامی("hello") == درست
    چاپ اعتبارسنجی.الزامی("") == نادرست

    چاپ اعتبارسنجی.طول("abc", 1, 5) == درست
    چاپ اعتبارسنجی.طول("abc", 3, 3) == درست
    چاپ اعتبارسنجی.طول("", 1, 5) == نادرست
    چاپ اعتبارسنجی.طول("toolong", 1, 5) == نادرست

    چاپ اعتبارسنجی.ایمیل است("user@example.com") == درست
    چاپ اعتبارسنجی.ایمیل است("no-at-sign.com") == نادرست
    چاپ اعتبارسنجی.ایمیل است("no-dot@example") == نادرست
    چاپ اعتبارسنجی.ایمیل است("") == نادرست
تمام
