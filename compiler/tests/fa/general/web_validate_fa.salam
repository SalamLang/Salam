// زبان: فارسی
واردکردن "web/validate"
تابع اصلی:
    چاپ validate.Required("hello") == درست
    چاپ validate.Required("") == نادرست

    چاپ validate.Length("abc", 1, 5) == درست
    چاپ validate.Length("abc", 3, 3) == درست
    چاپ validate.Length("", 1, 5) == نادرست
    چاپ validate.Length("toolong", 1, 5) == نادرست

    چاپ validate.IsEmail("user@example.com") == درست
    چاپ validate.IsEmail("no-at-sign.com") == نادرست
    چاپ validate.IsEmail("no-dot@example") == نادرست
    چاپ validate.IsEmail("") == نادرست
پایان
