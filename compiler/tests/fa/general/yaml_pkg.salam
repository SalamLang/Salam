// زبان: فارسی
واردکردن یامل

تابع اصلی:
    چاپ یامل.رشته یامل("hi \"there\"")
    چاپ یامل.عضو("name", "salam")
    چاپ یامل.عضو عدد("age", 5)
    چاپ یامل.عضو منطقی("ok", درست)
    چاپ یامل.عضو اعشار("pi", 3.5)
    چاپ یامل.عضو خام("raw", "[1, 2, 3]")

    متغیر برچسبها := وکتور {} بعنوان وکتور<رشته>
    برچسبها.بیفزا(یامل.رشته یامل("a"))
    برچسبها.بیفزا(یامل.رشته یامل("b"))
    برچسبها_یامل := یامل.آرایه(برچسبها)
    چاپ برچسبها_یامل

    متغیر نقطه := وکتور {} بعنوان وکتور<رشته>
    نقطه.بیفزا(یامل.عضو عدد("x", 1))
    نقطه.بیفزا(یامل.عضو عدد("y", 2))
    نقطه_یامل := یامل.شیء(نقطه)
    چاپ نقطه_یامل

    متغیر سند := وکتور {} بعنوان وکتور<رشته>
    سند.بیفزا(یامل.عضو("name", "salam"))
    سند.بیفزا(یامل.عضو عدد("version", 2))
    سند.بیفزا(یامل.عضو منطقی("active", درست))
    سند.بیفزا(یامل.عضو خام("tags", برچسبها_یامل))
    سند.بیفزا(یامل.عضو خام("point", نقطه_یامل))
    سند_یامل := یامل.شیء(سند)
    چاپ سند_یامل

    بلوک := "name: salam\nversion: 2\nactive: true\ntags:\n  - a\n  - b\npoint:\n  x: 1\n  y: 2\n"
    چاپ یامل.تجزیه(بلوک)
    چاپ یامل.به جیسون(بلوک) == یامل.تجزیه(بلوک)

    چاپ یامل.معتبر(بلوک)
    چاپ یامل.معتبر("{ not: valid")
    چاپ یامل.معتبر("[1, 2")
    چاپ یامل.معتبر("\"unterminated")

    چاپ یامل.دریافت(بلوک, "name")
    چاپ یامل.دریافت عدد(بلوک, "version")
    چاپ یامل.دریافت منطقی(بلوک, "active")
    چاپ یامل.دریافت(بلوک, "tags[0]")
    چاپ یامل.دریافت(بلوک, "tags[1]")
    چاپ یامل.دریافت عدد(بلوک, "point.x")
    چاپ یامل.دریافت عدد(بلوک, "point.y")
    چاپ یامل.دارد(بلوک, "point.y")
    چاپ یامل.دارد(بلوک, "missing")
    چاپ یامل.نوع(بلوک, "tags")
    چاپ یامل.نوع(بلوک, "point")
    چاپ یامل.نوع(بلوک, "name")
    چاپ یامل.نوع(بلوک, "version")
    چاپ یامل.نوع(بلوک, "missing")
    چاپ یامل.طول(بلوک, "tags")

    متغیر نیازمند := وکتور {} بعنوان وکتور<رشته>
    نیازمند.بیفزا("name")
    نیازمند.بیفزا("version")
    چاپ یامل.دارد کلیدها(بلوک, نیازمند)
    نیازمند.بیفزا("missing")
    چاپ یامل.دارد کلیدها(بلوک, نیازمند)

    جریان := "{a: 1, b: [1, 2, 3], c: {x: true, y: null}}"
    چاپ یامل.تجزیه(جریان)

    گیومه := "title: 'it''s here'\nurl: \"http://x:80/a#b\"\n"
    چاپ یامل.تجزیه(گیومه)

    بلوک_متن := "desc: |\n  line one\n  line two\nfolded: >\n  a b\n  c d\n"
    چاپ یامل.تجزیه(بلوک_متن)

    فهرست := "items:\n  - name: a\n    val: 1\n  - name: b\n    val: 2\n"
    چاپ یامل.تجزیه(فهرست)
    چاپ یامل.دریافت(فهرست, "items[1].name")
    چاپ یامل.دریافت عدد(فهرست, "items[0].val")

    چندسندی := "a: 1\n---\nb: 2\n"
    اسناد := یامل.جدا کردن اسناد(چندسندی)
    چاپ اسناد.طول()
    چاپ یامل.تجزیه(اسناد.بگیر(0)[0])
    چاپ یامل.تجزیه(اسناد.بگیر(1)[0])

    چاپ یامل.برونریزی(سند_یامل)
    چاپ یامل.برونریزی سفارشی(سند_یامل, "    ")
    چاپ یامل.برونریزی تب(سند_یامل)

    چاپ یامل.تجزیه(یامل.برونریزی(بلوک)) == یامل.تجزیه(بلوک)
تمام
