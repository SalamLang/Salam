// زبان: فارسی
تابع سازنده افزاینده(ن : صحیح) : تابع (صحیح) صحیح:
    بازگشت (مقدار : صحیح) => مقدار + ن
تمام

تابع اصلی:
    دوبرابر := (شمار : صحیح) => شمار * 2
    چاپ دوبرابر(21)
    افزاینده ده := سازنده افزاینده(10)
    چاپ افزاینده ده(5)
    متغیر پایه := 100
    افزایش := () =>:
        پایه = پایه + 1
    تمام
    افزایش()
    افزایش()
    چاپ پایه
تمام
