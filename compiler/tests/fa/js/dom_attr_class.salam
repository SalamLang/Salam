    دام.تنظیم‌ویژگی(عنصر, "data-role", "tag")
    چاپ دام.دریافت‌ویژگی(عنصر, "data-role")

    دام.افزودن‌کلاس(عنصر, "card")
    دام.افزودن‌کلاس(عنصر, "big")
    چاپ دام.دریافت‌ویژگی(عنصر, "class")

    دام.تعویض‌کلاس(عنصر, "big")
    چاپ دام.دریافت‌ویژگی(عنصر, "class")

    دام.تعویض‌کلاس(عنصر, "big")
    چاپ دام.دریافت‌ویژگی(عنصر, "class")

    دام.حذف‌کلاس(عنصر, "card")
