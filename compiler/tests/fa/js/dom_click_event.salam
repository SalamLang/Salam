// زبان: فارسی
واردکردن دام

متغیر تعداد کلیک := 0

تابع اصلی:
    دکمه := دام.بساز("button")
    دام.تنظیم ویژگی(دکمه, "id", "btn")
    دام.تنظیم ویژگی(دکمه, "data-autofire", "click")
    دام.افزودن(دام.بدنه(), دکمه)
    دام.هنگام رویداد(
        دکمه, "click", (): تعداد کلیک = تعداد کلیک + 1 چاپ "clicked" تمام
    )
    چاپ "before"
    چاپ تعداد کلیک
تمام
