واردکردن دام

متغیر تعداد کلیک := 0

تابع اصلی:
    دکمه := dom.Create("button")
    dom.SetAttr(دکمه, "id", "btn")
    dom.SetAttr(دکمه, "data-autofire", "click")
    dom.Append(dom.Body(), دکمه)
    dom.OnEvent(دکمه, "click", () =>:
        تعداد کلیک = تعداد کلیک + 1
        چاپ "clicked"
    تمام)
    چاپ "before"
    چاپ تعداد کلیک
تمام
