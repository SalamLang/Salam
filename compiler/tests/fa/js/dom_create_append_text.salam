// زبان: فارسی
واردکردن دام

تابع اصلی:
    جعبه := دام.بساز("div")
    دام.تنظیم‌ویژگی(جعبه, "id", "box")
    دام.تنظیم‌متن(جعبه, "hello dom")
    دام.افزودن(دام.بدنه(), جعبه)

    یافته := دام.با‌شناسه("box")
    چاپ دام.دریافت‌متن(یافته)

    دام.تنظیم‌اچ‌تی‌ام‌ال(یافته, "<b>bold</b>")
    چاپ یافته != دام.بدنه()
تمام
