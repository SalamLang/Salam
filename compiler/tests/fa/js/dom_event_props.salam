// زبان: فارسی
واردکردن دام

تابع اصلی:
    عنصر := دام.بساز("div")
    دام.تنظیم‌ویژگی(عنصر, "id", "surface")
    دام.تنظیم‌ویژگی(عنصر, "data-autofire", "keydown")
    دام.تنظیم‌ویژگی(عنصر, "data-autofire-key", "Enter")
    دام.تنظیم‌ویژگی(عنصر, "data-autofire-x", "12")
    دام.تنظیم‌ویژگی(عنصر, "data-autofire-y", "34")
    دام.افزودن(دام.بدنه(), عنصر)
    دام.هنگام‌رویداد‌جزئی(عنصر, "keydown", (رویداد : صحیح۶۴) =>:
        چاپ دام.کلید‌رویداد(رویداد)
        چاپ دام.رویداد‌افقی(رویداد)
        چاپ دام.رویداد‌عمودی(رویداد)
        دام.جلوگیری‌پیش‌فرض(رویداد)
        چاپ "handled"
    تمام)
    چاپ "ready"
تمام
