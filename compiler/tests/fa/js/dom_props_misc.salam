// زبان: فارسی
واردکردن دام

تابع اصلی:
    دام.تنظیم عنوان("Salam Page")

    شی := دام.بدنه()
    دام.تنظیم خاصیت عددی(شی, "score", 9.5)
    چاپ دام.دریافت خاصیت عددی(شی, "score")
    دام.تنظیم خاصیت رشته ای(شی, "label", "top")
    چاپ دام.دریافت خاصیت رشته ای(شی, "label")
    دام.تنظیم خاصیت منطقی(شی, "active", درست)
    چاپ دام.دریافت خاصیت منطقی(شی, "active")

    تایید := دام.تایید("proceed?")
    چاپ تایید
    پاسخ := دام.درخواست ورودی("your name?")
    چاپ پاسخ
تمام
