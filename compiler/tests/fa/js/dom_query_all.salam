// زبان: فارسی
واردکردن دام

تابع اصلی:
    تکرار 3 با ن:
        مورد := دام.بساز("li")
        دام.تنظیم‌ویژگی(مورد, "class", "row")
        دام.تنظیم‌متن(مورد, "item")
        دام.افزودن(دام.بدنه(), مورد)
    تمام
    همه := دام.پرسمان‌همه(".row")
    چاپ دام.تعداد(همه)
    اولی := دام.عنصر‌شماره(همه, 0)
    چاپ دام.دریافت‌متن(اولی)
تمام
