واردکردن دام

تابع اصلی:
    تکرار 3 با ن:
        مورد := dom.Create("li")
        dom.SetAttr(مورد, "class", "row")
        dom.SetText(مورد, "item")
        dom.Append(dom.Body(), مورد)
    تمام
    همه := dom.QueryAll(".row")
    چاپ dom.CountOf(همه)
    اولی := dom.ItemAt(همه, 0)
    چاپ dom.GetText(اولی)
تمام
