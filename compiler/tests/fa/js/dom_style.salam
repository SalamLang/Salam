// زبان: فارسی
واردکردن دام

تابع اصلی:
    عنصر := دام.بساز("div")
    دام.افزودن(دام.بدنه(), عنصر)
    دام.تنظیم‌سبک(عنصر, "color", "red")
    دام.تنظیم‌سبک(عنصر, "font-size", "12px")
    چاپ دام.دریافت‌سبک(عنصر, "color")
    چاپ دام.دریافت‌سبک(عنصر, "font-size")
    دام.تنظیم‌سبک(عنصر, "color", "blue")
    چاپ دام.دریافت‌سبک(عنصر, "color")
تمام
