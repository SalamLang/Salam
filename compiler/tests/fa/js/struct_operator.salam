// زبان: فارسی
ساختار بردار۲:
    عمومی افقی : صحیح = 0
    عمومی عمودی : صحیح = 0
    عمومی تابع عملگر + (دیگر : بردار۲) : بردار۲:
        بازگشت بردار۲ { افقی = این.افقی + دیگر.افقی, عمودی = این.عمودی + دیگر.عمودی }
    تمام
    عمومی تابع عملگر == (دیگر : بردار۲) : منطقی:
        بازگشت این.افقی == دیگر.افقی && این.عمودی == دیگر.عمودی
    تمام
تمام

تابع اصلی:
    الف := بردار۲ { افقی = 3, عمودی = 4 }
    ب := بردار۲ { افقی = 1, عمودی = 2 }
    ج := الف + ب
    چاپ ج.افقی
    چاپ ج.عمودی
    الف۲ := بردار۲ { افقی = 3, عمودی = 4 }
    چاپ الف == الف۲
    چاپ الف == ب
تمام
