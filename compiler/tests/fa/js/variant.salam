// زبان: فارسی
ساختار جعبه:
    عمومی برچسب: رشته
    عمومی مقدار: گوناگون<صحیح, رشته, منطقی>
تمام

تابع شرح(م: گوناگون<صحیح, رشته, منطقی>): رشته:
    بازگشت تطبیق م:
        صحیح ن => "عدد:" + ن
        رشته س => "رشته:" + س
        منطقی ب => "منطقی:" + ب
    تمام
تمام

تابع اصلی:
    متغیر خ := 42 بعنوان گوناگون<صحیح, رشته, منطقی>
    چاپ شرح(خ)
    خ = "سلام"
    چاپ شرح(خ)
    خ = درست
    چاپ شرح(خ)

    ج := جعبه { برچسب = "الف", مقدار = 7 }
    چاپ ج.برچسب + ":" + شرح(ج.مقدار)
تمام
