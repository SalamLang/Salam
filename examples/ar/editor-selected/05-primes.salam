//! وضع: برنامج | عنوان: الأعداد الأولية
دالة أولي_هو(ن صحيح) منطقي:
    إذا ن < 2: أرجع خطأ نهاية
    لكل متغير i = 2; i * i <= ن; i = i + 1:
        إذا ن % i == 0: أرجع خطأ نهاية
    نهاية
    أرجع صواب
نهاية
دالة الرئيسية:
    متغير سطر نص = ""
    لكل متغير ن = 2; ن <= 30; ن = ن + 1:
        إذا أولي_هو(ن): سطر = سطر + ن + " " نهاية
    نهاية
    اطبع "الأعداد الأولية حتى ٣٠:", سطر
نهاية
