//! وضع: برنامج | عنوان: الأعداد الأولية
// لغة: العربية
دالة أولی هو(ن: صحیح): منطقی:
    إذا ن < 2: أرجع خطأ نهاية
    متغير i := 2
    بينما i * i <= ن:
        إذا ن % i == 0: أرجع خطأ نهاية
        i = i + 1
    نهاية
    أرجع صواب
نهاية

دالة الرئیسیة:
    متغير سطر := ""
    كرر 2 إلى 30 مع ن:
        إذا أولی هو(ن): سطر = سطر + ن + " " نهاية
    نهاية
    اطبع "الأعداد الأولية حتى ٣٠:", سطر
نهاية
