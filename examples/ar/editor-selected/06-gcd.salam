//! وضع: برنامج | عنوان: القاسم المشترك
// لغة: العربية
دالة قاسم(أ: صحیح, ب: صحیح): صحیح:
    متغير س := أ
    متغير ص := ب
    بينما ص != 0:
        ت := ص
        ص = س % ص
        س = ت
    نهاية
    أرجع س
نهاية

دالة الرئیسیة:
    اطبع "قاسم ٤٨ و ٣٦ =", قاسم(48, 36)
    اطبع "قاسم ١٧ و ٥ =", قاسم(17, 5)
نهاية
