//! وضع: برنامج | عنوان: القاسم المشترك
دالة قاسم(أ : صحيح, ب : صحيح) : صحيح:
    متغير س := أ
    متغير ص := ب
    بينما ص != 0:
        متغير ت := ص
        ص = س % ص
        س = ت
    نهاية
    أرجع س
نهاية

دالة الرئيسية:
    اطبع "قاسم ٤٨ و ٣٦ =", قاسم(48, 36)
    اطبع "قاسم ١٧ و ٥ =", قاسم(17, 5)
نهاية
