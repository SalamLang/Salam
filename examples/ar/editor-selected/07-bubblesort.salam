//! وضع: برنامج | عنوان: الترتيب الفقاعي
دالة الرئيسية:
    متغير م : صحيح[6] = [5, 2, 8, 1, 9, 3]
    لكل متغير i = 0, i < 6, i = i + 1:
        لكل متغير ج = 0, ج < 5 - i, ج = ج + 1:
            إذا م[ج] > م[ج + 1]:
                متغير ت : صحيح = م[ج]
                م[ج] = م[ج + 1]
                م[ج + 1] = ت
            نهاية
        نهاية
    نهاية
    متغير سطر : نص = ""
    لكل متغير ك = 0, ك < 6, ك = ك + 1: سطر = سطر + م[ك] + " " نهاية
    اطبع "مرتب:", سطر
نهاية
