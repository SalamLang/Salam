//! وضع: برنامج | عنوان: الترتيب الفقاعي
دالة الرئيسية:
    متغير م := [5, 2, 8, 1, 9, 3] بوصفه صحيح[6]
    كرر 6 مع i:
        كرر 5 - i مع ج:
            إذا م[ج] > م[ج + 1]:
                متغير ت := م[ج]
                م[ج] = م[ج + 1]
                م[ج + 1] = ت
            نهاية
        نهاية
    نهاية
    متغير سطر := ""
    كرر 6 مع ك: سطر = سطر + م[ك] + " " نهاية
    اطبع "مرتب:", سطر
نهاية
