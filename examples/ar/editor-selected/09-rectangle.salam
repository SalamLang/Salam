//! وضع: برنامج | عنوان: بنية: مستطيل
// لغة: العربية
بنية مستطیل:
    طول: عشری٦٤ = 0.0
    عرض: عشری٦٤ = 0.0
    عام دالة مساحة(): عشری٦٤: أرجع هذا.طول * هذا.عرض نهاية
    عام دالة محیط(): عشری٦٤: أرجع 2.0 * (هذا.طول + هذا.عرض) نهاية
نهاية

دالة الرئیسیة:
    ر := مستطیل { طول = 4.0, عرض = 3.0 }
    اطبع "المساحة =", ر.مساحة()
    اطبع "المحيط =", ر.محیط()
نهاية
