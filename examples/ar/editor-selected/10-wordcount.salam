//! وضع: برنامج | عنوان: عد الكلمات
// لغة: العربية
دالة الرئیسیة:
    جملة := "قطة كلب قطة طائر قطة"
    متغير کلمات := جملة.قسم(" ")
    متغير إحصاء := خریطة {} بوصفه خریطة<نص, صحیح> كرر کلمات.طول() مع i: ک := کلمات.احصل(i)[0]
    إذا إحصاء.یحوی(ک): إحصاء.ضع(ک, إحصاء.احصل(ک) + 1)
    وإلا:
        إحصاء.ضع(ک, 1)
    نهاية
نهاية
متغير مکرر := إحصاء.تکرار()
بينما مکرر.یوجدتالی():
    اطبع مکرر.مفتاح(), "->", مکرر.قیمة()
    مکرر.التالی()
نهاية
نهاية
