//! وضع: برنامج | عنوان: متتالية كولاتز
دالة الرئيسية:
    متغير ن صحيح = 27
    متغير خطوات صحيح = 0
    اطبع "كولاتز من", ن
    بينما ن != 1:
        إذا ن % 2 == 0: ن = ن / 2
        وإلا:
            ن = 3 * ن + 1
        نهاية
        خطوات = خطوات + 1
    نهاية
    اطبع "وصل إلى ١ في", خطوات, "خطوة"
نهاية
