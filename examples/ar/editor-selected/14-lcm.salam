//! وضع: برنامج | عنوان: المضاعف المشترك
// لغة: العربية
دالة قاسم(أ : صحيح, ب : صحيح) : صحيح:
    متغير س := أ
    متغير ص := ب
    بينما ص != 0:
        ت := ص
        ص = س % ص
        س = ت
    نهاية
    أرجع س
نهاية

دالة مضاعف(أ : صحيح, ب : صحيح) : صحيح: أرجع أ / قاسم(أ, ب) * ب نهاية

دالة الرئيسية:
    اطبع "مضاعف ٤ و ٦ =", مضاعف(4, 6)
    اطبع "مضاعف ٢١ و ٦ =", مضاعف(21, 6)
نهاية
