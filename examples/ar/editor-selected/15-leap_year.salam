//! وضع: برنامج | عنوان: السنة الكبيسة
// لغة: العربية
دالة کبیسة هی(سنة: صحیح): منطقی:
    إذا سنة % 400 == 0: أرجع صواب نهاية
    إذا سنة % 100 == 0: أرجع خطأ نهاية
    أرجع سنة % 4 == 0
نهاية

دالة الرئیسیة:
    سنوات := [1900, 2000, 2012, 2021, 2024] بوصفه صحیح[5]
    كرر 5 مع i:
        إذا کبیسة هی(سنوات[i]): اطبع سنوات[i], "كبيسة"
        وإلا:
            اطبع سنوات[i], "ليست كبيسة"
        نهاية
    نهاية
نهاية
