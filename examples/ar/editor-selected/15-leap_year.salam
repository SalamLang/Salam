//! وضع: برنامج | عنوان: السنة الكبيسة
// لغة: العربية
دالة كبيسة هي(سنة : صحيح) : منطقي:
    إذا سنة % 400 == 0: أرجع صواب نهاية
    إذا سنة % 100 == 0: أرجع خطأ نهاية
    أرجع سنة % 4 == 0
نهاية

دالة الرئيسية:
    سنوات := [1900, 2000, 2012, 2021, 2024] بوصفه صحيح[5]
    كرر 5 مع i:
        إذا كبيسة هي(سنوات[i]): اطبع سنوات[i], "كبيسة"
        وإلا:
            اطبع سنوات[i], "ليست كبيسة"
        نهاية
    نهاية
نهاية
