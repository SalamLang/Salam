//! وضع: برنامج | عنوان: السنة الكبيسة
دالة كبيسة_هي(سنة صحيح) منطقي:
    إذا سنة % 400 == 0: أرجع صواب نهاية
    إذا سنة % 100 == 0: أرجع خطأ نهاية
    أرجع سنة % 4 == 0
نهاية
دالة الرئيسية:
    متغير سنوات صحيح[5] = [1900, 2000, 2012, 2021, 2024]
    لكل متغير i = 0; i < 5; i = i + 1:
        إذا كبيسة_هي(سنوات[i]): اطبع سنوات[i], "كبيسة"
        وإلا:
            اطبع سنوات[i], "ليست كبيسة"
        نهاية
    نهاية
نهاية
