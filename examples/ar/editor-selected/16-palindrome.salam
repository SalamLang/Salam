//! وضع: برنامج | عنوان: عدد متماثل
// لغة: العربية
دالة متماثل هو(ن: صحیح): منطقی:
    متغير س := ن
    متغير معکوس := 0
    بينما س > 0:
        معکوس = معکوس * 10 + س % 10
        س = س / 10
    نهاية
    أرجع معکوس == ن
نهاية

دالة الرئیسیة:
    أعداد := [121, 123, 1221, 13] بوصفه صحیح[4]
    كرر 4 مع i:
        إذا متماثل هو(أعداد[i]): اطبع أعداد[i], "متماثل"
        وإلا:
            اطبع أعداد[i], "غير متماثل"
        نهاية
    نهاية
نهاية
