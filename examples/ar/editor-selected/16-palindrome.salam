//! وضع: برنامج | عنوان: عدد متماثل
دالة متماثل_هو(ن : صحيح) : منطقي:
    متغير س : صحيح = ن
    متغير معكوس : صحيح = 0
    بينما س > 0:
        معكوس = معكوس * 10 + س % 10
        س = س / 10
    نهاية
    أرجع معكوس == ن
نهاية

دالة الرئيسية:
    متغير أعداد : صحيح[4] = [121, 123, 1221, 13]
    لكل متغير i = 0, i < 4, i = i + 1:
        إذا متماثل_هو(أعداد[i]): اطبع أعداد[i], "متماثل"
        وإلا:
            اطبع أعداد[i], "غير متماثل"
        نهاية
    نهاية
نهاية
