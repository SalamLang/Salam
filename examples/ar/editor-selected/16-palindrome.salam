//! وضع: برنامج | عنوان: عدد متماثل
دالة متماثل هو(ن : صحيح) : منطقي:
    متغير س := ن
    متغير معكوس := 0
    بينما س > 0:
        معكوس = معكوس * 10 + س % 10
        س = س / 10
    نهاية
    أرجع معكوس == ن
نهاية

دالة الرئيسية:
    أعداد := [121, 123, 1221, 13] بوصفه صحيح[4]
    كرر 4 مع i:
        إذا متماثل هو(أعداد[i]): اطبع أعداد[i], "متماثل"
        وإلا:
            اطبع أعداد[i], "غير متماثل"
        نهاية
    نهاية
نهاية
