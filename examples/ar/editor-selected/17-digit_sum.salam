//! وضع: برنامج | عنوان: مجموع الأرقام
// لغة: العربية
دالة مجموع الأرقام(ن : صحيح) : صحيح:
    متغير س := ن
    متغير مجموع := 0
    بينما س > 0:
        مجموع = مجموع + س % 10
        س = س / 10
    نهاية
    أرجع مجموع
نهاية

دالة الرئيسية:
    اطبع "مجموع أرقام ١٢٣٤٥ =", مجموع الأرقام(12345)
    اطبع "مجموع أرقام ٩٩ =", مجموع الأرقام(99)
نهاية
