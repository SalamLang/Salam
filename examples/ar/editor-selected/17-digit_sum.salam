//! وضع: برنامج | عنوان: مجموع الأرقام
دالة مجموع_الأرقام(ن صحيح) صحيح:
    متغير س صحيح = ن
    متغير مجموع صحيح = 0
    بينما س > 0:
        مجموع = مجموع + س % 10
        س = س / 10
    نهاية
    أرجع مجموع
نهاية
دالة الرئيسية:
    اطبع "مجموع أرقام ١٢٣٤٥ =", مجموع_الأرقام(12345)
    اطبع "مجموع أرقام ٩٩ =", مجموع_الأرقام(99)
نهاية
