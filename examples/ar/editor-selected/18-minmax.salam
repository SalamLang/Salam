//! وضع: برنامج | عنوان: الأصغر والأكبر
// لغة: العربية
دالة الرئیسیة:
    م := [5, 9, 1, 7, 3, 8, 2] بوصفه صحیح[7]
    متغير أصغر := م[0]
    متغير أکبر := م[0]
    كرر 1 إلى 7 - 1 مع i:
        إذا م[i] < أصغر: أصغر = م[i] نهاية
        إذا م[i] > أکبر: أکبر = م[i] نهاية
    نهاية
    اطبع "الأصغر =", أصغر, "الأكبر =", أکبر
نهاية
