//! وضع: برنامج | عنوان: الأصغر والأكبر
دالة الرئيسية:
    متغير م : صحيح[7] = [5, 9, 1, 7, 3, 8, 2]
    متغير أصغر : صحيح = م[0]
    متغير أكبر : صحيح = م[0]
    لكل متغير i = 1, i < 7, i = i + 1:
        إذا م[i] < أصغر: أصغر = م[i] نهاية
        إذا م[i] > أكبر: أكبر = م[i] نهاية
    نهاية
    اطبع "الأصغر =", أصغر, "الأكبر =", أكبر
نهاية
