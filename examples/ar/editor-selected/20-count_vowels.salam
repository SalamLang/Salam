//! وضع: برنامج | عنوان: عد الحروف المتحركة
// لغة: العربية
دالة الرئیسیة:
    س := "salam donya"
    متغير عدد := 0
    كرر س.طول() مع i:
        ک := س.مقطع(i, 1)
        إذا ک == "a" أو ک == "e" أو ک == "i" أو ک == "o" أو ک == "u":
            عدد = عدد + 1
        نهاية
    نهاية
    اطبع "عدد الحروف المتحركة في", س, "=", عدد
نهاية
