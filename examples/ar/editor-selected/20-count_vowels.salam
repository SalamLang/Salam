//! وضع: برنامج | عنوان: عد الحروف المتحركة
دالة الرئيسية:
    س نص = "salam donya"
    متغير عدد صحيح = 0
    لكل متغير i = 0; i < س.len(); i = i + 1:
        ك نص = س.substr(i, 1)
        إذا ك == "a" أو ك == "e" أو ك == "i" أو ك == "o" أو ك == "u":
            عدد = عدد + 1
        نهاية
    نهاية
    اطبع "عدد الحروف المتحركة في", س, "=", عدد
نهاية
