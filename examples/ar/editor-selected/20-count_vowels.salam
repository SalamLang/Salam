//! وضع: برنامج | عنوان: عد الحروف المتحركة
// لغة: العربية
دالة الرئيسية:
    س := "salam donya"
    متغير عدد := 0
    كرر س.طول() مع i:
        ك := س.مقطع(i, 1)
        إذا ك == "a" أو ك == "e" أو ك == "i" أو ك == "o" أو ك == "u":
            عدد = عدد + 1
        نهاية
    نهاية
    اطبع "عدد الحروف المتحركة في", س, "=", عدد
نهاية
