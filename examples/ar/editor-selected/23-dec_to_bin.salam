//! وضع: برنامج | عنوان: تحويل إلى ثنائي
دالة تحويل ثنائي(ن : صحيح) : نص:
    إذا ن == 0: أرجع "0" نهاية
    متغير س := ن
    متغير بتات := ""
    بينما س > 0:
        بتات = "" + (س % 2) + بتات
        س = س / 2
    نهاية
    أرجع بتات
نهاية

دالة الرئيسية:
    أعداد := [0, 5, 10, 255] بوصفه صحيح[4]
    كرر 4 مع i:
        اطبع أعداد[i], "في النظام الثنائي =", تحويل ثنائي(أعداد[i])
    نهاية
نهاية
