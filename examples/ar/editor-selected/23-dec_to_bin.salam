//! وضع: برنامج | عنوان: تحويل إلى ثنائي
دالة إلى_ثنائي(ن صحيح) نص:
    إذا ن == 0: أرجع "0" نهاية
    متغير س صحيح = ن
    متغير بتات نص = ""
    بينما س > 0:
        بتات = "" + (س % 2) + بتات
        س = س / 2
    نهاية
    أرجع بتات
نهاية
دالة الرئيسية:
    متغير أعداد صحيح[4] = [0, 5, 10, 255]
    لكل متغير i = 0; i < 4; i = i + 1:
        اطبع أعداد[i], "في النظام الثنائي =", إلى_ثنائي(أعداد[i])
    نهاية
نهاية
