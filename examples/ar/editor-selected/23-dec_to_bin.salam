//! وضع: برنامج | عنوان: تحويل إلى ثنائي
// لغة: العربية
دالة تحویل ثنائی(ن: صحیح): نص:
    إذا ن == 0: أرجع "0" نهاية
    متغير س := ن
    متغير بتات := ""
    بينما س > 0:
        بتات = "" + (س % 2) + بتات
        س = س / 2
    نهاية
    أرجع بتات
نهاية

دالة الرئیسیة:
    أعداد := [0, 5, 10, 255] بوصفه صحیح[4]
    كرر 4 مع i:
        اطبع أعداد[i], "في النظام الثنائي =", تحویل ثنائی(أعداد[i])
    نهاية
نهاية
