//! وضع: برنامج | عنوان: العوامل الأولية
دالة الرئيسية:
    متغير ن := 360
    متغير س := ن
    متغير سطر := ""
    متغير د := 2
    بينما د * د <= س:
        بينما س % د == 0:
            سطر = سطر + د + " "
            س = س / د
        نهاية
        د = د + 1
    نهاية
    إذا س > 1: سطر = سطر + س + " " نهاية
    اطبع ن, "=", سطر
نهاية
