//! وضع: برنامج | عنوان: الأس الصحيح
دالة أس(أساس : صحيح, قوة : صحيح) : صحيح:
    متغير نتيجة : صحيح = 1
    لكل متغير i = 0, i < قوة, i = i + 1: نتيجة = نتيجة * أساس نهاية
    أرجع نتيجة
نهاية

دالة الرئيسية:
    لكل متغير e = 0, e <= 8, e = e + 1:
        اطبع "٢ أس", e, "=", أس(2, e)
    نهاية
نهاية
