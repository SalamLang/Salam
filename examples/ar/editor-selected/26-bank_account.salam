//! وضع: برنامج | عنوان: حساب بنكي
// لغة: العربية
بنية حساب:
    عام رصید: صحیح = 0
    عام دالة إیداع(مبلغ: صحیح): هذا.رصید = هذا.رصید + مبلغ نهاية
    عام دالة سحب(مبلغ: صحیح):
        إذا مبلغ <= هذا.رصید: هذا.رصید = هذا.رصید - مبلغ
        وإلا:
            اطبع "الرصيد غير كافٍ"
        نهاية
    نهاية
نهاية

دالة الرئیسیة:
    متغير ح := حساب { رصید = 100 }
    ح.إیداع(50)
    ح.سحب(30)
    ح.سحب(200)
    اطبع "الرصيد =", ح.رصید
نهاية
