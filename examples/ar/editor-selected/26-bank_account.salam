//! وضع: برنامج | عنوان: حساب بنكي
بنية حساب:
    عام رصيد : صحيح = 0
    عام دالة إيداع(مبلغ : صحيح): هذا.رصيد = هذا.رصيد + مبلغ نهاية
    عام دالة سحب(مبلغ : صحيح):
        إذا مبلغ <= هذا.رصيد: هذا.رصيد = هذا.رصيد - مبلغ
        وإلا:
            اطبع "الرصيد غير كافٍ"
        نهاية
    نهاية
نهاية

دالة الرئيسية:
    متغير ح := حساب { رصيد = 100 }
    ح.إيداع(50)
    ح.سحب(30)
    ح.سحب(200)
    اطبع "الرصيد =", ح.رصيد
نهاية
