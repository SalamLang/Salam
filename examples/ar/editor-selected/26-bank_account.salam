//! وضع: برنامج | عنوان: حساب بنكي
بنية حساب:
    رصيد صحيح = 0
    دالة إيداع(مبلغ صحيح): هذا.رصيد = هذا.رصيد + مبلغ نهاية
    دالة سحب(مبلغ صحيح):
        إذا مبلغ <= هذا.رصيد: هذا.رصيد = هذا.رصيد - مبلغ
        وإلا:
            اطبع "الرصيد غير كافٍ"
        نهاية
    نهاية
نهاية

دالة الرئيسية:
    متغير ح حساب = حساب { رصيد = 100 }
    ح.إيداع(50)
    ح.سحب(30)
    ح.سحب(200)
    اطبع "الرصيد =", ح.رصيد
نهاية
