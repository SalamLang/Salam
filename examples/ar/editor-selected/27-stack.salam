//! وضع: برنامج | عنوان: مكدس
// لغة: العربية
دالة الرئيسية:
    متغير مكدس := متجه {} بوصفه متجه<صحيح>
    مكدس.أضف(1)
    مكدس.أضف(2)
    مكدس.أضف(3)
    اطبع "الحجم =", مكدس.طول() بوصفه صحيح
    بينما مكدس.طول() > 0:
        اطبع "سحب", مكدس.أخرج()
    نهاية
    اطبع "الحجم =", مكدس.طول() بوصفه صحيح
نهاية
