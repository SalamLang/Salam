//! وضع: برنامج | عنوان: مكدس
// لغة: العربية
دالة الرئيسية:
    متغير مكدس := Vector {} بوصفه Vector<صحيح>
    مكدس.push(1)
    مكدس.push(2)
    مكدس.push(3)
    اطبع "الحجم =", مكدس.len() بوصفه صحيح
    بينما مكدس.len() > 0:
        اطبع "سحب", مكدس.pop()
    نهاية
    اطبع "الحجم =", مكدس.len() بوصفه صحيح
نهاية
