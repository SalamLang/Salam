//! وضع: برنامج | عنوان: مكدس
// لغة: العربية
دالة الرئیسیة:
    متغير مکدس := متجه {} بوصفه متجه<صحیح> مکدس.أضف(1)
    مکدس.أضف(2)
    مکدس.أضف(3)
    اطبع "الحجم =", مکدس.طول() بوصفه صحیح
    بينما مکدس.طول() > 0:
        اطبع "سحب", مکدس.أخرج()
    نهاية
    اطبع "الحجم =", مکدس.طول() بوصفه صحیح
نهاية
