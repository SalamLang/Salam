//! وضع: برنامج | عنوان: اختصار
// لغة: العربية
دالة الرئیسیة:
    عبارة := "salam azad multi platform"
    متغير کلمات := عبارة.قسم(" ")
    متغير اختصار := ""
    كرر کلمات.طول() مع i:
        ک := کلمات.احصل(i)[0]
        اختصار = اختصار + ک.مقطع(0, 1)
    نهاية
    اطبع عبارة, "->", اختصار
نهاية
