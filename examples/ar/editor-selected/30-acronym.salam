//! وضع: برنامج | عنوان: اختصار
دالة الرئيسية:
    عبارة : نص = "salam azad multi platform"
    متغير كلمات : Vector<نص> = عبارة.split(" ")
    متغير اختصار : نص = ""
    لكل متغير i = 0, i < كلمات.len(), i = i + 1:
        ك : نص = كلمات.get(i)[0]
        اختصار = اختصار + ك.substr(0, 1)
    نهاية
    اطبع عبارة, "->", اختصار
نهاية
