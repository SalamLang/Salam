//! وضع: برنامج | عنوان: اختصار
// لغة: العربية
دالة الرئيسية:
    عبارة := "salam azad multi platform"
    متغير كلمات := عبارة.قسم(" ")
    متغير اختصار := ""
    كرر كلمات.طول() مع i:
        ك := كلمات.احصل(i)[0]
        اختصار = اختصار + ك.مقطع(0, 1)
    نهاية
    اطبع عبارة, "->", اختصار
نهاية
