//! وضع: برنامج | عنوان: اختصار
// لغة: العربية
دالة الرئيسية:
    عبارة := "salam azad multi platform"
    متغير كلمات := عبارة.split(" ")
    متغير اختصار := ""
    كرر كلمات.len() مع i:
        ك := كلمات.get(i)[0]
        اختصار = اختصار + ك.substr(0, 1)
    نهاية
    اطبع عبارة, "->", اختصار
نهاية
