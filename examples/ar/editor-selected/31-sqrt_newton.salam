//! وضع: برنامج | عنوان: جذر نيوتن
// لغة: العربية
دالة جذر(س: عشری٦٤): عشری٦٤:
    إذا س <= 0.0: أرجع 0.0 نهاية
    متغير تخمین := س
    كرر 20 مع i:
        تخمین = (تخمین + س / تخمین) / 2.0
    نهاية
    أرجع تخمین
نهاية

دالة الرئیسیة:
    قیم := [2.0, 16.0, 50.0] بوصفه عشری٦٤[3]
    كرر 3 مع i:
        اطبع "جذر", قیم[i], "تقريبا", جذر(قیم[i])
    نهاية
نهاية
