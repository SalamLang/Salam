//! وضع: برنامج | عنوان: جذر نيوتن
دالة جذر(س : عشري٦٤) : عشري٦٤:
    إذا س <= 0.0: أرجع 0.0 نهاية
    متغير تخمين : عشري٦٤ = س
    لكل متغير i = 0, i < 20, i = i + 1:
        تخمين = (تخمين + س / تخمين) / 2.0
    نهاية
    أرجع تخمين
نهاية

دالة الرئيسية:
    متغير قيم : عشري٦٤[3] = [2.0, 16.0, 50.0]
    لكل متغير i = 0, i < 3, i = i + 1:
        اطبع "جذر", قيم[i], "تقريبا", جذر(قيم[i])
    نهاية
نهاية
