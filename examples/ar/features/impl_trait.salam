// لغة: العربية
واجهة مرتب:
    دالة رتبة() : صحيح
نهاية

تنفيذ مرتب على صحيح:
    دالة رتبة() : صحيح: أرجع هذا نهاية
نهاية

تنفيذ مرتب على نص:
    دالة رتبة() : صحيح: أرجع len(هذا) نهاية
نهاية

دالة الأكبر<ن: مرتب>(أ : ن, ب : ن) : صحيح:
    إذا أ.رتبة() > ب.رتبة(): أرجع أ.رتبة() نهاية
    أرجع ب.رتبة()
نهاية

دالة الرئيسية:
    اطبع الأكبر(3, 9)
    اطبع الأكبر("hi", "salam")
نهاية
