// لغة: العربية
واجهة مرتب:
    دالة رتبة(): صحیح
نهاية

تنفيذ مرتب على صحیح:
    دالة رتبة(): صحیح: أرجع هذا نهاية
نهاية

تنفيذ مرتب على نص:
    دالة رتبة(): صحیح: أرجع len(هذا) نهاية
نهاية

دالة الأکبر<ن: مرتب>(أ: ن, ب: ن): صحیح:
    إذا أ.رتبة() > ب.رتبة(): أرجع أ.رتبة() نهاية
    أرجع ب.رتبة()
نهاية

دالة الرئیسیة:
    اطبع الأکبر(3, 9)
    اطبع الأکبر("hi", "salam")
نهاية
