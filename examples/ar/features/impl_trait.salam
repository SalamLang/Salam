// لغة: العربية
واجهة محدد:
    دالة حجم() صحيح
نهاية

تنفيذ محدد لكل صحيح:
    دالة حجم() صحيح: أرجع هذا نهاية
نهاية

تنفيذ محدد لكل نص:
    دالة حجم() صحيح: أرجع len(هذا) نهاية
نهاية

دالة الأكبر<ن: محدد>(أ ن, ب ن) صحيح:
    إذا أ.حجم() > ب.حجم(): أرجع أ.حجم() نهاية
    أرجع ب.حجم()
نهاية

دالة الرئيسية:
    اطبع الأكبر(3, 9)
    اطبع الأكبر("hi", "salam")
نهاية
