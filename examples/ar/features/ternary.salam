// لغة: العربية
دالة الرئيسية:
    عمر := 20
    اطبع عمر >= 18 ؟ "بالغ" : "قاصر"

    درجة := 74
    تقدير := درجة >= 90 ؟ "أ" : درجة >= 75 ؟ "ب" : درجة >= 60 ؟ "ج" : "د"
    اطبع "التقدير:", تقدير

    ع := -8
    مطلق := ع < 0 ؟ -(ع) : ع
    اطبع "المطلق:", مطلق

    متغير زوجيات := 0
    كرر 10 مع عداد:
        زوجيات += عداد % 2 == 0 ؟ 1 : 0
    نهاية
    اطبع "الزوجيات:", زوجيات
نهاية
