// لغة: العربية
دالة الرئیسیة:
    عمر := 20
    اطبع عمر >= 18 ؟ "بالغ" : "قاصر"

    درجة := 74
    تقدیر := درجة >= 90 ؟ "أ" : درجة >= 75 ؟ "ب" : درجة >= 60 ؟ "ج" : "د"
    اطبع "التقدير:", تقدیر

    ع := -8
    مطلق := ع < 0 ؟ -(ع) : ع
    اطبع "المطلق:", مطلق

    متغير زوجیات := 0
    كرر 10 مع عداد:
        زوجیات += عداد % 2 == 0 ؟ 1 : 0
    نهاية
    اطبع "الزوجيات:", زوجیات
نهاية
