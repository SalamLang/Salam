package main

import http
import str

func main:
    resp := http.Get("http://example.com/")
    print "status: "
    println str.FromInt(resp.status as i64)
    print "body bytes: "
    println str.FromInt(str.Len(resp.body) as i64)
    if str.Find(resp.body, "<title>") >= 0:
        println "page has a <title> tag"
    else:
        println "(no title found)"
    end
end
