package main

import "http"
import "str"
import "io"

func main:
    resp := http.Get("http://example.com/")
    io.Print("status: ")
    io.Println(str.FromInt(resp.status as i64))
    io.Print("body bytes: ")
    io.Println(str.FromInt(str.Len(resp.body) as i64))
    if str.Find(resp.body, "<title>") >= 0:
        io.Println("page has a <title> tag")
    else:
        io.Println("(no title found)")
    end
end
