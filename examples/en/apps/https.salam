package main

import http
import str

func show(label: str, url: str):
    r := http.Get(url)
    print label
    print " -> status "
    print str.FromInt(r.status as i64)
    print ", "
    print str.FromInt(str.Len(r.body) as i64)
    println " bytes"
end

func main:
    show("https", "https://example.com/")
    show("http ", "http://example.com/")
    r := http.Get("https://api.github.com/zen")
    if http.Ok(r):
        print "github zen: "
        println r.body
    end
end
