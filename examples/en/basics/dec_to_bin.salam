func to_binary(n : int) : str:
    if n == 0: ret "0" end
    mut x : int = n
    mut bits : str = ""
    while x > 0:
        bits = "" + (x % 2) + bits
        x = x / 2
    end
    ret bits
end

func main:
    mut nums : int[4] = [0, 5, 10, 255]
    for mut i = 0, i < 4, i = i + 1:
        println nums[i], "=", to_binary(nums[i]), "in binary"
    end
end
