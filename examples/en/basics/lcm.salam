func gcd(a : int, b : int) : int:
    mut x : int = a
    mut y : int = b
    while y != 0:
        mut t : int = y
        y = x % y
        x = t
    end
    ret x
end

func lcm(a : int, b : int) : int: ret a / gcd(a, b) * b end

func main:
    println "lcm(4, 6) =", lcm(4, 6)
    println "lcm(21, 6) =", lcm(21, 6)
end
