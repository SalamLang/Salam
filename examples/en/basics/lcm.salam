func gcd(a i32, b i32) i32:
    mut x i32 = a
    mut y i32 = b
    while y != 0:
        mut t i32 = y
        y = x % y
        x = t
    end
    ret x
end
func lcm(a i32, b i32) i32: ret a / gcd(a, b) * b end
func main:
    println "lcm(4, 6) =", lcm(4, 6)
    println "lcm(21, 6) =", lcm(21, 6)
end
