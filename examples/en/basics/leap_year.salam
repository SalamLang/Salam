func is_leap(y i32) bool:
    if y % 400 == 0: ret true end
    if y % 100 == 0: ret false end
    ret y % 4 == 0
end
func main:
    mut years i32[5] = [1900, 2000, 2012, 2021, 2024]
    for mut i = 0; i < 5; i = i + 1:
        if is_leap(years[i]): println years[i], "is a leap year"
        else: println years[i], "is not a leap year"
        end
    end
end
