func is_palindrome(n : int) : bool:
    mut x : int = n
    mut rev : int = 0
    while x > 0:
        rev = rev * 10 + x % 10
        x = x / 10
    end
    ret rev == n
end

func main:
    mut nums : int[4] = [121, 123, 1221, 13]
    for mut i = 0, i < 4, i = i + 1:
        if is_palindrome(nums[i]): println nums[i], "is a palindrome"
        else:
            println nums[i], "is not a palindrome"
        end
    end
end
