func main:
    mut n : int = 360
    mut x : int = n
    mut line : str = ""
    mut d : int = 2
    while d * d <= x:
        while x % d == 0:
            line = line + d + " "
            x = x / d
        end
        d = d + 1
    end
    if x > 1: line = line + x + " " end
    println n, "=", line
end
