func main:
    repeat 3:
        println "hello"
    end

    n := 4
    repeat n * 2:
        print "*"
    end
    println ""

    zero := n - 4
    repeat zero: println "never" end
    repeat zero - 5: println "never either" end

    repeat 1 to 5:
        print "#"
    end
    println ""

    repeat 0 to 100 by 10:
        print "."
    end
    println ""
end
