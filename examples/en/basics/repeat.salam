func main:
    repeat 3:
        println "hello"
    end

    n i32 = 4
    repeat n * 2:
        print "*"
    end
    println ""

    repeat 0: println "never" end
    repeat -5: println "never either" end

    repeat 1 to 5:
        print "#"
    end
    println ""

    repeat 0 to 100 every 10:
        print "."
    end
    println ""
end
