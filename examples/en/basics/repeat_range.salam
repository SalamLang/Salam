func main:
    mut sum : int = 0
    mut k : int = 0
    repeat 1 to 10:
        k += 1
        sum += k
    end
    print "1+2+...+10 = "
    println sum

    mut row : int = 0
    repeat 1 to 5:
        row += 1
        repeat 1 to row:
            print "*"
        end
        println ""
    end
end
