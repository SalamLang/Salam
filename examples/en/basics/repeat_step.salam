func main:
    mut evens i32 = 0
    repeat 0 to 20 every 2:
        evens += 1
    end
    print "even values in 0..20: "
    println evens

    print "scale:"
    mut tick i32 = 0
    repeat 0 to 100 every 10:
        print " |"
        tick += 1
    end
    println ""
    print "ticks drawn: "
    println tick

    base i32 = 3
    mut beats i32 = 0
    repeat 0 to 30 every base * 5:
        beats += 1
    end
    print "0..30 every 15 -> "
    println beats
end
