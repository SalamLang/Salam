func main:
    mut evens := 0
    repeat 0 to 20 by 2:
        evens += 1
    end
    print "even values in 0..20: "
    println evens

    print "scale:"
    mut tick := 0
    repeat 0 to 100 by 10:
        print " |"
        tick += 1
    end
    println ""
    print "ticks drawn: "
    println tick

    base := 3
    mut beats := 0
    repeat 0 to 30 by base * 5:
        beats += 1
    end
    print "0..30 every 15 -> "
    println beats
end
