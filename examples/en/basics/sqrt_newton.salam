func sqrt(x: f64): f64:
    if x <= 0.0: ret 0.0 end
    mut guess := x
    repeat 20 with i:
        guess = (guess + x / guess) / 2.0
    end
    ret guess
end

func main:
    vals := [2.0, 16.0, 50.0] as f64[3]
    repeat 3 with i:
        println "sqrt of", vals[i], "~", sqrt(vals[i])
    end
end
