func sqrt(x f64) f64:
    if x <= 0.0: ret 0.0 end
    mut guess f64 = x
    for mut i = 0; i < 20; i = i + 1:
        guess = (guess + x / guess) / 2.0
    end
    ret guess
end

func main:
    mut vals f64[3] = [2.0, 16.0, 50.0]
    for mut i = 0; i < 3; i = i + 1:
        println "sqrt of", vals[i], "~", sqrt(vals[i])
    end
end
