const VERSION := "0.2.0"
func main:
    println ("Salam/" + VERSION)
    println ("count = " + 42)
    println ("pi ~= " + 3.14)
    println (7 + " items")
    println ("ok? " + true)
    println ("grade: " + 'A')
    name := "Salam"
    println ("Hello, " + name + "! v" + VERSION + " build " + 100)
    mut s := "a"
    s += "b"
    s += 1
    s += true
    println (s)
end
