func main:
    s : str = "salam donya"
    mut count : int = 0
    for mut i = 0, i < s.len(), i = i + 1:
        c : str = s.substr(i, 1)
        if c == "a" || c == "e" || c == "i" || c == "o" || c == "u":
            count = count + 1
        end
    end
    println "vowels in", s, "=", count
end
