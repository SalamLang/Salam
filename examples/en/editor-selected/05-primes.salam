//! mode: app | title: Primes
func is_prime(n : int) : bool:
    if n < 2: ret false end
    mut i := 2
    until i * i <= n:
        if n % i == 0: ret false end
        i = i + 1
    end
    ret true
end

func main:
    mut line := ""
    repeat 2 to 30 with n:
        if is_prime(n): line = line + n + " " end
    end
    println "Primes up to 30:", line
end
