//! mode: app | title: Bubble sort
func main:
    mut a : int[6] = [5, 2, 8, 1, 9, 3]
    for mut i = 0, i < 6, i = i + 1:
        for mut j = 0, j < 5 - i, j = j + 1:
            if a[j] > a[j + 1]:
                mut t : int = a[j]
                a[j] = a[j + 1]
                a[j + 1] = t
            end
        end
    end
    mut line : str = ""
    for mut k = 0, k < 6, k = k + 1: line = line + a[k] + " " end
    println "Sorted:", line
end
