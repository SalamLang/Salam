//! mode: app | title: Bubble sort
func main:
    mut a := [5, 2, 8, 1, 9, 3] as int[6]
    repeat 6 with i:
        repeat 5 - i with j:
            if a[j] > a[j + 1]:
                t := a[j]
                a[j] = a[j + 1]
                a[j + 1] = t
            end
        end
    end
    mut line := ""
    repeat 6 with k: line = line + a[k] + " " end
    println "Sorted:", line
end
