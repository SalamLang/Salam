//! mode: app | title: Struct: Rectangle
struct Rect:
    w f64 = 0.0
    h f64 = 0.0
    func area() f64: ret this.w * this.h end
    func perimeter() f64: ret 2.0 * (this.w + this.h) end
end

func main:
    r Rect = Rect { w = 4.0, h = 3.0 }
    println "area =", r.area()
    println "perimeter =", r.perimeter()
end
