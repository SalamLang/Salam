//! mode: app | title: Struct: Rectangle
struct Rect:
    pub w: f64 = 0.0
    pub h: f64 = 0.0
    pub func area(): f64: ret this.w * this.h end
    pub func perimeter(): f64: ret 2.0 * (this.w + this.h) end
end

func main:
    r := Rect { w = 4.0, h = 3.0 }
    println "area =", r.area()
    println "perimeter =", r.perimeter()
end
