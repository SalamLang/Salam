//! mode: app | title: Word count (HashMap)
func main:
    text := "the cat the dog the bird"
    mut words := text.split(" ")
    mut counts := HashMap {} as HashMap<str, int>
    repeat words.len() with i:
        w := words.get(i)[0]
        if counts.has(w): counts.put(w, counts.get(w) + 1)
        else:
            counts.put(w, 1)
        end
    end
    mut it := counts.iter()
    until it.has_next():
        println it.key(), "->", it.value()
        it.next()
    end
end
