//! mode: layout | title: Web page
layout:
    title = "My Page"
    lang = "english"
    dir = "left to right"
    header:
        background = "blue"
        color = "white"
        padding = "24px"
        heading: size = 1 content = "Welcome to Salam" font_size = "32px" end
    end
    box:
        padding = "20px"
        paragraph: content = "This page was generated from Salam." end
    end
end
