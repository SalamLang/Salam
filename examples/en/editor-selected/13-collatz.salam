//! mode: app | title: Collatz
func main:
    mut n : int = 27
    mut steps : int = 0
    println "Collatz from", n
    while n != 1:
        if n % 2 == 0: n = n / 2
        else:
            n = 3 * n + 1
        end
        steps = steps + 1
    end
    println "reached 1 in", steps, "steps"
end
