//! mode: app | title: Leap year
func is_leap(y : int) : bool:
    if y % 400 == 0: ret true
    else y % 100 == 0: ret false
    else: ret y % 4 == 0
    end
end

func main:
    years := [1900, 2000, 2012, 2021, 2024] as int[5]
    repeat 5 with i:
        if is_leap(years[i]): println years[i], "is a leap year"
        else:
            println years[i], "is not a leap year"
        end
    end
end
