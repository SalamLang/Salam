//! mode: app | title: Palindrome number
func is_palindrome(n i32) bool:
    mut x i32 = n
    mut rev i32 = 0
    while x > 0:
        rev = rev * 10 + x % 10
        x = x / 10
    end
    ret rev == n
end

func main:
    mut nums i32[4] = [121, 123, 1221, 13]
    for mut i = 0; i < 4; i = i + 1:
        if is_palindrome(nums[i]): println nums[i], "is a palindrome"
        else:
            println nums[i], "is not a palindrome"
        end
    end
end
