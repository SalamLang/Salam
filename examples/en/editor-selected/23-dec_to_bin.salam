//! mode: app | title: Decimal to binary
func to_binary(n i32) str:
    if n == 0: ret "0" end
    mut x i32 = n
    mut bits str = ""
    while x > 0:
        bits = "" + (x % 2) + bits
        x = x / 2
    end
    ret bits
end

func main:
    mut nums i32[4] = [0, 5, 10, 255]
    for mut i = 0; i < 4; i = i + 1:
        println nums[i], "=", to_binary(nums[i]), "in binary"
    end
end
