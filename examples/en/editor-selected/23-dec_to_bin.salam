//! mode: app | title: Decimal to binary
func to_binary(n : int) : str:
    if n == 0: ret "0" end
    mut x := n
    mut bits := ""
    until x > 0:
        bits = "" + (x % 2) + bits
        x = x / 2
    end
    ret bits
end

func main:
    mut nums := [0, 5, 10, 255] as int[4]
    repeat 4 with i:
        println nums[i], "=", to_binary(nums[i]), "in binary"
    end
end
