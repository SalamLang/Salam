//! mode: app | title: Prime factors
func main:
    mut n i32 = 360
    mut x i32 = n
    mut line str = ""
    mut d i32 = 2
    while d * d <= x:
        while x % d == 0:
            line = line + d + " "
            x = x / d
        end
        d = d + 1
    end
    if x > 1: line = line + x + " " end
    println n, "=", line
end
