//! mode: app | title: Bank account
struct Account:
    balance i32 = 0
    func deposit(n i32): this.balance = this.balance + n end
    func withdraw(n i32):
        if n <= this.balance: this.balance = this.balance - n
        else:                 println "insufficient funds"
        end
    end
end
func main:
    mut a Account = Account { balance = 100 }
    a.deposit(50)
    a.withdraw(30)
    a.withdraw(200)
    println "balance =", a.balance
end
