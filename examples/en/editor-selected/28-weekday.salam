//! mode: app | title: Weekdays (enum)
enum Day: Mon, Tue, Wed, Thu, Fri, Sat, Sun end
func is_weekend(d Day) bool: ret d == Day.Sat || d == Day.Sun end
func main:
    d Day = Day.Sat
    println "day index =", d as i32
    if is_weekend(d): println "it is the weekend"
    else:
        println "it is a weekday"
    end
end
