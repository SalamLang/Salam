//! mode: app | title: Acronym
func main:
    phrase str = "salam azad multi platform"
    mut words Vector<str> = phrase.split(" ")
    mut acro str = ""
    for mut i = 0; i < words.len(); i = i + 1:
        w str = words.get(i)[0]
        acro = acro + w.substr(0, 1)
    end
    println phrase, "->", acro
end
