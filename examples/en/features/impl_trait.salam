interface Ranked:
    func rank(): int
end

impl Ranked on int:
    func rank(): int: ret this end
end

impl Ranked on str:
    func rank(): int: ret len(this) end
end

func biggest<T: Ranked>(a: T, b: T): int:
    if a.rank() > b.rank(): ret a.rank() end
    ret b.rank()
end

func main:
    println biggest(3, 9)
    println biggest("hi", "salam")
end
