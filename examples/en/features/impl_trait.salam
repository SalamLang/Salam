interface Ranked:
    func rank() i32
end

impl Ranked for i32:
    func rank() i32: ret this end
end

impl Ranked for str:
    func rank() i32: ret len(this) end
end

func biggest<T: Ranked> (a T, b T) i32:
    if a.rank() > b.rank(): ret a.rank() end
    ret b.rank()
end

func main:
    println(biggest(3, 9))
    println(biggest("hi", "salam"))
end
