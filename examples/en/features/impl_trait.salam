interface Sized:
    func size() i32
end

impl Sized for i32:
    func size() i32: ret this end
end

impl Sized for str:
    func size() i32: ret len(this) end
end

func biggest<T: Sized> (a T, b T) i32:
    if a.size() > b.size(): ret a.size() end
    ret b.size()
end

func main:
    println(biggest(3, 9))            // 9  -> the i32 impl
    println(biggest("hi", "salam"))   // 5  -> the str impl
end
