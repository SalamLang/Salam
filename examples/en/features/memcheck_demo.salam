import "mem"
func main:
    _leaked := mem.Allocate(128 as u64)
    println "allocated 128 bytes (will be leaked)"
    buf := mem.Allocate(64 as u64)
    println "allocated 64 bytes"
    mem.Free(buf)
    println "freed 64 bytes"
    println "alloc count:", mem.AllocCount()
    println "free  count:", mem.FreeCount()
    println "live  bytes:", mem.LiveBytes()
    mem.CheckLeaks()
    println "done"
end
