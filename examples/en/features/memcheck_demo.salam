import "mem"
func main:
    _leaked : void* = mem.Allocate(128 as u64)
    __ "allocated 128 bytes (will be leaked)"
    mut buf : void* = mem.Allocate(64 as u64)
    __ "allocated 64 bytes"
    mem.Free(buf)
    __ "freed 64 bytes"
    __ "alloc count:", mem.AllocCount()
    __ "free  count:", mem.FreeCount()
    __ "live  bytes:", mem.LiveBytes()
    mem.CheckLeaks()
    __ "done"
end
