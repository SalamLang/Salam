struct Point:
    pub x : int
    pub y : int
end

func main:
    grid : int[3] = [1, 2, 3]
    grid[0] = 10
    grid[1]++
    __ "bare element write:", grid[0], grid[1], grid[2]

    p : Point = Point { x = 1, y = 2 }
    p.x = 99
    __ "bare field write:", p.x, p.y

    mut total : int = 5
    total = total + 1
    __ "mut reassign:", total

    const LIMIT : int = 100
    __ "const value:", LIMIT
end
