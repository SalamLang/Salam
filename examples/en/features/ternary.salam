func main:
    age := 20
    println age >= 18 ? "adult" : "minor"

    score := 74
    grade := score >= 90 ? "A" : score >= 75 ? "B" : score >= 60 ? "C" : "F"
    println "grade:", grade

    n := -8
    abs := n < 0 ? -(n) : n
    println "abs:", abs

    mut evens := 0
    repeat 10 with i:
        evens += i % 2 == 0 ? 1 : 0
    end
    println "evens:", evens
end
