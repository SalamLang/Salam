if SALAM_OS_WINDOWS:
    link "winsqlite3"
else:
    link "sqlite3"
end
extern:
    func printf(format : str, ...) : int
    func sqlite3_libversion() : str
    func sqlite3_libversion_number() : int
end

func main:
    printf(
        "SQLite version: %s (%d)\n", sqlite3_libversion(), sqlite3_libversion_number()
    )
end
