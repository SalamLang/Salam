@if SALAM_OS_WINDOWS
link "winsqlite3"
@else
link "sqlite3"
@end
extern "C":
    func printf(format str, ...) i32
    func sqlite3_libversion() str
    func sqlite3_libversion_number() i32
end

func main:
    printf(
        "SQLite version: %s (%d)\n", sqlite3_libversion(), sqlite3_libversion_number()
    )
end
