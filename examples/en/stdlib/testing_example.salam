package main
import (
    "testing" "str" "math" "encoding"
)

extern "C":
    func exit(code i32)
end

func main:
    testing.AssertEqStr(str.ToUpper("salam"), "SALAM")
    testing.AssertEqStr(str.Title("hello there"), "Hello There")
    testing.AssertTrue(str.HasPrefix("package", "pack"))
    testing.AssertEqInt(str.Count("a.b.c", "."), 2)
    testing.AssertEqInt(math.MaxInt(3, 9), 9)
    testing.AssertEqInt(math.Gcd(12, 18), 6)
    testing.AssertTrue(math.Mod(10.0, 3.0) == 1.0)
    testing.AssertEqStr(encoding.Base64Decode(encoding.Base64Encode("data!")), "data!")
    testing.AssertEqStr(encoding.HexDecode(encoding.HexEncode("xyz")), "xyz")
    exit(testing.Summary())
end
