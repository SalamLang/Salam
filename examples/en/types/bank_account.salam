struct Account:
    pub balance : int = 0
    pub func deposit(n : int): this.balance = this.balance + n end
    pub func withdraw(n : int):
        if n <= this.balance: this.balance = this.balance - n
        else:
            println "insufficient funds"
        end
    end
end

func main:
    mut a : Account = Account { balance = 100 }
    a.deposit(50)
    a.withdraw(30)
    a.withdraw(200)
    println "balance =", a.balance
end
