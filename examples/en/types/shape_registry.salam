interface Shape:
    func name() : str
    func area() : f64
end

struct Circle:
    r : f64 = 0.0
    func name() : str: ret "circle" end
    func area() : f64: ret 3.14159 * this.r * this.r end
end

struct Rect:
    w : f64 = 0.0
    h : f64 = 0.0
    func name() : str: ret "rect" end
    func area() : f64: ret this.w * this.h end
end

struct Triangle:
    base : f64 = 0.0
    height : f64 = 0.0
    func name() : str: ret "triangle" end
    func area() : f64: ret 0.5 * this.base * this.height end
end

func main:
    registry : Vector<dyn Shape> = Vector {}
    defer registry.free()
    registry.push(Circle { r = 2.0 })
    registry.push(Rect { w = 3.0, h = 4.0 })
    registry.push(Triangle { base = 6.0, height = 5.0 })
    mut i : int = 0
    mut total : f64 = 0.0
    while i < registry.len():
        _ registry.get(i).name()
        _ " -> "
        __ registry.get(i).area()
        total = total + registry.get(i).area()
        i = i + 1
    end
    _ "combined area = "
    __ total
    i = 0
    while i < registry.len():
        registry.get(i).free()
        i = i + 1
    end
end
