import "tcp"
func main:
    srv := tcp.Bind(9000)
    if !tcp.Ok(srv):
        __ "could not bind to port 9000"
        ret
    end
    __ "TCP echo server on port 9000"
    mut running := true
    until running:
        c := tcp.Accept(srv)
        if tcp.ConnOk(c):
            msg := tcp.Read(c, 4096)
            tcp.Write(c, msg)
            tcp.Close(c)
        end
    end
end
