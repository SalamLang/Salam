import "tcp"
func main:
    srv tcp.Server = tcp.Bind(9000)
    if !tcp.Ok(srv):
        __ "could not bind to port 9000"
        ret
    end
    __ "TCP echo server on port 9000"
    mut running bool = true
    while running:
        c tcp.Conn = tcp.Accept(srv)
        if tcp.ConnOk(c):
            msg str = tcp.Read(c, 4096)
            tcp.Write(c, msg)
            tcp.Close(c)
        end
    end
end
