// زبان: فارسی
تابع توان(پایه صحیح, نما صحیح) صحیح:
    متغیر نتیجه صحیح = 1
    برای متغیر i = 0; i < نما; i = i + 1:
        نتیجه = نتیجه * پایه
    پایان
    بازگشت نتیجه
پایان

تابع بیشینه(الف صحیح, ب صحیح) صحیح:
    اگر الف > ب:
        بازگشت الف
    پایان
    بازگشت ب
پایان

تابع اصلی:
    چاپ ("دو به توان ده:", توان(2, 10))
    چاپ ("بیشینه:", بیشینه(توان(2, 4), توان(3, 2)))
پایان
