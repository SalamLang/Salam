// زبان: فارسی
تابع فاکتوریل(ن صحیح۶۴) صحیح۶۴:
    اگر ن <= 1:
        بازگشت 1
    پایان
    بازگشت ن * فاکتوریل(ن - 1)
پایان

تابع فیبوناچی(ن صحیح) صحیح:
    اگر ن < 2:
        بازگشت ن
    پایان
    بازگشت فیبوناچی(ن - 1) + فیبوناچی(ن - 2)
پایان

تابع اصلی:
    چاپ (فاکتوریل(10))
    چاپ (فیبوناچی(10))
پایان
