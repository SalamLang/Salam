// زبان: فارسی
واردکردن "ورودی خروجی"

تابع اصلی:
    چاپ "یک عدد وارد کنید:"
    عدد := ورودی خروجی.بخوان()
    متغیر تعداد := 0

    تکرار عدد.طول() با i:
        حرف := عدد.زیررشته(i, 1)
        اگر حرف == "0" یا حرف == "5":
            تعداد = تعداد + 1
        تمام
    تمام

    چاپ "تعداد رقم‌های ۰ و ۵:", تعداد
تمام
