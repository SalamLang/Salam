// LANG: fa
واردکردن "ورودی_خروجی"

تابع اصلی:
    چاپ "یک عدد وارد کنید:"
    عدد رشته = ورودی_خروجی.بخوان()
    متغیر تعداد صحیح = 0

    برای متغیر i = 0; i < عدد.طول(); i = i + 1:
        حرف رشته = عدد.زیررشته(i, 1)
        اگر حرف == "0" || حرف == "5":
            تعداد = تعداد + 1
        پایان
    پایان

    چاپ "تعداد رقم‌های ۰ و ۵:", تعداد
پایان
