// زبان: فارسی
واردکردن "ورودی_خروجی"

تابع اصلی:
    چاپ "یک عدد وارد کنید:"
    عدد := ورودی_خروجی.بخوان()
    متغیر تعداد := 0

    تکرار عدد.طول() با i:
        حرف := عدد.زیررشته(i, 1)
        اگر حرف == "0" یا حرف == "5":
            تعداد = تعداد + 1
        پایان
    پایان

    چاپ "تعداد رقم‌های ۰ و ۵:", تعداد
پایان
