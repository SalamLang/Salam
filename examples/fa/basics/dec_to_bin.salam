// زبان: فارسی
تابع به دودویی(ن: صحیح): رشته:
    اگر ن == 0: بازگشت "0" تمام
    متغیر ایکس := ن
    متغیر بیتها := ""
    تاوقتی ایکس > 0:
        بیتها = "" + (ایکس % 2) + بیتها
        ایکس = ایکس / 2
    تمام
    بازگشت بیتها
تمام

تابع اصلی:
    اعداد := [0, 5, 10, 255] بعنوان صحیح[4]
    تکرار 4 با i:
        چاپ اعداد[i], "در مبنای دو =", به دودویی(اعداد[i])
    تمام
تمام
