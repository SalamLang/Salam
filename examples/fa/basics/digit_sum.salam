// زبان: فارسی
تابع جمع ارقام(ن : صحیح) : صحیح:
    متغیر ایکس := ن
    متغیر مجموع := 0
    تاوقتی ایکس > 0:
        مجموع = مجموع + ایکس % 10
        ایکس = ایکس / 10
    تمام
    بازگشت مجموع
تمام

تابع اصلی:
    چاپ "جمع ارقام ۱۲۳۴۵ =", جمع ارقام(12345)
    چاپ "جمع ارقام ۹۹ =", جمع ارقام(99)
تمام
