// زبان: فارسی
تابع اصلی:
    متغیر آ := [5, 9, 1, 7, 3, 8, 2] بعنوان صحیح[7]
    متغیر کمینه := آ[0]
    متغیر بیشینه := آ[0]
    تکرار 1 تا 7 - 1 با i:
        اگر آ[i] < کمینه: کمینه = آ[i] پایان
        اگر آ[i] > بیشینه: بیشینه = آ[i] پایان
    پایان
    چاپ "کمینه =", کمینه, "بیشینه =", بیشینه
پایان
