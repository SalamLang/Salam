// زبان: فارسی
تابع متقارن_است(ن : صحیح) : منطقی:
    متغیر ایکس := ن
    متغیر وارون := 0
    تاوقتی ایکس > 0:
        وارون = وارون * 10 + ایکس % 10
        ایکس = ایکس / 10
    پایان
    بازگشت وارون == ن
پایان

تابع اصلی:
    متغیر اعداد := [121, 123, 1221, 13] بعنوان صحیح[4]
    تکرار 4 با i:
        اگر متقارن_است(اعداد[i]): چاپ اعداد[i], "متقارن است"
        وگرنه:
            چاپ اعداد[i], "متقارن نیست"
        پایان
    پایان
پایان
