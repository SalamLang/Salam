// LANG: fa
تابع متقارن_است(ن صحیح۳۲) منطقی:
    متغیر ایکس صحیح۳۲ = ن
    متغیر وارون صحیح۳۲ = 0
    تاوقتی ایکس > 0:
        وارون = وارون * 10 + ایکس % 10
        ایکس = ایکس / 10
    پایان
    بازگشت وارون == ن
پایان
تابع اصلی:
    متغیر اعداد صحیح۳۲[4] = [121, 123, 1221, 13]
    برای متغیر i = 0; i < 4; i = i + 1:
        اگر متقارن_است(اعداد[i]): چاپ اعداد[i], "متقارن است"
        وگرنه:
            چاپ اعداد[i], "متقارن نیست"
        پایان
    پایان
پایان
