// زبان: فارسی
تابع اصلی:
    ن := 360
    متغیر ایکس := ن
    متغیر خط := ""
    متغیر د := 2
    تاوقتی د * د <= ایکس:
        تاوقتی ایکس % د == 0:
            خط = خط + د + " "
            ایکس = ایکس / د
        تمام
        د = د + 1
    تمام
    اگر ایکس > 1: خط = خط + ایکس + " " تمام
    چاپ ن, "=", خط
تمام
