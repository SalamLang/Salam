تابع اصلی:
    متغیر مجموع := 0
    متغیر ک := 0
    تکرار 1 تا 10:
        ک = ک + 1
        مجموع = مجموع + ک
    تمام
    بنویس "۱+۲+...+۱۰ = "
    چاپ مجموع

    متغیر سطر := 0
    تکرار 1 تا 5:
        سطر = سطر + 1
        تکرار 1 تا سطر:
            بنویس "*"
        تمام
        چاپ ""
    تمام
تمام
