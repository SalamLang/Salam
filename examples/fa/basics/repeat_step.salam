تابع اصلی:
    متغیر زوج‌ها صحیح = 0
    تکرار 0 تا 20 هر 2:
        زوج‌ها = زوج‌ها + 1
    پایان
    بنویس "تعداد زوج‌ها در ۰ تا ۲۰: "
    چاپ زوج‌ها

    بنویس "مقیاس:"
    متغیر نشانه صحیح = 0
    تکرار 0 تا 100 هر 10:
        بنویس " |"
        نشانه = نشانه + 1
    پایان
    چاپ ""
    بنویس "تعداد نشانه‌ها: "
    چاپ نشانه

    پایه صحیح = 3
    متغیر ضرب‌ها صحیح = 0
    تکرار 0 تا 30 هر پایه * 5:
        ضرب‌ها = ضرب‌ها + 1
    پایان
    بنویس "۰ تا ۳۰ هر ۱۵ -> "
    چاپ ضرب‌ها
پایان
