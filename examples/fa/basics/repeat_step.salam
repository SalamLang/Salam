// زبان: فارسی
تابع اصلی:
    متغیر زوج‌ها := 0
    تکرار 0 تا 20 گام 2:
        زوج‌ها = زوج‌ها + 1
    تمام
    بنویس "تعداد زوج‌ها در ۰ تا ۲۰: "
    چاپ زوج‌ها

    بنویس "مقیاس:"
    متغیر نشانه := 0
    تکرار 0 تا 100 گام 10:
        بنویس " |"
        نشانه = نشانه + 1
    تمام
    چاپ ""
    بنویس "تعداد نشانه‌ها: "
    چاپ نشانه

    پایه := 3
    متغیر ضرب‌ها := 0
    تکرار 0 تا 30 گام پایه * 5:
        ضرب‌ها = ضرب‌ها + 1
    تمام
    بنویس "۰ تا ۳۰ هر ۱۵ -> "
    چاپ ضرب‌ها
تمام
