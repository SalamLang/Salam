// زبان: فارسی
تابع جذر(ایکس : اعشار۶۴) : اعشار۶۴:
    اگر ایکس <= 0.0: بازگشت 0.0 تمام
    متغیر حدس := ایکس
    تکرار 20 با i:
        حدس = (حدس + ایکس / حدس) / 2.0
    تمام
    بازگشت حدس
تمام

تابع اصلی:
    مقادیر := [2.0, 16.0, 50.0] بعنوان اعشار۶۴[3]
    تکرار 3 با i:
        چاپ "جذر", مقادیر[i], "تقریباً", جذر(مقادیر[i])
    تمام
تمام
