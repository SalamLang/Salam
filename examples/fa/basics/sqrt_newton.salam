// زبان: فارسی
تابع جذر(ایکس اعشار۶۴) اعشار۶۴:
    اگر ایکس <= 0.0: بازگشت 0.0 پایان
    متغیر حدس اعشار۶۴ = ایکس
    برای متغیر i = 0; i < 20; i = i + 1:
        حدس = (حدس + ایکس / حدس) / 2.0
    پایان
    بازگشت حدس
پایان
تابع اصلی:
    متغیر مقادیر اعشار۶۴[3] = [2.0, 16.0, 50.0]
    برای متغیر i = 0; i < 3; i = i + 1:
        چاپ "جذر", مقادیر[i], "تقریباً", جذر(مقادیر[i])
    پایان
پایان
