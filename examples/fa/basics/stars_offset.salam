// زبان: فارسی
واردکردن "io"

تابع اصلی:
    ن صحیح = ورودی_خروجی.بخوان().به_صحیح()

    برای متغیر i = 0; i < ن; i = i + 1:
        متغیر خط رشته = ""

        اگر i % 2 == 0:
            خط = " "
        پایان

        برای متغیر j = 0; j < ن; j = j + 1:
            خط = خط + "* "
        پایان
        چاپ خط
    پایان
پایان
