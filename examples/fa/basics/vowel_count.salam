// LANG: fa
تابع اصلی:
    س رشته = "azcbobobegghakl"
    متغیر تعداد صحیح۳۲ = 0

    برای متغیر i = 0; i < س.طول(); i = i + 1:
        ک رشته = س.زیررشته(i, 1)
        اگر ک == "a" || ک == "e" || ک == "i" || ک == "o" || ک == "u":
            تعداد = تعداد + 1
        پایان
    پایان

    چاپ "Number of vowels:", تعداد
پایان
