// LANG: fa
تابع اصلی:
    متغیر اعداد وکتور<صحیح۳۲> = وکتور {}
    برای متغیر i = 1; i <= 5; i = i + 1:
        اعداد.بیفزا(i * i)
    پایان
    متغیر مجموع صحیح۳۲ = 0
    متغیر j صحیح۳۲ = 0
    تاوقتی j < اعداد.طول():
        مجموع = مجموع + اعداد.بگیر(j)[0]
        j = j + 1
    پایان
    چاپ ("تعداد:", اعداد.طول() بعنوان صحیح۶۴)
    چاپ ("مجموع مربع‌ها:", مجموع)
پایان
