// زبان: فارسی
تابع اصلی:
    متغیر سن‌ها := نگاشت {} بعنوان نگاشت<رشته, صحیح>
    سن‌ها.درج("سارا", 30)
    سن‌ها.درج("علی", 25)
    سن‌ها.درج("رضا", 40)
    چاپ "سن سارا:", سن‌ها.بگیر("سارا")
    چاپ "علی موجود است؟", سن‌ها.دارد("علی")
    چاپ "حسن موجود است؟", سن‌ها.دارد("حسن")
    چاپ "تعداد:", سن‌ها.اندازه()
تمام
