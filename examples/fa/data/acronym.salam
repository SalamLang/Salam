// زبان: فارسی
تابع اصلی:
    عبارت رشته = "salam azad multi platform"
    متغیر کلمات وکتور<رشته> = عبارت.بشکاف(" ")
    متغیر سرنام رشته = ""
    برای متغیر i = 0; i < کلمات.طول(); i = i + 1:
        ک رشته = کلمات.بگیر(i)[0]
        سرنام = سرنام + ک.زیررشته(0, 1)
    پایان
    چاپ عبارت, "->", سرنام
پایان
