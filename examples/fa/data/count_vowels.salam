// زبان: فارسی
تابع اصلی:
    س : رشته = "salam donya"
    متغیر تعداد : صحیح = 0
    برای متغیر i = 0, i < س.طول(), i = i + 1:
        ک : رشته = س.زیررشته(i, 1)
        اگر ک == "a" یا ک == "e" یا ک == "i" یا ک == "o" یا ک == "u":
            تعداد = تعداد + 1
        پایان
    پایان
    چاپ "تعداد مصوت‌ها در", س, "=", تعداد
پایان
