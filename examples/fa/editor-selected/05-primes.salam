//! حالت: برنامه | عنوان: اعداد اول
تابع اول_است(ن : صحیح) : منطقی:
    اگر ن < 2: بازگشت نادرست پایان
    متغیر i := 2
    تاوقتی i * i <= ن:
        اگر ن % i == 0: بازگشت نادرست پایان
        i = i + 1
    پایان
    بازگشت درست
پایان

تابع اصلی:
    متغیر خط := ""
    تکرار 2 تا 30 با ن:
        اگر اول_است(ن): خط = خط + ن + " " پایان
    پایان
    چاپ "اعداد اول تا ۳۰:", خط
پایان
