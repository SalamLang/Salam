//! حالت: app | عنوان: ب.م.م
تابع بمم(الف صحیح, ب صحیح) صحیح:
    متغیر ایکس صحیح = الف
    متغیر ایگرگ صحیح = ب
    تاوقتی ایگرگ != 0:
        متغیر ت صحیح = ایگرگ
        ایگرگ = ایکس % ایگرگ
        ایکس = ت
    پایان
    بازگشت ایکس
پایان
تابع اصلی:
    چاپ "ب.م.م ۴۸ و ۳۶ =", بمم(48, 36)
    چاپ "ب.م.م ۱۷ و ۵ =", بمم(17, 5)
پایان
