//! mode: app | title: ب.م.م
تابع بمم(الف صحیح۳۲, ب صحیح۳۲) صحیح۳۲:
    متغیر ایکس صحیح۳۲ = الف
    متغیر ایگرگ صحیح۳۲ = ب
    تاوقتی ایگرگ != 0:
        متغیر ت صحیح۳۲ = ایگرگ
        ایگرگ = ایکس % ایگرگ
        ایکس = ت
    پایان
    بازگشت ایکس
پایان
تابع اصلی:
    چاپ "ب.م.م ۴۸ و ۳۶ =", بمم(48, 36)
    چاپ "ب.م.م ۱۷ و ۵ =", بمم(17, 5)
پایان
