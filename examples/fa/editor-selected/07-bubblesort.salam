//! حالت: برنامه | عنوان: مرتب‌سازی حبابی
تابع اصلی:
    متغیر آ := [5, 2, 8, 1, 9, 3] بعنوان صحیح[6]
    تکرار 6 با i:
        تکرار 5 - i با ج:
            اگر آ[ج] > آ[ج + 1]:
                متغیر ت := آ[ج]
                آ[ج] = آ[ج + 1]
                آ[ج + 1] = ت
            پایان
        پایان
    پایان
    متغیر خط := ""
    تکرار 6 با ک: خط = خط + آ[ک] + " " پایان
    چاپ "مرتب‌شده:", خط
پایان
