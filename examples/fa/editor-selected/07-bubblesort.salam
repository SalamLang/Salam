//! حالت: برنامه | عنوان: مرتب‌سازی حبابی
تابع اصلی:
    متغیر آ صحیح[6] = [5, 2, 8, 1, 9, 3]
    برای متغیر i = 0; i < 6; i = i + 1:
        برای متغیر ج = 0; ج < 5 - i; ج = ج + 1:
            اگر آ[ج] > آ[ج + 1]:
                متغیر ت صحیح = آ[ج]
                آ[ج] = آ[ج + 1]
                آ[ج + 1] = ت
            پایان
        پایان
    پایان
    متغیر خط رشته = ""
    برای متغیر ک = 0; ک < 6; ک = ک + 1: خط = خط + آ[ک] + " " پایان
    چاپ "مرتب‌شده:", خط
پایان
