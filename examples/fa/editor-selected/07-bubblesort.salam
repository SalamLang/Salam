//! حالت: برنامه | عنوان: مرتب‌سازی حبابی
// زبان: فارسی
تابع اصلی:
    متغیر آ := [5, 2, 8, 1, 9, 3] بعنوان صحیح[6]
    تکرار 6 با i:
        تکرار 5 - i با ج:
            اگر آ[ج] > آ[ج + 1]:
                ت := آ[ج]
                آ[ج] = آ[ج + 1]
                آ[ج + 1] = ت
            تمام
        تمام
    تمام
    متغیر خط := ""
    تکرار 6 با ک: خط = خط + آ[ک] + " " تمام
    چاپ "مرتب‌شده:", خط
تمام
