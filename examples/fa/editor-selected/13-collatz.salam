//! mode: app | title: دنباله‌ی کولاتز
تابع اصلی:
    متغیر ن صحیح۳۲ = 27
    متغیر گامها صحیح۳۲ = 0
    چاپ "کولاتز از", ن
    تاوقتی ن != 1:
        اگر ن % 2 == 0: ن = ن / 2
        وگرنه:          ن = 3 * ن + 1
        پایان
        گامها = گامها + 1
    پایان
    چاپ "در", گامها, "گام به ۱ رسید"
پایان
