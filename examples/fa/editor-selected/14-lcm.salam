//! حالت: برنامه | عنوان: ک.م.م
// زبان: فارسی
تابع بمم(الف : صحیح, ب : صحیح) : صحیح:
    متغیر ایکس := الف
    متغیر ایگرگ := ب
    تاوقتی ایگرگ != 0:
        ت := ایگرگ
        ایگرگ = ایکس % ایگرگ
        ایکس = ت
    تمام
    بازگشت ایکس
تمام

تابع کمم(الف : صحیح, ب : صحیح) : صحیح: بازگشت الف / بمم(الف, ب) * ب تمام

تابع اصلی:
    چاپ "ک.م.م ۴ و ۶ =", کمم(4, 6)
    چاپ "ک.م.م ۲۱ و ۶ =", کمم(21, 6)
تمام
