//! mode: app | title: ک.م.م
تابع بمم(الف صحیح۳۲, ب صحیح۳۲) صحیح۳۲:
    متغیر ایکس صحیح۳۲ = الف
    متغیر ایگرگ صحیح۳۲ = ب
    تاوقتی ایگرگ != 0:
        متغیر ت صحیح۳۲ = ایگرگ
        ایگرگ = ایکس % ایگرگ
        ایکس = ت
    پایان
    بازگشت ایکس
پایان
تابع کمم(الف صحیح۳۲, ب صحیح۳۲) صحیح۳۲: بازگشت الف / بمم(الف, ب) * ب پایان
تابع اصلی:
    چاپ "ک.م.م ۴ و ۶ =", کمم(4, 6)
    چاپ "ک.م.م ۲۱ و ۶ =", کمم(21, 6)
پایان
