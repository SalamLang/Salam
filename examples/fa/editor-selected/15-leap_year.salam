//! حالت: برنامه | عنوان: سال کبیسه
تابع کبیسه_است(سال : صحیح) : منطقی:
    اگر سال % 400 == 0: بازگشت درست پایان
    اگر سال % 100 == 0: بازگشت نادرست پایان
    بازگشت سال % 4 == 0
پایان

تابع اصلی:
    متغیر سالها := [1900, 2000, 2012, 2021, 2024] بعنوان صحیح[5]
    تکرار 5 با i:
        اگر کبیسه_است(سالها[i]): چاپ سالها[i], "کبیسه است"
        وگرنه:
            چاپ سالها[i], "کبیسه نیست"
        پایان
    پایان
پایان
