//! حالت: برنامه | عنوان: جمع ارقام
تابع جمع_ارقام(ن صحیح) صحیح:
    متغیر ایکس صحیح = ن
    متغیر مجموع صحیح = 0
    تاوقتی ایکس > 0:
        مجموع = مجموع + ایکس % 10
        ایکس = ایکس / 10
    پایان
    بازگشت مجموع
پایان
تابع اصلی:
    چاپ "جمع ارقام ۱۲۳۴۵ =", جمع_ارقام(12345)
    چاپ "جمع ارقام ۹۹ =", جمع_ارقام(99)
پایان
