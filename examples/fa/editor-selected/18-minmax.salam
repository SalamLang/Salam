//! حالت: برنامه | عنوان: کمینه و بیشینه
تابع اصلی:
    متغیر آ : صحیح[7] = [5, 9, 1, 7, 3, 8, 2]
    متغیر کمینه : صحیح = آ[0]
    متغیر بیشینه : صحیح = آ[0]
    برای متغیر i = 1, i < 7, i = i + 1:
        اگر آ[i] < کمینه: کمینه = آ[i] پایان
        اگر آ[i] > بیشینه: بیشینه = آ[i] پایان
    پایان
    چاپ "کمینه =", کمینه, "بیشینه =", بیشینه
پایان
