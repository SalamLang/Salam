//! حالت: برنامه | عنوان: شمارش مصوت‌ها
تابع اصلی:
    س := "salam donya"
    متغیر تعداد := 0
    تکرار س.len() با i:
        ک := س.substr(i, 1)
        اگر ک == "a" یا ک == "e" یا ک == "i" یا ک == "o" یا ک == "u":
            تعداد = تعداد + 1
        پایان
    پایان
    چاپ "تعداد مصوت‌ها در", س, "=", تعداد
پایان
