//! حالت: برنامه | عنوان: تبدیل به دودویی
تابع به_دودویی(ن : صحیح) : رشته:
    اگر ن == 0: بازگشت "0" پایان
    متغیر ایکس := ن
    متغیر بیتها := ""
    تاوقتی ایکس > 0:
        بیتها = "" + (ایکس % 2) + بیتها
        ایکس = ایکس / 2
    پایان
    بازگشت بیتها
پایان

تابع اصلی:
    متغیر اعداد := [0, 5, 10, 255] بعنوان صحیح[4]
    تکرار 4 با i:
        چاپ اعداد[i], "در مبنای دو =", به_دودویی(اعداد[i])
    پایان
پایان
