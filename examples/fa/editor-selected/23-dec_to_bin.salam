//! mode: app | title: تبدیل به دودویی
تابع به_دودویی(ن صحیح۳۲) رشته:
    اگر ن == 0: بازگشت "0" پایان
    متغیر ایکس صحیح۳۲ = ن
    متغیر بیتها رشته = ""
    تاوقتی ایکس > 0:
        بیتها = "" + (ایکس % 2) + بیتها
        ایکس = ایکس / 2
    پایان
    بازگشت بیتها
پایان
تابع اصلی:
    متغیر اعداد صحیح۳۲[4] = [0, 5, 10, 255]
    برای متغیر i = 0; i < 4; i = i + 1:
        چاپ اعداد[i], "در مبنای دو =", به_دودویی(اعداد[i])
    پایان
پایان
