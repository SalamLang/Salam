//! حالت: app | عنوان: عوامل اول
تابع اصلی:
    متغیر ن صحیح = 360
    متغیر ایکس صحیح = ن
    متغیر خط رشته = ""
    متغیر د صحیح = 2
    تاوقتی د * د <= ایکس:
        تاوقتی ایکس % د == 0:
            خط = خط + د + " "
            ایکس = ایکس / د
        پایان
        د = د + 1
    پایان
    اگر ایکس > 1: خط = خط + ایکس + " " پایان
    چاپ ن, "=", خط
پایان
