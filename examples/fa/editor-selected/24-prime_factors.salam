//! حالت: برنامه | عنوان: عوامل اول
تابع اصلی:
    متغیر ن := 360
    متغیر ایکس := ن
    متغیر خط := ""
    متغیر د := 2
    تاوقتی د * د <= ایکس:
        تاوقتی ایکس % د == 0:
            خط = خط + د + " "
            ایکس = ایکس / د
        پایان
        د = د + 1
    پایان
    اگر ایکس > 1: خط = خط + ایکس + " " پایان
    چاپ ن, "=", خط
پایان
