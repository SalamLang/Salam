//! حالت: برنامه | عنوان: حساب بانکی
ساختار حساب:
    موجودی : صحیح = 0
    عمومی تابع واریز(مبلغ : صحیح): این.موجودی = این.موجودی + مبلغ پایان
    عمومی تابع برداشت(مبلغ : صحیح):
        اگر مبلغ <= این.موجودی: این.موجودی = این.موجودی - مبلغ
        وگرنه:
            چاپ "موجودی کافی نیست"
        پایان
    پایان
پایان

تابع اصلی:
    متغیر ح : حساب = حساب { موجودی = 100 }
    ح.واریز(50)
    ح.برداشت(30)
    ح.برداشت(200)
    چاپ "موجودی =", ح.موجودی
پایان
