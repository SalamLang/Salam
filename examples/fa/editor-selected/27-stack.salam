//! حالت: برنامه | عنوان: پشته
// زبان: فارسی
تابع اصلی:
    متغیر پشته := وکتور {} بعنوان وکتور<صحیح> پشته.بیفزا(1)
    پشته.بیفزا(2)
    پشته.بیفزا(3)
    چاپ "اندازه =", پشته.طول() بعنوان صحیح
    تاوقتی پشته.طول() > 0:
        چاپ "برداشت", پشته.دربیاور()
    تمام
    چاپ "اندازه =", پشته.طول() بعنوان صحیح
تمام
