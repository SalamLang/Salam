//! حالت: برنامه | عنوان: روزهای هفته
شمارش روز: دوشنبه, سه‌شنبه, چهارشنبه, پنجشنبه, جمعه, شنبه, یکشنبه پایان

تابع آخرهفته_است(ر : روز) : منطقی: بازگشت ر == روز.شنبه یا ر == روز.یکشنبه پایان

تابع اصلی:
    ر := روز.شنبه
    چاپ "شماره‌ی روز =", ر بعنوان صحیح
    اگر آخرهفته_است(ر): چاپ "آخر هفته است"
    وگرنه:
        چاپ "روز کاری است"
    پایان
پایان
