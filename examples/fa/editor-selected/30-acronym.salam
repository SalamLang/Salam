//! حالت: app | عنوان: سرنام
تابع اصلی:
    عبارت رشته = "salam azad multi platform"
    متغیر کلمات Vector<رشته> = عبارت.split(" ")
    متغیر سرنام رشته = ""
    برای متغیر i = 0; i < کلمات.len(); i = i + 1:
        ک رشته = کلمات.get(i)[0]
        سرنام = سرنام + ک.substr(0, 1)
    پایان
    چاپ عبارت, "->", سرنام
پایان
