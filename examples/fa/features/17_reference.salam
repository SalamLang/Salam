// زبان: فارسی
تابع افزایش(ایکس & صحیح):
    ایکس = ایکس + 1
پایان

تابع جابجایی(الف & صحیح, ب & صحیح):
    متغیر موقت صحیح = الف
    الف = ب
    ب = موقت
پایان

تابع اصلی:
    متغیر ن صحیح = 10
    افزایش(ن)
    افزایش(ن)
    چاپ ("ن =", ن)
    متغیر پ صحیح = 1
    متغیر ک صحیح = 2
    جابجایی(پ, ک)
    چاپ ("پ =", پ, "ک =", ک)
پایان
