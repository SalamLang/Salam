// زبان: فارسی
تابع افزایش(ایکس & : صحیح):
    ایکس = ایکس + 1
تمام

تابع جابجایی(الف & : صحیح, ب & : صحیح):
    موقت := الف
    الف = ب
    ب = موقت
تمام

تابع اصلی:
    متغیر ن := 10
    افزایش(ن)
    افزایش(ن)
    چاپ ("ن =", ن)
    متغیر پ := 1
    متغیر ک := 2
    جابجایی(پ, ک)
    چاپ ("پ =", پ, "ک =", ک)
تمام
