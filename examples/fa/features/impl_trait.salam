// زبان: فارسی
واسط رتبه‌دار:
    تابع رتبه() : صحیح
پایان

پیاده‌سازی رتبه‌دار برای صحیح:
    تابع رتبه() : صحیح: بازگشت این پایان
پایان

پیاده‌سازی رتبه‌دار برای رشته:
    تابع رتبه() : صحیح: بازگشت len(این) پایان
پایان

تابع بزرگترین<ت: رتبه‌دار>(الف : ت, ب : ت) : صحیح:
    اگر الف.رتبه() > ب.رتبه(): بازگشت الف.رتبه() پایان
    بازگشت ب.رتبه()
پایان

تابع اصلی:
    چاپ بزرگترین(3, 9)
    چاپ بزرگترین("hi", "salam")
پایان
