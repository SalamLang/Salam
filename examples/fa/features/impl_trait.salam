// زبان: فارسی
واسط رتبه دار:
    تابع رتبه(): صحیح
تمام

پیاده‌سازی رتبه دار بر صحیح:
    تابع رتبه(): صحیح: بازگشت این تمام
تمام

پیاده‌سازی رتبه دار بر رشته:
    تابع رتبه(): صحیح: بازگشت len(این) تمام
تمام

تابع بزرگترین<ت: رتبه دار>(الف: ت, ب: ت): صحیح:
    اگر الف.رتبه() > ب.رتبه(): بازگشت الف.رتبه() تمام
    بازگشت ب.رتبه()
تمام

تابع اصلی:
    چاپ بزرگترین(3, 9)
    چاپ بزرگترین("hi", "salam")
تمام
