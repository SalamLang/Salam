واردکردن "math"
@en "Circle"
@fa "دایره"
ساختار Circle:
    @en "radius"
    @fa "شعاع"
    radius اعشار۶۴ = 0.0
    @en "Area"
    @fa "مساحت"
    تابع Area() اعشار۶۴: بازگشت math.PI * این.radius * این.radius پایان
پایان
@en "label"
@fa "برچسب"
تابع label() رشته:
    اگر lang() == "fa": بازگشت "مساحت: " پایان
    بازگشت "area: "
پایان

تابع اصلی:
    متغیر c Circle = Circle { radius = 2.0 }
    label()
    c.Area()
پایان
