import "math"
@en "Circle"
@fa "دایره"
struct Circle:
    @en "radius"
    @fa "شعاع"
    radius f64 = 0.0
    @en "Area"
    @fa "مساحت"
    func Area() f64: ret math.PI * this.radius * this.radius end
end
@en "label"
@fa "برچسب"
func label() str:
    if lang() == "fa": ret "مساحت: " end
    ret "area: "
end

func main:
    mut c Circle = Circle { radius = 2.0 }
    _ label()
    __ c.Area()
end
