// زبان: فارسی
تابع اصلی:
    متغیر شمار := 0
    تکرار 3 با شاخص:
        شمار += شاخص
    تمام
    چاپ "جمع:", شمار

    متغیر سطح := 1
    اگر شمار > 2:
        سطح = 2
    تمام
    چاپ "سطح:", سطح

    متغیر ضربه := 9
    ضربه++
    چاپ "ضربه:", ضربه

    درود := "سلام"
    چاپ "تغییرناپذیر:", درود

    ثابت سقف := 100
    چاپ "ثابت:", سقف
تمام
