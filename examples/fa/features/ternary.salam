// زبان: فارسی
تابع اصلی:
    سن := 20
    چاپ سن >= 18 ؟ "بزرگسال" : "خردسال"

    نمره := 74
    رتبه := نمره >= 90 ؟ "الف" : نمره >= 75 ؟ "ب" : نمره >= 60 ؟ "ج" : "د"
    چاپ "رتبه:", رتبه

    ع := -8
    قدرمطلق := ع < 0 ؟ -(ع) : ع
    چاپ "قدرمطلق:", قدرمطلق

    متغیر شمار زوج := 0
    تکرار 10 با شمارنده:
        شمار زوج += شمارنده % 2 == 0 ؟ 1 : 0
    تمام
    چاپ "شمار زوج:", شمار زوج
تمام
