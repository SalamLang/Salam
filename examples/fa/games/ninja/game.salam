سکه پایه ایکس := [130.0, 380.0, 620.0, 800.0, 1050.0, 1400.0, 0.0, 0.0, 150.0, 420.0, 700.0, 900.0, 1200.0, 1650.0, 1850.0, 0.0, 120.0, 430.0, 590.0, 600.0, 850.0, 1150.0, 1350.0, 1950.0] بعنوان اعشار۶۴[24]
سکه پایه ایگرگ := [186.0, 186.0, 186.0, 157.0, 186.0, 186.0, 0.0, 0.0, 186.0, 186.0, 151.0, 186.0, 186.0, 166.0, 186.0, 0.0, 186.0, 186.0, 186.0, 156.0, 186.0, 186.0, 146.0, 186.0] بعنوان اعشار۶۴[24]

