سکو ایگرگ := [198.0, 171.0, 196.0, 0.0, 0.0, 194.0, 166.0, 192.0, 181.0, 176.0, 196.0, 171.0, 190.0, 161.0, 194.0] بعنوان اعشار۶۴[15]
سکو عرض := [20.0, 100.0, 22.0, 0.0, 0.0, 20.0, 110.0, 24.0, 90.0, 70.0, 20.0, 100.0, 24.0, 90.0, 22.0] بعنوان اعشار۶۴[15]
سکو ارتفاع := [28.0, 14.0, 30.0, 0.0, 0.0, 32.0, 14.0, 34.0, 14.0, 14.0, 30.0, 14.0, 36.0, 14.0, 32.0] بعنوان اعشار۶۴[15]
سکو متحرک := [نادرست, نادرست, نادرست, نادرست, نادرست, نادرست, نادرست, نادرست, نادرست, درست, نادرست, نادرست, نادرست, درست, درست] بعنوان منطقی[15]
