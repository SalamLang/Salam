متغیر دوربین ایکس := 0.0

متغیر کشیدن چپ := نادرست
متغیر کشیدن راست := نادرست
متغیر درخواست پرش := نادرست

تابع شاخص چاله(مرحله : صحیح, چ : صحیح) : صحیح:
    بازگشت مرحله * 2 + چ
تمام

تابع شاخص سکو(مرحله : صحیح, پ : صحیح) : صحیح:
    بازگشت مرحله * 5 + پ
تمام

تابع شاخص دشمن(مرحله : صحیح, د : صحیح) : صحیح:
    بازگشت مرحله * 5 + د
تمام

تابع شاخص سکه(مرحله : صحیح, ک : صحیح) : صحیح:
    بازگشت مرحله * 8 + ک
تمام

تابع همپوشانی(یکم ایکس : اعشار۶۴, یکم ایگرگ : اعشار۶۴, یکم عرض : اعشار۶۴, یکم ارتفاع : اعشار۶۴, دوم ایکس : اعشار۶۴, دوم ایگرگ : اعشار۶۴, دوم عرض : اعشار۶۴, دوم ارتفاع : اعشار۶۴) : منطقی:
    بازگشت یکم ایکس < دوم ایکس + دوم عرض && یکم ایکس + یکم عرض > دوم ایکس && یکم ایگرگ < دوم ایگرگ + دوم ارتفاع && یکم ایگرگ + یکم ارتفاع > دوم ایگرگ
تمام

تابع در چاله(ایکس : اعشار۶۴) : منطقی:
    تکرار تعداد چاله[مرحله] با چ:
        شماره := شاخص چاله(مرحله, چ)
        اگر ایکس >= چاله شروع[شماره] && ایکس < چاله پایان[شماره]:
            بازگشت درست
        تمام
    تمام
    بازگشت نادرست
تمام

تابع نمایش هود():
    دام.تنظیم‌متن(هود, "امتیاز: " + امتیاز + "   بهترین: " + بهترین + "   جان: " + جان + "   مرحله: " + (مرحله + 1) + "/" + تعداد مرحله)
تمام

تابع بارگذاری مرحله(ل : صحیح):
    مرحله = ل
    بازیکن ایکس = 24.0
    بازیکن ایگرگ = زمین ایگرگ - ارتفاع بازیکن
    بازیکن سرعت ایگرگ = 0.0
    بازیکن جهت = 1
    روی زمین = درست
    دوربین ایکس = 0.0
    درخواست پرش = نادرست
    تکرار تعداد دشمن[مرحله] با د:
        شماره := شاخص دشمن(مرحله, د)
        دشمن ایکس[د] = دشمن پایه ایکس[شماره]
        دشمن جهت[د] = 1
        دشمن زنده[د] = درست
    تمام
    تکرار تعداد سکه[مرحله] با ک:
        سکه گرفته[ک] = نادرست
    تمام
    تکرار تعداد سکو[مرحله] با پ:
        شماره := شاخص سکو(مرحله, پ)
        سکو افست[پ] = 0.0
        سکو جهت حرکت[پ] = 1
        سکو موثر ایکس[پ] = سکو ایکس[شماره]
    تمام
    نمایش هود()
    دام.تنظیم‌متن(پیام, "با کلیدهای چپ/راست حرکت کنید، با بالا یا Space بپرید")
تمام

تابع شروع کامل():
    امتیاز = 0
    جان = 3
    بارگذاری مرحله(0)
    وضعیت = 0
تمام

تابع مرگ():
    جان = جان - 1
    دام.صدا(150.0, 250.0)
    اگر جان <= 0:
        وضعیت = 2
        اگر امتیاز > بهترین:
            بهترین = امتیاز
            دام.تنظیم‌عدد‌ذخیره("salam ninja best", بهترین بعنوان صحیح۶۴)
        تمام
        دام.تنظیم‌متن(پیام, "باختید! امتیاز: " + امتیاز + " — برای شروع دوباره Enter را بزنید یا ضربه بزنید")
    وگرنه:
        بازیکن ایکس = 24.0
        بازیکن ایگرگ = زمین ایگرگ - ارتفاع بازیکن
        بازیکن سرعت ایگرگ = 0.0
        دوربین ایکس = 0.0
        دام.تنظیم‌متن(پیام, "جان از دست رفت! " + جان + " جان باقی مانده")
    تمام
    نمایش هود()
تمام

تابع ادامه یا شروع():
    اگر وضعیت == 1:
        بارگذاری مرحله(مرحله + 1)
        وضعیت = 0
        بازگشت
    تمام
    اگر وضعیت != 0:
        شروع کامل()
    تمام
تمام

تابع بروزرسانی(دلتا : اعشار۶۴):
    ثانیه := دلتا / 1000.0
    قبلی ایگرگ := بازیکن ایگرگ

    تکرار تعداد سکو[مرحله] با پ:
        شماره := شاخص سکو(مرحله, پ)
        اگر سکو متحرک[شماره]:
            سکو افست[پ] = سکو افست[پ] + (سکو جهت حرکت[پ] بعنوان اعشار۶۴) * سکو سرعت حرکت[شماره] * ثانیه
            اگر سکو افست[پ] < 0.0:
                سکو افست[پ] = 0.0
                سکو جهت حرکت[پ] = 1
            تمام
            اگر سکو افست[پ] > سکو دامنه[شماره]:
                سکو افست[پ] = سکو دامنه[شماره]
                سکو جهت حرکت[پ] = 0 - 1
            تمام
            سکو موثر ایکس[پ] = سکو ایکس[شماره] + سکو افست[پ]
        وگرنه:
            سکو موثر ایکس[پ] = سکو ایکس[شماره]
        تمام
    تمام

    متغیر حرکت ایکس := 0.0
    اگر کلیدها.نگه‌داشته("ArrowRight") || کشیدن راست:
        حرکت ایکس = سرعت دویدن * ثانیه
        بازیکن جهت = 1
    تمام
    اگر کلیدها.نگه‌داشته("ArrowLeft") || کشیدن چپ:
        حرکت ایکس = 0.0 - سرعت دویدن * ثانیه
        بازیکن جهت = 0 - 1
    تمام

    متغیر ایکس جدید := بازیکن ایکس + حرکت ایکس
    اگر ایکس جدید < 0.0: ایکس جدید = 0.0 تمام
    اگر ایکس جدید > عرض مرحله[مرحله] - عرض بازیکن: ایکس جدید = عرض مرحله[مرحله] - عرض بازیکن تمام

    تکرار تعداد سکو[مرحله] با پ:
        شماره := شاخص سکو(مرحله, پ)
        اگر سکو عرض[شماره] > 0.0 && همپوشانی(ایکس جدید, بازیکن ایگرگ, عرض بازیکن, ارتفاع بازیکن, سکو موثر ایکس[پ], سکو ایگرگ[شماره], سکو عرض[شماره], سکو ارتفاع[شماره]):
            اگر حرکت ایکس > 0.0: ایکس جدید = سکو موثر ایکس[پ] - عرض بازیکن تمام
            اگر حرکت ایکس < 0.0: ایکس جدید = سکو موثر ایکس[پ] + سکو عرض[شماره] تمام
        تمام
    تمام
    بازیکن ایکس = ایکس جدید

    پرش خواسته شده := درخواست پرش
    درخواست پرش = نادرست
    اگر (کلیدها.فشرده‌شد(" ") || کلیدها.فشرده‌شد("ArrowUp") || پرش خواسته شده) && روی زمین:
        بازیکن سرعت ایگرگ = 0.0 - سرعت پرش
        روی زمین = نادرست
        دام.صدا(600.0, 60.0)
    تمام

    بازیکن سرعت ایگرگ = بازیکن سرعت ایگرگ + جاذبه * ثانیه
    متغیر ایگرگ جدید := بازیکن ایگرگ + بازیکن سرعت ایگرگ * ثانیه
    روی زمین = نادرست

    اگر !در چاله(بازیکن ایکس + عرض بازیکن * 0.5) && ایگرگ جدید + ارتفاع بازیکن >= زمین ایگرگ && بازیکن سرعت ایگرگ >= 0.0:
        ایگرگ جدید = زمین ایگرگ - ارتفاع بازیکن
        بازیکن سرعت ایگرگ = 0.0
        روی زمین = درست
    تمام

    تکرار تعداد سکو[مرحله] با پ:
        شماره := شاخص سکو(مرحله, پ)
        اگر سکو عرض[شماره] > 0.0 && بازیکن سرعت ایگرگ >= 0.0 && قبلی ایگرگ + ارتفاع بازیکن <= سکو ایگرگ[شماره] + 1.0 && ایگرگ جدید + ارتفاع بازیکن >= سکو ایگرگ[شماره] && بازیکن ایکس + عرض بازیکن > سکو موثر ایکس[پ] && بازیکن ایکس < سکو موثر ایکس[پ] + سکو عرض[شماره]:
            ایگرگ جدید = سکو ایگرگ[شماره] - ارتفاع بازیکن
            بازیکن سرعت ایگرگ = 0.0
            روی زمین = درست
        تمام
    تمام

    بازیکن ایگرگ = ایگرگ جدید

    اگر بازیکن ایگرگ > ارتفاع بوم:
        مرگ()
        بازگشت
    تمام

    سرعت دشمن := سرعت دشمن پایه * ضریب سرعت[مرحله]
    تکرار تعداد دشمن[مرحله] با د:
        اگر دشمن زنده[د]:
            شماره := شاخص دشمن(مرحله, د)
            دشمن ایکس[د] = دشمن ایکس[د] + (دشمن جهت[د] بعنوان اعشار۶۴) * سرعت دشمن * ثانیه
            اگر دشمن ایکس[د] < دشمن پایه ایکس[شماره] - دشمن بازه[شماره]:
                دشمن ایکس[د] = دشمن پایه ایکس[شماره] - دشمن بازه[شماره]
                دشمن جهت[د] = 1
            تمام
            اگر دشمن ایکس[د] > دشمن پایه ایکس[شماره] + دشمن بازه[شماره]:
                دشمن ایکس[د] = دشمن پایه ایکس[شماره] + دشمن بازه[شماره]
                دشمن جهت[د] = 0 - 1
            تمام
            اگر همپوشانی(بازیکن ایکس, بازیکن ایگرگ, عرض بازیکن, ارتفاع بازیکن, دشمن ایکس[د], زمین ایگرگ - ارتفاع دشمن, عرض دشمن, ارتفاع دشمن):
                اگر بازیکن سرعت ایگرگ > 0.0 && بازیکن ایگرگ + ارتفاع بازیکن - (زمین ایگرگ - ارتفاع دشمن) < 12.0:
                    دشمن زنده[د] = نادرست
                    بازیکن سرعت ایگرگ = 0.0 - سرعت پرش * 0.55
                    امتیاز = امتیاز + 50
                    دام.صدا(700.0, 40.0)
                    نمایش هود()
                وگرنه:
                    مرگ()
                    بازگشت
                تمام
            تمام
        تمام
    تمام

    تکرار تعداد سکه[مرحله] با ک:
        اگر !سکه گرفته[ک]:
            شماره := شاخص سکه(مرحله, ک)
            اگر همپوشانی(بازیکن ایکس, بازیکن ایگرگ, عرض بازیکن, ارتفاع بازیکن, سکه پایه ایکس[شماره] - شعاع سکه, سکه پایه ایگرگ[شماره] - شعاع سکه, شعاع سکه * 2.0, شعاع سکه * 2.0):
                سکه گرفته[ک] = درست
                امتیاز = امتیاز + 10
                دام.صدا(900.0, 30.0)
                نمایش هود()
            تمام
        تمام
    تمام

    اگر بازیکن ایکس + عرض بازیکن >= پرچم ایکس[مرحله]:
        امتیاز = امتیاز + 100 * (مرحله + 1)
        اگر مرحله + 1 >= تعداد مرحله:
            وضعیت = 3
            اگر امتیاز > بهترین:
                بهترین = امتیاز
                دام.تنظیم‌عدد‌ذخیره("salam ninja best", بهترین بعنوان صحیح۶۴)
            تمام
            دام.تنظیم‌متن(پیام, "آفرین! تمام مراحل را با موفقیت به پایان رساندید")
        وگرنه:
            وضعیت = 1
            دام.تنظیم‌متن(پیام, "مرحله " + (مرحله + 1) + " تمام شد! Enter را بزنید یا ضربه بزنید")
        تمام
        نمایش هود()
        بازگشت
    تمام

    دوربین ایکس = بازیکن ایکس - عرض بوم * 0.4
    اگر دوربین ایکس < 0.0: دوربین ایکس = 0.0 تمام
    اگر دوربین ایکس > عرض مرحله[مرحله] - عرض بوم: دوربین ایکس = عرض مرحله[مرحله] - عرض بوم تمام
تمام

تابع رسم():
    بوم.سبک‌پرشدگی(زمینه, رنگ آسمان[مرحله])
    بوم.پرکردن‌مستطیل(زمینه, 0.0, 0.0, عرض بوم, ارتفاع بوم)

    بوم.سبک‌پرشدگی(زمینه, رنگ تپه[مرحله])
    تکرار 6 با تپه:
        هاف ایکس := (تپه بعنوان اعشار۶۴) * 220.0 - دوربین ایکس * 0.3
        بوم.شروع‌مسیر(زمینه)
        بوم.کمان(زمینه, هاف ایکس, ارتفاع بوم - 40.0, 90.0, 3.14159265, 6.2831853)
        بوم.پرکن(زمینه)
