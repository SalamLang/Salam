تابع دور جدید():
    دور = دور + 1
    حالت سوال = دام.تصادفی صحیح(2) بعنوان صحیح
    اگر حالت سوال == 0:
        شکل جاری = دام.تصادفی صحیح(11) بعنوان صحیح
    وگرنه:
        شکل جاری = چندضلعی شاخص[دام.تصادفی صحیح(8) بعنوان صحیح]
    تمام
    رنگ جاری = رنگ ها[دام.تصادفی صحیح(9) بعنوان صحیح]
    اگر شکل جاری == 3 || شکل جاری == 4 || شکل جاری == 5:
        چرخش جاری = 0.0
    وگرنه:
        چرخش جاری = ریاضی.رادیان(دام.تصادفی صحیح(360) بعنوان اعشار۶۴)
    تمام
    پاسخ درست = دام.تصادفی صحیح(4) بعنوان صحیح
    اگر حالت سوال == 0:
        دام.تنظیم متن(سوال جعبه, "نام این شکل چیست؟")
        متغیر ش := 0
        متغیر تلاش := 0
        تاوقتی ش < 4 && تلاش < 300:
            تلاش = تلاش + 1
            اگر ش == پاسخ درست:
                گزینه متن[ش] = نام شکل[شکل جاری]
                ش = ش + 1
                ادامه
            تمام
            ک := دام.تصادفی صحیح(11) بعنوان صحیح
            اگر ک == شکل جاری: ادامه تمام
            متغیر تکراری := نادرست
            تکرار ش با م:
                اگر گزینه متن[م] == نام شکل[ک]: تکراری = درست تمام
            تمام
            اگر تکراری: ادامه تمام
            گزینه متن[ش] = نام شکل[ک]
            ش = ش + 1
        تمام
    وگرنه:
        دام.تنظیم متن(سوال جعبه, "این شکل چند ضلع دارد؟")
        درست عدد := اضلاع شکل[شکل جاری]
        متغیر ش := 0
        متغیر تلاش := 0
        تاوقتی ش < 4 && تلاش < 300:
            تلاش = تلاش + 1
            اگر ش == پاسخ درست:
                گزینه متن[ش] = "" + درست عدد
                ش = ش + 1
                ادامه
            تمام
            ک := 3 + (دام.تصادفی صحیح(6) بعنوان صحیح)
            اگر ک == درست عدد: ادامه تمام
            متغیر تکراری := نادرست
            تکرار ش با م:
                اگر گزینه متن[م] == "" + ک: تکراری = درست تمام
            تمام
            اگر تکراری: ادامه تمام
            گزینه متن[ش] = "" + ک
            ش = ش + 1
        تمام
    تمام
تمام

