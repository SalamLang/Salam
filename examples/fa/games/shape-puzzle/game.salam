تابع کلیک گزینه(ن: صحیح):
    اگر !بازی فعال: بازگشت تمام
    بازی فعال = نادرست
    اگر ن == پاسخ درست:
        رکورد متوالی = رکورد متوالی + 1
        اگر رکورد متوالی > بهترین متوالی: بهترین متوالی = رکورد متوالی تمام
        امتیاز = امتیاز + 10 + رکورد متوالی * 2
        دام.افزودن کلاس(گزینه عنصر[ن], "درست")
        دام.صدا(880.0, 90.0)
        دام.تنظیم متن(پیام, "درسته! 🎉")
    وگرنه:
        رکورد متوالی = 0
        جان = جان - 1
        دام.افزودن کلاس(گزینه عنصر[ن], "غلط")
        دام.افزودن کلاس(گزینه عنصر[پاسخ درست], "درست")
        دام.صدا(180.0, 220.0)
        دام.تنظیم متن(پیام, "اشتباه بود! پاسخ درست: " + گزینه متن[پاسخ درست])
    تمام
    نمایش هود()
    اگر جان <= 0:
        پایان بازی()
        بازگشت
    تمام
    دام.تنظیم مهلت(
        () =>: دور جدید و نمایش() تمام, 900
    )
تمام

