تابع رسم چندضلعی(شعاع: اعشار۶۴, تعداد: صحیح, چرخش: اعشار۶۴):
    بوم.شروع مسیر(زمینه)
    تکرار تعداد با ن:
        زاویه := چرخش + (ن بعنوان اعشار۶۴) * تاو / (تعداد بعنوان اعشار۶۴)
        ایکس := عرض بوم * 0.5 + شعاع * ریاضی.کسینوس(زاویه)
        ایگرگ := ارتفاع بوم * 0.5 + شعاع * ریاضی.سینوس(زاویه)
        اگر ن == 0:
            بوم.برو به(زمینه, ایکس, ایگرگ)
        وگرنه:
            بوم.خط به(زمینه, ایکس, ایگرگ)
        تمام
    تمام
    بوم.بستن مسیر(زمینه)
    بوم.پرکن(زمینه)
تمام

تابع رسم ستاره(شعاع بیرون: اعشار۶۴, شعاع درون: اعشار۶۴, چرخش: اعشار۶۴):
    بوم.شروع مسیر(زمینه)
    تکرار 10 با ن:
        شعاع := ن % 2 == 0 ? شعاع بیرون : شعاع درون
        زاویه := چرخش + (ن بعنوان اعشار۶۴) * تاو / 10.0
        ایکس := عرض بوم * 0.5 + شعاع * ریاضی.کسینوس(زاویه)
        ایگرگ := ارتفاع بوم * 0.5 + شعاع * ریاضی.سینوس(زاویه)
        اگر ن == 0:
            بوم.برو به(زمینه, ایکس, ایگرگ)
        وگرنه:
            بوم.خط به(زمینه, ایکس, ایگرگ)
        تمام
    تمام
    بوم.بستن مسیر(زمینه)
    بوم.پرکن(زمینه)
تمام

تابع رسم لوزی(نیم عرض: اعشار۶۴, نیم ارتفاع: اعشار۶۴):
    مرکز ایکس := عرض بوم * 0.5
    مرکز ایگرگ := ارتفاع بوم * 0.5
    بوم.شروع مسیر(زمینه)
    بوم.برو به(زمینه, مرکز ایکس, مرکز ایگرگ - نیم ارتفاع)
    بوم.خط به(زمینه, مرکز ایکس + نیم عرض, مرکز ایگرگ)
    بوم.خط به(زمینه, مرکز ایکس, مرکز ایگرگ + نیم ارتفاع)
    بوم.خط به(زمینه, مرکز ایکس - نیم عرض, مرکز ایگرگ)
    بوم.بستن مسیر(زمینه)
    بوم.پرکن(زمینه)
تمام

تابع رسم بیضی(شعاع ایکس: اعشار۶۴, شعاع ایگرگ: اعشار۶۴):
