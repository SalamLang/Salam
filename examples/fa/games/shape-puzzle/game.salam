تابع فریم(دلتا: اعشار۶۴):
    اگر بازی فعال:
        زمان باقی = زمان باقی - دلتا
        اگر زمان باقی <= 0.0:
            زمان باقی = 0.0
            زمان
        تمام ()
    تمام
