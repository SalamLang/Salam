// زبان: فارسی
صفحه:
    زبان = "فارسی"
    جهت = "راست به چپ"
    عنوان = "سلام دوز"
    سراسری: اندازه جعبه = "border-box" تمام
    سراسری:
        گزینشگر = "body"
        حاشیه = "0"
        کمینه ارتفاع = "100dvh"
        نمایش = "flex"
        ترازعمودی = "center"
        چینش = "center"
        پس‌زمینه = "radial-gradient(circle at top,#161327 0%,#050510 70%)"
        رنگ = "#eee8ff"
        خانواده قلم = "Vazirmatn,Tahoma,Arial,sans-serif"
        فاصله داخلی = "14px"
    تمام
    جعبه:
        شناسه = "wrap"
        ترازمتن = "center"
        عرض = "100%"
        بیشینه عرض = "360px"
        سرتیتر:
            شناسه = "title"
            محتوا = "دوز"
            رنگ = "#ffd21f"
            حاشیه = "6px 0 4px"
            اندازه قلم = "clamp(22px,6vw,32px)"
            سایه متن = "0 0 16px rgba(255,210,31,.4)"
        تمام
        جعبه:
            شناسه = "hud"
            محتوا = "..."
            اندازه قلم = "clamp(14px,4vw,18px)"
            رنگ = "#9ee7ff"
            حاشیه = "6px 0"
        تمام
        جعبه:
            شناسه = "board"
            نمایش = "grid"
            ستون‌های شبکه = "repeat(3,1fr)"
            شکاف = "8px"
            عرض = "min(300px,86vw)"
            حاشیه = "10px auto"
            دکمه:
                شناسه = "c0"
                محتوا = ""
                کلاس = "خانه"
                نسبت ابعاد = "1"
                اندازه قلم = "clamp(28px,9vw,44px)"
