            شناسه = "msg"
            محتوا = "..."
            رنگ = "#c8cdf5"
            اندازه قلم = "clamp(12px,3.4vw,15px)"
            کمینه ارتفاع = "1.4em"
        تمام
        دکمه:
            شناسه = "again"
            محتوا = "بازی دوباره"
            حاشیه بالا = "10px"
            خانواده قلم = "Vazirmatn,Tahoma,Arial,sans-serif"
            اندازه قلم = "15px"
            رنگ = "#101018"
            پس‌زمینه = "#ffd21f"
            کادر = "none"
            گردی کادر = "10px"
            فاصله داخلی = "10px 22px"
            کنش لمسی = "manipulation"
        تمام
    تمام
    سبک: محتوا = "@media (max-width:820px),(pointer:coarse){body{padding:0;}#wrap{width:100%;max-width:560px;min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;justify-content:center;padding:20px 16px;}#title{font-size:clamp(26px,8vw,42px);margin:4px 0 10px;}#hud{font-size:clamp(16px,4.5vw,22px);}#board{width:min(440px,92vw);margin:14px auto;}#score{font-size:clamp(13px,3.6vw,16px);}#msg{font-size:clamp(13px,3.6vw,16px);}}" تمام
    اسکریپت سفارشی: منبع = "game.salam" تمام
تمام
