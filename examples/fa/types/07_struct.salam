// زبان: فارسی
ساختار مستطیل:
    طول : اعشار۶۴ = 0.0
    عرض : اعشار۶۴ = 0.0
    عمومی تابع مساحت() : اعشار۶۴:
        بازگشت این.طول * این.عرض
    تمام
    عمومی تابع محیط() : اعشار۶۴:
        بازگشت 2.0 * (این.طول + این.عرض)
    تمام
تمام

تابع اصلی:
    متغیر r := مستطیل { طول = 4.0, عرض = 3.0 }
    چاپ "مساحت:", r.مساحت()
    چاپ "محیط:", r.محیط()
تمام
