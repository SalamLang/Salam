// LANG: fa
ساختار مستطیل:
    طول اعشاری۶۴ = 0.0
    عرض اعشاری۶۴ = 0.0
    تابع مساحت() اعشاری۶۴:
        بازگشت این.طول * این.عرض
    پایان
    تابع محیط() اعشاری۶۴:
        بازگشت 2.0 * (این.طول + این.عرض)
    پایان
پایان
تابع اصلی:
    متغیر r مستطیل = مستطیل { طول = 4.0, عرض = 3.0 }
    چاپ ("مساحت:", r.مساحت())
    چاپ ("محیط:", r.محیط())
پایان
