// زبان: فارسی
ساختار مستطیل:
    طول : اعشار۶۴ = 0.0
    عرض : اعشار۶۴ = 0.0
    تابع مساحت() : اعشار۶۴:
        بازگشت این.طول * این.عرض
    پایان
    تابع محیط() : اعشار۶۴:
        بازگشت 2.0 * (این.طول + این.عرض)
    پایان
پایان

تابع اصلی:
    متغیر r : مستطیل = مستطیل { طول = 4.0, عرض = 3.0 }
    چاپ ("مساحت:", r.مساحت())
    چاپ ("محیط:", r.محیط())
پایان
