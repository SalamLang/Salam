// LANG: fa
ساختار حساب:
    موجودی صحیح۳۲ = 0
    تابع واریز(مبلغ صحیح۳۲): این.موجودی = این.موجودی + مبلغ پایان
    تابع برداشت(مبلغ صحیح۳۲):
        اگر مبلغ <= این.موجودی: این.موجودی = این.موجودی - مبلغ
        وگرنه:                   چاپ "موجودی کافی نیست"
        پایان
    پایان
پایان
تابع اصلی:
    متغیر ح حساب = حساب { موجودی = 100 }
    ح.واریز(50)
    ح.برداشت(30)
    ح.برداشت(200)
    چاپ "موجودی =", ح.موجودی
پایان
