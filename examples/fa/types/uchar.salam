// زبان: فارسی
تابع اصلی:
    حرف := u"A"
    فارسی := u"م"
    چینی := u"中"
    ایموجی := u"😀"
    یورو := u"€"

    چاپ "حرف:", حرف
    چاپ "فارسی:", فارسی
    چاپ "چینی:", چینی
    چاپ "ایموجی:", ایموجی
    چاپ "یورو:", یورو

    شکلک := u"\U0001F600"
    چاپ "شکلک:", شکلک

    کلمه := حرف + فارسی
    چاپ "پیوند:", کلمه

    متن := ایموجی
    چاپ "به رشته:", متن
تمام
