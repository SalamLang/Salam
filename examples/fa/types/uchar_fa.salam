// زبان: فارسی
تابع اصلی:
    حرف : یونیکد = u"A"
    فارسی : یونیکد = u"م"
    چینی : خودکار = u"中"
    ایموجی : خودکار = u"😀"
    یورو : خودکار = u"€"

    چاپ "حرف:", حرف
    چاپ "فارسی:", فارسی
    چاپ "چینی:", چینی
    چاپ "ایموجی:", ایموجی
    چاپ "یورو:", یورو

    شکلک : خودکار = u"\U0001F600"
    چاپ "شکلک:", شکلک

    کلمه : خودکار = حرف + فارسی
    چاپ "پیوند:", کلمه

    متن : رشته = ایموجی
    چاپ "به رشته:", متن
پایان
