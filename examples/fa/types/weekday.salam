// زبان: فارسی
شمارش روز: شنبه, یکشنبه, دوشنبه, سه‌شنبه, چهارشنبه, پنجشنبه, جمعه تمام

تابع آخرهفته است(ر : روز) : منطقی: بازگشت ر == روز.شنبه یا ر == روز.یکشنبه تمام

تابع اصلی:
    ر := روز.شنبه
    چاپ "شماره‌ی روز =", ر بعنوان صحیح
    اگر آخرهفته است(ر): چاپ "آخر هفته است"
    وگرنه:
        چاپ "روز کاری است"
    تمام
تمام
