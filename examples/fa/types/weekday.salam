// زبان: فارسی
شمارش روز: شنبه, یکشنبه, دوشنبه, سه‌شنبه, چهارشنبه, پنجشنبه, جمعه پایان

تابع آخرهفته_است(ر روز) منطقی: بازگشت ر == روز.شنبه یا ر == روز.یکشنبه پایان

تابع اصلی:
    ر روز = روز.شنبه
    چاپ "شماره‌ی روز =", ر بعنوان صحیح
    اگر آخرهفته_است(ر): چاپ "آخر هفته است"
    وگرنه:
        چاپ "روز کاری است"
    پایان
پایان
