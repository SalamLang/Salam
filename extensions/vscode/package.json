{
  "name": "salam-programming-language",
  "displayName": "Salam Programming Language",
  "description": "Language support for Salam - syntax highlighting, snippets, formatting, and build/run integration for the Salam programming language (English, Persian & Arabic).",
  "version": "0.2.3",
  "publisher": "salamlanguage",
  "license": "MIT",
  "icon": "icons/salam-icon.png",
  "galleryBanner": {
    "color": "#0B3D2E",
    "theme": "dark"
  },
  "homepage": "https://github.com/SalamLang/Salam",
  "repository": {
    "type": "git",
    "url": "https://github.com/SalamLang/Salam.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/SalamLang/Salam/issues"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "salam",
    "salamlang",
    "persian",
    "farsi",
    "programming language"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "gen-grammar": "node scripts/gen-grammar.js > syntaxes/salam.tmLanguage.json",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "catalog:"
  },
  "contributes": {
    "languages": [
      {
        "id": "salam",
        "aliases": [
          "Salam",
          "salam"
        ],
        "extensions": [
          ".salam"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/salam-file.svg",
          "dark": "./icons/salam-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "salam",
        "scopeName": "source.salam",
        "path": "./syntaxes/salam.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "salam",
        "path": "./snippets/salam.code-snippets"
      }
    ],
    "configuration": {
      "title": "Salam",
      "properties": {
        "salam.compilerPath": {
          "type": "string",
          "default": "salam",
          "markdownDescription": "Path to the `salam` compiler executable. If `salam` is on your `PATH`, the default is fine; otherwise set an absolute path."
        },
        "salam.languagePack": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "fa",
            "ar"
          ],
          "enumDescriptions": [
            "Detect from the file content (Persian/Arabic script or lang directive)",
            "English keyword pack",
            "Persian keyword pack",
            "Arabic keyword pack"
          ],
          "default": "auto",
          "description": "Language pack passed to salam (--lang). 'auto' inspects the file."
        },
        "salam.run.command": {
          "type": "string",
          "enum": [
            "run",
            "exec"
          ],
          "enumDescriptions": [
            "Compile with the C backend and run the executable (needs a C toolchain)",
            "Run with the tree-walking interpreter (no C toolchain required)"
          ],
          "default": "exec",
          "description": "Which salam subcommand the 'Run File' action uses."
        },
        "salam.build.target": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional LLVM target triple for cross-compilation, passed as `--target` to `salam build` (e.g. `x86_64-pc-windows-msvc`, `wasm32-wasi`). When set, `build` uses the LLVM backend instead of the C backend and needs the LLVM toolchain (clang/llc, plus lld for Windows). Leave empty for a host-native build. Note: the LLVM cross path compiles a single file only (no stdlib auto-include)."
        },
        "salam.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the document formatter (uses 'salam format')."
        },
        "salam.format.indent": {
          "type": "string",
          "default": "4",
          "markdownDescription": "Indentation passed to `salam format --indent`: `tab`, or a number of spaces (1-16)."
        },
        "salam.stdlibPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional root directory for `std/...` imports, passed as `--stdlib-path`. Leave empty to use the compiler default."
        }
      }
    },
    "commands": [
      {
        "command": "salam.run",
        "title": "Salam: Run File",
        "category": "Salam",
        "icon": "$(play)"
      },
      {
        "command": "salam.build",
        "title": "Salam: Build Executable",
        "category": "Salam",
        "icon": "$(tools)"
      },
      {
        "command": "salam.exec",
        "title": "Salam: Run with Interpreter",
        "category": "Salam"
      },
      {
        "command": "salam.format",
        "title": "Salam: Format Document",
        "category": "Salam"
      },
      {
        "command": "salam.emitTokens",
        "title": "Salam: Show Token Stream (XML)",
        "category": "Salam"
      },
      {
        "command": "salam.emitAst",
        "title": "Salam: Show AST (XML)",
        "category": "Salam"
      },
      {
        "command": "salam.newProject",
        "title": "Salam: New Project…",
        "category": "Salam"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam",
          "group": "salam@1"
        },
        {
          "command": "salam.build",
          "when": "resourceLangId == salam",
          "group": "salam@2"
        }
      ],
      "explorer/context": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam",
          "group": "salam@1"
        }
      ],
      "commandPalette": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.build",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.exec",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.format",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.emitTokens",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.emitAst",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.newProject"
        }
      ]
    }
  }
}
