{
  "name": "salam-programming-language",
  "displayName": "Salam Programming Language",
  "description": "Language support for Salam - syntax highlighting, snippets, formatting, and build/run integration for the Salam programming language (English & Persian).",
  "version": "0.1.0",
  "publisher": "salamlanguage",
  "license": "MIT",
  "icon": "icons/salam-icon.png",
  "galleryBanner": {
    "color": "#0B3D2E",
    "theme": "dark"
  },
  "homepage": "https://github.com/SalamLang/Salam",
  "repository": {
    "type": "git",
    "url": "https://github.com/SalamLang/Salam.git",
    "directory": "VSCode"
  },
  "bugs": {
    "url": "https://github.com/SalamLang/Salam/issues"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "salam",
    "salamlang",
    "persian",
    "farsi",
    "programming language"
  ],
  "main": "./extension.js",
  "scripts": {
    "gen-grammar": "node scripts/gen-grammar.js > syntaxes/salam.tmLanguage.json"
  },
  "devDependencies": {
    "@types/vscode": "^1.92.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "salam",
        "aliases": [
          "Salam",
          "salam"
        ],
        "extensions": [
          ".salam"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/salam-file.svg",
          "dark": "./icons/salam-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "salam",
        "scopeName": "source.salam",
        "path": "./syntaxes/salam.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "salam",
        "path": "./snippets/salam.code-snippets"
      }
    ],
    "configuration": {
      "title": "Salam",
      "properties": {
        "salam.compilerPath": {
          "type": "string",
          "default": "salamc",
          "markdownDescription": "Path to the `salamc` compiler executable. If `salamc` is on your `PATH`, the default is fine; otherwise set an absolute path."
        },
        "salam.languagePack": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "fa"
          ],
          "enumDescriptions": [
            "Detect from the file content (Persian words / LANG directive)",
            "English keyword pack",
            "Persian keyword pack"
          ],
          "default": "auto",
          "description": "Language pack passed to salamc (--lang). 'auto' inspects the file."
        },
        "salam.run.command": {
          "type": "string",
          "enum": [
            "run",
            "exec"
          ],
          "enumDescriptions": [
            "Compile with the C backend and run the executable (needs a C toolchain)",
            "Run with the tree-walking interpreter (no C toolchain required)"
          ],
          "default": "exec",
          "description": "Which salamc subcommand the 'Run File' action uses."
        },
        "salam.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the document formatter (uses 'salamc fmt')."
        },
        "salam.format.indent": {
          "type": "string",
          "default": "4",
          "markdownDescription": "Indentation passed to `salamc fmt --indent`: `tab`, or a number of spaces (1-16)."
        },
        "salam.stdlibPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional root directory for `std/...` imports, passed as `--stdlib-path`. Leave empty to use the compiler default."
        }
      }
    },
    "commands": [
      {
        "command": "salam.run",
        "title": "Salam: Run File",
        "category": "Salam",
        "icon": "$(play)"
      },
      {
        "command": "salam.build",
        "title": "Salam: Build Executable",
        "category": "Salam",
        "icon": "$(tools)"
      },
      {
        "command": "salam.exec",
        "title": "Salam: Run with Interpreter",
        "category": "Salam"
      },
      {
        "command": "salam.format",
        "title": "Salam: Format Document",
        "category": "Salam"
      },
      {
        "command": "salam.emitTokens",
        "title": "Salam: Show Token Stream (XML)",
        "category": "Salam"
      },
      {
        "command": "salam.emitAst",
        "title": "Salam: Show AST (XML)",
        "category": "Salam"
      },
      {
        "command": "salam.newProject",
        "title": "Salam: New Project…",
        "category": "Salam"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam",
          "group": "salam@1"
        },
        {
          "command": "salam.build",
          "when": "resourceLangId == salam",
          "group": "salam@2"
        }
      ],
      "explorer/context": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam",
          "group": "salam@1"
        }
      ],
      "commandPalette": [
        {
          "command": "salam.run",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.build",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.exec",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.format",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.emitTokens",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.emitAst",
          "when": "resourceLangId == salam"
        },
        {
          "command": "salam.newProject"
        }
      ]
    }
  }
}
