{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Salam",
	"scopeName": "source.salam",
	"patterns": [
		{
			"include": "#directives"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#meta-annotations"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#definitions"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#layout-element"
		},
		{
			"include": "#function-call"
		},
		{
			"include": "#member"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#punctuation"
		}
	],
	"repository": {
		"directives": {
			"patterns": [
				{
					"name": "comment.line.directive.salam",
					"begin": "//!",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.salam"
						}
					},
					"end": "$",
					"patterns": [
						{
							"match": "\\b(mode|title|lang|dir|name|version)\\b",
							"name": "keyword.other.directive.salam"
						},
						{
							"match": "\\|",
							"name": "punctuation.separator.directive.salam"
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.salam",
					"begin": "/\\*",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.salam"
						}
					},
					"end": "\\*/",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.comment.salam"
						}
					}
				},
				{
					"name": "comment.line.double-slash.salam",
					"begin": "//",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.salam"
						}
					},
					"end": "$"
				}
			]
		},
		"meta-annotations": {
			"patterns": [
				{
					"match": "(@)([A-Za-z_][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)",
					"captures": {
						"1": {
							"name": "punctuation.definition.annotation.salam"
						},
						"2": {
							"name": "storage.modifier.annotation.salam"
						}
					}
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.triple.salam",
					"begin": "\"\"\"",
					"end": "\"\"\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.salam"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.salam"
						}
					},
					"patterns": [
						{
							"include": "#string-escapes"
						}
					]
				},
				{
					"name": "string.quoted.double.salam",
					"begin": "\"",
					"end": "\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.salam"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.salam"
						}
					},
					"patterns": [
						{
							"include": "#string-escapes"
						},
						{
							"name": "invalid.illegal.newline.salam",
							"match": "\\n"
						}
					]
				},
				{
					"name": "string.quoted.raw.salam",
					"begin": "`",
					"end": "`",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.salam"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.salam"
						}
					}
				},
				{
					"name": "string.quoted.single.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])u?'(\\\\(?:x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|u[0-9A-Fa-f]{4}|.)|[^'\\\\])'"
				}
			]
		},
		"string-escapes": {
			"patterns": [
				{
					"name": "constant.character.escape.salam",
					"match": "\\\\(?:x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|u[0-9A-Fa-f]{4}|[0abfnrtv\"'\\\\])"
				},
				{
					"name": "invalid.illegal.unknown-escape.salam",
					"match": "\\\\."
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?|[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*)f?(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "constant.numeric.hex.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])0[xX][0-9A-Fa-f][0-9A-Fa-f_]*(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "constant.numeric.binary.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])0[bB][01][01_]*(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "constant.numeric.octal.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])0[oO][0-7][0-7_]*(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "constant.numeric.integer.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])[0-9][0-9_]*f?(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				}
			]
		},
		"definitions": {
			"patterns": [
				{
					"match": "((?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:func|تابع)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]))\\s+([A-Za-z_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)",
					"captures": {
						"1": {
							"name": "storage.type.function.salam keyword.declaration.function.salam"
						},
						"2": {
							"name": "entity.name.function.salam"
						}
					}
				},
				{
					"match": "((?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:interface|component|package|struct|ساختار|شمارش|مولفه|type|enum|واسط|بسته|نوع)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]))\\s+([A-Za-z_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)",
					"captures": {
						"1": {
							"name": "storage.type.salam keyword.declaration.type.salam"
						},
						"2": {
							"name": "entity.name.type.salam"
						}
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:continue|repeat|تاوقتی|بازگشت|while|break|every|defer|وگرنه|ادامه|تکرار|تعلیق|پایان|else|برای|بشکن|for|ret|end|اگر|if|to|تا|هر)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "storage.type.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:پیاده‌سازی|interface|component|operator|واردکردن|package|struct|import|layout|extern|ساختار|بعنوان|const|متغیر|شمارش|عمومی|مولفه|عملگر|خارجی|func|type|enum|impl|تابع|ثابت|واسط|بسته|صفحه|mut|pub|نوع|as)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "support.function.builtin.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:printerrln|printerr|خطابنویس|println|خطاچاپ|print|input|بنویس|بخوان|چاپ)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "support.function.builtin.print.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])_{1,2}(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "constant.language.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:نادرست|false|true|null|درست|پوچ)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "variable.language.this.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:this|این)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "storage.type.auto.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:خودکار|auto)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "support.type.primitive.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:اعشاری۳۲|اعشاری۶۴|کاراکتر|صحیح۱۶|صحیح۳۲|صحیح۶۴|isize|usize|صحیح۸|منطقی|bool|char|void|رشته|بایت|i16|i32|i64|u16|u32|u64|f32|f64|str|i8|u8)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				},
				{
					"name": "keyword.other.salam",
					"match": "(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?:framework|dynamic|static|چارچوب|پیوند|ایستا|link|kind|پویا|گونه|dyn)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])"
				}
			]
		},
		"layout-element": {
			"patterns": [
				{
					"match": "^\\s*(?<![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}])(?!(?:else|وگرنه)(?![A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]))([A-Za-z_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)\\s*(:)\\s*$",
					"captures": {
						"1": {
							"name": "entity.name.tag.layout.salam"
						},
						"2": {
							"name": "punctuation.section.layout.salam"
						}
					}
				}
			]
		},
		"function-call": {
			"patterns": [
				{
					"match": "([A-Za-z_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)\\s*(?=\\()",
					"name": "entity.name.function.call.salam"
				}
			]
		},
		"member": {
			"patterns": [
				{
					"match": "(?<=\\.)\\s*([A-Za-z_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)",
					"name": "variable.other.member.salam"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.arrow.salam",
					"match": "=>"
				},
				{
					"name": "keyword.operator.spread.salam",
					"match": "\\.\\.\\."
				},
				{
					"name": "keyword.operator.comparison.salam",
					"match": "==|!=|<=|>=|<|>"
				},
				{
					"name": "keyword.operator.assignment.compound.salam",
					"match": "\\+=|-=|\\*=|/=|%="
				},
				{
					"name": "keyword.operator.logical.salam",
					"match": "&&|\\|\\||!"
				},
				{
					"name": "keyword.operator.arithmetic.salam",
					"match": "\\*\\*|[+\\-*/%]"
				},
				{
					"name": "keyword.operator.reference.salam",
					"match": "&"
				},
				{
					"name": "keyword.operator.assignment.salam",
					"match": "="
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.terminator.statement.salam",
					"match": ";"
				},
				{
					"name": "punctuation.separator.salam",
					"match": "[,:]"
				},
				{
					"name": "punctuation.accessor.salam",
					"match": "\\."
				},
				{
					"name": "meta.brace.round.salam",
					"match": "[()]"
				},
				{
					"name": "meta.brace.square.salam",
					"match": "[\\[\\]]"
				},
				{
					"name": "meta.brace.curly.salam",
					"match": "[{}]"
				}
			]
		}
	}
}
