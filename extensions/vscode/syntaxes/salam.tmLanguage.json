          "match": "(?<=\\.)\\s*([A-Za-z_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}][A-Za-z0-9_\\x{0600}-\\x{06FF}\\x{0750}-\\x{077F}\\x{08A0}-\\x{08FF}\\x{FB50}-\\x{FDFF}\\x{FE70}-\\x{FEFF}\\x{200C}\\x{200D}]*)",
          "name": "variable.other.member.salam"
