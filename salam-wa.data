@en "collections"
@fa "مجموعه‌ها"
package collections
import "mem"

extern "C":
    func salam_panic(msg str)
end

@en "Vector"
@fa "بردار"
pub struct Vector<T>:
    data T* = null
    _len i32 = 0
    _cap i32 = 0

    func reserve(need i32):
        if need <= this._cap: ret end
        mut c i32 = this._cap
        if c == 0: c = 4 end
        while c < need: c = c * 2 end
        this.data = mem.Reallocate(this.data as void*, (c as u64) * sizeof(T)) as T*
        this._cap = c
    end
    func push(x T):
        this.reserve(this._len + 1)
        mut d T* = this.data
        d[this._len] = x
        this._len = this._len + 1
    end
    func pop() T:
        if this._len <= 0: salam_panic("Vector.pop: empty") end
        this._len = this._len - 1
        mut d T* = this.data
        ret d[this._len]
    end
    func get(i i32) T*:
        if i < 0 || i >= this._len: salam_panic("Vector.get: index out of bounds") end
        ret (this.data as i64 + (i as i64) * (sizeof(T) as i64)) as T*
    end
    func set(i i32, x T):
        if i < 0: salam_panic("Vector.set: negative index") end
        this.reserve(i + 1)
        if i >= this._len: this._len = i + 1 end
        mut d T* = this.data
        d[i] = x
    end
    func len() i32: ret this._len end
    func cap() i32: ret this._cap end
    func is_empty() bool: ret this._len == 0 end
    func first() T: ret this.get(0)[0] end
    func last() T: ret this.get(this._len - 1)[0] end
    func clear(): this._len = 0 end
    func insert(i i32, x T):
        if i < 0 || i > this._len: salam_panic("Vector.insert: index out of bounds") end
        this.reserve(this._len + 1)
        mut d T* = this.data
        mut j i32 = this._len
        while j > i:
            d[j] = d[j - 1]
            j = j - 1
        end
        d[i] = x
        this._len = this._len + 1
    end
    func remove_at(i i32) T:
        if i < 0 || i >= this._len: salam_panic("Vector.remove_at: index out of bounds") end
        mut d T* = this.data
        out T = d[i]
        mut j i32 = i
        while j < this._len - 1:
            d[j] = d[j + 1]
            j = j + 1
        end
        this._len = this._len - 1
        ret out
    end
    func operator_index(i i32) T:
        ret this.get(i)[0]
    end
    func operator_index_set(i i32, x T):
        this.set(i, x)
    end
    func iter() VectorIter<T>:
        mut it VectorIter<T> = VectorIter {}
        it.data = this.data
        it.len = this._len
        it.pos = 0
        ret it
    end
    func free():
        if this.data != null: mem.Free(this.data as void*) end
        this.data = null
        this._len = 0
        this._cap = 0
    end
end

@en "VectorIter"
@fa "پیمایشگر_بردار"
pub struct VectorIter<T>:
    data T* = null
    len i32 = 0
    pos i32 = 0
    func has_next() bool: ret this.pos < this.len end
    func value() T:
        mut d T* = this.data
        ret d[this.pos]
    end
    func next(): this.pos = this.pos + 1 end
end

@en "HashMap"
@fa "نگاشت_درهم"
pub struct HashMap<K, V>:
    keys K* = null
    vals V* = null
    state i32* = null
    cap i32 = 0
    count i32 = 0
    used i32 = 0

    func _zalloc(nbytes u64) void*:
        p void* = mem.Allocate(nbytes)
        mut b i8* = p as i8*
        ni i32 = nbytes as i32
        mut i i32 = 0
        while i < ni:
            b[i] = 0 as i8
            i = i + 1
        end
        ret p
    end

    func _index(k K) i32:
        mut idx i32 = (hash(k) % (this.cap as u64)) as i32
        mut firstdel i32 = 0 - 1
        mut kp K* = this.keys
        mut go bool = true
        while go:
            st i32 = this.state[idx]
            if st == 0:
                if firstdel >= 0: ret firstdel end
                ret idx
            end
            if st == 1:
                if kp[idx] == k: ret idx end
            else:
                if firstdel < 0: firstdel = idx end
            end
            idx = (idx + 1) % this.cap
        end
        ret idx
    end

    func _resize(newcap i32):
        ok K* = this.keys
        ov V* = this.vals
        os i32* = this.state
        oc i32 = this.cap
        this.keys = mem.Allocate((newcap as u64) * sizeof(K)) as K*
        this.vals = mem.Allocate((newcap as u64) * sizeof(V)) as V*
        this.state = this._zalloc((newcap as u64) * sizeof(i32)) as i32*
        this.cap = newcap
        this.count = 0
        this.used = 0
        mut i i32 = 0
        while i < oc:
            if os[i] == 1:
                mut okp K* = ok
                mut ovp V* = ov
                this.put(okp[i], ovp[i])
            end
            i = i + 1
        end
        if ok != null: mem.Free(ok as void*) end
        if ov != null: mem.Free(ov as void*) end
        if os != null: mem.Free(os as void*) end
    end

    func put(k K, v V):
        if this.cap == 0:
            this._resize(8)
        else:
            if (this.used + 1) * 10 >= this.cap * 7: this._resize(this.cap * 2) end
        end
        mut idx i32 = this._index(k)
        mut kp K* = this.keys
        mut vp V* = this.vals
        st i32 = this.state[idx]
        if st != 1:
            this.count = this.count + 1
            if st == 0: this.used = this.used + 1 end
        end
        this.state[idx] = 1
        kp[idx] = k
        vp[idx] = v
    end
    func insert(k K, v V): this.put(k, v) end

    func has(k K) bool:
        if this.cap == 0: ret false end
        mut idx i32 = this._index(k)
        ret this.state[idx] == 1
    end

    func get(k K) V:
        if this.cap != 0:
            mut idx i32 = this._index(k)
            mut vp V* = this.vals
            if this.state[idx] == 1: ret vp[idx] end
        end
        mut z V* = this._zalloc(sizeof(V)) as V*
        zv V = z[0]
        mem.Free(z as void*)
        ret zv
    end

    func remove(k K) bool:
        if this.cap == 0: ret false end
        mut idx i32 = this._index(k)
        if this.state[idx] != 1: ret false end
        this.state[idx] = 2
        this.count = this.count - 1
        ret true
    end

    func size() i32: ret this.count end
    func is_empty() bool: ret this.count == 0 end

    func iter() MapIter<K, V>:
        mut it MapIter<K, V> = MapIter {}
        it.keys = this.keys
        it.vals = this.vals
        it.state = this.state
        it.cap = this.cap
        it.pos = 0
        ret it
    end
    func free():
        if this.keys != null: mem.Free(this.keys as void*) end
        if this.vals != null: mem.Free(this.vals as void*) end
        if this.state != null: mem.Free(this.state as void*) end
        this.keys = null
        this.vals = null
        this.state = null
        this.cap = 0
        this.count = 0
        this.used = 0
    end
end

@en "MapIter"
@fa "پیمایشگر_نگاشت"
pub struct MapIter<K, V>:
    keys K* = null
    vals V* = null
    state i32* = null
    cap i32 = 0
    pos i32 = 0
    func _seek():
        while this.pos < this.cap:
            if this.state[this.pos] == 1: ret end
            this.pos = this.pos + 1
        end
    end
    func has_next() bool:
        this._seek()
        ret this.pos < this.cap
    end
    func key() K:
        this._seek()
        mut kp K* = this.keys
        ret kp[this.pos]
    end
    func value() V:
        this._seek()
        mut vp V* = this.vals
        ret vp[this.pos]
    end
    func next(): this.pos = this.pos + 1 end
end

@en "Stack"
@fa "پشته"
pub struct Stack<T>:
    items Vector<T> = Vector {}
    func push(x T): this.items.push(x) end
    func pop() T: ret this.items.pop() end
    func peek() T: ret this.items.last() end
    func size() i32: ret this.items.len() end
    func is_empty() bool: ret this.items.is_empty() end
    func clear(): this.items.clear() end
    func free(): this.items.free() end
end

@en "Queue"
@fa "صف"
pub struct Queue<T>:
    inbox Vector<T> = Vector {}
    outbox Vector<T> = Vector {}
    func _shift():
        if this.outbox.len() == 0:
            while this.inbox.len() > 0: this.outbox.push(this.inbox.pop()) end
        end
    end
    func enqueue(x T): this.inbox.push(x) end
    func dequeue() T:
        this._shift()
        ret this.outbox.pop()
    end
    func peek() T:
        this._shift()
        ret this.outbox.last()
    end
    func size() i32: ret this.inbox.len() + this.outbox.len() end
    func is_empty() bool: ret this.size() == 0 end
    func free():
        this.inbox.free()
        this.outbox.free()
    end
end

@en "Deque"
@fa "صف_دوسر"
pub struct Deque<T>:
    front Vector<T> = Vector {}
    back Vector<T> = Vector {}
    func _to_front(): while this.back.len() > 0: this.front.push(this.back.pop()) end end
    func _to_back(): while this.front.len() > 0: this.back.push(this.front.pop()) end end
    func push_front(x T): this.front.push(x) end
    func push_back(x T): this.back.push(x) end
    func pop_front() T:
        if this.front.len() == 0: this._to_front() end
        ret this.front.pop()
    end
    func pop_back() T:
        if this.back.len() == 0: this._to_back() end
        ret this.back.pop()
    end
    func front_val() T:
        if this.front.len() == 0: this._to_front() end
        ret this.front.last()
    end
    func back_val() T:
        if this.back.len() == 0: this._to_back() end
        ret this.back.last()
    end
    func size() i32: ret this.front.len() + this.back.len() end
    func is_empty() bool: ret this.size() == 0 end
    func get(i i32) T:
        fl i32 = this.front.len()
        if i < fl: ret this.front.get(fl - 1 - i)[0] end
        ret this.back.get(i - fl)[0]
    end
    func free():
        this.front.free()
        this.back.free()
    end
end

@en "LinkedList"
@fa "لیست_پیوندی"
pub struct LinkedList<T>:
    vals Vector<T> = Vector {}
    nxt Vector<i32> = Vector {}
    prv Vector<i32> = Vector {}
    head i32 = 0 - 1
    tail i32 = 0 - 1
    freed i32 = 0 - 1
    count i32 = 0
    func _alloc(v T) i32:
        if this.freed >= 0:
            idx i32 = this.freed
            this.freed = this.nxt.get(idx)[0]
            this.vals.set(idx, v)
            ret idx
        end
        idx i32 = this.vals.len()
        this.vals.push(v)
        this.nxt.push(0 - 1)
        this.prv.push(0 - 1)
        ret idx
    end
    func push_back(v T):
        n i32 = this._alloc(v)
        this.nxt.set(n, 0 - 1)
        this.prv.set(n, this.tail)
        if this.tail >= 0: this.nxt.set(this.tail, n) else:
            this.head = n
        end
        this.tail = n
        this.count = this.count + 1
    end
    func push_front(v T):
        n i32 = this._alloc(v)
        this.prv.set(n, 0 - 1)
        this.nxt.set(n, this.head)
        if this.head >= 0: this.prv.set(this.head, n) else:
            this.tail = n
        end
        this.head = n
        this.count = this.count + 1
    end
    func _unlink(n i32):
        p i32 = this.prv.get(n)[0]
        q i32 = this.nxt.get(n)[0]
        if p >= 0: this.nxt.set(p, q) else:
            this.head = q
        end
        if q >= 0: this.prv.set(q, p) else:
            this.tail = p
        end
        this.nxt.set(n, this.freed)
        this.freed = n
        this.count = this.count - 1
    end
    func pop_front() T:
        if this.head < 0: salam_panic("LinkedList.pop_front: empty") end
        n i32 = this.head
        v T = this.vals.get(n)[0]
        this._unlink(n)
        ret v
    end
    func pop_back() T:
        if this.tail < 0: salam_panic("LinkedList.pop_back: empty") end
        n i32 = this.tail
        v T = this.vals.get(n)[0]
        this._unlink(n)
        ret v
    end
    func front_val() T: ret this.vals.get(this.head)[0] end
    func back_val() T: ret this.vals.get(this.tail)[0] end
    func size() i32: ret this.count end
    func is_empty() bool: ret this.count == 0 end
    func get(i i32) T:
        if i < 0 || i >= this.count: salam_panic("LinkedList.get: index out of bounds") end
        mut cur i32 = this.head
        mut k i32 = 0
        while k < i:
            cur = this.nxt.get(cur)[0]
            k = k + 1
        end
        ret this.vals.get(cur)[0]
    end
    func to_vector() Vector<T>:
        mut out Vector<T> = Vector {}
        mut cur i32 = this.head
        while cur >= 0:
            out.push(this.vals.get(cur)[0])
            cur = this.nxt.get(cur)[0]
        end
        ret out
    end
    func free():
        this.vals.free()
        this.nxt.free()
        this.prv.free()
    end
end

@en "CircularList"
@fa "لیست_حلقوی"
pub struct CircularList<T>:
    items Vector<T> = Vector {}
    head i32 = 0
    func add(x T): this.items.push(x) end
    func size() i32: ret this.items.len() end
    func is_empty() bool: ret this.items.is_empty() end
    func get(i i32) T:
        n i32 = this.items.len()
        if n <= 0: salam_panic("CircularList.get: empty list") end
        ret this.items.get(((this.head + i) % n + n) % n)[0]
    end
    func rotate(k i32):
        n i32 = this.items.len()
        if n > 0: this.head = ((this.head + k) % n + n) % n end
    end
    func current() T: ret this.get(0) end
    func advance(): this.rotate(1) end
    func to_vector() Vector<T>:
        mut out Vector<T> = Vector {}
        mut i i32 = 0
        while i < this.items.len():
            out.push(this.get(i))
            i = i + 1
        end
        ret out
    end
    func free(): this.items.free() end
end

@en "PriorityQueue"
@fa "صف_اولویت‌دار"
pub struct PriorityQueue<T>:
    h Vector<T> = Vector {}
    func _swap(i i32, j i32):
        a T = this.h.get(i)[0]
        b T = this.h.get(j)[0]
        this.h.set(i, b)
        this.h.set(j, a)
    end
    func push(x T):
        this.h.push(x)
        mut i i32 = this.h.len() - 1
        mut go bool = true
        while go:
            if i == 0:
                go = false
            else:
                p i32 = (i - 1) / 2
                if this.h.get(i)[0] < this.h.get(p)[0]:
                    this._swap(i, p)
                    i = p
                else:
                    go = false
                end
            end
        end
    end
    func peek() T: ret this.h.get(0)[0] end
    func size() i32: ret this.h.len() end
    func is_empty() bool: ret this.h.len() == 0 end
    func pop() T:
        if this.h.len() == 0: salam_panic("PriorityQueue.pop: empty") end
        n i32 = this.h.len()
        top T = this.h.get(0)[0]
        last T = this.h.pop()
        if n > 1:
            this.h.set(0, last)
            mut i i32 = 0
            mut go bool = true
            while go:
                l i32 = 2 * i + 1
                r i32 = 2 * i + 2
                mut sm i32 = i
                if l < this.h.len() && this.h.get(l)[0] < this.h.get(sm)[0]: sm = l end
                if r < this.h.len() && this.h.get(r)[0] < this.h.get(sm)[0]: sm = r end
                if sm == i: go = false
                else:
                    this._swap(i, sm)
                    i = sm
                end
            end
        end
        ret top
    end
    func free(): this.h.free() end
end

@en "Set"
@fa "مجموعه"
pub struct Set<T>:
    m HashMap<T, bool> = HashMap {}
    func add(x T): this.m.put(x, true) end
    func has(x T) bool: ret this.m.has(x) end
    func remove(x T) bool: ret this.m.remove(x) end
    func size() i32: ret this.m.size() end
    func is_empty() bool: ret this.m.is_empty() end
    func free(): this.m.free() end
end

@en "Counter"
@fa "شمارنده"
pub struct Counter<K>:
    m HashMap<K, i32> = HashMap {}
    func add(k K): this.m.put(k, this.count(k) + 1) end
    func add_n(k K, n i32): this.m.put(k, this.count(k) + n) end
    func count(k K) i32:
        if this.m.has(k): ret this.m.get(k) end
        ret 0
    end
    func distinct() i32: ret this.m.size() end
    func free(): this.m.free() end
end

@en "Pair"
@fa "زوج"
pub struct Pair<A, B>:
    first A
    second B
end

@en "contains"
@fa "دارد"
pub func contains<T>(v Vector<T>, x T) bool:
    mut i i32 = 0
    while i < v.len():
        if v.get(i)[0] == x: ret true end
        i = i + 1
    end
    ret false
end

@en "index_of"
@fa "اندیس"
pub func index_of<T>(v Vector<T>, x T) i32:
    mut i i32 = 0
    while i < v.len():
        if v.get(i)[0] == x: ret i end
        i = i + 1
    end
    ret 0 - 1
end

@en "reverse"
@fa "وارونه"
pub func reverse<T>(v Vector<T>) Vector<T>:
    mut out Vector<T> = Vector {}
    mut i i32 = v.len() - 1
    while i >= 0:
        out.push(v.get(i)[0])
        i = i - 1
    end
    ret out
end
@en "console"
@fa "کنسول"
package console
import "mem"
func _fmt(fmt str, cap u64, write_int bool, iv i64, fv f64) str:
    b void* = mem.Allocate(cap)
    if write_int:
        sprintf(b, fmt, iv)
    else:
        sprintf(b, fmt, fv)
    end
    ret b as str
end

func _dup(src str) str:
    n i32 = src.len()
    d void* = mem.AllocateZeroed((n + 1) as u64)
    mem.Copy(d, src as void*, n as u64)
    ret d as str
end
extern "C":
    func sprintf(buf void*, fmt str, ...) i32
    func printf(fmt str, ...) i32
    func salam_tostr_i32(x i32) str: ret _fmt("%d", 16 as u64, true, x as i64, 0.0) end
    func salam_tostr_i64(x i64) str: ret _fmt("%lld", 24 as u64, true, x, 0.0) end
    func salam_tostr_u32(x u32) str: ret _fmt("%u", 16 as u64, true, x as i64, 0.0) end
    func salam_tostr_u64(x u64) str: ret _fmt("%llu", 24 as u64, true, x as i64, 0.0) end
    func salam_tostr_f64(x f64) str: ret _fmt("%g", 40 as u64, false, 0, x) end
    func salam_tostr_bool(b bool) str:
        if b: ret _dup("true") end
        ret _dup("false")
    end
    func salam_tostr_char(c char) str:
        ret char_from_code(c as i32)
    end
end
@if SALAM_OS_WINDOWS
extern "C":
    func _write(fd i32, buf void*, n u32) i32
end

func _err_raw(s str): _write(2, s as void*, s.len() as u32) end
@else
extern "C":
    func write(fd i32, buf void*, n u64) i64
end

func _err_raw(s str): write(2, s as void*, s.len() as u64) end

@end
extern "C":
    func salam_emit(s str, err i32):
        if err != 0:
            _err_raw(s)
        else:
            printf("%s", s)
        end
    end
    func salam_emit_owned(s str, err i32):
        salam_emit(s, err)
        mem.Free(s as void*)
    end
end
@en "core"
@fa "هسته"
package core
import "mem"
import "map"
import "text"
import "console"
import "fs"
import "thread"
import "crypto"
extern "C":
    func getchar() i32
    func strcmp(a str, b str) i32
    func strstr(haystack str, needle str) str
    func strtol(s str, endptr void*, base i32) i64
    func strtod(s str, endptr void*) f64
    func strlen(s str) u64
end

func _strptr(s str) i64:
    v void* = s as void*
    ret v as i64
end

func _i64s(n i64) str:
    if n == 0: ret "0" end
    mut v i64 = n
    mut neg bool = false
    if v < 0:
        neg = true
        v = 0 - v
    end
    mut r str = ""
    while v > 0:
        r = char_from_code((v % 10) as i32 + 48).concat(r)
        v = v / 10
    end
    if neg: ret "-".concat(r) end
    ret r
end
extern "C":
    func abort()
    func salam_idx(idx i64, len i64) i64:
        if idx < 0 || idx >= len:
            !__ "salam: array index ".concat(_i64s(idx)).concat(" out of bounds [0,").concat(_i64s(len)).concat(")")
            abort()
        end
        ret idx
    end
    func salam_panic(msg str):
        !__ "salam panic: ".concat(msg)
        abort()
    end
end

@en "Panic"
@fa "خطای_مرگبار"
pub func Panic(msg str): salam_panic(msg) end
extern "C":
    func salam_input() str:
        mut out str = ""
        mut c i32 = getchar()
        while c != -1:
            if c == 10: ret out end
            out = out.concat(char_from_code(c))
            c = getchar()
        end
        ret out
    end
end
mut _argc i32 = 0
mut _argv void* = null
extern "C":
    func salam_set_args(argc i32, argv void*):
        _argc = argc
        _argv = argv
    end
    func salam_args(out_count void*) void*:
        mut oc i32* = out_count as i32*
        n i32 = _argc
        mut slots i32 = n
        if slots < 1: slots = 1 end
        arr void* = mem.Allocate((slots * 8) as u64)
        mut a64 i64* = arr as i64*
        mut av i64* = _argv as i64*
        mut i i32 = 0
        while i < n:
            cp void* = av[i] as void*
            s str = cp as str
            a64[i] = _strptr(s.substr(0, s.len()))
            i = i + 1
        end
        oc[0] = n
        ret arr
    end
end
@en "crypto"
@fa "رمزنگاری"
package crypto

extern "C":
    func salam_hash_bytes(p void*, n u64) u64:
        bp i8* = p as i8*
        ni i32 = n as i32
        mut h u64 = 14695981039346656037 as u64
        mut i i32 = 0
        while i < ni:
            mut c i32 = bp[i] as i32
            if c < 0: c = c + 256 end
            h = h * (1099511628211 as u64)
            h = h + (c as u64)
            i = i + 1
        end
        ret h
    end
    func salam_str_hash(s str) u64:
        bp i8* = (s as void*) as i8*
        mut h u64 = 14695981039346656037 as u64
        mut j i32 = 0
        while bp[j] != 0:
            mut c i32 = bp[j] as i32
            if c < 0: c = c + 256 end
            h = h * (1099511628211 as u64)
            h = h + (c as u64)
            j = j + 1
        end
        ret h
    end
    func salam_hash_int(x u64) u64:
        mut h u64 = x + (14695981039346656037 as u64)
        h = h * (1099511628211 as u64)
        h = h + (1099511628211 as u64)
        h = h * (1099511628211 as u64)
        ret h
    end
end

@en "HashBytes"
@fa "درهم_بایت"
pub func HashBytes(p void*, n u64) u64: ret salam_hash_bytes(p, n) end

@en "HashStr"
@fa "درهم_رشته"
pub func HashStr(s str) u64: ret salam_str_hash(s) end

@en "HashInt"
@fa "درهم_عدد"
pub func HashInt(x u64) u64: ret salam_hash_int(x) end
@en "csv"
@fa "سی‌اس‌وی"
package csv
func replace(s str, find str, with str) str:
    fl i32 = find.len()
    if fl == 0: ret s end
    mut result str = ""
    mut rest str = s
    mut idx i32 = rest.find(find)
    while idx >= 0:
        result = result.concat(rest.substr(0, idx))
        result = result.concat(with)
        rest = rest.substr(idx + fl, rest.len() - idx - fl)
        idx = rest.find(find)
    end
    ret result.concat(rest)
end

@en "ReadLine"
@fa "خواندن_خط"
pub func ReadLine(line str) Vector<str>:
    mut result Vector<str> = Vector {}
    n i32 = line.len()
    mut i i32 = 0
    mut done bool = false
    while done == false:
        mut field str = ""
        if i < n && char_code(line.substr(i, 1)) == 34:
            i = i + 1
            mut in_q bool = true
            while i < n && in_q:
                c i32 = char_code(line.substr(i, 1))
                if c == 34:
                    if i + 1 < n && char_code(line.substr(i + 1, 1)) == 34:
                        field = field.concat("\"")
                        i = i + 2
                    else:
                        i = i + 1
                        in_q = false
                    end
                else:
                    field = field.concat(line.substr(i, 1))
                    i = i + 1
                end
            end
        else:
            mut at_sep bool = false
            while i < n && at_sep == false:
                c i32 = char_code(line.substr(i, 1))
                if c == 44:
                    at_sep = true
                else:
                    field = field.concat(line.substr(i, 1))
                    i = i + 1
                end
            end
        end
        result.push(field)
        if i < n && char_code(line.substr(i, 1)) == 44:
            i = i + 1
        else:
            done = true
        end
    end
    ret result
end

func needs_quote(field str) bool:
    if field.find(",") >= 0:
        ret true
    end
    if field.find("\"") >= 0:
        ret true
    end
    ret false
end

@en "WriteLine"
@fa "نوشتن_خط"
pub func WriteLine(fields Vector<str>) str:
    mut out str = ""
    mut i = 0
    while i < fields.len():
        if i > 0:
            out = out.concat(",")
        end
        f str = fields.get(i)[0]
        if needs_quote(f):
            out = out.concat("\"")
            out = out.concat(replace(f, "\"", "\"\""))
            out = out.concat("\"")
        else:
            out = out.concat(f)
        end
        i = i + 1
    end
    ret out
end
@en "mysql"
