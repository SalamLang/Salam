@en "UUID"
@fa "شناسه_یکتا"
pub func UUID() str:
    hex str = "0123456789abcdef"
    mut result str = ""
    mut i i32 = 0
    while i < 16:
        b i32 = rand_int32() % 256
        mut bval i32 = b
        if i == 6: bval = b % 16 + 64 end
        if i == 8: bval = b % 64 + 128 end
        result = result.concat(hex.substr(bval / 16, 1))
        result = result.concat(hex.substr(bval % 16, 1))
        if i == 3 || i == 5 || i == 7 || i == 9:
            result = result.concat("-")
        end
        i = i + 1
    end
    ret result
end

