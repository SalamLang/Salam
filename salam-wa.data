@en "ShuffleStr"
@fa "بهم‌ریختن_رشته"
pub func ShuffleStr(v Vector<str>) Vector<str>:
    mut out Vector<str> = Vector {}
    mut i i32 = 0
    while i < v.len():
        out.push(v.get(i)[0])
        i = i + 1
    end
    mut k i32 = out.len() - 1
    while k > 0:
        j i32 = rand_int32() % (k + 1)
        tmp str = out.get(k)[0]
        out.set(k, out.get(j)[0])
        out.set(j, tmp)
        k = k - 1
    end
    ret out
end

