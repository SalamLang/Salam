pub func Split(s str, delim str) Vector<str>: ret s.split(delim) end

@en "Join"
@fa "بپیوند"
pub func Join(parts Vector<str>, sep str) str:
    mut out str = ""
    mut i i32 = 0
    while i < parts.len():
        if i > 0: out = out.concat(sep) end
        out = out.concat(parts.get(i)[0])
        i = i + 1
    end
    ret out
end

@en "Trim"
@fa "پیرایش"
pub func Trim(s str) str: ret s.trim() end

@en "ToInt"
@fa "تبدیل_به_عدد"
pub func ToInt(s str) i32: ret s.to_int() end

@en "ToFloat"
@fa "تبدیل_به_اعشار"
pub func ToFloat(s str) f64: ret s.to_float() end

@en "IsEmpty"
@fa "خالی_است"
pub func IsEmpty(s str) bool: ret s.len() == 0 end

@en "Replace"
@fa "جایگزینی"
pub func Replace(s str, find str, with str) str:
    fl i32 = find.len()
    if fl == 0: ret s end
    mut result str = ""
    mut rest str = s
    mut idx i32 = rest.find(find)
    while idx >= 0:
        result = result.concat(rest.substr(0, idx))
        result = result.concat(with)
        rest = rest.substr(idx + fl, rest.len() - idx - fl)
        idx = rest.find(find)
    end
    ret result.concat(rest)
end

@en "FromInt"
@fa "از_عدد"
pub func FromInt(i i64) str:
    if i == 0: ret "0" end
    mut n i64 = i
    mut result str = ""
    mut neg bool = false
    if n < 0:
        neg = true
        n = 0 - n
    end
    while n > 0:
        digit i32 = (n % 10) as i32
        result = char_from_code(digit + 48).concat(result)
        n = n / 10
    end
    if neg: ret "-".concat(result) end
    ret result
end
