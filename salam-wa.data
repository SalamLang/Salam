    if x < lo: ret lo end
    if x > hi: ret hi end
    ret x
end

@en "MinI"
@fa "کمینه_صحیح"
pub func MinI(a i32, b i32) i32: if a < b: ret a end ret b end

@en "MaxI"
@fa "بیشینه_صحیح"
pub func MaxI(a i32, b i32) i32: if a > b: ret a end ret b end

@en "AbsI"
@fa "قدرمطلق_صحیح"
pub func AbsI(x i32) i32: if x < 0: ret 0 - x end ret x end

@en "ClampI"
@fa "محدودسازی_صحیح"
pub func ClampI(x i32, lo i32, hi i32) i32:
    if x < lo: ret lo end
    if x > hi: ret hi end
    ret x
end

@en "Gcd"
@fa "بزرگترین_مقسوم‌علیه_مشترک"
pub func Gcd(a i32, b i32) i32:
    mut x i32 = a
    mut y i32 = b
    if x < 0: x = 0 - x end
    if y < 0: y = 0 - y end
    while y != 0:
        t i32 = y
        y = x % y
        x = t
    end
    ret x
end

@en "Lcm"
@fa "کوچکترین_مضرب_مشترک"
pub func Lcm(a i32, b i32) i32:
    if a == 0:
        ret 0
    end
    if b == 0:
        ret 0
    end
    g i32 = Gcd(a, b)
    p i32 = a / g * b
    if p < 0: ret 0 - p end
    ret p
end

@en "Max"
@fa "بیشینه"
pub func Max(a f64, b f64) f64: ret MaxF(a, b) end

@en "Min"
@fa "کمینه"
