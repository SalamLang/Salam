@en "FileInfo"
@fa "اطلاعات_پرونده"
pub struct FileInfo:
    size i64 = 0
    is_dir bool = false
    exists bool = false
end

@en "Stat"
@fa "وضعیت_پرونده"
pub func Stat(path str) FileInfo:
    if _os_exists(path) == false:
        ret FileInfo { size = 0, is_dir = false, exists = false }
    end
    dir bool = _os_is_dir(path)
    mut sz i64 = 0
    if dir == false:
        fp void* = fopen(path, "rb")
        if fp != null:
            fseek(fp, 0, 2)
            sz = ftell(fp) as i64
            fclose(fp)
        end
    end
    ret FileInfo { size = sz, is_dir = dir, exists = true }
end
@en "rand"
@fa "تصادفی"
package rand
import "time"
mut _g_state u64 = 0 as u64
mut _g_seeded i32 = 0
func _pcg_step():
    _g_state = _g_state * (6364136223846793005 as u64) + (1442695040888963407 as u64)
end

func _ensure_seeded():
    if _g_seeded == 0:
        rand_seed(time.Now())
    end
end

func rand_seed(s i64):
    _g_state = (s as u64) + (1442695040888963407 as u64)
    _pcg_step()
    _g_seeded = 1
end

func rand_int32() i32:
    _ensure_seeded()
    _pcg_step()
    h u64 = _g_state / (4294967296 as u64)
    ret (h % (2147483648 as u64)) as i32
end

func rand_int64() i64:
    _ensure_seeded()
    _pcg_step()
    hi u64 = _g_state / (4294967296 as u64) % (2147483648 as u64)
    _pcg_step()
    lo u64 = _g_state / (4294967296 as u64)
    ret (hi * (4294967296 as u64) + lo) as i64
end

func rand_float64() f64:
    n i64 = rand_int64()
    n53 i64 = n % 9007199254740992
    ret n53 as f64 / 9007199254740992.0
end

func rand_bytes(n i32) str:
    if n <= 0: ret "" end
    mut r str = ""
    mut i i32 = 0
    while i < n:
        b i32 = rand_int32() % 255 + 1
        r = r.concat(char_from_code(b))
        i = i + 1
    end
    ret r
end

func hex_bytes(n i32) str:
    hex str = "0123456789abcdef"
    mut result str = ""
    mut i i32 = 0
    while i < n:
        b i32 = rand_int32() % 256
        result = result.concat(hex.substr(b / 16, 1))
        result = result.concat(hex.substr(b % 16, 1))
        i = i + 1
    end
    ret result
end

@en "Seed"
@fa "بذر"
pub func Seed(s i64):
    rand_seed(s)
end

