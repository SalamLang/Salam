link "mysqlclient"
@else
link "mariadb"
@end

@end
extern "C":
    func strdup(s str) str
end

func _parse_i64(s str) i64:
    l i32 = s.len()
    if l == 0:
        ret 0
    end
    mut p i32 = 0
    mut neg bool = false
    first str = s.substr(0, 1)
    if first == "-":
        neg = true
        p = 1
    else:
        if first == "+":
            p = 1
        end
    end
    mut v i64 = 0
    while p < l:
        code i32 = char_code(s.substr(p, 1))
        if code < 48 || code > 57:
            break
        end
        v = v * 10 + ((code - 48) as i64)
        p = p + 1
    end
    if neg:
        ret -v
    end
    ret v
end
