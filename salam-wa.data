@en "BubbleSort"
@fa "مرتب‌سازی_حبابی"
pub func BubbleSort<T>(v Vector<T>):
    n i32 = v.len()
    mut end_i i32 = n - 1
    mut swapped bool = true
    while swapped:
        swapped = false
        mut i i32 = 0
        while i < end_i:
            if v.get(i + 1)[0] < v.get(i)[0]:
                Swap(v, i, i + 1)
                swapped = true
            end
            i = i + 1
        end
        end_i = end_i - 1
    end
end
package sort

@en "BucketSort"
@fa "مرتب‌سازی_سطلی"
pub func BucketSort(v Vector<i32>):
    n i32 = v.len()
    if n < 2: ret end
    mut lo i32 = v.get(0)[0]
    mut hi i32 = lo
    mut i i32 = 1
    while i < n:
        x i32 = v.get(i)[0]
        if x < lo: lo = x end
        if hi < x: hi = x end
        i = i + 1
    end
    if lo == hi: ret end
    span i64 = (hi as i64) - (lo as i64) + 1
    mut count Vector<i32> = Vector {}
    mut b i32 = 0
    while b <= n:
        count.push(0)
        b = b + 1
    end
    i = 0
    while i < n:
        bi i32 = _bucket_of(v.get(i)[0], lo, span, n)
        count.set(bi, count.get(bi)[0] + 1)
        i = i + 1
    end
    mut s i32 = 1
    while s <= n:
        count.set(s, count.get(s)[0] + count.get(s - 1)[0])
        s = s + 1
    end
    mut starts Vector<i32> = Vector {}
    mut k i32 = 0
    while k < n:
        if k == 0: starts.push(0) else:
            starts.push(count.get(k - 1)[0])
        end
        k = k + 1
    end
    mut cursor Vector<i32> = Vector {}
    k = 0
    while k < n:
        cursor.push(starts.get(k)[0])
        k = k + 1
    end
    mut out Vector<i32> = Vector {}
    i = 0
    while i < n:
        out.push(0)
        i = i + 1
    end
    i = 0
    while i < n:
        bi i32 = _bucket_of(v.get(i)[0], lo, span, n)
        pos i32 = cursor.get(bi)[0]
        out.set(pos, v.get(i)[0])
        cursor.set(bi, pos + 1)
        i = i + 1
    end
    k = 0
    while k < n:
        bstart i32 = starts.get(k)[0]
        mut bend i32 = n
        if k < n - 1: bend = starts.get(k + 1)[0] end
        if bend - bstart > 1:
            _insertion_range(out, bstart, bend - 1)
        end
        k = k + 1
    end
    i = 0
    while i < n:
        v.set(i, out.get(i)[0])
        i = i + 1
    end
    count.free()
    starts.free()
    cursor.free()
    out.free()
end

func _bucket_of(x i32, lo i32, span i64, n i32) i32:
    off i64 = (x as i64) - (lo as i64)
    bi i64 = off * (n as i64) / span
    if bi >= (n as i64): ret n - 1 end
    ret bi as i32
end
package sort

@en "CocktailSort"
@fa "مرتب‌سازی_نوشیدنی"
pub func CocktailSort<T>(v Vector<T>):
    mut lo i32 = 0
    mut hi i32 = v.len() - 1
    mut swapped bool = true
    while swapped:
        swapped = false
        mut i i32 = lo
        while i < hi:
            if v.get(i + 1)[0] < v.get(i)[0]:
                Swap(v, i, i + 1)
                swapped = true
            end
            i = i + 1
        end
        hi = hi - 1
        mut j i32 = hi
        while j > lo:
            if v.get(j)[0] < v.get(j - 1)[0]:
                Swap(v, j, j - 1)
                swapped = true
            end
            j = j - 1
        end
        lo = lo + 1
    end
end
package sort

@en "CombSort"
@fa "مرتب‌سازی_شانه‌ای"
pub func CombSort<T>(v Vector<T>):
    n i32 = v.len()
    mut gap i32 = n
    mut swapped bool = true
    while gap > 1 || swapped:
        gap = gap * 10 / 13
        if gap < 1: gap = 1 end
        swapped = false
        mut i i32 = 0
        while i + gap < n:
            if v.get(i + gap)[0] < v.get(i)[0]:
                Swap(v, i, i + gap)
                swapped = true
            end
            i = i + 1
        end
    end
end
package sort

@en "Swap"
@fa "جابجایی"
pub func Swap<T>(v Vector<T>, i i32, j i32):
    t T = v.get(i)[0]
    v.set(i, v.get(j)[0])
    v.set(j, t)
end

func _insertion_range<T>(v Vector<T>, lo i32, hi i32):
    mut i i32 = lo + 1
    while i <= hi:
        key T = v.get(i)[0]
        mut j i32 = i - 1
        mut go bool = true
        while go:
            if j < lo:
                go = false
            else:
                if key < v.get(j)[0]:
                    v.set(j + 1, v.get(j)[0])
                    j = j - 1
                else:
                    go = false
                end
            end
        end
        v.set(j + 1, key)
        i = i + 1
    end
end

func _partition<T>(v Vector<T>, lo i32, hi i32) i32:
    mid i32 = lo + (hi - lo) / 2
    if v.get(mid)[0] < v.get(lo)[0]: Swap(v, lo, mid) end
    if v.get(hi)[0] < v.get(lo)[0]: Swap(v, lo, hi) end
    if v.get(hi)[0] < v.get(mid)[0]: Swap(v, mid, hi) end
    Swap(v, mid, hi)
    pivot T = v.get(hi)[0]
    mut i i32 = lo - 1
    mut j i32 = lo
    while j < hi:
        if v.get(j)[0] < pivot:
            i = i + 1
            Swap(v, i, j)
        end
        j = j + 1
    end
    Swap(v, i + 1, hi)
    ret i + 1
end
package sort

@en "SortBy"
@fa "مرتب‌سازی_با"
pub func SortBy<T>(v Vector<T>, less func (T, T) bool):
    n i32 = v.len()
    if n < 2: ret end
    _quick_by(v, 0, n - 1, less)
end

func _quick_by<T>(v Vector<T>, lo_in i32, hi_in i32, less func (T, T) bool):
    mut lo i32 = lo_in
    mut hi i32 = hi_in
    while lo < hi:
        mid i32 = lo + (hi - lo) / 2
        if less(v.get(mid)[0], v.get(lo)[0]): Swap(v, lo, mid) end
        if less(v.get(hi)[0], v.get(lo)[0]): Swap(v, lo, hi) end
        if less(v.get(hi)[0], v.get(mid)[0]): Swap(v, mid, hi) end
        Swap(v, mid, hi)
        pivot T = v.get(hi)[0]
        mut i i32 = lo - 1
        mut j i32 = lo
        while j < hi:
            if less(v.get(j)[0], pivot):
                i = i + 1
                Swap(v, i, j)
            end
            j = j + 1
        end
        Swap(v, i + 1, hi)
        p i32 = i + 1
        if p - lo < hi - p:
            _quick_by(v, lo, p - 1, less)
            lo = p + 1
        else:
            _quick_by(v, p + 1, hi, less)
            hi = p - 1
        end
    end
end

@en "StableSortBy"
@fa "مرتب‌سازی_پایدار_با"
pub func StableSortBy<T>(v Vector<T>, less func (T, T) bool):
    n i32 = v.len()
    if n < 2: ret end
    mut buf Vector<T> = Vector {}
    mut i i32 = 0
    while i < n:
        buf.push(v.get(i)[0])
        i = i + 1
    end
    mut width i32 = 1
    while width < n:
        mut lo i32 = 0
        while lo < n:
            mut mid i32 = lo + width
            if mid > n: mid = n end
            mut hi i32 = lo + 2 * width
            if hi > n: hi = n end
            _merge_by(v, buf, lo, mid, hi, less)
            lo = lo + 2 * width
        end
        width = width * 2
    end
    buf.free()
end

func _merge_by<T>(v Vector<T>, buf Vector<T>, lo i32, mid i32, hi i32, less func (T, T) bool):
    mut k i32 = lo
    while k < hi:
        buf.set(k, v.get(k)[0])
        k = k + 1
    end
    mut i i32 = lo
    mut j i32 = mid
    mut o i32 = lo
    while o < hi:
        if i >= mid:
            v.set(o, buf.get(j)[0])
            j = j + 1
        else:
            if j >= hi:
                v.set(o, buf.get(i)[0])
                i = i + 1
            else:
                if less(buf.get(j)[0], buf.get(i)[0]):
                    v.set(o, buf.get(j)[0])
                    j = j + 1
                else:
                    v.set(o, buf.get(i)[0])
                    i = i + 1
                end
            end
        end
        o = o + 1
    end
end

@en "SortedBy"
@fa "مرتب‌شده_با"
pub func SortedBy<T>(v Vector<T>, less func (T, T) bool) Vector<T>:
    mut out Vector<T> = Vector {}
    mut i i32 = 0
    while i < v.len():
        out.push(v.get(i)[0])
        i = i + 1
    end
    SortBy(out, less)
    ret out
end

@en "IsSortedBy"
@fa "مرتب_است_با"
pub func IsSortedBy<T>(v Vector<T>, less func (T, T) bool) bool:
    mut i i32 = 1
    while i < v.len():
        if less(v.get(i)[0], v.get(i - 1)[0]): ret false end
        i = i + 1
    end
    ret true
end
