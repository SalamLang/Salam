    _it_set_i(it, cap)
end
extern "C":
    func salam_map_iter_new(m void*) void*:
        it void* = mem.AllocateZeroed(16 as u64)
        mut p i64* = it as i64*
        p[0] = m as i64
        p[1] = 0
        _it_seek(it)
        ret it
    end
    func salam_map_iter_valid(it void*) i32:
        m void* = _it_map(it)
        if _it_i(it) < _m_cap(m): ret 1 end
        ret 0
    end
    func salam_map_iter_key(it void*) i64:
        m void* = _it_map(it)
        keys i64* = _m_keys(m)
        ret keys[_it_i(it)]
    end
    func salam_map_iter_value(it void*) i64:
        m void* = _it_map(it)
        vals i64* = _m_vals(m)
        ret vals[_it_i(it)]
    end
    func salam_map_iter_next(it void*):
        _it_set_i(it, _it_i(it) + 1)
        _it_seek(it)
    end
end
