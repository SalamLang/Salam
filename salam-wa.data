@en "URL"
@fa "نشانی"
pub struct URL:
    scheme str = ""
    host str = ""
    port i32 = 0
    path str = "/"
end

func url_strip_scheme(url str) str:
    i i32 = url.find("://")
    if i >= 0:
        ret url.substr(i + 3, url.len() - i - 3)
    end
    ret url
end

@en "RawRequest"
@fa "درخواست_خام"
pub func RawRequest(host str, port i32, request str) str:
    s Socket = Connect(host, port)
    if !Ok(s):
        ret ""
    end
    Send(s, request)
    mut response str = ""
    mut chunk str = Recv(s, 4096)
    while chunk.len() > 0:
        response = response.concat(chunk)
        chunk = Recv(s, 4096)
    end
    Close(s)
    ret response
end

@en "Parse"
@fa "تجزیه"
pub func Parse(url str) URL:
    mut u URL = URL { scheme = "", host = "", port = 0, path = "/" }
    s i32 = url.find("://")
    if s >= 0:
        u.scheme = url.substr(0, s)
    end
    rest str = url_strip_scheme(url)
    mut hostend i32 = rest.len()
    slash i32 = rest.find("/")
    if slash >= 0:
        hostend = slash
        u.path = rest.substr(slash, rest.len() - slash)
    end
    colon i32 = rest.find(":")
    if colon >= 0:
        if colon < hostend:
            u.host = rest.substr(0, colon)
            u.port = rest.substr(colon + 1, hostend - colon - 1).to_int()
        else:
            u.host = rest.substr(0, hostend)
        end
    else:
        u.host = rest.substr(0, hostend)
    end
    ret u
end
@en "option"
@fa "اختیاری"
package option

extern "C":
    func salam_alloc(size u64) void*
    func salam_free(ptr void*)
    func salam_panic(msg str)
end

@en "Option"
@fa "اختیاری"
pub struct Option<T>:
    value T
    present bool
end

@en "Some"
@fa "یک‌مقدار"
pub func Some<T>(x T) Option<T>:
    ret Option { value = x, present = true }
end

@en "None"
@fa "هیچ‌مقدار"
pub func None<T>() Option<T>:
    nb u64 = sizeof(T)
    p void* = salam_alloc(nb)
    mut b i8* = p as i8*
    ni i32 = nb as i32
    mut i i32 = 0
    while i < ni:
        b[i] = 0 as i8
        i = i + 1
    end
    mut vp T* = p as T*
    v T = vp[0]
    salam_free(p)
    ret Option { value = v, present = false }
end

@en "IsSome"
@fa "دارد"
pub func IsSome<T>(o Option<T>) bool:
    ret o.present
end

@en "IsNone"
@fa "ندارد"
pub func IsNone<T>(o Option<T>) bool:
    ret o.present == false
end

@en "UnwrapOr"
@fa "یابرگردان"
pub func UnwrapOr<T>(o Option<T>, fallback T) T:
    if o.present:
        ret o.value
    end
    ret fallback
end

@en "Unwrap"
@fa "بازکن"
pub func Unwrap<T>(o Option<T>) T:
    if o.present == false:
        salam_panic("called Unwrap on a None value")
    end
    ret o.value
end

@en "Expect"
@fa "انتظار"
pub func Expect<T>(o Option<T>, msg str) T:
    if o.present == false:
        salam_panic(msg)
    end
    ret o.value
end
@en "os"
@fa "سیستم‌عامل"
package os
extern "C":
    func salam_open(path str, mode str) File*
    func strdup(s str) str
    func getenv(name str) void*
    func exit(code i32)
    func abort()
    func remove(path str) i32
    func rename(old str, new_path str) i32
    func fopen(path str, mode str) void*
    func fseek(fp void*, off i32, whence i32) i32
    func ftell(fp void*) i32
    func fclose(fp void*) i32
    func salam_alloc(size u64) void*
    func salam_free(ptr void*)
end
@if SALAM_OS_WINDOWS
extern "C":
    func _mkdir(path str) i32
    func _rmdir(path str) i32
    func _chdir(path str) i32
    func GetCurrentDirectoryA(sz i32, buf void*) i32
    func GetFileAttributesA(path str) i32
end

func _os_mkdir(path str) i32: if _mkdir(path) == 0: ret 0 end ret -1 end
func _os_rmdir(path str) i32: if _rmdir(path) == 0: ret 0 end ret -1 end
func _os_chdir(path str) i32: if _chdir(path) == 0: ret 0 end ret -1 end
func _os_cwd() str:
    buf void* = salam_alloc(2048 as u64)
    n i32 = GetCurrentDirectoryA(2048, buf)
    mut s str = ""
    if n > 0: s = strdup(buf as str) end
    salam_free(buf)
    ret s
end

func _os_exists(path str) bool:
    ret GetFileAttributesA(path) != -1
end

func _os_is_dir(path str) bool:
    attr i32 = GetFileAttributesA(path)
    if attr == -1: ret false end
    ret (attr / 16) % 2 == 1
end
@else
extern "C":
    func mkdir(path str, mode i32) i32
    func rmdir(path str) i32
    func chdir(path str) i32
    func access(path str, mode i32) i32
    func getcwd(buf void*, sz i32) void*
    func opendir(path str) void*
    func closedir(d void*) i32
end

func _os_mkdir(path str) i32: if mkdir(path, 511) == 0: ret 0 end ret -1 end
func _os_rmdir(path str) i32: if rmdir(path) == 0: ret 0 end ret -1 end
func _os_chdir(path str) i32: if chdir(path) == 0: ret 0 end ret -1 end
func _os_cwd() str:
    buf void* = salam_alloc(2048 as u64)
    r void* = getcwd(buf, 2048)
    mut s str = ""
    if r != null: s = strdup(r as str) end
    salam_free(buf)
    ret s
end

func _os_exists(path str) bool:
    ret access(path, 0) == 0
end

func _os_is_dir(path str) bool:
    d void* = opendir(path)
    if d == null: ret false end
    closedir(d)
    ret true
end

@end

