@en "IntWithLength"
@fa "عدد_با_طول"
pub func IntWithLength(digits i32) i64:
    if digits <= 1:
        ret rand_int64() % 10
    end
    mut lo i64 = 1
    mut k i32 = 1
    while k < digits:
        lo = lo * 10
        k = k + 1
    end
    hi i64 = lo * 10 - 1
    ret lo + rand_int64() % (hi - lo + 1)
end

