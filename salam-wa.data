end

@en "ColumnName"
@fa "نام_ستون"
pub func ColumnName(res Result, col i32) str:
    if res.handle == null:
        ret ""
    end
    fld void* = mysql_fetch_field_direct(res.handle, col as u32)
    if fld == null:
        ret ""
    end
    fptrs i64* = fld as i64*
    namep i64 = fptrs[0]
    if namep == 0:
        ret ""
    end
    ret strdup(namep as void* as str)
end

func _cell(res Result, col i32) i64:
    if res.row == null:
        ret 0
    end
    ptrs i64* = res.row as i64*
    ret ptrs[col]
end

@en "Text"
@fa "متن"
pub func Text(res Result, col i32) str:
    cell i64 = _cell(res, col)
    if cell == 0:
        ret ""
    end
    ret strdup(cell as void* as str)
end

@en "Int"
@fa "عدد_صحیح"
pub func Int(res Result, col i32) i32:
    ret Int64(res, col) as i32
end

@en "Int64"
@fa "عدد_صحیح۶۴"
pub func Int64(res Result, col i32) i64:
    cell i64 = _cell(res, col)
    if cell == 0:
        ret 0
    end
    s str = cell as void* as str
    ret _parse_i64(s)
end

@en "Float"
@fa "عدد_اعشار"
pub func Float(res Result, col i32) f64:
    cell i64 = _cell(res, col)
    if cell == 0:
        ret 0.0
    end
    s str = cell as void* as str
    ret s.to_float()
end

@en "IsNull"
@fa "خالی_است"
pub func IsNull(res Result, col i32) bool:
    ret _cell(res, col) == 0
end

@en "Escape"
@fa "اسکیپ"
pub func Escape(db Database, s str) str:
    if db.handle == null:
        ret s
    end
    n i32 = s.len()
    buf void* = mem.Allocate(((n * 2) + 1) as u64)
    if buf == null:
        ret s
    end
    mysql_real_escape_string(db.handle, buf, s, n as u64)
    out str = strdup(buf as str)
    mem.Free(buf)
    ret out
end

@en "QueryInt"
@fa "پرسمان_عدد"
pub func QueryInt(db Database, sql str) i32:
    mut res Result = Query(db, sql)
    mut out i32 = 0
    if Next(res):
        out = Int(res, 0)
    end
    Finish(res)
    ret out
end

@en "QueryText"
@fa "پرسمان_متن"
pub func QueryText(db Database, sql str) str:
    mut res Result = Query(db, sql)
    mut out str = ""
    if Next(res):
        out = Text(res, 0)
    end
    Finish(res)
    ret out
end
