    mut keys i64* = _m_keys(m)
    mut vals i64* = _m_vals(m)
    st[i] = 1
    keys[i] = key
    vals[i] = val
    _m_set_count(m, _m_count(m) + 1)
end

func _m_grow(m void*):
    oc i64 = _m_cap(m)
    ost i32* = _m_state(m)
    okeys i64* = _m_keys(m)
    ovals i64* = _m_vals(m)
    ncap i64 = oc * 2
    _m_set_cap(m, ncap)
    _m_set_count(m, 0)
    _m_set_state(m, mem.AllocateZeroed((ncap * 4) as u64))
    _m_set_keys(m, mem.AllocateZeroed((ncap * 8) as u64))
