@en "StringBuilder"
@fa "سازنده_رشته"
pub struct StringBuilder:
    data void* = null
    _len i64 = 0
    _cap i64 = 0
end

@en "NewBuilder"
@fa "سازنده"
pub func NewBuilder() StringBuilder:
    ret StringBuilder { data = null, _len = 0, _cap = 0 }
end

func _buf_ensure(b & StringBuilder, need i64):
    if need + 1 <= b._cap: ret end
    mut c i64 = b._cap
    if c == 0: c = 64 end
    while c < need + 1: c = c * 2 end
    b.data = mem.Reallocate(b.data, c as u64)
    b._cap = c
end

@en "BufAppend"
@fa "افزودن_به_بافر"
pub func BufAppend(b & StringBuilder, s str):
    n i64 = s.len() as i64
    if n <= 0: ret end
    _buf_ensure(b, b._len + n)
    dst void* = ((b.data as i64) + b._len) as void*
    mem.Copy(dst, s as void*, n as u64)
    b._len = b._len + n
end

@en "BufAppendChar"
@fa "افزودن_نویسه_به_بافر"
pub func BufAppendChar(b & StringBuilder, code i32):
    _buf_ensure(b, b._len + 1)
    mut p i8* = b.data as i8*
    p[b._len as i32] = code as i8
    b._len = b._len + 1
end

@en "BufLen"
@fa "طول_بافر"
pub func BufLen(b & StringBuilder) i64: ret b._len end

@en "BufIsEmpty"
@fa "بافر_خالی_است"
pub func BufIsEmpty(b & StringBuilder) bool: ret b._len == 0 end

@en "BufStr"
@fa "رشته_بافر"
pub func BufStr(b & StringBuilder) str:
    if b.data == null: ret "" end
    mut p i8* = b.data as i8*
    p[b._len as i32] = 0 as i8
    ret strdup(b.data as str)
end

@en "BufReset"
@fa "بازنشانی_بافر"
pub func BufReset(b & StringBuilder): b._len = 0 end

@en "BufFree"
@fa "آزادسازی_بافر"
pub func BufFree(b & StringBuilder):
    if b.data != null: mem.Free(b.data) end
    b.data = null
    b._len = 0
    b._cap = 0
end
@en "sync"
@fa "همگام‌سازی"
package sync
@if SALAM_OS_UNIX
@ifndef SALAM_CC_TCC
link "pthread"
@end

@end
extern "C":
    func salam_alloc(size u64) void*
    func salam_free(ptr void*)
end
@if SALAM_OS_WINDOWS
extern "C":
    func CreateMutexA(attr void*, init_owned i32, name void*) void*
    func WaitForSingleObject(handle void*, milliseconds i32) i32
    func ReleaseMutex(handle void*) i32
    func CloseHandle(handle void*) i32
    func Sleep(ms i32)
end

func mutex_new() void*:
    ret CreateMutexA(null, 0, null)
end

func mutex_lock(h void*) i32:
    if WaitForSingleObject(h, 0 - 1) == 0: ret 0 end
    ret 0 - 1
end

func mutex_unlock(h void*) i32:
    if ReleaseMutex(h) != 0: ret 0 end
    ret 0 - 1
end

func mutex_free(h void*):
    CloseHandle(h)
end

func _sync_sleep_ms(ms i32): Sleep(ms) end
@else
extern "C":
    func pthread_mutex_init(mutex void*, attr void*) i32
    func pthread_mutex_lock(mutex void*) i32
    func pthread_mutex_unlock(mutex void*) i32
    func pthread_mutex_destroy(mutex void*) i32
    func usleep(us i32) i32
end

func mutex_new() void*:
    m void* = salam_alloc(80 as u64)
    pthread_mutex_init(m, null)
    ret m
end

func mutex_lock(h void*) i32:
    if pthread_mutex_lock(h) == 0: ret 0 end
    ret 0 - 1
end

func mutex_unlock(h void*) i32:
    if pthread_mutex_unlock(h) == 0: ret 0 end
    ret 0 - 1
end

func mutex_free(h void*):
    pthread_mutex_destroy(h)
    salam_free(h)
end

func _sync_sleep_ms(ms i32):
    if ms > 0: usleep(ms * 1000) end
end

@end

@en "Mutex"
@fa "قفل"
pub struct Mutex:
    handle void* = null
end

@en "NewMutex"
@fa "قفل_جدید"
pub func NewMutex() Mutex: ret Mutex { handle = mutex_new() } end

@en "Lock"
@fa "قفل_کردن"
pub func Lock(m Mutex) i32: ret mutex_lock(m.handle) end

@en "Unlock"
@fa "باز_کردن_قفل"
pub func Unlock(m Mutex) i32: ret mutex_unlock(m.handle) end

@en "Destroy"
@fa "نابودسازی"
pub func Destroy(m Mutex): mutex_free(m.handle) end

@en "WaitGroup"
@fa "گروه_انتظار"
pub struct WaitGroup:
    counter i64* = null
    mu void* = null
end

@en "NewWaitGroup"
@fa "گروه_انتظار_جدید"
pub func NewWaitGroup() WaitGroup:
    mut c i64* = salam_alloc(8 as u64) as i64*
    c[0] = 0
    ret WaitGroup { counter = c, mu = mutex_new() }
end

@en "Add"
@fa "افزودن"
pub func Add(wg WaitGroup, delta i64):
    mut c i64* = wg.counter
    mutex_lock(wg.mu)
    c[0] = c[0] + delta
    mutex_unlock(wg.mu)
end

@en "Done"
@fa "اتمام"
pub func Done(wg WaitGroup):
    mut c i64* = wg.counter
    mutex_lock(wg.mu)
    c[0] = c[0] - 1
    mutex_unlock(wg.mu)
end

@en "Wait"
@fa "انتظار"
pub func Wait(wg WaitGroup):
    while wg.counter[0] > 0:
        _sync_sleep_ms(1)
    end
end

@en "DestroyWaitGroup"
@fa "نابودسازی_گروه_انتظار"
pub func DestroyWaitGroup(wg WaitGroup):
    salam_free(wg.counter as void*)
    mutex_free(wg.mu)
end
