    ret DateTime { epoch = seconds }
end

@en "Epoch"
@fa "مبدا"
pub func Epoch(dt DateTime) i64:
    ret dt.epoch
end

@en "Year"
@fa "سال"
pub func Year(epoch i64) i32: ret time_year(epoch) end

@en "Month"
@fa "ماه"
pub func Month(epoch i64) i32: ret time_month(epoch) end

@en "Day"
@fa "روز"
pub func Day(epoch i64) i32: ret time_day(epoch) end

@en "Hour"
@fa "ساعت"
pub func Hour(epoch i64) i32: ret time_hour(epoch) end

@en "Minute"
@fa "دقیقه"
pub func Minute(epoch i64) i32: ret time_minute(epoch) end

@en "Second"
@fa "ثانیه"
pub func Second(epoch i64) i32: ret time_second(epoch) end

@en "Format"
@fa "قالب‌بندی"
pub func Format(epoch i64) str:
    y i32 = time_year(epoch)
    mo i32 = time_month(epoch)
    d i32 = time_day(epoch)
    h i32 = time_hour(epoch)
    mi i32 = time_minute(epoch)
    s i32 = time_second(epoch)
    date str = itos(y as i64).concat("-").concat(pad2(mo)).concat("-").concat(pad2(d))
    tstr str = pad2(h).concat(":").concat(pad2(mi)).concat(":").concat(pad2(s))
    ret date.concat(" ").concat(tstr)
end

