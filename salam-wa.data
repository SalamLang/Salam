@en "Trunc"
@fa "بریدن"
pub func Trunc(x f64) f64:
    if x < 0.0: ret ceil(x) end
    ret floor(x)
end
@en "mem"
@fa "حافظه"
package mem
@if SALAM_MEM_DEBUG
mut _md_allocs i64 = 0
mut _md_frees i64 = 0
mut _md_live i64 = 0
mut _md_peak i64 = 0
extern "C":
    func malloc(size u64) void*
    func realloc(ptr void*, size u64) void*
    func free(ptr void*)
    func salam_alloc(size u64) void*:
        p void* = malloc(size + (8 as u64))
        if p == null: ret null end
        mut hdr i64* = p as i64*
        hdr[0] = size as i64
        _md_allocs = _md_allocs + 1
        _md_live = _md_live + (size as i64)
        if _md_live > _md_peak: _md_peak = _md_live end
        ret ((p as i64) + 8) as void*
    end
    func salam_realloc(ptr void*, size u64) void*:
        if ptr == null: ret salam_alloc(size) end
        orig void* = ((ptr as i64) - 8) as void*
        ohdr i64* = orig as i64*
        old_sz i64 = ohdr[0]
        p void* = realloc(orig, size + (8 as u64))
        if p == null: ret null end
        mut hdr i64* = p as i64*
        hdr[0] = size as i64
        if _md_live > old_sz:
            _md_live = _md_live - old_sz + (size as i64)
        else:
            _md_live = size as i64
        end
        if _md_live > _md_peak: _md_peak = _md_live end
        ret ((p as i64) + 8) as void*
    end
    func salam_free(ptr void*):
        if ptr == null: ret end
        orig void* = ((ptr as i64) - 8) as void*
        hdr i64* = orig as i64*
        sz i64 = hdr[0]
        if _md_live >= sz: _md_live = _md_live - sz end
        _md_frees = _md_frees + 1
        free(orig)
    end
end

@en "AllocCount"
@fa "تعداد_تخصیص"
pub func AllocCount() i64: ret _md_allocs end

@en "FreeCount"
@fa "تعداد_آزادسازی"
pub func FreeCount() i64: ret _md_frees end

@en "LiveBytes"
@fa "بایت‌های_زنده"
pub func LiveBytes() i64: ret _md_live end

@en "PeakBytes"
@fa "بیشینه_بایت"
pub func PeakBytes() i64: ret _md_peak end

@en "IsMemDebug"
@fa "در_حالت_اشکال‌زدایی_حافظه"
pub func IsMemDebug() bool: ret true end
@else
extern "C":
    func malloc(size u64) void*
    func realloc(ptr void*, size u64) void*
    func free(ptr void*)
    func salam_alloc(size u64) void*:
        ret malloc(size)
    end
    func salam_realloc(ptr void*, size u64) void*:
        ret realloc(ptr, size)
    end
    func salam_free(ptr void*):
        free(ptr)
    end
end

@en "AllocCount"
@fa "تعداد_تخصیص"
pub func AllocCount() i64: ret 0 end

@en "FreeCount"
@fa "تعداد_آزادسازی"
pub func FreeCount() i64: ret 0 end

@en "LiveBytes"
@fa "بایت‌های_زنده"
pub func LiveBytes() i64: ret 0 end

@en "PeakBytes"
@fa "بیشینه_بایت"
pub func PeakBytes() i64: ret 0 end

@en "IsMemDebug"
@fa "در_حالت_اشکال‌زدایی_حافظه"
pub func IsMemDebug() bool: ret false end

@end
@if SALAM_ASAN
@en "IsAsanActive"
@fa "ازن_فعال_است"
pub func IsAsanActive() bool: ret true end
@else
@en "IsAsanActive"
@fa "ازن_فعال_است"
pub func IsAsanActive() bool: ret false end

@end
extern "C":
    func memset(ptr void*, value i32, n u64) void*
    func memcpy(dst void*, src void*, n u64) void*
end

@en "Allocate"
@fa "تخصیص"
pub func Allocate(size u64) void*: ret salam_alloc(size) end

@en "Reallocate"
@fa "بازتخصیص"
pub func Reallocate(ptr void*, size u64) void*: ret salam_realloc(ptr, size) end

@en "Free"
@fa "آزادسازی"
pub func Free(ptr void*): salam_free(ptr) end

@en "Set"
@fa "تنظیم"
pub func Set(ptr void*, value i32, n u64):
    memset(ptr, value, n)
end

@en "Copy"
@fa "کپی"
pub func Copy(dst void*, src void*, n u64):
    memcpy(dst, src, n)
end

@en "AllocateZeroed"
@fa "تخصیص_صفرشده"
pub func AllocateZeroed(size u64) void*:
    mut p void* = salam_alloc(size)
    memset(p, 0, size)
    ret p
end

@en "AllocateArray"
@fa "تخصیص_آرایه"
pub func AllocateArray(count u64, size u64) void*:
    ret AllocateZeroed(count * size)
end

@en "MemDebugActive"
@fa "اشکال‌زدایی_حافظه_فعال"
pub func MemDebugActive() bool:
    ret IsMemDebug() || IsAsanActive()
end

func _itos(n i64) str:
    if n == 0: ret "0" end
    mut v i64 = n
    mut r str = ""
    while v > 0:
        r = char_from_code((v % 10) as i32 + 48).concat(r)
        v = v / 10
    end
    ret r
end

@en "CheckLeaks"
@fa "بررسی_نشتی"
pub func CheckLeaks():
    if IsAsanActive():
        !__ "[salam memcheck] ASAN is active - leak report will appear at process exit."
    else IsMemDebug():
        a i64 = AllocCount()
        f i64 = FreeCount()
        lb i64 = LiveBytes()
        pb i64 = PeakBytes()
        !_ "[salam memcheck] allocs="
        !_ _itos(a)
        !_ "  frees="
        !_ _itos(f)
        !_ "  live_bytes="
        !_ _itos(lb)
        !_ "  peak_bytes="
        !__ _itos(pb)
        if lb > 0:
            !_ "[salam memcheck] WARNING: "
            !_ _itos(lb)
            !__ " bytes still allocated (possible leak)"
        end
    end
end

extern "C":
    func salam_memcpy(dst void*, src void*, n u64) void*:
        mut d i8* = dst as i8*
        s i8* = src as i8*
        ni i32 = n as i32
        mut i i32 = 0
        while i < ni:
            d[i] = s[i]
            i = i + 1
        end
        ret dst
    end
    func salam_memmove(dst void*, src void*, n u64) void*:
        mut d i8* = dst as i8*
        s i8* = src as i8*
        ni i32 = n as i32
        if (dst as i64) < (src as i64):
            mut i i32 = 0
            while i < ni:
                d[i] = s[i]
                i = i + 1
            end
        else:
            mut i i32 = ni - 1
            while i >= 0:
                d[i] = s[i]
                i = i - 1
            end
        end
        ret dst
    end
end
@en "net"
@fa "شبکه"
package net
import "mem"
@if SALAM_OS_WINDOWS
link "ws2_32"
@end
extern "C":
    func gethostbyname(name str) void*
    func memset(ptr void*, val i32, n u64) void*
    func htons(n i32) i32
    func inet_ntoa(addr i32) str
    func strdup(s str) str
end

func _net_hostaddr(he void*) i32:
    listp i64* = (he as i64 + 24) as i64*
    list i64 = listp[0]
    if list == 0: ret 0 end
    addrp i64* = list as i64*
    addr i64 = addrp[0]
    if addr == 0: ret 0 end
    bytes i32* = addr as i32*
    ret bytes[0]
end

func _n2s(n i32) str:
    if n == 0: ret "0" end
    mut v i32 = n
    mut r str = ""
    while v > 0:
        r = char_from_code(v % 10 + 48).concat(r)
        v = v / 10
    end
    ret r
end

func _net_resolve_addr(host str) i32:
    he void* = gethostbyname(host)
    if he == null: ret 0 end
    ret _net_hostaddr(he)
end

func _net_make_sa(h_addr i32, port i32) void*:
    sa void* = mem.Allocate(16 as u64)
    memset(sa, 0, 16 as u64)
    mut sa32 i32* = sa as i32*
    port_n i32 = htons(port)
    packed i64 = (port_n as i64) * 65536 + 2
    sa32[0] = packed as i32
    sa32[1] = h_addr
    ret sa
end
@if SALAM_OS_WINDOWS
extern "C":
    func WSAStartup(version i32, wsa void*) i32
    func socket(family i32, socktype i32, proto i32) i64
    func connect(s i64, addr void*, addrlen i32) i32
    func bind(s i64, addr void*, addrlen i32) i32
    func listen(s i64, backlog i32) i32
    func accept(s i64, addr void*, addrlen void*) i64
    func send(s i64, buf void*, len i32, flags i32) i32
    func recv(s i64, buf void*, len i32, flags i32) i32
    func closesocket(s i64) i32
    func setsockopt(s i64, level i32, optname i32, optval void*, optlen i32) i32
end
mut _g_wsa_init i32 = 0
func _net_init():
    if _g_wsa_init == 0:
        wsa void* = mem.Allocate(512 as u64)
        WSAStartup(514, wsa)
        mem.Free(wsa)
        _g_wsa_init = 1
    end
end

func net_connect(host str, port i32) i64:
    _net_init()
    h_addr i32 = _net_resolve_addr(host)
    if h_addr == 0: ret 0 - 1 end
    sa void* = _net_make_sa(h_addr, port)
    s i64 = socket(2, 1, 0)
    if s == 0 - 1:
        mem.Free(sa)
        ret 0 - 1
    end
    r i32 = connect(s, sa, 16)
    mem.Free(sa)
    if r != 0:
        closesocket(s)
        ret 0 - 1
    end
    ret s
end

func net_listen(port i32) i64:
    _net_init()
    s i64 = socket(2, 1, 0)
    if s == 0 - 1: ret 0 - 1 end
    opt void* = mem.Allocate(4 as u64)
    mut opt32 i32* = opt as i32*
    opt32[0] = 1
    setsockopt(s, 65535, 0 - 5, opt, 4)
    mem.Free(opt)
    sa void* = mem.Allocate(16 as u64)
    memset(sa, 0, 16 as u64)
    mut sa32 i32* = sa as i32*
    port_n i32 = htons(port)
    packed i64 = (port_n as i64) * 65536 + 2
    sa32[0] = packed as i32
    r1 i32 = bind(s, sa, 16)
    mem.Free(sa)
    if r1 != 0:
        closesocket(s)
        ret 0 - 1
    end
    r2 i32 = listen(s, 16)
    if r2 != 0:
        closesocket(s)
        ret 0 - 1
    end
    ret s
end

func net_accept(fd i64) i64:
    c i64 = accept(fd, null, null)
    if c == 0 - 1: ret 0 - 1 end
    ret c
end

func net_send(fd i64, data str) i32:
    ret send(fd, data as void*, len(data) as i32, 0)
end

func net_send_bytes(fd i64, ptr void*, n i32) i32:
    mut sent i32 = 0
    while sent < n:
        r i32 = send(fd, (ptr as i64 + sent) as void*, n - sent, 0)
        if r <= 0:
            ret sent
        end
        sent = sent + r
    end
    ret sent
end

func net_recv(fd i64, max i32) str:
    mut m i32 = max
    if m <= 0: m = 4096 end
    buf void* = mem.Allocate((m + 1) as u64)
    memset(buf, 0, (m + 1) as u64)
    recv(fd, buf, m, 0)
    s str = strdup(buf as str)
    mem.Free(buf)
    ret s
end

func net_close(fd i64):
    if fd >= 0:
        closesocket(fd)
    end
end

func net_resolve(host str) str:
    _net_init()
    addr i32 = _net_resolve_addr(host)
    if addr == 0: ret "" end
    ret strdup(inet_ntoa(addr))
end
@else
extern "C":
    func socket(family i32, socktype i32, proto i32) i32
    func connect(s i32, addr void*, addrlen i32) i32
    func bind(s i32, addr void*, addrlen i32) i32
    func listen(s i32, backlog i32) i32
    func accept(s i32, addr void*, addrlen void*) i32
    func send(s i32, buf void*, len i32, flags i32) i32
    func recv(s i32, buf void*, len i32, flags i32) i32
    func close(s i32) i32
    func setsockopt(s i32, level i32, optname i32, optval void*, optlen i32) i32
end

func _net_init(): ret end
func net_connect(host str, port i32) i64:
    h_addr i32 = _net_resolve_addr(host)
    if h_addr == 0: ret 0 - 1 end
    sa void* = _net_make_sa(h_addr, port)
    s i32 = socket(2, 1, 0)
    if s == 0 - 1:
        mem.Free(sa)
        ret 0 - 1
    end
    r i32 = connect(s, sa, 16)
    mem.Free(sa)
    if r != 0:
        close(s)
        ret 0 - 1
    end
    ret s as i64
end

func net_listen(port i32) i64:
    s i32 = socket(2, 1, 0)
    if s == 0 - 1: ret 0 - 1 end
    opt void* = mem.Allocate(4 as u64)
    mut opt32 i32* = opt as i32*
    opt32[0] = 1
    setsockopt(s, 1, 2, opt, 4)
    mem.Free(opt)
    sa void* = mem.Allocate(16 as u64)
    memset(sa, 0, 16 as u64)
    mut sa32 i32* = sa as i32*
    port_n i32 = htons(port)
    packed i64 = (port_n as i64) * 65536 + 2
    sa32[0] = packed as i32
    r1 i32 = bind(s, sa, 16)
    mem.Free(sa)
    if r1 != 0:
        close(s)
        ret 0 - 1
    end
    r2 i32 = listen(s, 16)
    if r2 != 0:
        close(s)
        ret 0 - 1
    end
    ret s as i64
end

func net_accept(fd i64) i64:
    c i32 = accept(fd as i32, null, null)
    if c == 0 - 1: ret 0 - 1 end
    ret c as i64
end

func net_send(fd i64, data str) i32:
    ret send(fd as i32, data as void*, len(data) as i32, 0)
end

func net_send_bytes(fd i64, ptr void*, n i32) i32:
    mut sent i32 = 0
    while sent < n:
        r i32 = send(fd as i32, (ptr as i64 + sent) as void*, n - sent, 0)
        if r <= 0:
            ret sent
        end
        sent = sent + r
    end
    ret sent
end

func net_recv(fd i64, max i32) str:
    mut m i32 = max
    if m <= 0: m = 4096 end
    buf void* = mem.Allocate((m + 1) as u64)
    memset(buf, 0, (m + 1) as u64)
    recv(fd as i32, buf, m, 0)
    s str = strdup(buf as str)
    mem.Free(buf)
    ret s
end

func net_close(fd i64):
    if fd >= 0:
        close(fd as i32)
    end
end

func net_resolve(host str) str:
    addr i32 = _net_resolve_addr(host)
    if addr == 0: ret "" end
    ret strdup(inet_ntoa(addr))
end

@end

@en "Socket"
@fa "سوکت"
pub struct Socket:
    fd i64 = 0 - 1
end

func ok(s Socket) bool: ret s.fd >= 0 end

@en "SocketFromFd"
@fa "سوکت_از_توصیف‌گر"
pub func SocketFromFd(fd i64) Socket:
    ret Socket { fd = fd }
end

@en "Connect"
@fa "اتصال"
pub func Connect(host str, port i32) Socket:
    ret Socket { fd = net_connect(host, port) }
end

@en "Dial"
