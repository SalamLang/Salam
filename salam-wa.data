pub struct Database:
    handle void* = null
end

@en "Result"
@fa "نتیجه"
pub struct Result:
    handle void* = null
    row void* = null
end

@en "Available"
@fa "در_دسترس"
pub func Available() bool:
    ret true
end

@en "ClientVersion"
@fa "نسخه_کلاینت"
pub func ClientVersion() str:
    ret strdup(mysql_get_client_info())
end

@en "ServerVersion"
@fa "نسخه_سرور"
pub func ServerVersion(db Database) str:
    if db.handle == null:
        ret ""
    end
    ret strdup(mysql_get_server_info(db.handle))
end

@en "Open"
@fa "بازکردن"
pub func Open(host str, user str, pass str, dbname str, port i32) Database:
    ret OpenFull(host, user, pass, dbname, port, "", 0 as u64)
end

@en "OpenFull"
@fa "بازکردن_کامل"
pub func OpenFull(host str, user str, pass str, dbname str, port i32, socket str, flags u64) Database:
    conn void* = mysql_init(null)
    if conn == null:
        ret Database { handle = null }
    end
    mut sock void* = null
    if socket != "":
        sock = socket as void*
    end
    res void* = mysql_real_connect(conn, host, user, pass, dbname, port as u32, sock, flags)
    if res == null:
        mysql_close(conn)
        ret Database { handle = null }
    end
    ret Database { handle = conn }
end

@en "Ok"
@fa "معتبر"
pub func Ok(db Database) bool:
    ret db.handle != null
end

@en "Close"
@fa "بستن"
pub func Close(db Database):
    if db.handle != null:
        mysql_close(db.handle)
    end
end

