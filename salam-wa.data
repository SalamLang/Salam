@en "ColumnType"
@fa "نوع_ستون"
pub func ColumnType(rows Rows, col i32) i32:
    if rows.handle == null:
        ret 5
    end
    ret sqlite3_column_type(rows.handle, col)
end

@en "IsNull"
@fa "خالی_است"
pub func IsNull(rows Rows, col i32) bool:
    ret ColumnType(rows, col) == 5
end

@en "QueryInt"
@fa "پرسمان_عدد"
pub func QueryInt(db Database, sql str) i32:
    rows Rows = Prepare(db, sql)
    mut out i32 = 0
    if rows.handle != null:
        if sqlite3_step(rows.handle) == 100:
            out = sqlite3_column_int(rows.handle, 0)
        end
        sqlite3_finalize(rows.handle)
    end
    ret out
end

@en "QueryText"
@fa "پرسمان_متن"
pub func QueryText(db Database, sql str) str:
    rows Rows = Prepare(db, sql)
    mut out str = ""
    if rows.handle != null:
        if sqlite3_step(rows.handle) == 100:
            mut p void* = sqlite3_column_text(rows.handle, 0)
            if p != null:
                out = strdup(p as str)
            end
        end
        sqlite3_finalize(rows.handle)
    end
    ret out
end
@en "encoding"
@fa "کدگذاری"
package encoding
func b64val(c str) i32:
    code i32 = char_code(c)
    if code >= 65 && code <= 90: ret code - 65 end
    if code >= 97 && code <= 122: ret code - 71 end
    if code >= 48 && code <= 57: ret code + 4 end
    if code == 43: ret 62 end
    if code == 47: ret 63 end
    ret 0 - 1
end

@en "Base64Encode"
@fa "کدگذاری_شصت_و_چهار"
pub func Base64Encode(data str) str:
    alpha str = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    n i32 = data.len()
    mut result str = ""
    mut i i32 = 0
    while i < n:
        b0 i32 = char_code(data.substr(i, 1))
        mut b1 i32 = 0
        mut b2 i32 = 0
        if i + 1 < n: b1 = char_code(data.substr(i + 1, 1)) end
        if i + 2 < n: b2 = char_code(data.substr(i + 2, 1)) end
        result = result.concat(alpha.substr(b0 / 4, 1))
        result = result.concat(alpha.substr((b0 % 4) * 16 + b1 / 16, 1))
        if i + 1 < n:
            result = result.concat(alpha.substr((b1 % 16) * 4 + b2 / 64, 1))
        else:
            result = result.concat("=")
        end
        if i + 2 < n:
            result = result.concat(alpha.substr(b2 % 64, 1))
        else:
            result = result.concat("=")
        end
        i = i + 3
    end
    ret result
end

@en "Base64Decode"
@fa "کدگشایی_شصت_و_چهار"
pub func Base64Decode(s str) str:
    n i32 = s.len()
    mut result str = ""
    mut qi i32 = 0
    mut q0 i32 = 0
    mut q1 i32 = 0
    mut q2 i32 = 0
    mut q3 i32 = 0
    mut i i32 = 0
    while i < n:
        c str = s.substr(i, 1)
        code i32 = char_code(c)
        i = i + 1
        if code != 32 && code != 9 && code != 10 && code != 13:
            v i32 = b64val(c)
            if v >= 0:
                if qi == 0:
                    q0 = v
                    qi = 1
                else if qi == 1:
                    q1 = v
                    qi = 2
                else if qi == 2:
                    q2 = v
                    qi = 3
                else:
                    q3 = v
                    result = result.concat(char_from_code(q0 * 4 + q1 / 16))
                    result = result.concat(char_from_code((q1 % 16) * 16 + q2 / 4))
                    result = result.concat(char_from_code((q2 % 4) * 64 + q3))
                    qi = 0
                end
            end
        end
    end
    if qi >= 2:
        result = result.concat(char_from_code(q0 * 4 + q1 / 16))
    end
    if qi >= 3:
        result = result.concat(char_from_code((q1 % 16) * 16 + q2 / 4))
    end
    ret result
end

@en "HexEncode"
@fa "کدگذاری_شانزده"
pub func HexEncode(data str) str:
    digits str = "0123456789abcdef"
    l i32 = data.len()
    mut result str = ""
    mut i i32 = 0
    while i < l:
        b i32 = char_code(data.substr(i, 1))
        result = result.concat(digits.substr(b / 16, 1))
        result = result.concat(digits.substr(b % 16, 1))
        i = i + 1
    end
    ret result
end

func hexval(c str) i32:
    code i32 = char_code(c)
    if code >= 48 && code <= 57: ret code - 48 end
    if code >= 97 && code <= 102: ret code - 87 end
    if code >= 65 && code <= 70: ret code - 55 end
    ret 0 - 1
end

@en "HexDecode"
@fa "کدگشایی_شانزده"
pub func HexDecode(s str) str:
    l i32 = s.len()
    mut result str = ""
    mut i i32 = 0
    while i + 1 < l:
        hi i32 = hexval(s.substr(i, 1))
        lo i32 = hexval(s.substr(i + 1, 1))
        if hi < 0 || lo < 0:
            ret result
        end
        result = result.concat(char_from_code(hi * 16 + lo))
        i = i + 2
    end
    ret result
end
@en "fmt"
@fa "قالب‌بندی"
package fmt
import "str"
func int_str(i i64) str:
    if i == 0: ret "0" end
    mut n i64 = i
    mut result str = ""
    mut neg bool = false
    if n < 0:
        neg = true
        n = 0 - n
    end
    while n > 0:
        digit i32 = (n % 10) as i32
        result = char_from_code(digit + 48).concat(result)
        n = n / 10
    end
    if neg: ret "-".concat(result) end
    ret result
end

@en "Int"
@fa "عدد_صحیح"
pub func Int(i i64) str: ret int_str(i) end

@en "Float"
@fa "عدد_اعشار"
pub func Float(f f64) str: ret str.FromFloat(f) end

@en "Bool"
@fa "منطقی"
pub func Bool(b bool) str:
    if b:
        ret "true"
    end
    ret "false"
end

func rep_str(s str, n i32) str:
    mut result str = ""
    mut i i32 = 0
    while i < n:
        result = result.concat(s)
        i = i + 1
    end
    ret result
end

@en "Repeat"
@fa "تکرار"
pub func Repeat(s str, n i32) str: ret rep_str(s, n) end

@en "PadLeft"
@fa "پرکردن_چپ"
pub func PadLeft(s str, width i32) str:
    gap i32 = width - s.len()
    if gap <= 0:
        ret s
    end
    ret rep_str(" ", gap).concat(s)
end

@en "PadRight"
@fa "پرکردن_راست"
pub func PadRight(s str, width i32) str:
    gap i32 = width - s.len()
    if gap <= 0:
        ret s
    end
    ret s.concat(rep_str(" ", gap))
end

@en "Center"
@fa "وسط‌چین"
pub func Center(s str, width i32) str:
    gap i32 = width - s.len()
    if gap <= 0:
        ret s
    end
    left i32 = gap / 2
    ret rep_str(" ", left).concat(s).concat(rep_str(" ", gap - left))
end

@en "Sprintf"
@fa "قالب_رشته"
pub func Sprintf(tmpl str, args Vector<str>) str:
    parts Vector<str> = tmpl.split("{}")
    mut out str = parts.get(0)[0]
    mut i = 1
    while i < parts.len():
        if i - 1 < args.len():
            out = out.concat(args.get(i - 1)[0])
        end
        out = out.concat(parts.get(i)[0])
        i = i + 1
    end
    parts.free()
    ret out
end

@en "Fprintf"
@fa "قالب_نوشتن"
pub func Fprintf(f File*, tmpl str, args Vector<str>) i32:
    ret f.write(Sprintf(tmpl, args))
end

@en "Line"
@fa "خط"
pub func Line(a str, b str) str:
    ret a.concat(b)
end

@en "Pair"
@fa "زوج"
pub func Pair(key str, value str) str:
    ret key.concat(": ").concat(value)
end
@en "fs"
@fa "سیستم_پرونده"
package fs
import "mem"
func _strptr(s str) i64:
    v void* = s as void*
    ret v as i64
end
extern "C":
    func fopen(path str, mode str) void*
    func fclose(fp void*) i32
    func fread(ptr void*, size u64, nmemb u64, stream void*) u64
    func fwrite(ptr void*, size u64, nmemb u64, stream void*) u64
    func fgetc(stream void*) i32
    func fseek(fp void*, off i32, whence i32) i32
    func salam_open(path str, mode str) File*:
        fp void* = fopen(path, mode)
        if fp == null: ret null end
        ret fp as File*
    end
    func salam_file_read(f File*, size u64) str:
        if f == null: ret "" end
        fp void* = f as void*
        buf void* = mem.AllocateZeroed(size + (1 as u64))
        fread(buf, 1 as u64, size, fp)
        ret buf as str
    end
    func salam_file_readline(f File*) str:
        if f == null: ret "" end
        fp void* = f as void*
        mut out str = ""
        mut c i32 = fgetc(fp)
        while c != -1:
            if c == 10: ret out end
            out = out.concat(char_from_code(c))
            c = fgetc(fp)
        end
        ret out
    end
    func salam_file_write(f File*, data str) i32:
        if f == null: ret 0 - 1 end
        fp void* = f as void*
        n u64 = data.len() as u64
        w u64 = fwrite(data as void*, 1 as u64, n, fp)
        ret w as i32
    end
    func salam_file_close(f File*):
        if f == null: ret end
        fclose(f as void*)
    end
    func salam_file_seek(f File*, off i64, whence i32) i32:
        if f == null: ret 0 - 1 end
        fp void* = f as void*
        mut w i32 = 0

        if whence == 1: w = 1 end

        if whence == 2: w = 2 end

        if _fs_seek64(fp, off, w) == 0: ret 0 end
        ret 0 - 1
    end
end

@if SALAM_OS_WINDOWS
extern "C":
    func _fseeki64(fp void*, off i64, whence i32) i32
end

func _fs_seek64(fp void*, off i64, w i32) i32: ret _fseeki64(fp, off, w) end
@else
extern "C":
    func fseeko(fp void*, off i64, whence i32) i32
end

func _fs_seek64(fp void*, off i64, w i32) i32: ret fseeko(fp, off, w) end

@end
func _ld_push(arr void*, n i32, cap_box void*, name str) void*:
    mut cap i32* = cap_box as i32*
    mut a void* = arr
    if n >= cap[0]:
        if cap[0] == 0: cap[0] = 8 else:
            cap[0] = cap[0] * 2
        end
        a = mem.Reallocate(a, (cap[0] * 8) as u64)
    end
    mut a64 i64* = a as i64*
    a64[n] = _strptr(name.substr(0, name.len()))
    ret a
end

func _ld_skip(name str) bool:
    if name == ".": ret true end
    if name == "..": ret true end
    ret false
end
@if SALAM_OS_WINDOWS
extern "C":
    func FindFirstFileA(pat str, data void*) void*
    func FindNextFileA(h void*, data void*) i32
    func FindClose(h void*) i32
end
extern "C":
    func salam_os_listdir(path str, out_count void*) void*:
        mut oc i32* = out_count as i32*
        fd void* = mem.Allocate(320 as u64)
        h void* = FindFirstFileA(path.concat("/*"), fd)
        mut arr void* = null
        mut n i32 = 0
        cap_box void* = mem.AllocateZeroed(4 as u64)
        if (h as i64) != (0 - 1):
            mut more i32 = 1
            while more != 0:
                np void* = ((fd as i64) + 44) as void*
                nm str = np as str
                if _ld_skip(nm) == false:
                    arr = _ld_push(arr, n, cap_box, nm)
                    n = n + 1
                end
                more = FindNextFileA(h, fd)
            end
            FindClose(h)
        end
        mem.Free(fd)
        mem.Free(cap_box)
        if arr == null: arr = mem.Allocate(8 as u64) end
        oc[0] = n
        ret arr
    end
end
@else
extern "C":
    func opendir(path str) void*
    func readdir(d void*) void*
    func closedir(d void*) i32
end
@if SALAM_OS_MAC
func _dname_off() i64: ret 21 end
@elif SALAM_OS_BSD
func _dname_off() i64: ret 24 end
@else
func _dname_off() i64: ret 19 end

@end
extern "C":
    func salam_os_listdir(path str, out_count void*) void*:
        mut oc i32* = out_count as i32*
        mut arr void* = null
        mut n i32 = 0
        cap_box void* = mem.AllocateZeroed(4 as u64)
        off i64 = _dname_off()
        d void* = opendir(path)
        if d != null:
            mut e void* = readdir(d)
            while e != null:
                np void* = ((e as i64) + off) as void*
                nm str = np as str
                if _ld_skip(nm) == false:
                    arr = _ld_push(arr, n, cap_box, nm)
                    n = n + 1
                end
                e = readdir(d)
            end
            closedir(d)
        end
        mem.Free(cap_box)
        if arr == null: arr = mem.Allocate(8 as u64) end
        oc[0] = n
        ret arr
    end
end

@end
@en "http"
@fa "اچ_تی_تی_پی"
package http
import "mem"
@if SALAM_OS_WINDOWS
link "winhttp"
@end

@en "Response"
@fa "پاسخ"
pub struct Response:
    status i32 = 0
    body str = ""
    head str = ""
end
mut _g_http_status i32 = 0
mut _g_http_headers str = ""
@if SALAM_OS_WINDOWS
extern "C":
    func MultiByteToWideChar(codepage i32, flags i32, src str, srclen i32, dst void*, dstlen i32) i32
    func WideCharToMultiByte(codepage i32, flags i32, src void*, srclen i32, dst void*, dstlen i32, def void*, used void*) i32
    func WinHttpOpen(agent void*, access_type i32, proxy void*, bypass void*, flags i32) void*
    func WinHttpConnect(session void*, host void*, port i32, flags i32) void*
    func WinHttpOpenRequest(conn void*, verb void*, path void*, ver void*, ref void*, types void*, flags i32) void*
    func WinHttpSendRequest(req void*, headers void*, hlen i32, body str, blen i32, total i32, ctx i64) i32
    func WinHttpReceiveResponse(req void*, reserved void*) i32
    func WinHttpQueryHeaders(req void*, info i32, name void*, buf void*, buflen void*, index void*) i32
    func WinHttpReadData(req void*, buf void*, toread i32, read void*) i32
    func WinHttpAddRequestHeaders(req void*, headers void*, hlen i32, modifiers i32) i32
    func WinHttpCloseHandle(handle void*) i32
end

func _make_str(buf void*, len i32) str:
    if buf == null || len <= 0:
        ret ""
    end
    dst void* = mem.Allocate((len + 1) as u64)
    mem.Set(dst, 0, (len + 1) as u64)
    mem.Copy(dst, buf, len as u64)
    ret dst as str
end

func _str_to_wide(s str) void*:
    n i32 = MultiByteToWideChar(65001, 0, s, 0 - 1, null, 0)
    if n <= 0:
        ret mem.Allocate(2 as u64)
    end
    w void* = mem.Allocate((n * 2) as u64)
    MultiByteToWideChar(65001, 0, s, 0 - 1, w, n)
    ret w
end

func _wide_to_str(w void*) str:
    if w == null: ret "" end
    n i32 = WideCharToMultiByte(65001, 0, w, 0 - 1, null, 0, null, null)
    if n <= 0: ret "" end
    buf void* = mem.Allocate(n as u64)
    WideCharToMultiByte(65001, 0, w, 0 - 1, buf, n, null, null)
    ret _make_str(buf, n - 1)
end

func _fetch_https(method str, url str, headers str, body str) str:
    mut p str = url
    mut secure i32 = 1
    mut wport i32 = 443
    if url.substr(0, 8) == "https://":
        p = url.substr(8, url.len() - 8)
    else:
        if url.substr(0, 7) == "http://":
            secure = 0
            wport = 80
            p = url.substr(7, url.len() - 7)
        end
    end
    slash_pos i32 = p.find("/")
    mut host_part str = p
    mut path_part str = "/"
    if slash_pos >= 0:
        host_part = p.substr(0, slash_pos)
        path_part = p.substr(slash_pos, p.len() - slash_pos)
    end
    colon_pos i32 = host_part.find(":")
    mut host_only str = host_part
    if colon_pos >= 0:
        host_only = host_part.substr(0, colon_pos)
        wport = host_part.substr(colon_pos + 1, host_part.len() - colon_pos - 1).to_int()
    end
    wagent void* = _str_to_wide("Salam/1.0")
    sess void* = WinHttpOpen(wagent, 0, null, null, 0)
    mem.Free(wagent)
    if sess == null: ret "" end
    whost void* = _str_to_wide(host_only)
    conn void* = WinHttpConnect(sess, whost, wport, 0)
    mem.Free(whost)
    if conn == null:
        WinHttpCloseHandle(sess)
        ret ""
    end
    mut req_flags i32 = 0
    if secure == 1: req_flags = 8388608 end
    wverb void* = _str_to_wide(method)
    wpath void* = _str_to_wide(path_part)
    req void* = WinHttpOpenRequest(conn, wverb, wpath, null, null, null, req_flags)
    mem.Free(wverb)
    mem.Free(wpath)
    if req == null:
        WinHttpCloseHandle(conn)
        WinHttpCloseHandle(sess)
        ret ""
    end
    if headers.len() > 0:
        wh void* = _str_to_wide(headers)
        WinHttpAddRequestHeaders(req, wh, 0 - 1, 805306368)
        mem.Free(wh)
    end
    blen i32 = body.len()
    sent i32 = WinHttpSendRequest(req, null, 0, body, blen, blen, 0)
    if sent == 0:
        WinHttpCloseHandle(req)
        WinHttpCloseHandle(conn)
        WinHttpCloseHandle(sess)
        ret ""
    end
    recv_ok i32 = WinHttpReceiveResponse(req, null)
    if recv_ok == 0:
        WinHttpCloseHandle(req)
        WinHttpCloseHandle(conn)
        WinHttpCloseHandle(sess)
        ret ""
    end
    mut hlen i64* = mem.Allocate(8 as u64) as i64*
    hlen[0] = 0
    WinHttpQueryHeaders(req, 22, null, null, hlen as void*, null)
    hsize i32 = hlen[0] as i32
    mut hdr_str str = "HTTP/1.1 0 \r\n\r\n"
    if hsize > 0:
        wh void* = mem.Allocate((hsize + 4) as u64)
        q2 i32 = WinHttpQueryHeaders(req, 22, null, wh, hlen as void*, null)
        if q2 != 0:
            hdr_str = _wide_to_str(wh)
        end
        mem.Free(wh)
    end
    mem.Free(hlen as void*)
    hend i32 = hdr_str.len() - 4
    if hend < 0 || hdr_str.substr(hend, 4) != "\r\n\r\n":
        hdr_str = hdr_str.concat("\r\n\r\n")
    end
    buf void* = mem.Allocate(2050 as u64)
    mut got i64* = mem.Allocate(8 as u64) as i64*
    mut body_str str = ""
    mut reading bool = true
    while reading:
        got[0] = 0
        rd_ok i32 = WinHttpReadData(req, buf, 2048, got as void*)
        if rd_ok == 0 || got[0] == 0:
            reading = false
        else:
            chunk str = _make_str(buf, got[0] as i32)
            body_str = body_str.concat(chunk)
        end
    end
    mem.Free(buf)
    mem.Free(got as void*)
    WinHttpCloseHandle(req)
    WinHttpCloseHandle(conn)
    WinHttpCloseHandle(sess)
    ret hdr_str.concat(body_str)
end
@else
@if SALAM_LINK_CURL
extern "C":
    func curl_easy_init() void*
    func curl_easy_setopt(h void*, opt i32, ...) i64
    func curl_easy_perform(h void*) i64
    func curl_easy_cleanup(h void*)
    func curl_slist_append(list void*, s str) void*
    func curl_slist_free_all(list void*)
end
const _CURLOPT_URL = 10002
const _CURLOPT_WRITEDATA = 10001
const _CURLOPT_WRITEFUNCTION = 20011
const _CURLOPT_POSTFIELDS = 10015
const _CURLOPT_HTTPHEADER = 10023
const _CURLOPT_CUSTOMREQUEST = 10036
const _CURLOPT_USERAGENT = 10018
const _CURLOPT_HEADERFUNCTION = 20079
const _CURLOPT_HEADERDATA = 10029
const _CURLOPT_FOLLOWLOCATION = 52
func _cbuf() void*:
    ret mem.AllocateZeroed(24 as u64)
end

func _cbuf_str(b void*) str:
    p i64* = b as i64*
    if p[0] == 0: ret "" end
    d void* = p[0] as void*
    ret d as str
end

func _curl_write(ptr void*, size u64, nmemb u64, ud void*) u64:
    n i64 = (size * nmemb) as i64
    mut b i64* = ud as i64*
    mut len i64 = b[1]
    mut cap i64 = b[2]
    if (len + n + 1) > cap:
        while (len + n + 1) > cap:
            if cap == 0: cap = 4096 else:
                cap = cap * 2
            end
        end
        nd void* = mem.Reallocate(b[0] as void*, cap as u64)
        b[0] = nd as i64
        b[2] = cap
    end
    dst void* = (b[0] + len) as void*
    mem.Copy(dst, ptr, n as u64)
    len = len + n
    b[1] = len
    term void* = (b[0] + len) as void*
    mem.Set(term, 0, 1 as u64)
    ret n as u64
end

func _fetch_https(method str, url str, headers str, body str) str:
    h void* = curl_easy_init()
    if h == null: ret "" end
    buf void* = _cbuf()
    hbuf void* = _cbuf()
    wcb i64 = funcptr(_curl_write)
    curl_easy_setopt(h, _CURLOPT_URL, url)
    curl_easy_setopt(h, _CURLOPT_WRITEFUNCTION, wcb)
    curl_easy_setopt(h, _CURLOPT_WRITEDATA, buf)
    curl_easy_setopt(h, _CURLOPT_HEADERFUNCTION, wcb)
    curl_easy_setopt(h, _CURLOPT_HEADERDATA, hbuf)
    curl_easy_setopt(h, _CURLOPT_FOLLOWLOCATION, 1 as i64)
    curl_easy_setopt(h, _CURLOPT_USERAGENT, "Salam/1.0")
    if method != "GET":
        curl_easy_setopt(h, _CURLOPT_CUSTOMREQUEST, method)
    end
    if body.len() > 0:
        curl_easy_setopt(h, _CURLOPT_POSTFIELDS, body)
    end
    mut slist void* = null
    if headers.len() > 0:
        lines Vector<str> = headers.split("\r\n")
        mut i i32 = 0
        while i < lines.len():
            line str = lines.get(i)[0]
            if line.len() > 0:
                slist = curl_slist_append(slist, line)
            end
            i = i + 1
        end
    end
    if slist != null:
        curl_easy_setopt(h, _CURLOPT_HTTPHEADER, slist)
    end
    curl_easy_perform(h)
    if slist != null:
        curl_slist_free_all(slist)
    end
    curl_easy_cleanup(h)
    mut result str = _cbuf_str(hbuf).concat(_cbuf_str(buf))
    hp i64* = hbuf as i64*
    bp i64* = buf as i64*
    if hp[0] != 0: mem.Free(hp[0] as void*) end
    if bp[0] != 0: mem.Free(bp[0] as void*) end
    mem.Free(hbuf)
    mem.Free(buf)
    ret result
end
@else
func _fetch_https(_method str, _url str, _headers str, _body str) str:
    ret ""
end

@end
@end
func _parse_response(req str) Response:
    sp i32 = req.find(" ")
    if sp >= 0:
        _g_http_status = req.substr(sp + 1, 3).to_int()
    else:
        _g_http_status = 0
    end
    sep_pos i32 = req.find("\r\n\r\n")
    if sep_pos >= 0:
        _g_http_headers = req.substr(0, sep_pos + 4)
        ret Response { status = _g_http_status, body = req.substr(sep_pos + 4, req.len() - sep_pos - 4), head = _g_http_headers }
    end
    _g_http_headers = ""
    ret Response { status = _g_http_status, body = req, head = "" }
end

@en "NewHeaders"
@fa "سرصفحه_جدید"
pub func NewHeaders() HashMap<str, str>:
    m HashMap<str, str> = HashMap {}
    ret m
end

func serialize(headers HashMap<str, str>) str:
    mut out str = ""
    it MapIter<str, str> = headers.iter()
    while it.has_next():
        out = out.concat(it.key()).concat(": ").concat(it.value()).concat("\r\n")
        it.next()
    end
    ret out
end

func send(method str, url str, header_block str, body str) Response:
    _g_http_status = 0
    _g_http_headers = ""
    mut effective_headers str = header_block
    if body.len() > 0:
        if header_block.find("Content-Type") < 0:
            effective_headers = header_block.concat("Content-Type: application/x-www-form-urlencoded\r\n")
        end
    end
    req str = _fetch_https(method, url, effective_headers, body)
    ret _parse_response(req)
end

@en "Get"
@fa "دریافت"
pub func Get(url str) Response: ret send("GET", url, "", "") end

@en "Post"
@fa "ارسال"
pub func Post(url str, body str) Response: ret send("POST", url, "", body) end

@en "GetWith"
@fa "دریافت_با"
pub func GetWith(url str, headers HashMap<str, str>) Response:
    ret send("GET", url, serialize(headers), "")
end

@en "PostWith"
@fa "ارسال_با"
pub func PostWith(url str, body str, headers HashMap<str, str>) Response:
    ret send("POST", url, serialize(headers), body)
end

@en "Request"
@fa "درخواست"
pub func Request(method str, url str, headers HashMap<str, str>, body str) Response:
    ret send(method, url, serialize(headers), body)
end

@en "RequestRaw"
@fa "درخواست_خام"
pub func RequestRaw(method str, url str, header_block str, body str) Response:
    ret send(method, url, header_block, body)
end

@en "Ok"
@fa "موفق"
pub func Ok(r Response) bool:
    ret r.status >= 200 && r.status < 300
end

@en "Status"
@fa "وضعیت"
pub func Status(r Response) i32:
    ret r.status
end

@en "Body"
@fa "بدنه"
pub func Body(r Response) str:
    ret r.body
end

@en "Headers"
@fa "سرصفحه‌ها"
pub func Headers(r Response) HashMap<str, str>:
    m HashMap<str, str> = HashMap {}
    lines Vector<str> = r.head.split("\r\n")
    mut i = 0
    while i < lines.len():
        line str = lines.get(i)[0]
        c i32 = line.find(":")
        if c > 0:
            key str = line.substr(0, c)
            val str = line.substr(c + 1, line.len() - c - 1)
            m.put(key, val.trim())
        end
        i = i + 1
    end
    lines.free()
    ret m
end

func _hdr_lower(s str) str:
    l i32 = s.len()
    mut out str = ""
    mut i i32 = 0
    while i < l:
        code i32 = char_code(s.substr(i, 1))
        if code >= 65 && code <= 90:
            out = out.concat(char_from_code(code + 32))
        else:
            out = out.concat(s.substr(i, 1))
        end
        i = i + 1
    end
    ret out
end

@en "GetHeader"
@fa "دریافت_سرصفحه"
pub func GetHeader(r Response, name str) str:
    target str = _hdr_lower(name)
    lines Vector<str> = r.head.split("\r\n")
    mut result str = ""
    mut found bool = false
    mut i = 0
    while i < lines.len():
        if found == false:
            line str = lines.get(i)[0]
            c i32 = line.find(":")
            if c > 0:
                if _hdr_lower(line.substr(0, c)) == target:
                    result = line.substr(c + 1, line.len() - c - 1).trim()
                    found = true
                end
            end
        end
        i = i + 1
    end
    lines.free()
    ret result
end

@en "Raw"
@fa "خام"
pub func Raw(r Response) str:
    ret r.head.concat(r.body)
end

@en "RawHeaders"
@fa "سرصفحه‌های_خام"
pub func RawHeaders(r Response) str:
    ret r.head
end
@en "io"
