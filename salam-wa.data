@en "Upper"
@fa "بزرگ"
pub func Upper(s str) str:
    l i32 = s.len()
    mut result str = ""
    mut i i32 = 0
    while i < l:
        code i32 = char_code(s.substr(i, 1))
        if code >= 97 && code <= 122:
            result = result.concat(char_from_code(code - 32))
        else:
            result = result.concat(s.substr(i, 1))
        end
        i = i + 1
    end
    ret result
end

@en "Lower"
@fa "کوچک"
pub func Lower(s str) str:
    l i32 = s.len()
    mut result str = ""
    mut i i32 = 0
    while i < l:
        code i32 = char_code(s.substr(i, 1))
        if code >= 65 && code <= 90:
            result = result.concat(char_from_code(code + 32))
        else:
            result = result.concat(s.substr(i, 1))
        end
        i = i + 1
    end
    ret result
end

@en "Reverse"
@fa "وارونه"
pub func Reverse(s str) str:
    n i32 = s.len()
    mut result str = ""
    mut i i32 = 0
    while i < n:
        b i32 = char_code(s.substr(i, 1))
        mut clen i32 = 1
        if b >= 240:
            clen = 4
        else:
            if b >= 224:
                clen = 3
            else:
                if b >= 192:
                    clen = 2
                end
            end
        end
        if i + clen > n: clen = n - i end
        result = s.substr(i, clen).concat(result)
        i = i + clen
    end
    ret result
end

@en "CharCount"
@fa "شمارنویسه"
pub func CharCount(s str) i32:
    n i32 = s.len()
    mut count i32 = 0
    mut i i32 = 0
    while i < n:
        b i32 = char_code(s.substr(i, 1))
        mut clen i32 = 1
        if b >= 240:
            clen = 4
        else:
            if b >= 224:
                clen = 3
            else:
                if b >= 192:
                    clen = 2
                end
            end
        end
        if i + clen > n: clen = n - i end
        count = count + 1
        i = i + clen
    end
    ret count
end

@en "Repeat"
@fa "تکرار"
pub func Repeat(s str, n i32) str:
    mut result str = ""
    mut i i32 = 0
    while i < n:
        result = result.concat(s)
        i = i + 1
    end
    ret result
end

@en "Contains"
@fa "شامل_است"
pub func Contains(s str, sub str) bool:
    ret s.find(sub) >= 0
end

@en "StartsWith"
@fa "شروع_با"
pub func StartsWith(s str, prefix str) bool:
    if prefix.len() > s.len():
        ret false
    end
    ret s.substr(0, prefix.len()) == prefix
end

@en "EndsWith"
@fa "پایان_با"
pub func EndsWith(s str, suffix str) bool:
    n i32 = suffix.len()
    if n > s.len():
        ret false
    end
    ret s.substr(s.len() - n, n) == suffix
end

@en "Count"
@fa "شمارش"
pub func Count(s str, sub str) i32:
    if sub.len() == 0:
        ret 0
    end
    pieces Vector<str> = s.split(sub)
    n i32 = pieces.len() - 1
    pieces.free()
    ret n
end

@en "Index"
@fa "اندیس"
pub func Index(s str, sub str) i32: ret s.find(sub) end

@en "LastIndex"
@fa "آخرین_اندیس"
pub func LastIndex(s str, sub str) i32:
    sl i32 = s.len()
    bl i32 = sub.len()
    if bl == 0: ret 0 - 1 end
    if bl > sl: ret 0 - 1 end
    mut i i32 = sl - bl
    while i >= 0:
        if s.substr(i, bl) == sub:
            ret i
        end
        i = i - 1
    end
    ret 0 - 1
end

@en "ToUpper"
@fa "تبدیل_به_بزرگ"
pub func ToUpper(s str) str: ret Upper(s) end

@en "ToLower"
