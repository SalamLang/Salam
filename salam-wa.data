@fa "نوشتن_اچ_تی_تی_پی"
pub func WriteHTTP(c Conn, status_line str, content_type str, body str):
    blen str = itos(len(body) as i64)
    resp str = "HTTP/1.1 " + status_line + "\r\n" + "Content-Type: " + content_type + "\r\n" + "Content-Length: " + blen + "\r\n" + "Connection: close\r\n\r\n" + body
    s net.Socket = net.SocketFromFd(c.fd)
    net.Send(s, resp)
end
