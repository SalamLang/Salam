package testing
func itos(n i64) str:
    if n == 0: ret "0" end
    mut v i64 = n
    mut digits str = ""
    mut neg bool = false
    if v < 0: neg = true; v = 0 - v end
    while v > 0:
        digits = char_from_code((v % 10) as i32 + 48).concat(digits)
        v = v / 10
    end
    if neg: ret "-".concat(digits) end
    ret digits
end
mut _tpass i32 = 0
mut _tfail i32 = 0
func record(cond bool, msg str):
    if cond:
        _tpass = _tpass + 1
    else:
        _tfail = _tfail + 1
        !_ "FAIL: "
        !__ msg
    end
end
pub func Assert(cond bool):            record(cond, "assertion failed") end
pub func AssertMsg(cond bool, msg str): record(cond, msg) end
pub func AssertTrue(cond bool):        record(cond, "expected true") end
pub func AssertFalse(cond bool):       record(cond == false, "expected false") end
pub func AssertEqInt(got i32, want i32):
    record(got == want, "ints differ: got ".concat(itos(got as i64)).concat(" want ").concat(itos(want as i64)))
end
pub func AssertEqStr(got str, want str):
    record(got == want, "strings differ: got '".concat(got).concat("' want '").concat(want).concat("'"))
end
pub func AssertEqBool(got bool, want bool):
    record(got == want, "bools differ")
end
pub func AssertNeInt(a i32, b i32):
    record(a != b, "ints unexpectedly equal")
end
pub func AssertNeStr(a str, b str):
    record((a == b) == false, "strings unexpectedly equal")
end
pub func AssertNil(p void*):    record(p == null, "expected nil") end
pub func AssertNotNil(p void*): record((p == null) == false, "expected non-nil") end
pub func Passed() i32: ret _tpass end
pub func Failed() i32: ret _tfail end
pub func Summary() i32:
    println("--")
    print("tests: ")
    print(_tpass)
    print(" passed, ")
    print(_tfail)
    println(" failed")
    ret _tfail
end
