package validate
import "web"
import "regex"
pub func Required(value str) bool:
    ret len(value) > 0
end
pub func Length(value str, min_len i32, max_len i32) bool:
    l i32 = len(value)
    ret l >= min_len && l <= max_len
end
pub func IsEmail(value str) bool:
    if value.find("@") < 0:
        ret false
    end
    if value.find(".") < 0:
        ret false
    end
    ret true
end
pub func Matches(value str, pattern str) bool:
    ret regex.MatchStr(pattern, value)
end
pub func Assert(ctx i64, ok bool, message str):
    if ok:
        ret
    end
    web.Ctx_status(ctx, 400)
    web.Ctx_json(ctx, "{\"error\":\"" + message + "\"}")
end
