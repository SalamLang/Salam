import "db/mysql"
import "_linkmock.salam"
func main:
    db mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(id INTEGER PRIMARY KEY)")
    mut r mysql.Result = mysql.Query(db, "SELECT id FROM t WHERE id > 100")
    __ mysql.RowCount(r)
    __ mysql.Next(r)
    mysql.Finish(r)
    mysql.Close(db)
end
