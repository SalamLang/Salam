import "db/mysql"
import "_linkmock.salam"
func main:
    db mysql.Database = mysql.Open("", "root", "", "test", 3306)
    mysql.Exec(db, "CREATE TABLE t(v INTEGER)")
    mysql.Exec(db, "INSERT INTO t(v) VALUES (3),(1),(2)")
    mut r mysql.Result = mysql.Query(db, "SELECT v FROM t ORDER BY v DESC")
    while mysql.Next(r):
        __ mysql.Int(r, 0)
    end
    mysql.Finish(r)
    mysql.Close(db)
end
