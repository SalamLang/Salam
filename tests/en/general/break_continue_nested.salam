func main:
    // nested for: inner break when j == i
    // counts j < i for each i in 0..3 => 0+1+2+3 = 6
    mut count = 0
    for mut i = 0; i < 4; i = i + 1:
        for mut j = 0; j < 4; j = j + 1:
            if j == i: break end
            count = count + 1
        end
    end
    __ count

    // nested for: inner continue skips j == 1
    // each i counts j in {0,2} => 2 per i, 3 i's => 6
    mut sum = 0
    for mut i = 0; i < 3; i = i + 1:
        for mut j = 0; j < 3; j = j + 1:
            if j == 1: continue end
            sum = sum + 1
        end
    end
    __ sum

    // inner break must NOT stop the outer loop
    mut outer = 0
    repeat 3:
        outer = outer + 1
        repeat 5:
            break
        end
    end
    __ outer

    // while-outer, for-inner: 3 * 2 = 6
    mut total = 0
    mut x = 0
    while x < 3:
        x = x + 1
        for mut y = 0; y < 10; y = y + 1:
            if y == 2: break end
            total = total + 1
        end
    end
    __ total

    // inner continue must NOT skip the outer iteration
    mut outerhits = 0
    mut innerhits = 0
    for mut i = 0; i < 3; i = i + 1:
        outerhits = outerhits + 1
        for mut j = 0; j < 4; j = j + 1:
            if j % 2 == 0: continue end
            innerhits = innerhits + 1
        end
    end
    __ outerhits
    __ innerhits
end
