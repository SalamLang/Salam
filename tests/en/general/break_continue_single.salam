func main:
    // for + break: sum 0..9 but stop at 5
    mut a = 0
    for mut i = 0; i < 10; i = i + 1:
        if i == 5: break end
        a = a + i
    end
    __ a

    // for + continue: skip evens, sum odds 0..9
    mut b = 0
    for mut i = 0; i < 10; i = i + 1:
        if i % 2 == 0: continue end
        b = b + i
    end
    __ b

    // while + break: count up to 7
    mut c = 0
    mut j = 0
    while j < 100:
        if j == 7: break end
        c = c + 1
        j = j + 1
    end
    __ c

    // while + continue: count odd values of k in 1..10
    mut d = 0
    mut k = 0
    while k < 10:
        k = k + 1
        if k % 2 == 0: continue end
        d = d + 1
    end
    __ d

    // repeat + break: stop after 3 iterations
    mut e = 0
    repeat 10:
        e = e + 1
        if e == 3: break end
    end
    __ e

    // repeat + continue: count iterations not divisible by 3
    mut f = 0
    mut g = 0
    repeat 6:
        g = g + 1
        if g % 3 == 0: continue end
        f = f + 1
    end
    __ f
end
