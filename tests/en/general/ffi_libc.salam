extern "C":
    func printf(format str, ...) i32
    func atoi(s str) i32
    func toupper(c i32) i32
    func tolower(c i32) i32
    func strcmp(a str, b str) i32
    func abs(n i32) i32
end
func main:
    printf("atoi=%d\n", atoi("42"))
    printf("toupper=%d\n", toupper(97))
    printf("tolower=%d\n", tolower(90))
    printf("abs=%d\n", abs(0 - 7))
    printf("cmp_eq=%d\n", strcmp("hi", "hi"))
    if strcmp("a", "b") < 0:
        printf("cmp_lt=yes\n")
    else:
        printf("cmp_lt=no\n")
    end
end
