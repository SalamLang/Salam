import (
    "io"
    "os"
    "time"
)
func main:
    path str = "_iosys_test.txt"
    os.Remove(path)
    io.WriteFile(path, "alpha\n")
    io.AppendFile(path, "beta\n")
    io.AppendFile(path, "gamma\n")
    lines Vector<str> = io.Lines(path)
    __ lines.len()
    __ lines.get(0)[0]
    __ lines.get(2)[0]
    lines.free()
    __ os.Exists(path)
    os.Remove(path)
    __ os.Exists(path)
    __ os.Cwd().len() > 0
    t0 i64 = time.Now()
    time.Sleep(0)
    __ time.Now() >= t0
end
