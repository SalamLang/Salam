extern "C":
    func salam_alloc(size u64) void*
    func salam_realloc(ptr void*, size u64) void*
    func salam_free(ptr void*)
end
func main:
    mut p i32* = salam_alloc(40 as u64) as i32*
    mut i = 0
    while i < 10:
        p[i] = i * i
        i = i + 1
    end
    mut sum = 0
    i = 0
    while i < 10:
        sum = sum + p[i]
        i = i + 1
    end
    __ sum
    p = salam_realloc(p as void*, 80 as u64) as i32*
    p[10] = 100
    __ p[10]
    salam_free(p as void*)
end
