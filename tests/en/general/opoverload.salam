struct Vector2:
    x i32 = 0
    y i32 = 0
    func operator+(other Vector2) Vector2:
        ret Vector2 { x = this.x + other.x, y = this.y + other.y }
    end
    func operator-(other Vector2) Vector2:
        ret Vector2 { x = this.x - other.x, y = this.y - other.y }
    end
    func operator-() Vector2:
        ret Vector2 { x = -this.x, y = -this.y }
    end
    func operator==(other Vector2) bool:
        ret this.x == other.x && this.y == other.y
    end
end
struct Bag:
    data i32[4] = [0,0,0,0]
    func operator[](i i32) i32:
        ret this.data[i]
    end
    func operator[]=(i i32, v i32):
        this.data[i] = v
    end
end
func main:
    a Vector2 = Vector2 { x = 3, y = 4 }
    b Vector2 = Vector2 { x = 1, y = 2 }
    c Vector2 = a + b
    __ c.x
    __ c.y
    d Vector2 = a - b
    __ d.x
    __ d.y
    e Vector2 = -a
    __ e.x
    __ e.y
    a2 Vector2 = Vector2 { x = 3, y = 4 }
    __ a == a2
    __ a == b
    __ a != b
    mut f Vector2 = Vector2 { x = 1, y = 1 }
    f += b
    __ f.x
    __ f.y
    mut bag Bag = Bag {}
    bag[0] = 10
    bag[1] = 20
    bag[2] = 30
    __ bag[0]
    __ bag[1]
    __ bag[2]
end
