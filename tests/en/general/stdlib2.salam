import (
    "csv"
    "json"
    "regex"
    "str"
)
func main:
    __ regex.MatchStr("[0-9]+", "abc123")
    __ regex.FindStr("l+", "hello")
    re regex.Regex = regex.Compile("o")
    __ regex.Replace(re, "world", "0")
    doc str = "{ \"name\": \"ada\", \"age\": 36, \"ok\": true }"
    __ json.Valid(doc)
    __ json.Valid("{ bad }")
    __ json.Get(doc, "name")
    __ json.Get(doc, "age")
    __ json.Minify(doc)
    rec Vector<str> = csv.ReadLine("a,\"b,c\",\"d\"\"e\"")
    __ rec.len()
    __ rec.get(1)[0]
    __ rec.get(2)[0]
    __ str.Replace("a.b.c.d", ".", "-")
    rec.free()
end
