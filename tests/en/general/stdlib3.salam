import (
    "fmt" "str" "math" "collections"
)
func main:
    __ fmt.PadLeft("hi", 5).concat("|")
    __ fmt.PadRight("hi", 5).concat("|")
    __ fmt.Center("ab", 6).concat("|")
    __ fmt.Repeat("ab", 3)
    mut a Vector<str> = Vector {}
    a.push("Ada")
    a.push("36")
    __ fmt.Sprintf("{} is {}", a)
    a.free()
    __ str.Upper("hello")
    __ str.Lower("HELLO")
    __ str.Reverse("salam")
    __ str.Contains("hello world", "o w")
    __ str.StartsWith("salam", "sal")
    __ str.EndsWith("salam", "lam")
    __ str.Count("a.b.c.d", ".")
    __ str.Equals("abc", "abc")
    __ math.Round(2.6)
    __ math.Log2(8.0)
    __ math.Gcd(12, 18)
    __ math.Lcm(4, 6)
    __ math.ClampI(15, 0, 10)
    __ math.MaxF(2.5, 1.5)
    __ math.Sign(0.0 - 3.0)
    mut v Vector<str> = Vector {}
    v.push("x")
    v.push("y")
    v.push("z")
    __ collections.index_of(v, "y")
    __ collections.contains(v, "q")
    r Vector<str> = collections.reverse(v)
    mut joined str = ""
    mut ji i32 = 0
    while ji < r.len():
        joined = joined.concat(r.get(ji)[0])
        ji = ji + 1
    end
    __ joined
    v.free()
    r.free()
end
