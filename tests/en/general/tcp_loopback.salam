import (
    "tcp" "sync"
)
mut srv_wg sync.WaitGroup = sync.NewWaitGroup()
func echo_server():
    srv tcp.Server = tcp.Bind(19202)
    sync.Done(srv_wg)
    if !tcp.Ok(srv):
        ret
    end
    c tcp.Conn = tcp.Accept(srv)
    if tcp.ConnOk(c):
        msg str = tcp.Read(c, 1024)
        tcp.Write(c, "echo:" + msg)
        tcp.Close(c)
    end
    tcp.CloseServer(srv)
end
func main:
    sync.Add(srv_wg, 1 as i64)
    t i64 = spawn(echo_server)
    sync.Wait(srv_wg)
    c tcp.Conn = tcp.Dial("127.0.0.1", 19202)
    __ tcp.ConnOk(c)
    tcp.Write(c, "hello")
    resp str = tcp.Read(c, 1024)
    __ resp
    tcp.Close(c)
    join(t)
end
