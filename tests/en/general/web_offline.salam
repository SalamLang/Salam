import "web"
func h_dummy(_ctx i64): ret end
func main:
    r0 web.Router = web.NewRouter()
    __ r0.routes.len() == 0
    mut r web.Router = web.NewRouter()
    web.Get(r, "/", funcptr(h_dummy))
    web.Post(r, "/items", funcptr(h_dummy))
    __ r.routes.len() == 2
    __ r.has_static == false
    web.Static(r, "/static/", "./public")
    __ r.has_static == true
    __ r.static_prefix == "/static/"
    s web.Server = web.NewServer(8080)
    __ s.port == 8080
    __ s.hide_tokens == false
end
