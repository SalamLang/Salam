// LANG: fa
تابع اصلی:
    // ادامه و بشکن در یک حلقه:
    // رد مضارب ۳، جمع، و توقف وقتی جمع از ۱۰ گذشت
    متغیر s i32 = 0
    متغیر last i32 = -1
    برای متغیر i = 0; i < 100; i = i + 1:
        اگر i % 3 == 0: ادامه پایان
        اگر s > 10: بشکن پایان
        s = s + i
        last = i
    پایان
    چاپ s
    چاپ last

    // سه‌تایی تودرتو: بشکن میانی (j == 2) + ادامه درونی (k == 1)
    متغیر c i32 = 0
    برای متغیر i = 0; i < 3; i = i + 1:
        برای متغیر j = 0; j < 3; j = j + 1:
            اگر j == 2: بشکن پایان
            برای متغیر k = 0; k < 3; k = k + 1:
                اگر k == 1: ادامه پایان
                c = c + 1
            پایان
        پایان
    پایان
    چاپ c

    // شبیه‌سازی بشکن برچسب‌دار با یک پرچم برای خروج از دو حلقه
    متغیر found i32 = 0
    متغیر fi i32 = -1
    متغیر fj i32 = -1
    برای متغیر i = 0; i < 5; i = i + 1:
        برای متغیر j = 0; j < 5; j = j + 1:
            اگر i * j == 6:
                found = 1
                fi = i
                fj = j
                بشکن
            پایان
        پایان
        اگر found == 1: بشکن پایان
    پایان
    چاپ fi
    چاپ fj

    // ادامه به‌عنوان نگهبان پیش از کار سنگین، همراه با بودجه بشکن
    متغیر processed i32 = 0
    متغیر budget i32 = 5
    تکرار 20:
        budget = budget - 1
        اگر budget < 0: بشکن پایان
        اگر budget % 2 == 0: ادامه پایان
        processed = processed + 1
    پایان
    چاپ processed
پایان
