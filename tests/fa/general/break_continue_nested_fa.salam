// LANG: fa
تابع اصلی:
    // برای تودرتو: بشکن داخلی وقتی j == i
    // شمارش j < i برای هر i در ۰..۳ => ۰+۱+۲+۳ = ۶
    متغیر count i32 = 0
    برای متغیر i = 0; i < 4; i = i + 1:
        برای متغیر j = 0; j < 4; j = j + 1:
            اگر j == i: بشکن پایان
            count = count + 1
        پایان
    پایان
    چاپ count

    // برای تودرتو: ادامه داخلی، رد کردن j == 1
    متغیر sum i32 = 0
    برای متغیر i = 0; i < 3; i = i + 1:
        برای متغیر j = 0; j < 3; j = j + 1:
            اگر j == 1: ادامه پایان
            sum = sum + 1
        پایان
    پایان
    چاپ sum

    // بشکن داخلی نباید حلقه بیرونی را متوقف کند
    متغیر outer i32 = 0
    تکرار 3:
        outer = outer + 1
        تکرار 5:
            بشکن
        پایان
    پایان
    چاپ outer

    // تاوقتی بیرونی، برای داخلی: ۳ * ۲ = ۶
    متغیر total i32 = 0
    متغیر x i32 = 0
    تاوقتی x < 3:
        x = x + 1
        برای متغیر y = 0; y < 10; y = y + 1:
            اگر y == 2: بشکن پایان
            total = total + 1
        پایان
    پایان
    چاپ total

    // ادامه داخلی نباید تکرار بیرونی را رد کند
    متغیر outerhits i32 = 0
    متغیر innerhits i32 = 0
    برای متغیر i = 0; i < 3; i = i + 1:
        outerhits = outerhits + 1
        برای متغیر j = 0; j < 4; j = j + 1:
            اگر j % 2 == 0: ادامه پایان
            innerhits = innerhits + 1
        پایان
    پایان
    چاپ outerhits
    چاپ innerhits
پایان
