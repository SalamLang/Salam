// LANG: fa
@en "Point"
@fa "نقطه"
struct Point:
    @en "x"
    @fa "ایکس"
    x i32 = 0
    @en "y"
    @fa "وای"
    y i32 = 0
    @en "Sum"
    @fa "جمع"
    func Sum() i32: ret this.x + this.y end
end
تابع اصلی:
    mut p Point = Point { ایکس = 3, وای = 4 }
    چاپ p.ایکس
    چاپ p.جمع()
    چاپ lang()
پایان
