// LANG: fa
واردکردن (
    "web" "net" "str" "time"
)
تابع get_h(ctx i64): web.Ctx_text(ctx, "GET-ok") پایان
تابع post_h(ctx i64): web.Ctx_text(ctx, "POST-ok") پایان
تابع put_h(ctx i64):
    web.Ctx_text(ctx, "PUT-ok id=" + web.Ctx_param(ctx, "id"))
پایان
تابع del_h(ctx i64):
    web.Ctx_text(ctx, "DELETE-ok id=" + web.Ctx_param(ctx, "id"))
پایان
تابع run_web():
    متغیر r web.Router = web.NewRouter()
    web.Get(r, "/res", funcptr(get_h))
    web.Post(r, "/res", funcptr(post_h))
    web.Put(r, "/res/:id", funcptr(put_h))
    web.Delete(r, "/res/:id", funcptr(del_h))
    s web.Server = web.NewServer(19216)
    web.Use(s, r)
    web.Run(s)
پایان
تابع req(method str, path str) str:
    sock net.Socket = net.Connect("127.0.0.1", 19216)
    اگر !net.Ok(sock):
        بازگشت ""
    پایان
    net.Send(sock, method + " " + path + " HTTP/1.0\r\nHost: localhost\r\n\r\n")
    resp str = net.Recv(sock, 8192)
    net.Close(sock)
    بازگشت resp
پایان
تابع اصلی:
    _t i64 = spawn(run_web)
    time.Sleep(150)

    چاپ str.Contains(req("GET", "/res"), "GET-ok")
    چاپ str.Contains(req("POST", "/res"), "POST-ok")

    چاپ str.Contains(req("PUT", "/res/7"), "PUT-ok id=7")
    چاپ str.Contains(req("DELETE", "/res/9"), "DELETE-ok id=9")

    چاپ str.Contains(req("PUT", "/res"), "404")
    چاپ str.Contains(req("GET", "/res/7"), "404")
پایان
